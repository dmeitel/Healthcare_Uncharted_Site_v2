{
  "permissions": {
    "allow": [
      "Bash(node node_modules/@11ty/eleventy/cmd.cjs)",
      "Bash(node node_modules/@11ty/eleventy/cmd.cjs --serve)",
      "Bash(node node_modules/@11ty/eleventy/cmd.cjs --input=src --output=_site)",
      "Bash(npm run *)",
      "Bash(npx @11ty/eleventy --input=src --output=_site)",
      "Bash(npm start *)",
      "Bash(npx @11ty/eleventy)",
      "Bash(npx @11ty/eleventy --serve --port 8081)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8081/)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8081/learn/)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8081/tools/)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8081/about/)"
    ]
  }
}
