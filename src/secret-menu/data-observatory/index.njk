---
layout: base.njk
title: "Data Observatory"
description: "Every dataset on the site, where it came from, and what reads it. The plumbing, drawn."
noindex: true
no_footer: true
eleventyExcludeFromCollections: true
---
{% raw %}
<style>
/* Scoped scene vars only (--dmap-*). Global tokens are never redefined here.
   The canvas is pinned to #0a0f1a in BOTH themes: the five kind hues below
   were CVD/contrast-validated against that exact surface, so the surface
   travels with them. Everything drawn ON the canvas therefore uses --dmap-*
   literals (theme tokens would flip dark in light mode and vanish). */
.obs-shell {
  --dmap-canvas: #0a0f1a;            /* validated chart surface, both themes */
  --dmap-t1: #e9eef6;                /* label ink on the pinned-dark canvas */
  --dmap-t2: #9db0c4;
  --dmap-t3: #64788e;
  --dmap-edge: rgba(158,178,200,.20);
  --dmap-src:  #3f87e8;              /* sources        */
  --dmap-scr:  #c2801a;              /* pipeline       */
  --dmap-ds:   #1fa096;              /* datasets       */
  --dmap-int:  #8f7fe0;              /* build-time     */
  --dmap-tool: #2f9c6a;              /* tools          */
}

.obs-shell .shell-canvas { background: var(--dmap-canvas); overflow: auto; }
#obsWrap { position: relative; min-height: 100%; }
#obsSvg { display: block; font-family: var(--mono); }

#obsSvg .obs-node { cursor: pointer; }
#obsSvg .obs-node rect { transition: opacity .15s; }
#obsSvg .obs-node:focus { outline: none; }
#obsSvg .obs-node:focus-visible rect { stroke: var(--teal); stroke-width: 2.5; }
#obsSvg .obs-label { fill: var(--dmap-t1); font-size: 10px; pointer-events: none; }
#obsSvg .obs-sub   { fill: var(--dmap-t2); font-size: 9px;  pointer-events: none; }
#obsSvg .obs-colhead {
  fill: var(--dmap-t3); font-size: 9px; font-weight: 600;
  letter-spacing: .16em; text-transform: uppercase;
}

/* tooltip — floats over the canvas; dark literals to match the pinned surface */
#obsTip {
  position: absolute; z-index: 60; pointer-events: none; display: none;
  max-width: 260px; padding: 9px 11px; border-radius: 8px;
  background: rgba(13,20,33,.96); border: 1px solid rgba(158,178,200,.25);
  box-shadow: 0 8px 24px rgba(0,0,0,.5);
  font-family: var(--mono); font-size: 11px; line-height: 1.55; color: var(--dmap-t2);
}
#obsTip .tt-name { color: var(--dmap-t1); font-weight: 600; font-size: 12px; margin-bottom: 3px; }
#obsTip .tt-kind { text-transform: uppercase; letter-spacing: .1em; font-size: 9px; }

/* right dock — lives on theme surfaces, so real tokens apply here */
.obs-dock { padding: 16px; font-size: 12px; color: var(--t2); }
.obs-dock h2 {
  font-family: var(--display); font-size: 15px; font-weight: 700;
  color: var(--t1); line-height: 1.3; margin: 0 0 4px; overflow-wrap: anywhere;
}
.obs-kind-badge {
  display: inline-flex; align-items: center; gap: 6px; margin-bottom: 14px;
  font-family: var(--mono); font-size: 9px; font-weight: 600;
  letter-spacing: .12em; text-transform: uppercase; color: var(--t2);
}
.obs-kind-badge i { width: 10px; height: 10px; border-radius: 3px; display: inline-block; }
.obs-meta { display: grid; grid-template-columns: 84px 1fr; gap: 5px 10px; margin-bottom: 14px; }
.obs-meta dt { font-family: var(--mono); font-size: 9px; letter-spacing: .1em; text-transform: uppercase; color: var(--t3); padding-top: 2px; }
.obs-meta dd { margin: 0; font-family: var(--mono); font-size: 11px; color: var(--t1); overflow-wrap: anywhere; }
.obs-detail { font-size: 12.5px; line-height: 1.65; color: var(--t2); margin-bottom: 16px; }
.obs-sec {
  font-family: var(--mono); font-size: 9px; font-weight: 600; letter-spacing: .14em;
  text-transform: uppercase; color: var(--t3);
  border-top: 1px solid var(--border); padding-top: 10px; margin: 12px 0 7px;
}
.obs-links { list-style: none; margin: 0; padding: 0; }
.obs-links li { display: flex; align-items: baseline; gap: 8px; padding: 3px 0; font-family: var(--mono); font-size: 11px; color: var(--t1); }
.obs-links li .mode {
  flex-shrink: 0; font-size: 8.5px; letter-spacing: .08em; text-transform: uppercase;
  padding: 1px 7px; border-radius: 8px; border: 1px solid var(--border); color: var(--t3);
}
.obs-links li button {
  background: none; border: none; padding: 0; font: inherit; color: inherit;
  cursor: pointer; text-align: left; overflow-wrap: anywhere;
}
.obs-links li button:hover { color: var(--teal); }
[data-theme="light"] .obs-links li button:hover { color: var(--teal-dk); }
.obs-hint { padding: 28px 8px; text-align: center; color: var(--t3); font-size: 12px; line-height: 1.7; }
.obs-hint .glyph { font-size: 22px; display: block; margin-bottom: 10px; opacity: .6; }

/* foot legend */
.obs-legend { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; font-family: var(--mono); font-size: 10px; color: var(--t2); }
.obs-legend .sw { display: inline-flex; align-items: center; gap: 5px; }
.obs-legend .sw i { width: 10px; height: 10px; border-radius: 3px; display: inline-block; border: 1.5px solid; }
.obs-legend .ek { display: inline-flex; align-items: center; gap: 5px; }
.obs-legend .ek svg { display: block; }
.obs-legend .sep { width: 1px; height: 14px; background: var(--border); }
#obsTotals { font-family: var(--mono); font-size: 10px; color: var(--t3); }

/* phone: the DAG can't reflow — fixed-width svg inside a scroll strip */
@media (max-width: 699px) {
  .obs-shell .shell-canvas { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  #obsSvg { min-width: 1080px; }
}
</style>

<div class="hu-shell obs-shell">
  <header class="tool-bar">
    <span class="tool-bar-kicker">Secret Menu</span>
    <span class="tool-bar-title">Data <span>Observatory</span></span>
    <span class="tool-bar-crumb">sources &rarr; pipeline &rarr; datasets &rarr; tools</span>
    <span class="tool-bar-spacer"></span>
    <a class="toggle-chip" href="/secret-menu/">&larr; Secret Menu</a>
  </header>

  <div class="shell-main">
    <div class="shell-canvas">
      <div id="obsWrap">
        <svg id="obsSvg" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Flow map of every data source, pipeline script, dataset, build artifact, and tool on the site"></svg>
        <div id="obsTip"></div>
      </div>
    </div>
    <aside class="shell-dock shell-dock--right">
      <div class="obs-dock" id="obsDock">
        <div class="obs-hint" id="obsHint">
          <span class="glyph">&#9678;</span>
          Hover a node to light up its full chain, upstream and down.<br><br>
          Click to pin it here: size on disk, refresh mode, provenance, and everything it feeds.
        </div>
        <div id="obsDetail" hidden></div>
      </div>
    </aside>
  </div>

  <footer class="shell-foot">
    <div class="obs-legend" id="obsLegend"></div>
    <span class="tool-bar-spacer"></span>
    <span id="obsTotals"></span>
{% endraw %}
    {% include "components/tool-attribution.njk" %}
{% raw %}
  </footer>
</div>

<script src="https://cdn.jsdelivr.net/npm/d3@7"></script>
<script>
(function () {
'use strict';

/* Validated categorical palette (CVD + contrast, against #0a0f1a).
   Identity is never color-alone: labels sit on every node and the
   chain-highlight interaction carries lineage beyond hue. */
var KIND = {
  source:       { color: '#3f87e8', label: 'Sources',    col: 0 },
  script:       { color: '#c2801a', label: 'Pipeline',   col: 1 },
  dataset:      { color: '#1fa096', label: 'Datasets',   col: 2 },
  intermediate: { color: '#8f7fe0', label: 'Build-time', col: 3 },
  tool:         { color: '#2f9c6a', label: 'Tools',      col: 4 }
};
var COLS = ['Sources', 'Pipeline', 'Datasets', 'Build-time', 'Tools'];
var NODE_W = 172, NODE_GAP = 2, FIXED_H = 26, MIN_H = 22, MAX_H = 64;
var MARGIN = { top: 46, right: 24, bottom: 24, left: 24 };

var svg = d3.select('#obsSvg');
var wrap = document.getElementById('obsWrap');
var canvas = document.querySelector('.obs-shell .shell-canvas');
var tip = document.getElementById('obsTip');
var hintEl = document.getElementById('obsHint');
var detailEl = document.getElementById('obsDetail');

var nodes = [], edges = [], byId = {}, outAdj = {}, inAdj = {};
var pinned = null;

function fmtBytes(b) {
  if (b == null) return '—';
  if (b < 1024) return b + ' B';
  if (b < 1048576) return (b / 1024).toFixed(1) + ' KB';
  return (b / 1048576).toFixed(1) + ' MB';
}
function esc(s) {
  return String(s).replace(/[&<>"]/g, function (c) {
    return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c];
  });
}

fetch('/assets/data/derived/datamap.json')
  .then(function (r) { return r.json(); })
  .then(init)
  .catch(function (err) {
    wrap.insertAdjacentHTML('beforeend',
      '<div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:#9db0c4;font-family:var(--mono);font-size:12px">Could not load datamap.json (' + esc(err.message) + ')</div>');
  });

function init(data) {
  nodes = data.nodes; edges = data.edges;
  nodes.forEach(function (n) { byId[n.id] = n; outAdj[n.id] = []; inAdj[n.id] = []; });
  edges.forEach(function (e, i) {
    e._i = i;
    outAdj[e.from].push(e);
    inAdj[e.to].push(e);
  });
  layout();
  render();
  legend();
  totals(data);
}

/* ── layout: fixed columns, packed vertically, sorted by bytes desc ── */
var totalW = 0, totalH = 0;
function layout() {
  var maxBytes = d3.max(nodes, function (n) { return n.bytes || 0; }) || 1;
  var sqrtMax = Math.sqrt(maxBytes);
  nodes.forEach(function (n) {
    var scaled = n.kind === 'dataset' || n.kind === 'intermediate';
    n.h = scaled && n.bytes
      ? Math.max(MIN_H, Math.min(MAX_H, MIN_H + (MAX_H - MIN_H) * Math.sqrt(n.bytes) / sqrtMax))
      : FIXED_H;
    n.col = KIND[n.kind].col;
  });

  var colNodes = [[], [], [], [], []];
  nodes.forEach(function (n) { colNodes[n.col].push(n); });
  colNodes.forEach(function (list) {
    list.sort(function (a, b) { return (b.bytes || 0) - (a.bytes || 0); });
  });

  var colHeights = colNodes.map(function (list) {
    return d3.sum(list, function (n) { return n.h; }) + NODE_GAP * Math.max(0, list.length - 1);
  });
  var maxColH = d3.max(colHeights);
  totalH = maxColH + MARGIN.top + MARGIN.bottom;

  var avail = Math.max((canvas ? canvas.clientWidth : 0) - 2, 1080);
  totalW = Math.max(avail, MARGIN.left + MARGIN.right + NODE_W * 5 + 60 * 4);
  var pitch = (totalW - MARGIN.left - MARGIN.right - NODE_W) / 4;

  colNodes.forEach(function (list, c) {
    var y = MARGIN.top + (maxColH - colHeights[c]) / 2;   /* center the column */
    list.forEach(function (n) {
      n.x = MARGIN.left + c * pitch;
      n.y = y;
      y += n.h + NODE_GAP;
    });
  });
}

/* ── chain walk: full upstream + downstream from one node ── */
function chainOf(id) {
  var nset = {}, eset = {};
  nset[id] = true;
  var q = [id];
  while (q.length) {                                   /* downstream */
    var cur = q.shift();
    outAdj[cur].forEach(function (e) {
      eset[e._i] = true;
      if (!nset[e.to]) { nset[e.to] = true; q.push(e.to); }
    });
  }
  q = [id];
  var seen = {}; seen[id] = true;
  while (q.length) {                                   /* upstream */
    var cur2 = q.shift();
    inAdj[cur2].forEach(function (e) {
      eset[e._i] = true;
      nset[e.from] = true;
      if (!seen[e.from]) { seen[e.from] = true; q.push(e.from); }
    });
  }
  return { nodes: nset, edges: eset };
}

/* ── render ── */
var edgeSel, nodeSel;
function render() {
  svg.attr('width', totalW).attr('height', totalH)
     .attr('viewBox', '0 0 ' + totalW + ' ' + totalH);

  var pitch = (totalW - MARGIN.left - MARGIN.right - NODE_W) / 4;
  svg.append('g').selectAll('text')
    .data(COLS).enter().append('text')
    .attr('class', 'obs-colhead')
    .attr('x', function (d, i) { return MARGIN.left + i * pitch + NODE_W / 2; })
    .attr('y', 26)
    .attr('text-anchor', 'middle')
    .text(function (d) { return d; });

  var link = d3.linkHorizontal()
    .source(function (e) {
      var a = byId[e.from], b = byId[e.to];
      return a.col <= b.col ? [a.x + NODE_W, a.y + a.h / 2] : [a.x, a.y + a.h / 2];
    })
    .target(function (e) {
      var a = byId[e.from], b = byId[e.to];
      return a.col <= b.col ? [b.x, b.y + b.h / 2] : [b.x + NODE_W, b.y + b.h / 2];
    })
    .x(function (p) { return p[0]; }).y(function (p) { return p[1]; });

  edgeSel = svg.append('g').attr('fill', 'none').selectAll('path')
    .data(edges).enter().append('path')
    .attr('d', link)
    .attr('stroke', 'var(--dmap-edge)')
    .attr('stroke-width', 1.2)
    .attr('stroke-dasharray', function (e) {
      if (e.mode === 'lazy') return '4,3';
      if (e.mode === 'embedded') return '2,2';
      return null;                                    /* eager + pipeline: solid */
    });

  nodeSel = svg.append('g').selectAll('g')
    .data(nodes).enter().append('g')
    .attr('class', 'obs-node')
    .attr('transform', function (n) { return 'translate(' + n.x + ',' + n.y + ')'; })
    .attr('tabindex', 0)
    .attr('role', 'button')
    .attr('aria-label', function (n) { return n.label + ', ' + n.kind; });

  nodeSel.append('rect')
    .attr('width', NODE_W).attr('height', function (n) { return n.h; })
    .attr('rx', 6).attr('ry', 6)
    .attr('fill', function (n) { return KIND[n.kind].color; })
    .attr('fill-opacity', 0.18)
    .attr('stroke', function (n) { return KIND[n.kind].color; })
    .attr('stroke-width', 1.5);

  nodeSel.append('text')
    .attr('class', 'obs-label')
    .attr('x', 9)
    .attr('y', function (n) { return n.h >= 40 && n.bytes ? n.h / 2 - 2 : n.h / 2 + 3.5; })
    .text(function (n) { return truncate(n.label, NODE_W - 18); });

  nodeSel.filter(function (n) { return n.h >= 40 && n.bytes; })
    .append('text')
    .attr('class', 'obs-sub')
    .attr('x', 9)
    .attr('y', function (n) { return n.h / 2 + 11; })
    .text(function (n) { return fmtBytes(n.bytes); });

  nodeSel
    .on('mouseenter', function (ev, n) { highlight(n.id); showTip(ev, n); })
    .on('mousemove', function (ev) { moveTip(ev); })
    .on('mouseleave', function () { hideTip(); highlight(pinned); })
    .on('focus', function (ev, n) { highlight(n.id); })
    .on('blur', function () { highlight(pinned); })
    .on('click', function (ev, n) { ev.stopPropagation(); select(n.id); })
    .on('keydown', function (ev, n) {
      if (ev.key === 'Enter' || ev.key === ' ') { ev.preventDefault(); select(n.id); }
    });

  svg.on('click', function () { select(null); });
}

function truncate(label, px) {
  var maxChars = Math.floor(px / 6);                  /* ~6px per mono char at 10px */
  return label.length > maxChars ? label.slice(0, maxChars - 1) + '…' : label;
}

/* ── chain highlight: selected node's hue carries the lineage ── */
function highlight(id) {
  if (!id) {
    edgeSel.attr('stroke', 'var(--dmap-edge)').attr('stroke-opacity', 1).attr('stroke-width', 1.2);
    nodeSel.attr('opacity', 1)
      .select('rect').attr('stroke-width', 1.5)
      .attr('stroke', function (n) { return KIND[n.kind].color; });
    return;
  }
  var chain = chainOf(id);
  var hue = KIND[byId[id].kind].color;
  edgeSel
    .attr('stroke', function (e) { return chain.edges[e._i] ? hue : 'var(--dmap-edge)'; })
    .attr('stroke-opacity', function (e) { return chain.edges[e._i] ? 0.7 : 0.15; })
    .attr('stroke-width', function (e) { return chain.edges[e._i] ? 1.6 : 1.2; });
  nodeSel.attr('opacity', function (n) { return chain.nodes[n.id] ? 1 : 0.25; });
  /* selection accent is brand teal, reserved for UI state, never node identity */
  nodeSel.select('rect')
    .attr('stroke', function (n) { return n.id === id ? 'var(--teal)' : KIND[n.kind].color; })
    .attr('stroke-width', function (n) { return n.id === id ? 2.5 : 1.5; });
}

function select(id) {
  pinned = id;
  highlight(id);
  if (!id) {
    hintEl.hidden = false; detailEl.hidden = true;
    return;
  }
  hintEl.hidden = true; detailEl.hidden = false;
  detailEl.innerHTML = dockHTML(byId[id]);
  detailEl.querySelectorAll('button[data-goto]').forEach(function (b) {
    b.addEventListener('click', function () { select(b.getAttribute('data-goto')); });
  });
}

function dockHTML(n) {
  var k = KIND[n.kind];
  var h = '<h2>' + esc(n.label) + '</h2>';
  h += '<div class="obs-kind-badge"><i style="background:' + k.color + '"></i>' + esc(k.label) + ' &middot; ' + esc(n.kind) + '</div>';
  h += '<dl class="obs-meta">';
  if (n.path) h += '<dt>Path</dt><dd>' + esc(n.path) + '</dd>';
  if (n.bytes != null) h += '<dt>Size</dt><dd>' + fmtBytes(n.bytes) + '</dd>';
  if (n.mtime) h += '<dt>Updated</dt><dd>' + esc(n.mtime.slice(0, 10)) + '</dd>';
  if (n.refresh) h += '<dt>Refresh</dt><dd>' + esc(n.refresh) + '</dd>';
  if (n.provenance) h += '<dt>Provenance</dt><dd>' + esc(n.provenance) + '</dd>';
  if (n.note) h += '<dt>Note</dt><dd>' + esc(n.note) + '</dd>';
  h += '</dl>';
  if (n.detail) h += '<p class="obs-detail">' + esc(n.detail) + '</p>';

  var ups = inAdj[n.id];
  if (ups.length) {
    h += '<div class="obs-sec">Fed by</div><ul class="obs-links">';
    ups.forEach(function (e) {
      h += '<li><button data-goto="' + esc(e.from) + '">' + esc(byId[e.from].label) + '</button>'
        + (e.mode ? '<span class="mode">' + esc(e.mode) + '</span>' : '') + '</li>';
    });
    h += '</ul>';
  }
  var downs = outAdj[n.id];
  if (downs.length) {
    h += '<div class="obs-sec">Feeds</div><ul class="obs-links">';
    downs.forEach(function (e) {
      h += '<li><button data-goto="' + esc(e.to) + '">' + esc(byId[e.to].label) + '</button>'
        + (e.mode ? '<span class="mode">' + esc(e.mode) + '</span>' : '') + '</li>';
    });
    h += '</ul>';
  }
  if (n.consumers && n.consumers.length) {
    h += '<div class="obs-sec">Consumers (curated)</div><ul class="obs-links">';
    n.consumers.forEach(function (c) { h += '<li><span>' + esc(c) + '</span></li>'; });
    h += '</ul>';
  }
  return h;
}

/* ── tooltip ── */
function showTip(ev, n) {
  var head = '<span class="tt-kind" style="color:' + KIND[n.kind].color + '">' + esc(KIND[n.kind].label) + '</span>'
           + '<div class="tt-name">' + esc(n.label) + '</div>';
  var rows = [];
  if (n.bytes != null) rows.push('size ' + fmtBytes(n.bytes));
  if (n.refresh) rows.push('refresh ' + esc(n.refresh));
  if (n.provenance) rows.push('provenance ' + esc(n.provenance));
  tip.innerHTML = head + rows.join('<br>');
  tip.style.display = 'block';
  moveTip(ev);
}
function moveTip(ev) {
  var r = wrap.getBoundingClientRect();
  var x = ev.clientX - r.left + 14, y = ev.clientY - r.top + 12;
  if (x + 270 > totalW) x -= 290;
  tip.style.left = x + 'px';
  tip.style.top = y + 'px';
}
function hideTip() { tip.style.display = 'none'; }

/* ── legend + totals ── */
function legend() {
  var h = Object.keys(KIND).map(function (k) {
    var c = KIND[k].color;
    return '<span class="sw"><i style="border-color:' + c + ';background:' + c + '2e"></i>' + KIND[k].label + '</span>';
  }).join('');
  h += '<span class="sep"></span>';
  var line = function (dash, name) {
    return '<span class="ek"><svg width="26" height="6"><line x1="0" y1="3" x2="26" y2="3" stroke="currentColor" stroke-width="1.4"'
      + (dash ? ' stroke-dasharray="' + dash + '"' : '') + '/></svg>' + name + '</span>';
  };
  h += line(null, 'eager') + line('4,3', 'lazy') + line('2,2', 'embedded');
  document.getElementById('obsLegend').innerHTML = h;
}

function totals(data) {
  var ds = nodes.filter(function (n) { return n.kind === 'dataset'; });
  var deployed = d3.sum(ds, function (n) { return n.bytes || 0; });
  var buildOnly = d3.sum(nodes.filter(function (n) { return n.kind === 'intermediate'; }),
                         function (n) { return n.bytes || 0; });
  document.getElementById('obsTotals').textContent =
    ds.length + ' datasets · ' + fmtBytes(deployed) + ' deployed · '
    + fmtBytes(buildOnly) + ' build-only · mapped ' + (data._meta.generated || '').slice(0, 10);
}

})();
</script>
{% endraw %}
