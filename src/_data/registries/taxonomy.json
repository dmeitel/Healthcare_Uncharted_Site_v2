{
  "_meta": {
    "note": "One canonical classification for the whole site. Everything (metrics, rounds, tools, atlas nodes, facility facets) should classify into a `domain` id. The crosswalks map the three legacy vocabularies onto these domains so they all line up.",
    "rule": "Reference content by `domain` id. Keep the legacy vocabularies working via the crosswalks rather than renaming them in place."
  },
  "domains": {
    "patient":           { "id": "patient",           "code": "P1",  "label": "Patient",                "color": "#4ECDC4" },
    "provider-clinical": { "id": "provider-clinical", "code": "P2a", "label": "Provider — Clinical",   "color": "#6AABFF" },
    "provider-ops":      { "id": "provider-ops",      "code": "P2b", "label": "Provider — Operations", "color": "#5B86C9" },
    "payer":             { "id": "payer",             "code": "P3",  "label": "Payer",                  "color": "#E8A838" },
    "policy":            { "id": "policy",            "code": "P4",  "label": "Policy",                 "color": "#8B5CF6" },
    "public-health":     { "id": "public-health",     "code": "PH",  "label": "Public Health",          "color": "#5DBF87" },
    "med-science":       { "id": "med-science",       "code": "SCI", "label": "Medical Science",        "color": "#FF6B6B" },
    "tech-econ":         { "id": "tech-econ",         "code": "TEC", "label": "Technology & Economics", "color": "#0EA5E9" }
  },
  "crosswalk": {
    "_note": "Maps the three existing vocabularies onto canonical domain ids. Left = legacy code, right = canonical domain id.",
    "lens": {
      "patient": "patient",
      "clinical": "provider-clinical",
      "operations": "provider-ops",
      "payer": "payer",
      "policy": "policy",
      "economics": "tech-econ",
      "baseline": "public-health"
    },
    "fourPs": {
      "patient": "patient",
      "provider-p2a": "provider-clinical",
      "provider-p2b": "provider-ops",
      "payer": "payer",
      "policy": "policy"
    },
    "atlasZone": {
      "patient": "patient",
      "provider": "provider-ops",
      "payer": "payer",
      "policy": "policy",
      "pubhealth": "public-health",
      "medsci": "med-science",
      "techeco": "tech-econ"
    }
  }
}
