      [legendLine('fork'), 'A <b>fork</b>: two roles at the same time (e.g. work + teach).'],
      ['grp','Tile buttons (hover)'],
      [legendBadge('✓','lg-b-green'), 'Mark a goal as something you now <b>have</b>.'],
