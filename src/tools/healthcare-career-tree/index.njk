    aen.append('text').attr('class','hct-band-txt').attr('x',EAX_W-14).attr('y',0).attr('text-anchor','end');
    aen.append('text').attr('class','ed-ax-sub').attr('x',EAX_W-14).attr('y',16).attr('text-anchor','end');
