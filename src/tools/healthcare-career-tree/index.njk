  // identity-bar header: current role · level + vital stat chips
  function renderSheetHeader(){
    const nm = document.getElementById('bp-name'); if (nm && document.activeElement !== nm) nm.value = build.name || '';
    const gl = document.getElementById('bp-goal'); if (gl && document.activeElement !== gl) gl.value = build.goal || '';
    const roleEl = document.getElementById('bp-role');
    if (roleEl){
