    document.getElementById('hct-zoomin').onclick  = () => { userZoomed = true; svg.transition().duration(180).call(zoom.scaleBy, 1.4); };
    document.getElementById('hct-zoomout').onclick = () => { userZoomed = true; svg.transition().duration(180).call(zoom.scaleBy, 1/1.4); };
