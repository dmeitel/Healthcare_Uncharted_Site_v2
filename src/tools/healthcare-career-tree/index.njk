      [legendBadge('×','#ff8080'), 'Remove the tile.'],
      [legendForkBadge('#C9A6E6'), '<b>Fork</b> — add a concurrent role (you can stack more than one).'],
      ['grp','View'],
      ['<svg width="56" height="20"><rect x="3" y="4" width="50" height="13" rx="4" style="fill:rgba(78,205,196,0.16);stroke:rgba(78,205,196,0.45)"/></svg>', '<b>Current / Future / Both</b> — switch between what you have, what you want, and both layered.']
    ];
