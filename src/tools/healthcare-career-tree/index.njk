      ['grp','On every map'],
      [ringHex(false), '<b>On your path</b>. A solid ring means you have it. Same ring on the Career Matrix, the Education Matrix, and the expertise map.'],
      [ringHex(true), '<b>Aiming for it</b>. A dashed ring is a goal you set.'],
