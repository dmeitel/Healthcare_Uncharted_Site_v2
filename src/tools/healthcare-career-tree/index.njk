      const role = cur.length ? cur[cur.length-1] : null;   // most-advanced role you HAVE
      if (role){ roleEl.innerHTML = '<b>'+esc(tileDisplayName(role,'career'))+'</b>';   // current role only — the "Tier N" depth number read as jargon
