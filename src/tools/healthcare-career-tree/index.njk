  function renderSchooling(){ if (DATA.meta.schooling){ renderEducationMatrix(); eduRendered = true; } }   // Education Matrix (time + exams ride inside each level band)

  // the degree/cert a role earns: the cert if it has one, else the degree it requires
  function metaV(n,k){ const m=(n.meta||[]).find(x=>x.k===k); return m ? m.v : ''; }
  function credFace(n){
    const c = metaV(n,'Credential');
    if (c && !/^\(?none|^none\b|employer|^None /i.test(c)){
      let s = c.split(/\s+(?:or|then)\s+/i)[0];                          // first option only
      const paren = s.match(/\(([A-Z][A-Za-z0-9\/.\- ]{1,13})\)/);       // an acronym in parens, if any
      s = s.replace(/\([^)]*\)/g,'')                                     // drop all parentheticals
           .replace(/\bspecialty\b/ig,'').replace(/\bnational\b/ig,'').replace(/\bstate\b/ig,'').replace(/\bagency\b/ig,'')
           .replace(/\bregistry\b/ig,'').replace(/\bcertificates?\b/ig,'').replace(/\bcertifications?\b/ig,'')
           .replace(/\bcert\b/ig,'').replace(/\bboard\b(?!s)/ig,'').replace(/\blicen[cs]e\b/ig,'').replace(/\bexam\b/ig,'')
           .replace(/\bpost-primary\b/ig,'').replace(/\s*\+\s*CSE\b/ig,'')
           .replace(/\+/g,' ').replace(/\s{2,}/g,' ').replace(/^[\s/\-]+|[\s/\-]+$/g,'').trim();
      if (s.length < 2 && paren) s = paren[1];
      if (/^[a-z]/.test(s) && !s.includes(' ')) s = s[0].toUpperCase() + s.slice(1);   // tidy single lowercase words
      if (s.length >= 2) return s;
    }
    const e = metaV(n,'Education');
    if (/MHA|health admin/i.test(e)) return 'MHA';
    if (/MBA/i.test(e)) return 'MBA';
    if (/MPH|public health/i.test(e)) return 'MPH';
    if (/MSN|master.*nurs/i.test(e)) return 'MSN';
    if (/bachelor.*nurs|BSN/i.test(e)) return 'BSN';
    if (/doctor|ph\.?d|dnp|dnap/i.test(e)) return (DATA.meta.degrees[n.degree]||{}).label || 'Doctoral';
    if (/master/i.test(e)) return "Master's";
    if (/bachelor/i.test(e)) return "Bachelor's";
    if (/associate/i.test(e)) return 'Associate';
    if (/certificat|state-approved/i.test(e)) return 'Certificate';
    return (DATA.meta.degrees[n.degree]||{}).label || n.degree;
  }

  // Education Matrix: each tile IS a degree/cert, tiered by level, click jumps to its career
  // a pointy-top credential hex for the Education Matrix cards (face wrapped + fitted inside)
  function eduHexSVG(face, color, dashed){
    const R = 40, w = 2*R, h = 2*R, cx = R, cy = R;
    const lines = wrapLabel(String(face||''), 9).slice(0,2);
    const ml = Math.max(...lines.map(l=>l.length), 1);
    const fs = ml>9 ? 11 : ml>7 ? 13 : ml>5 ? 15.5 : ml>3 ? 18 : 22, lh = fs + 2;
    let tspans = '';
    lines.forEach((ln,i) => tspans += '<tspan x="'+cx+'" y="'+(((cy) + (i-(lines.length-1)/2)*lh) + fs*0.34).toFixed(1)+'">'+esc(ln)+'</tspan>');
    return '<svg class="edu-hex" width="'+w+'" height="'+h+'" viewBox="0 0 '+w+' '+h+'">'+
      '<path d="'+hexPath(cx,cy,R-1.5)+'" style="fill:'+hexA(color,0.22)+';stroke:'+color+';stroke-width:1.7'+(dashed?';stroke-dasharray:4 3':'')+'"/>'+
      '<text text-anchor="middle" class="edu-hex-tx" style="font-size:'+fs+'px">'+tspans+'</text></svg>';
  }

  // Education Matrix — iceberg-style: each degree LEVEL is a stacked band (label box + credential cards)
  function renderEducationMatrix(){
    const host = document.getElementById('hct-edu-layers'); if (!host) return;
    const cls = DATA.classes.roles;
    const fcfg = cls.families, famOrder = cls.familyOrder, nodes = cls.nodes;
    const sch = DATA.meta.schooling || {};
    const ladderByDeg = {}; (sch.ladder||[]).forEach(L => ladderByDeg[L.degree] = L);
    const examsByLvl = {}; DEG_ORDER.forEach(d => examsByLvl[d] = []);
    (sch.exams||[]).forEach(e => String(e.level||'').split(' / ').forEach(tok => { tok = tok.trim(); if (examsByLvl[tok]) examsByLvl[tok].push(e); }));

    // Per level: HS/Cert show the CREDENTIAL/program (one per role → its job); AS+ show DEGREES, each linking to the
    // jobs it opens (a CNO is a JOB a Master's helps you reach, not a degree). credFace = the cert; roleDegrees = degrees.
    const rows = {};
    DEG_ORDER.forEach((deg,t) => {
      const lvlNodes = nodes.filter(n => (DEG_LEVEL[n.degree]||0) === t);
      if (deg === 'HS' || deg === 'Cert'){
        rows[t] = lvlNodes
          .sort((a,b)=> (famOrder.indexOf(a.family)-famOrder.indexOf(b.family)) || (a.label<b.label?-1:1))
          .map(n => ({ kind:'cert', n, face:credFace(n) }));
      } else {
        const byDeg = new Map();                                   // degree face → { def, roles:[] }
        lvlNodes.forEach(n => roleDegrees(n).forEach(def => {
          if (!byDeg.has(def.face)) byDeg.set(def.face, { def, roles:[] });
          byDeg.get(def.face).roles.push(n);
        }));
        rows[t] = [...byDeg.values()]
          .sort((a,b)=> (a.def.rank||0)-(b.def.rank||0) || (a.def.face<b.def.face?-1:1))   // discipline first, named next, generic last
          .map(e => ({ kind:'degree', face:e.def.face, label:e.def.label, roles:e.roles, generic:!!e.def.generic }));
      }
    });

    // build one iceberg-style band per degree level (skip empty levels — no blank rows)
    eduCards = [];
    let html = '';
    DEG_ORDER.forEach((deg,t) => {
      const items = rows[t]; if (!items.length) return;
      const dmeta = DATA.meta.degrees[deg] || {}, dc = dmeta.color || '#888', L = ladderByDeg[deg] || {}, exs = examsByLvl[deg] || [];
      const isCredLvl = (deg === 'HS' || deg === 'Cert');
      let ll = '<div class="edu-ll" style="--lc:'+dc+'">'+
        '<div class="edu-ll-top"><span class="edu-ln" style="color:'+dc+';border-color:'+hexA(dc,0.45)+';background:'+hexA(dc,0.12)+'">L'+t+'</span>'+
        '<span class="edu-deg-chip" style="background:'+dc+'">'+esc(deg)+'</span></div>'+
        '<div class="edu-lt">'+esc(dmeta.label||deg)+'</div>';
      if (L.time) ll += '<div class="edu-ltime">'+esc(L.time)+'</div>';
      ll += '<div class="edu-lcount">'+items.length+(isCredLvl ? (' credential'+(items.length!==1?'s':'')) : (' degree'+(items.length!==1?'s':'')))+'</div>';
      if (exs.length){ ll += '<div class="edu-lexams"><div class="edu-lexh">EXAMS / LICENSURE</div>';
        exs.forEach(e => ll += '<div class="edu-lex"><span class="edu-lex-dot" style="background:'+dc+'"></span><span>'+esc(e.name)+'</span></div>');
        ll += '</div>'; }
      ll += '</div>';
      let cards = '<div class="edu-cards">';
      items.forEach(item => {
        const idx = eduCards.length;
        if (item.kind === 'degree'){
          const jobs = item.roles.map(r=>r.label.replace(/\n/g,' ')).join(' ');
          const search = (item.face+' '+(item.label||'')+' '+(dmeta.label||deg)+' '+deg+' degree '+jobs).toLowerCase();
          eduCards.push({ kind:'degree', face:item.face, degree:deg, color:dc, label:item.label, roles:item.roles, search });
          cards += '<div class="edu-card" data-ec="'+idx+'" style="--cc:'+dc+'">'+ eduHexSVG(item.face, dc, !!item.generic) +
            '<div class="edu-card-sub">'+item.roles.length+' job'+(item.roles.length!==1?'s':'')+'</div></div>';
        } else {
          const fc = (fcfg[item.n.family]||{}).color || '#4ECDC4', famLbl = (fcfg[item.n.family]||{}).label || item.n.family || '';
          const search = (item.face+' '+item.n.label.replace(/\n/g,' ')+' '+famLbl+' '+(dmeta.label||deg)+' '+deg+' '+(metaV(item.n,'Credential')||'')+' '+(metaV(item.n,'Education')||'')).toLowerCase();
          eduCards.push({ kind:'cert', face:item.face, degree:item.n.degree, color:fc, role:item.n, family:item.n.family, search });
          cards += '<div class="edu-card" data-ec="'+idx+'" style="--cc:'+fc+'">'+ eduHexSVG(item.face, fc, false) +
            '<div class="edu-card-sub">'+esc(item.n.label.replace(/\n/g,' '))+'</div></div>';
        }
      });
      cards += '</div>';
      html += '<div class="edu-row">'+ll+cards+'</div>';
    });
    host.innerHTML = html || '<div class="edu-detail-empty">No credential data.</div>';
    host.querySelectorAll('.edu-card').forEach(el => { el.onclick = () => selectEduCred(parseInt(el.dataset.ec,10)); });
    if (eduMatrixSel != null && eduCards[eduMatrixSel]) selectEduCred(eduMatrixSel); else eduDetailEmpty();
  }

  function eduDetailEmpty(){
    const host = document.getElementById('hct-edu-detail'); if (!host) return;
    host.innerHTML = '<div class="edu-detail-empty">Click a degree to see how long it takes and the jobs it helps you get — then add it to your Education Growth. (The first two bands are entry credentials and certificate programs.)</div>';
  }

  // forgiving search over the Education Matrix: matches credential face, the role(s) it opens, family, degree, even
  // what someone THINKS is a degree (type "nurse" → RN/BSN/MSN; "coding" → the coder). Hides non-matches + empty bands.
  function eduFilter(q){
    const layers = document.getElementById('hct-edu-layers'); if (!layers) return;
    const toks = (q||'').trim().toLowerCase().split(/\s+/).filter(Boolean);
    let total = 0;
    layers.querySelectorAll('.edu-card').forEach(el => {
      const c = eduCards[parseInt(el.dataset.ec,10)];
      const hit = !toks.length || (c && toks.every(t => c.search.indexOf(t) >= 0));
      el.classList.toggle('edu-hide', !hit);
      if (toks.length) el.classList.remove('ip','dim','sel');   // clean result view while searching
      if (hit) total++;
    });
    layers.querySelectorAll('.edu-row').forEach(row => row.classList.toggle('edu-row-hide', !row.querySelector('.edu-card:not(.edu-hide)')));
    const note = document.getElementById('hct-edu-searchnote');
    if (note) note.textContent = toks.length ? (total ? total+' match'+(total!==1?'es':'') : 'no matches') : '';
    if (!toks.length && eduMatrixSel != null && eduCards[eduMatrixSel]) selectEduCred(eduMatrixSel);   // restore highlight when cleared
  }

  function selectEduCred(idx){
    const c = eduCards[idx]; if (!c) return;
    eduMatrixSel = idx;
    document.querySelectorAll('#hct-edu-layers .edu-card').forEach(el => {
      const i = parseInt(el.dataset.ec,10), cc = eduCards[i], sel = i===idx;
