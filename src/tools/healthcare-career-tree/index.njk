  /* credential reality block (career-tree-creds.json): pass rate · exam fee · program length */
  .hct-cred { background: var(--raised); border: 1px solid var(--border); border-radius: 10px; padding: 13px 15px; margin: 2px 0 8px; }
  .hct-cred-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .hct-cred-stat .v { font-family: var(--display); font-size: 22px; font-weight: 800; color: var(--t1); line-height: 1.05; }
  .hct-cred-stat .k { font-family: var(--mono); font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--t3); margin-top: 4px; }
  .hct-cred-len { font-size: 11.5px; color: var(--t2); margin-top: 11px; }
  .hct-list-h { font-family: var(--display); font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(78,205,196,0.85); margin: 14px 0 7px; }
  .hct-list { list-style: none; padding: 0; margin: 0; }
  .hct-list li { font-size: 12.5px; line-height: 1.45; color: rgba(220,235,240,0.88); padding-left: 16px; position: relative; margin-bottom: 5px; }
  .hct-list li::before { content: ''; position: absolute; left: 2px; top: 7px; width: 5px; height: 5px; border-radius: 50%; background: rgba(78,205,196,0.6); }
  .hct-leads { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 6px; }
  .hct-chip { font-size: 11.5px; font-weight: 600; padding: 4px 10px; border-radius: 16px; cursor: pointer; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.12); color: #cfe0e6; transition: all .12s; }
  .hct-chip:hover { background: rgba(78,205,196,0.14); border-color: rgba(78,205,196,0.4); color: #fff; }
  .hct-pin-btn {
    width: 100%; margin-top: 18px; padding: 11px; cursor: pointer; border-radius: 9px;
    font-family: var(--display); font-size: 13.5px; font-weight: 700; letter-spacing: 0.02em;
    background: rgba(232,197,71,0.14); border: 1px solid rgba(232,197,71,0.4); color: #F0CF6B; transition: all .14s;
  }
  .hct-pin-btn:hover { background: rgba(232,197,71,0.22); }
  .hct-pin-btn.pinned { background: rgba(232,197,71,0.9); color: #1a1405; border-color: rgba(232,197,71,1); }
  /* role panel: educational requirement + one-click add to Education Growth */
  .hct-edu-req { display: flex; align-items: baseline; gap: 9px; margin: 5px 0 9px; }
  .hct-edu-req-face { font-family: var(--mono); font-weight: 700; font-size: 14px; color: #6FE3D8; }
  .hct-edu-req-deg { font-size: 12px; color: rgba(180,205,215,0.72); }
  .hct-edu-add { width: 100%; margin-top: 4px; padding: 9px; cursor: pointer; border-radius: 9px; font-family: var(--display); font-size: 12.5px; font-weight: 700; background: rgba(78,205,196,0.14); border: 1px solid rgba(78,205,196,0.42); color: #8FE8DC; transition: all .14s; }
  /* explicit-layer add pairs: Current vs Future chosen at the moment of adding */
  .hct-add-lbl { font-family: var(--mono); font-size: 9px; letter-spacing: .12em; text-transform: uppercase; color: var(--t3); margin: 16px 0 6px; }
  .hct-add-lbl.gold { color: rgba(232,197,71,0.65); }
  [data-theme='light'] .hct-add-lbl.gold { color: #8A6A15; }
  .hct-add-pair { display: flex; gap: 8px; }
  .hct-add-pair .hct-pin-btn, .hct-add-pair .hct-edu-add { flex: 1; width: auto; margin-top: 0; }
  .hct-edu-add:hover { background: rgba(78,205,196,0.24); color: #fff; }
  .hct-edu-add.added { background: rgba(93,191,135,0.18); border-color: #5DBF87; color: #BFF0CE; cursor: default; }
  /* ── My Path builder (top container) ───────────────────── */
  #hct-mypath { flex-shrink: 0; margin: 0; z-index: 26; border-radius: 12px; }
  .mp-count { font-family: var(--mono); font-size: 11px; color: rgba(232,197,71,0.85); background: rgba(232,197,71,0.14); padding: 1px 8px; border-radius: 10px; }
  #hct-mp-svg { display: block; }
  .mp-fbtn { padding: 5px 11px; font-size: 11.5px; font-weight: 600; border-radius: 7px; cursor: pointer; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.14); color: #cfe0e6; }
  .mp-fbtn:hover { background: rgba(232,197,71,0.14); border-color: rgba(232,197,71,0.4); color: #F0CF6B; }
  /* ── My Path: build planner ────────────────────────────── */
  /* career "character sheet": identity bar + trunk-centric 3-column sheet */
  .bp-id { flex-shrink: 0; display: flex; align-items: center; justify-content: center; gap: 20px; flex-wrap: wrap; padding: 9px 16px 10px; border-bottom: 1px solid rgba(78,205,196,0.14); }
  .bp-id-center { flex: 0 0 auto; display: flex; align-items: center; gap: 14px; }
  /* shifter + score chips */
  .bp-id-block { display: flex; flex-direction: column; gap: 2px; }
  .bp-id-name { background: transparent; border: none; border-bottom: 1px solid rgba(120,200,190,0.28); color: #F4FAF8; font-family: var(--display); font-size: 18px; font-weight: 800; padding: 2px 1px; width: 210px; }
  .bp-id-name::placeholder { color: rgba(150,190,200,0.45); font-weight: 700; }
  .bp-id-name:focus { outline: none; border-bottom-color: #4ECDC4; }
  .bp-id-sub { font-size: 11.5px; color: rgba(180,205,215,0.62); font-family: var(--font); }
  .bp-id-tagline { font-size: 11px; font-style: italic; color: rgba(160,200,210,0.72); font-family: var(--font); line-height: 1.2; max-width: 250px; margin: 1px 0; }
  .bp-id-sub b { color: #6FE3D8; font-weight: 700; }
  .bp-id-lbl { font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(232,197,71,0.8); font-weight: 700; font-family: var(--display); }
  .bp-id-goal-in { background: rgba(0,0,0,0.3); border: 1px solid rgba(232,197,71,0.3); border-radius: 7px; color: #E2EEF4; font-size: 12.5px; padding: 5px 10px; width: 250px; font-family: var(--font); }
  .bp-id-goal-in::placeholder { color: rgba(180,170,130,0.5); font-style: italic; }
  .bp-id-goal-in:focus { outline: none; border-color: #E8C547; }
  .bp-id-vitals { display: flex; gap: 7px; }
  .bp-vital { text-align: center; padding: 4px 11px; border: 1px solid rgba(120,200,190,0.22); border-radius: 9px; background: rgba(255,255,255,0.02); min-width: 46px; }
  .bp-vital-n { font-family: var(--display); font-size: 17px; font-weight: 800; color: #6FE3D8; line-height: 1.05; }
  .bp-vital.goal .bp-vital-n { color: #E8C547; }
  .bp-vital-l { font-size: 8px; letter-spacing: 0.05em; text-transform: uppercase; color: rgba(170,200,210,0.6); font-family: var(--font); }
  .bp-sheet { flex: 1; min-height: 0; overflow-y: auto; overflow-x: hidden; padding: 12px; }
  .bp-col { max-width: 1240px; margin: 0 auto; display: flex; flex-direction: column; gap: 12px; }
  .bp-sheet::-webkit-scrollbar { width: 6px; }
  .bp-sheet::-webkit-scrollbar-thumb { background: rgba(78,205,196,0.2); border-radius: 3px; }
  .bp-spiral-wrap { display: flex; justify-content: center; }
  /* movable dashboard: Career on top, the rest flow into a multi-column card grid */
  .bp-dash-bar { display: flex; align-items: center; gap: 10px; padding: 2px 4px; }
  .bp-dash-lbl { font-size: 10.5px; letter-spacing: 0.05em; text-transform: uppercase; color: rgba(160,195,210,0.5); font-family: var(--display); }
  .bp-addwrap { position: relative; margin-left: auto; }
  .bp-addbtn { padding: 4px 11px; font-size: 11.5px; font-weight: 600; border-radius: 7px; cursor: pointer; background: rgba(120,200,190,0.1); border: 1px solid rgba(120,200,190,0.3); color: #9fe0d6; font-family: var(--font); }
  .bp-addbtn:hover { background: rgba(120,200,190,0.2); }
  .bp-addmenu { position: absolute; right: 0; top: calc(100% + 4px); min-width: 190px; background: #0a1712; border: 1px solid rgba(78,205,196,0.3); border-radius: 8px; padding: 4px; display: none; z-index: 40; box-shadow: 0 8px 28px rgba(0,0,0,0.55); }
  .bp-addmenu.open { display: block; }
  .bp-addmenu-item { padding: 6px 10px; font-size: 12px; color: rgba(214,234,238,0.88); cursor: pointer; border-radius: 6px; font-family: var(--font); }
  .bp-addmenu-item:hover { background: rgba(120,200,190,0.14); color: #fff; }
  /* the toolbar's ⋯ More overflow reuses the addmenu dress, anchored under its button */
  .mp-more { margin-left: 0; display: inline-flex; }
  .mp-more .bp-addmenu { top: calc(100% + 6px); z-index: 60; }
  .bp-dash { display: flex; flex-wrap: wrap; gap: 12px; align-items: flex-start; }
  .bp-dash.bp-dash-dragging { outline: 2px dashed rgba(78,205,196,0.45); outline-offset: 10px; border-radius: 16px; }
  /* shuffling: frame the whole sections area */
  .bp-card { flex: 1 1 290px; min-width: 290px; box-sizing: border-box; position: relative; }
  /* Education runs as a full-width horizontal timeline (like the Career Path), not a 290px column card */
  .bp-card[data-key="education"] { flex: 1 1 100%; min-width: 0; }
  .bp-card[data-key="education"] .bp-grid { overflow-x: auto; overflow-y: hidden; }
  /* Education timeline: compact, zigzagged tiles — narrower cells + tight gap; labels overflow a little but the up/down offset keeps them clear */
  #bp-grid-education { gap: 8px; }
  #bp-grid-career { gap: 12px; }   /* tighter trunk to match the compact Education timeline */
  #bp-grid-education.bp-grid-lanes .bp-node { width: 120px; }
  #bp-grid-education.bp-grid-lanes .bp-node .bp-node-lbl { max-width: 140px; }
  .bp-card:focus-within { z-index: 100; }
  /* a card with its search focused lifts above siblings so its dropdown isn't hidden behind them */
  /* Notes / Strengths cards: drag the bottom-right corner to grow them down OR sideways; the textarea fills the card */
  .bp-card.bp-resize { flex: 0 0 auto; display: flex; flex-direction: column; resize: both; overflow: auto;
    width: 320px; height: 210px; min-width: 240px; min-height: 150px; max-width: 880px; max-height: 760px; }
  .bp-card.bp-resize .bp-card-h { flex-shrink: 0; }
  .bp-card.bp-resize .bp-text { flex: 1; height: auto; min-height: 0; resize: none; }
  .bp-card { animation: bpFlyIn .32s ease both; }
  @keyframes bpFlyIn { from { opacity: 0; transform: translateX(26px); } to { opacity: 1; transform: none; } }
  .bp-card-h { display: flex; align-items: center; gap: 7px; margin: -2px -2px 8px; }
  .bp-card-t { font-family: var(--display); font-size: 12.5px; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; color: #6FE3D8; flex: 1; }
  .bp-card-t-edit { background: transparent; border: none; border-bottom: 1px dashed transparent; padding: 1px 2px; min-width: 0; }
  .bp-card-t-edit:hover { border-bottom-color: rgba(120,200,190,0.4); }
  .bp-card-t-edit:focus { outline: none; border-bottom-color: #4ECDC4; color: #8FF0E4; }
  .bp-grip { cursor: grab; color: rgba(120,200,190,0.5); font-size: 13px; line-height: 1; user-select: none; letter-spacing: -2px; }
  .bp-grip:hover { color: #4ECDC4; }
  .bp-card-h[draggable="true"] { cursor: grab; }
  .bp-card-x { border: none; background: none; color: rgba(180,205,215,0.35); font-size: 15px; line-height: 1; cursor: pointer; padding: 0 3px; border-radius: 4px; }
  .bp-card-x:hover { color: #ff8080; }
  .bp-card-dragging { opacity: 0.45; }
  .bp-card-over { outline: 2px dashed rgba(78,205,196,0.55); outline-offset: 2px; }
  .bp-panel { background: rgba(8,16,13,0.6); border: 1px solid rgba(78,205,196,0.18); border-radius: 12px; padding: 12px; transition: border-color .18s; }
  .bp-sec:hover { border-color: rgba(78,205,196,0.34); }
  .bp-sec[data-sec="plan"]:hover { border-color: rgba(232,197,71,0.45); }
  /* ── Save / Load modal ── */
  .bp-modal { position: absolute; inset: 0; z-index: 80; display: none; align-items: center; justify-content: center; background: rgba(2,7,5,0.74); padding: 24px; }
  .bp-modal.open { display: flex; }
  .bp-modal-card { position: relative; width: min(560px, 94%); max-height: 88%; overflow-y: auto; background: #0b1512; border: 1px solid rgba(78,205,196,0.34); border-radius: 14px; padding: 22px 24px 24px; box-shadow: 0 18px 50px rgba(0,0,0,0.62); }
  .bp-modal-x { position: absolute; top: 12px; right: 14px; background: none; border: none; color: rgba(180,205,215,0.5); font-size: 22px; line-height: 1; cursor: pointer; }
  .bp-modal-x:hover { color: #fff; }
  .bp-modal-h { font-family: var(--display); font-size: 17px; font-weight: 800; letter-spacing: 0.03em; color: #6FE3D8; margin-bottom: 16px; }
  .bp-modal-sec { margin-bottom: 18px; }
  .bp-modal-lbl { font-size: 12px; color: rgba(200,224,228,0.82); margin-bottom: 7px; line-height: 1.4; }
  .bp-modal-lbl b { color: #F0CF6B; }
  .bp-modal-ta { width: 100%; box-sizing: border-box; height: 86px; resize: vertical; background: rgba(0,0,0,0.34); border: 1px solid rgba(78,205,196,0.25); border-radius: 8px; color: #DCEef0; font-family: var(--mono); font-size: 11px; line-height: 1.4; padding: 9px 11px; word-break: break-all; }
  .bp-modal-ta:focus { outline: none; border-color: #4ECDC4; }
  .bp-modal-row { display: flex; align-items: center; gap: 9px; margin-top: 9px; flex-wrap: wrap; }
  .bp-modal-btn { padding: 6px 13px; font-size: 12px; font-weight: 600; border-radius: 7px; cursor: pointer; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.16); color: #cfe0e6; font-family: var(--font); transition: all .12s; }
  .bp-modal-btn:hover { background: rgba(255,255,255,0.1); color: #fff; }
  .bp-modal-btn.primary { background: rgba(78,205,196,0.18); border-color: rgba(78,205,196,0.5); color: #8FE8DC; }
  .bp-modal-btn.primary:hover { background: rgba(78,205,196,0.3); color: #fff; }
  .bp-modal-file { display: inline-block; }
  .bp-modal-msg { font-size: 11.5px; font-family: var(--font); }
  .bp-modal-msg.ok { color: #7FE3A0; }
  .bp-modal-msg.err { color: #ff9090; }
  /* ── Legend / key content — renderLegend() builds these rows inside the "? How it works" popover ── */
  .bp-legend-body { padding: 6px 14px 14px; overflow-y: auto; }
  .bp-legend-grp { font-family: var(--display); font-size: 10.5px; font-weight: 800; letter-spacing: 0.07em; text-transform: uppercase; color: rgba(160,200,210,0.65); margin: 13px 0 6px; }
  .bp-legend-grp:first-child { margin-top: 2px; }
  .bp-legend-row { display: flex; align-items: center; gap: 11px; padding: 4px 0; }
  .bp-legend-sw { flex: 0 0 50px; display: flex; align-items: center; justify-content: center; }
  .bp-legend-tx { font-size: 12px; line-height: 1.38; color: rgba(222,236,239,0.92); }
  .bp-legend-tx b { color: #F4FAF8; }

  /* ── Export sheet: a fixed-width, designed poster built from the build data (device-independent, polished) ── */
  .hct-export-sheet { box-sizing: border-box; background: linear-gradient(180deg,#0b1512,#0d1117 60%); color: #E6EEF0; font-family: var(--font); padding: 40px 42px 30px; }
  .hct-export-sheet * { animation: none !important; }
  /* nothing mid-fly-in in the capture */
  .hct-export-sheet .bp-del, .hct-export-sheet .bp-fork, .hct-export-sheet .bp-layer, .hct-export-sheet .bp-node-add { display: none !important; }
  .ex-hd { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; border-bottom: 2px solid rgba(78,205,196,0.32); padding-bottom: 18px; margin-bottom: 24px; }
  .ex-hd-name { font-family: var(--display); font-size: 35px; font-weight: 800; color: #F4FAF8; line-height: 1.04; }
  .ex-hd-role { font-size: 15px; color: #7FE3D8; margin-top: 6px; }
  .ex-hd-tagline { font-size: 14px; font-style: italic; color: rgba(180,210,215,0.82); margin-top: 5px; }
  .ex-hd-goal { font-size: 13.5px; color: #E8C547; margin-top: 5px; }
  .ex-hd-logo { width: 232px; height: auto; flex-shrink: 0; align-self: flex-end; }
  .ex-sec-ttl { font-family: var(--display); font-size: 13px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: #6FE3D8; margin-bottom: 11px; }
  .ex-trunk-wrap { border: 1px solid rgba(78,205,196,0.18); border-radius: 14px; background: rgba(8,16,13,0.55); padding: 16px 18px; margin-bottom: 18px; overflow: hidden; }
  .ex-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; align-items: start; }
  .ex-card { border: 1px solid rgba(78,205,196,0.18); border-radius: 14px; background: rgba(8,16,13,0.55); padding: 15px 17px; }
  .ex-card.ex-wide { grid-column: 1 / -1; }
  .ex-items { display: flex; flex-wrap: wrap; gap: 9px; }
  .ex-item { display: inline-flex; align-items: center; gap: 7px; font-size: 13px; color: #E2EEF0; background: rgba(255,255,255,0.035); border: 1px solid rgba(255,255,255,0.09); border-radius: 9px; padding: 4px 11px 4px 5px; }
  .ex-item.ex-fut { border-color: rgba(232,197,71,0.42); border-style: dashed; }
  .ex-item.ex-fut .ex-il { color: #F0CF6B; }
  .ex-item .ex-iy { color: rgba(180,205,210,0.6); font-size: 11.5px; }
  .ex-text { font-size: 13.5px; line-height: 1.55; color: rgba(220,235,238,0.92); white-space: pre-wrap; word-break: break-word; }
  .ex-next-grp { font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #7FE3D8; margin: 9px 0 4px; }
  .ex-next-grp:first-child { margin-top: 0; }
  .ex-next-item { font-size: 13px; color: #E2EEF0; margin: 3px 0; }
  .ex-next-item::before { content: '◇ '; color: #E8C547; }
  .ex-ft { margin-top: 22px; padding-top: 13px; border-top: 1px solid rgba(255,255,255,0.09); text-align: right; font-family: var(--mono); font-size: 11.5px; color: rgba(120,200,190,0.62); }
  /* roomier Career Path tiles so full titles fit — applies in the live tool AND the export */
  .bp-grid-lanes .bp-node { width: 132px; }
  .bp-grid-lanes .bp-node-add { position: relative; }   /* sit above the (now-underneath) connector overlay */
  .bp-grid-lanes .bp-node .bp-node-lbl { height: 48px; max-width: 130px; box-sizing: border-box; display: flex; align-items: flex-end; justify-content: center; text-align: center; -webkit-line-clamp: unset; overflow: hidden; line-height: 1.16; font-size: 11.5px; padding: 2px 6px; background: rgba(8,16,12,0.92); border-radius: 8px; }
  .bp-grid-lanes .bp-node .bp-name-role { width: 130px; height: 46px; box-sizing: border-box; white-space: pre-wrap; overflow-wrap: anywhere; overflow: hidden; resize: none; line-height: 1.16; text-align: center; font-size: 11.5px; padding: 2px 6px; background: rgba(8,16,12,0.92); border-radius: 8px; }
  /* opaque backings so connector lines pass BEHIND the title/years text, not through it */
  .bp-grid-lanes .bp-years { background: rgba(8,16,12,0.92); }
  /* a gold backdrop marks the FUTURE (goal) side vs the current side — live + export */
  .bp-grid-lanes .bp-node.bp-future { background: rgba(232,197,71,0.10); border: 1px solid rgba(232,197,71,0.30); border-radius: 12px; }
  .hct-export-sheet .ex-item.ex-fut { background: rgba(232,197,71,0.10); }
  .ex-card.ex-next { border-color: rgba(232,197,71,0.34); background: rgba(36,29,8,0.5); }
  .bp-panel-next { border-color: rgba(232,197,71,0.3); background: rgba(20,16,6,0.5); }
  .bp-next-goal { font-size: 12px; color: rgba(220,238,238,0.9); margin-bottom: 6px; padding-bottom: 8px; border-bottom: 1px solid rgba(255,255,255,0.07); line-height: 1.35; }
  .bp-next-goal b { color: #F0CF6B; }
  .bp-next-nogoal { color: rgba(180,205,215,0.5); font-style: italic; }
  .bp-next-grp { font-size: 9px; letter-spacing: 0.07em; text-transform: uppercase; color: rgba(120,210,200,0.72); font-weight: 700; margin: 9px 0 4px; font-family: var(--display); }
  .bp-next-item { display: flex; align-items: flex-start; gap: 8px; font-size: 12px; color: rgba(212,232,236,0.86); padding: 4px 2px; cursor: pointer; border-radius: 5px; font-family: var(--font); }
  .bp-next-item:hover { color: #fff; background: rgba(120,200,190,0.08); }
  .bp-next-chk { color: #E8C547; font-size: 13px; flex-shrink: 0; line-height: 1.35; }
  .bp-next-item:hover .bp-next-chk { color: #5DBF87; }
  .bp-next-tx { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
  .bp-next-act { font-size: 10.5px; font-style: italic; color: rgba(175,200,212,0.6); line-height: 1.25; }
  .bp-next-act + .bp-next-act { margin-top: 2px; }
  .bp-next-lbl { font-style: normal; font-weight: 700; color: rgba(120,210,200,0.9); font-size: 8.5px; text-transform: uppercase; letter-spacing: 0.05em; margin-right: 5px; }
  .bp-next-sug { cursor: default; }
  .bp-next-sug .bp-next-chk { color: #8FD9CE; }
  .bp-next-sug:hover, .bp-next-sug:hover .bp-next-chk { background: rgba(120,200,190,0.05); color: #8FD9CE; }
  .bp-next-add { cursor: pointer; }
  .bp-next-add .bp-next-chk { color: #F0CF6B; font-weight: 700; }
  .bp-next-add:hover { background: rgba(232,197,71,0.09); color: #fff; }
  .bp-next-add:hover .bp-next-chk { color: #E8C547; }
  .bp-next-empty { font-size: 11.5px; color: rgba(180,205,215,0.55); font-style: italic; line-height: 1.5; }
  .bp-h { display: flex; align-items: center; flex-wrap: wrap; gap: 8px;
    font-family: var(--display); font-size: 12px; font-weight: 800; letter-spacing: 0.08em;
    text-transform: uppercase; color: #6FE3D8; margin-bottom: 10px; }
  .bp-hint { font-size: 11px; color: rgba(180,205,215,0.5); margin: 0 0 10px; line-height: 1.4; }
  /* QA: once someone is exploring, the advice tidbits collapse for good (the "?" popover keeps the grammar) */
  #hct-shell.hints-min .view-hint, #hct-shell.hints-min #hct-blurb { display: none; }
  /* ── numbered story sections — the character-creation spine rides the section headers ── */
  .bp-secn { display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; border-radius: 999px; border: 1.5px solid color-mix(in srgb, var(--teal) 55%, transparent); color: var(--teal); font-family: var(--display); font-weight: 800; font-size: 12px; flex-shrink: 0; }
  [data-theme='light'] .bp-secn { color: var(--teal-dk); border-color: color-mix(in srgb, var(--teal-dk) 55%, transparent); }
  /* the guide chip: each section's station state, arrow on the first incomplete, click = focused picker */
  .bp-guide { display: inline-flex; align-items: center; gap: 7px; margin-left: auto; padding: 3px 10px; border-radius: 999px; border: 1px solid var(--border); background: var(--raised); color: var(--t2); font-family: var(--font); font-size: 11px; font-weight: 600; letter-spacing: 0; text-transform: none; cursor: pointer; transition: border-color .15s, background .15s; }
  .bp-guide:hover { border-color: var(--teal); }
  .bp-guide.todo { color: var(--t3); font-style: italic; font-weight: 500; }
  .bp-guide.done { border-color: color-mix(in srgb, var(--teal) 40%, transparent); color: var(--t1); }
  .bp-guide.dormant { opacity: 0.55; font-style: italic; color: var(--t3); }
  .bp-guide.next { border-color: var(--teal); background: color-mix(in srgb, var(--teal) 8%, var(--raised)); font-style: normal; color: var(--t1); }
  .bp-h .bp-guide:not([hidden]) ~ .bp-h-link { margin-left: 12px; }
  .st-arrow { font-family: var(--mono); font-size: 10px; font-weight: 700; color: #062024; background: var(--teal); border-radius: 999px; padding: 2px 9px; white-space: nowrap; animation: stPulse 2s ease-in-out infinite; }
  @keyframes stPulse { 0%, 100% { transform: none; } 50% { transform: translateX(3px); } }
  /* first-run spotlight: one cascade down the four numbers after the survey, then never again */
  .bp-secn.guide-flash { animation: guideFlash 1s ease; }
  @keyframes guideFlash { 0%, 100% { box-shadow: none; } 45% { box-shadow: 0 0 0 7px color-mix(in srgb, var(--teal) 30%, transparent); background: color-mix(in srgb, var(--teal) 18%, transparent); } }
  /* expertise zones: four tracks side by side inside section ③, folding to 2 then 1 */
  .bp-zones { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; align-items: start; }
  .bp-zone { min-width: 0; }
  .bp-zone-h { font-family: var(--display); font-size: 10.5px; font-weight: 800; letter-spacing: 0.07em; text-transform: uppercase; color: var(--t2); margin: 0 0 7px; }
  @media (max-width: 1100px){ .bp-zones { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px){ .bp-zones { grid-template-columns: 1fr; } }
  /* station picker internals */
  #bp-station-body { max-height: 62vh; overflow-y: auto; }
  .st-rows { display: flex; flex-direction: column; gap: 6px; margin: 8px 0 4px; }
  .st-row { display: flex; align-items: center; gap: 9px; padding: 7px 10px; background: var(--raised); border: 1px solid var(--border); border-radius: 8px; font-size: 12px; color: var(--t1); }
  .st-row .st-sub { color: var(--t3); font-size: 10.5px; font-family: var(--mono); }
  .st-add { margin-left: auto; background: rgba(232,197,71,0.14); border: 1px solid rgba(232,197,71,0.4); color: #F0CF6B; border-radius: 7px; padding: 4px 10px; font-size: 11px; font-weight: 700; cursor: pointer; font-family: var(--font); white-space: nowrap; }
  .st-add:hover { background: rgba(232,197,71,0.24); }
  [data-theme='light'] .st-add { color: #8A6A15; border-color: rgba(138,106,21,0.45); }
  .st-have { margin-left: auto; }
  .st-x { background: none; border: none; color: var(--t3); cursor: pointer; font-size: 14px; margin-left: auto; }
  .st-x:hover { color: #ff8080; }
  [data-theme='light'] .st-x:hover { color: #C0392B; }
  /* flow links — every surface names its next stop on the loop (sheet → matrices → sheet) */
  .bp-h-link { margin-left: auto; background: none; border: none; cursor: pointer; font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.04em; color: var(--teal); opacity: 0.75; padding: 2px 0; white-space: nowrap; }
  .bp-h-link:hover { opacity: 1; text-decoration: underline; }
  .bp-card-h .bp-h-link { margin-left: 0; text-transform: none; }
  [data-theme='light'] .bp-h-link { color: var(--teal-dk); }
  .hct-jump { display: block; background: none; border: none; cursor: pointer; font-family: var(--mono); font-size: 10.5px; font-weight: 700; color: var(--teal); opacity: 0.85; padding: 0; margin: 9px 0 2px; text-align: left; text-decoration: none; }
  /* the on-ramp block inside the credential-reality box */
  .hct-cred-onramp { border-bottom: 1px solid var(--border); padding-bottom: 9px; margin-bottom: 9px; }
  .hct-cred-oh { font-family: var(--display); font-size: 10px; font-weight: 800; letter-spacing: 0.07em; text-transform: uppercase; color: #8FE8DC; margin: 2px 0 5px; }
  [data-theme='light'] .hct-cred-oh { color: var(--teal-dk); }
  .hct-jump:hover { opacity: 1; text-decoration: underline; }
  [data-theme='light'] .hct-jump { color: var(--teal-dk); }
  /* tiles in a row (Career steps into family lanes); connectors drawn by one overlay SVG on top */
  .bp-grid { position: relative; display: flex; flex-direction: row; align-items: flex-start; gap: 20px; overflow-x: auto; overflow-y: hidden; padding-bottom: 6px; }
  .bp-conn-ov { position: absolute; left: 0; top: 0; pointer-events: none; overflow: visible; }
  /* container kept for layout + drag, but transparent to cut clutter */
  .bp-node { position: relative; flex: 0 0 auto; width: 76px; display: flex; flex-direction: column; align-items: center; gap: 4px;
    padding: 20px 0 8px; border-radius: 10px; background: transparent; border: 1px solid transparent; transition: border-color .12s, opacity .12s, margin-top .18s ease; }
  .bp-node .bp-hex { cursor: grab; }
  .bp-node.bp-dragging { opacity: 0.45; }
  .bp-node.bp-dragging .bp-hex { cursor: grabbing; }
  .bp-node.bp-dragover { border-color: rgba(78,205,196,0.55); background: rgba(78,205,196,0.06); }
  .bp-node-add.bp-dragover { outline: 2px dashed rgba(120,200,190,0.7); outline-offset: 3px; border-radius: 12px; }
  .bp-node-add { flex: 0 0 auto; align-self: flex-start; margin-top: 0; }
  /* fork button (Career) + forked concurrent tile */
  .bp-fork { position: absolute; top: 2px; left: 2px; width: 16px; height: 16px; display: flex; align-items: center; justify-content: center;
    border: none; background: rgba(6,14,12,0.82); color: rgba(120,200,190,0.7); cursor: pointer; border-radius: 50%; opacity: 0; transition: opacity .12s, color .12s; }
  .bp-node:hover .bp-fork { opacity: 1; }
  .bp-fork:hover { color: #4ECDC4; }
  .bp-years { width: 60px; height: 32px; box-sizing: border-box; resize: none; overflow: hidden; white-space: pre-wrap; word-break: break-word;
    background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.16); border-radius: 5px; color: #EAF4F2; font-weight: 600;
    font-size: 11px; line-height: 1.25; padding: 3px 4px; text-align: center; font-family: var(--mono); }
  .bp-years::placeholder { color: rgba(180,205,215,0.4); }
  .bp-years:focus { outline: none; border-color: #4ECDC4; }
  .bp-name { width: 66px; height: 26px; box-sizing: border-box; background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.2);
    border-radius: 6px; color: #F4FAF8; font-size: 12px; font-weight: 700; padding: 3px 5px; text-align: center; font-family: var(--font); }
  .bp-name::placeholder { color: rgba(120,200,190,0.7); font-style: italic; font-weight: 600; }
  .bp-name:focus { outline: none; border-color: #E8C547; }
  /* the "Other" anchor's name field WRAPS to ~2 lines (and scrolls beyond) instead of scrolling a single line — fits longer free text */
  .bp-name-area { width: 74px; height: 34px; resize: none; overflow-y: auto; white-space: pre-wrap; overflow-wrap: anywhere; line-height: 1.12; font-size: 11px; padding: 3px 5px; }
  .bp-del { position: absolute; top: 2px; right: 3px; width: 16px; height: 16px; line-height: 15px; text-align: center;
    border: none; background: rgba(6,14,12,0.82); color: rgba(200,215,222,0.62); font-size: 13px; cursor: pointer; border-radius: 50%; opacity: 0; transition: opacity .12s, color .12s; }
  .bp-node:hover .bp-del { opacity: 1; }
  .bp-del:hover { color: #ff8080; }
  /* "Goals only" theorycraft toggle — gold, the goal layer's color */
  .mp-fbtn.on { background: rgba(232,197,71,0.16); border-color: rgba(232,197,71,0.5); color: #F0CF6B; }
  .bp-layer { position: absolute; top: 2px; right: 22px; width: 16px; height: 16px; line-height: 15px; text-align: center;
    border: none; background: rgba(6,14,12,0.82); color: rgba(240,207,107,0.85); font-size: 10px; cursor: pointer; border-radius: 50%; opacity: 0; transition: opacity .12s, color .12s; }
  .bp-node:hover .bp-layer { opacity: 1; }
  /* hover-only, like the × */
  .bp-layer:hover { color: #F0CF6B; }
  /* current tile shows ◇ (amber) → click to set a goal */
  /* FUTURE/goal tiles read as an aspirational layer: hollow gold-dashed hex, amber label, green ✓ on hover → make it Current */
  .bp-node.bp-future .bp-hexbg { stroke-dasharray: 5 3; stroke-width: 2.4; fill-opacity: 0.45; }
  .bp-node.bp-future .bp-node-lbl, .bp-node.bp-future .bp-name, .bp-node.bp-future .bp-cred-in { color: rgba(240,212,140,0.95); }
  .bp-node.bp-future .bp-layer { color: rgba(127,227,160,0.95); }
  .bp-node.bp-future .bp-layer:hover { color: #9CF0B8; }
  .bp-node.bp-ghost { opacity: 0.32; }
  .bp-node.bp-ghost .bp-name, .bp-node.bp-ghost .bp-cred-in, .bp-node.bp-ghost .bp-years, .bp-node.bp-ghost .bp-fork, .bp-node.bp-ghost .bp-del, .bp-node.bp-ghost .bp-layer { pointer-events: none; }
  .bp-sp-cell.bp-sp-ghost { opacity: 0.34; }
  .bp-sp-cell.bp-sp-future .bp-sp-hex { fill-opacity: 0.4; }
  /* hollow = a credential you want, not yet earned */

  /* matrix-style hex tiles (skills, specs, credentials) */
  .bp-hex { display: block; }
  .bp-hexbg { stroke-width: 2; transition: filter .12s; }
  .bp-hex-tx { font-family: var(--mono); font-weight: 800; fill: #FFFFFF; pointer-events: none;
    paint-order: stroke; stroke: rgba(4,12,9,0.6); stroke-width: 3px; stroke-linejoin: round; }
  .bp-node:hover .bp-hexbg, .bp-cred:hover .bp-hexbg, .bp-node-add:hover .bp-hexbg { filter: brightness(1.3); }
  .bp-node-add { background: none; border: none; cursor: pointer; padding: 0; display: flex; align-items: flex-start; justify-content: center; }
  .bp-cred { position: relative; display: flex; flex-direction: column; align-items: center; gap: 3px; }
  .bp-cred .bp-del { top: -2px; right: 50%; transform: translateX(26px); }
  .bp-node-lbl { font-size: 11px; font-weight: 600; color: rgba(228,242,246,0.96); text-align: center; line-height: 1.12; height: 26px; max-width: 74px;
    overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
  /* Education Growth = honeycomb shell (spiral of credential hexes) */
  .bp-spiral { display: block; max-width: 100%; height: auto; max-height: 260px; margin: 0 auto; }
  .bp-sp-cell { cursor: pointer; }
  .bp-sp-hex { stroke-width: 2; transition: filter .12s; }
  .bp-sp-cell:hover .bp-sp-hex { filter: brightness(1.3); }
  .bp-sp-cell.sel .bp-sp-hex { stroke-width: 3; }
  .bp-sp-del { opacity: 0; cursor: pointer; transition: opacity .12s; }
  .bp-sp-cell:hover .bp-sp-del { opacity: 1; }
  .bp-sp-del circle { fill: rgba(6,14,12,0.92); stroke: rgba(255,128,128,0.5); stroke-width: 1; }
  .bp-sp-del text { fill: rgba(255,170,170,0.92); font-size: 12px; font-weight: 700; font-family: var(--font); }
  .bp-sp-del:hover circle { stroke: #ff8080; fill: rgba(40,10,10,0.92); }
  .bp-sp-del:hover text { fill: #ff8080; }
  /* layer-flip badge (top-left, opposite the × ): hover-only like the ×. Green ✓ on a Want tile to mark it Current, amber ◇ on a Have tile to set a goal */
  .bp-sp-layer { opacity: 0; cursor: pointer; transition: opacity .12s; }
  .bp-sp-cell:hover .bp-sp-layer { opacity: 1; }
  .bp-sp-layer circle { fill: rgba(6,14,12,0.92); stroke: rgba(232,197,71,0.5); stroke-width: 1; }
  .bp-sp-layer text { fill: rgba(240,207,107,0.92); font-size: 11px; font-weight: 800; font-family: var(--font); }
  .bp-sp-cell.bp-sp-future .bp-sp-layer circle { stroke: rgba(93,191,135,0.6); }
  .bp-sp-cell.bp-sp-future .bp-sp-layer text { fill: #7FE3A0; }
  .bp-sp-layer:hover circle { fill: rgba(10,40,20,0.92); stroke: #5DBF87; }
  .bp-sp-layer:hover text { fill: #9CF0B8; }
  .bp-sp-tx { font-family: var(--mono); font-weight: 800; fill: #FFFFFF; pointer-events: none;
    paint-order: stroke; stroke: rgba(4,12,9,0.6); stroke-width: 3px; stroke-linejoin: round; }
  .bp-sp-add { cursor: pointer; }
  .bp-sp-addhex { fill: rgba(255,255,255,0.03); stroke: rgba(232,197,71,0.4); stroke-width: 1.5; stroke-dasharray: 4 3; }
  .bp-sp-add:hover .bp-sp-addhex { stroke: #E8C547; }
  .bp-sp-add .bp-sp-tx { font-size: 24px; fill: rgba(232,197,71,0.85); }
  .bp-cred-in { width: 100%; box-sizing: border-box; background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.12);
    border-radius: 5px; color: #EDF6F4; font-size: 10px; padding: 2px 4px; text-align: center; font-family: var(--mono); }
  .bp-cred-in:focus { outline: none; border-color: #E8C547; }
  /* real-data picker (search → drop a tree node in) */
  .bp-pick { position: relative; margin-bottom: 10px; }
  .bp-pick-in { width: 100%; box-sizing: border-box; background: rgba(0,0,0,0.28); border: 1px solid rgba(78,205,196,0.25);
    border-radius: 7px; color: #E2EEF4; font-size: 11.5px; padding: 6px 9px; font-family: var(--font); }
  .bp-pick-in:focus { outline: none; border-color: rgba(78,205,196,0.55); }
  .bp-suggest { position: absolute; top: calc(100% + 3px); left: 0; right: 0; z-index: 50; background: rgba(7,15,12,0.99);
    border: 1px solid rgba(78,205,196,0.25); border-radius: 8px; box-shadow: 0 10px 26px rgba(0,0,0,0.55); max-height: 240px; overflow-y: auto; display: none; }
  .bp-suggest.open { display: block; }
  .bp-suggest.bp-float { position: fixed; left: 0; top: 0; right: auto; z-index: 200; }
  .bp-sg { display: flex; align-items: center; gap: 8px; padding: 6px 9px; cursor: pointer; font-size: 11.5px; color: #E2EEF4; }
  .bp-sg-head { padding: 7px 10px 6px; font-size: 9.5px; font-style: italic; color: rgba(150,190,200,0.72); border-bottom: 1px solid rgba(255,255,255,0.08); margin-bottom: 3px; }
  .bp-sg:hover { background: rgba(78,205,196,0.1); }
  .bp-sg-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .bp-sg-nm { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .bp-sg-ab { margin-left: auto; font-family: var(--mono); font-size: 9.5px; color: rgba(160,195,210,0.7); flex-shrink: 0; }
  .bp-sg.on { opacity: 0.55; }
  /* ── Areas of Expertise Matrix (one map, three zones) ──────────────── */
  .view-head { flex-shrink: 0; display: flex; align-items: baseline; gap: 12px; padding: 9px 16px 8px; }
  .view-ttl { font-family: var(--display); font-size: 14px; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; color: #6FE3D8; }
  .view-hint { font-size: 11.5px; color: rgba(180,205,215,0.5); font-style: italic; }
  #hct-atlas { padding: 0; }
  #hct-atlas-board { position: relative; flex: 1; min-height: 0; overflow: hidden; margin: 0 8px 8px;
    border: 1px solid rgba(78,205,196,0.18); border-radius: 12px; background: rgba(6,13,11,0.4); }
  #hct-atlas-svg { width: 100%; height: 100%; display: block; cursor: grab; }
  #hct-atlas-svg.grabbing { cursor: grabbing; }
  #hct-atlas-svg text { user-select: none; -webkit-user-select: none; }
  .atlas-node-back { fill: #08120e; }
  [data-theme='light'] .atlas-node-back { fill: #FBFDFC; }
  .atlas-abbr { fill: #EAF6F4; font-family: var(--mono); pointer-events: none; }
  [data-theme='light'] .atlas-abbr { fill: #22333B; }
  /* board-grammar chrome (the radial wedges/hulls/territories retired to the archive) */
  .at-sub { font-size: 7.5px; font-weight: 600; fill: rgba(200,224,230,0.8); font-family: var(--font); pointer-events: none; transition: opacity .15s; }
  [data-theme='light'] .at-sub { fill: #3f5a64; }
  #hct-atlas-svg.ed-far .at-sub { opacity: 0; }
  /* parked ALWAYS wins — .dim/.atlas-dim land on parked tiles too (equal specificity, later
     rules won), which resurrected other zones' tiles at 28% ON TOP of a snapped zone */
  .atlas-node.at-off { opacity: 0 !important; pointer-events: none; }
  .atlas-node.dim { opacity: 0.28; }
  .atlas-node.at-active .atlas-hex { fill-opacity: 0.55; stroke-width: 2.6; }
  /* lens dock — top-left, token surfaces so it flips themes by construction */
  .atlas-lens { position: absolute; top: 10px; left: 10px; z-index: 3; display: flex; align-items: center; gap: 5px; flex-wrap: wrap;
    max-width: calc(100% - 20px); box-sizing: border-box; background: var(--surface); border: 1px solid var(--border); border-radius: 9px; padding: 5px 8px; }
  .atlas-lens-lbl { font-family: var(--mono); font-size: 9.5px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--t3); margin-right: 2px; }
  .atlas-lens button { padding: 3px 10px; font-size: 11px; font-weight: 700; border-radius: 999px; cursor: pointer; font-family: var(--font);
    background: rgba(255,255,255,0.04); border: 1px solid var(--border); color: var(--t2); transition: all .12s; }
  .atlas-lens button:hover { color: var(--t1); border-color: var(--teal); }
  .atlas-lens button.on { background: var(--teal); border-color: var(--teal); color: #062024; }
  [data-theme='light'] .atlas-lens button { background: rgba(0,0,0,0.03); }
  [data-theme='light'] .atlas-lens button.on { background: var(--teal); color: #062024; }
  /* multi-select owns the bottom edge — the HUD steps aside so the selbar never covers it */
  #hct-atlas-selbar.on ~ .atlas-hud { opacity: 0; transition: opacity .15s; }
  @media (max-width: 640px) { .atlas-selbar { bottom: 60px; } }   /* clear of the bottom edge on phones */
  /* Education Matrix cards speak the same on-path ring language */
  .lg-ring { stroke: #F6F9FC; }
  [data-theme='light'] .lg-ring { stroke: #2E4450; }
  .lg-teal { fill: var(--teal); }
  [data-theme='light'] .lg-teal { fill: var(--teal-dk); }
  /* legend "tile button" badges flip with the theme like the real buttons do */
  .lg-badge { fill: rgba(6,14,12,0.92); stroke-width: 1.2; }
  [data-theme='light'] .lg-badge { fill: rgba(255,255,255,0.94); }
  circle.lg-b-green { stroke: #7FE3A0; } text.lg-b-green { fill: #7FE3A0; }
  circle.lg-b-gold { stroke: #F0CF6B; } text.lg-b-gold { fill: #F0CF6B; }
  circle.lg-b-red { stroke: #ff8080; } text.lg-b-red { fill: #ff8080; }
  circle.lg-b-purp { stroke: #C9A6E6; } path.lg-b-purp { stroke: #C9A6E6; }
  [data-theme='light'] circle.lg-b-green { stroke: #1E7A48; } [data-theme='light'] text.lg-b-green { fill: #1E7A48; }
  [data-theme='light'] circle.lg-b-gold { stroke: #8A6A15; } [data-theme='light'] text.lg-b-gold { fill: #8A6A15; }
  [data-theme='light'] circle.lg-b-red { stroke: #C0392B; } [data-theme='light'] text.lg-b-red { fill: #C0392B; }
  [data-theme='light'] circle.lg-b-purp { stroke: #6B3F92; } [data-theme='light'] path.lg-b-purp { stroke: #6B3F92; }
  /* ── light-mode sweep (QA audit 2026-07-12): dark-tuned leftovers that never flipped ── */
  [data-theme='light'] .bp-hex-tx, [data-theme='light'] .bp-sp-tx, [data-theme='light'] .edu-hex-tx { fill: #22333B; stroke: rgba(246,249,252,0.65); }
  [data-theme='light'] .atlas-node.atlas-sel .atlas-hex { stroke: #2E4450; }
  [data-theme='light'] .hct-clegend .cl-nd i { background: #d7dee5; border-color: #b9c3cd; }
  [data-theme='light'] .atlas-selbar { background: var(--surface); border-color: var(--border); }
  [data-theme='light'] #hct-atlas-selcount { color: var(--t2); }
  [data-theme='light'] .atlas-selbtn { color: var(--t2); background: rgba(0,0,0,0.03); border-color: var(--border); }
  [data-theme='light'] .atlas-selbtn:hover { background: rgba(0,0,0,0.07); color: var(--t1); }
  [data-theme='light'] .atlas-selbtn.add { color: #6B3F92; }
  [data-theme='light'] .atlas-selbtn.add:hover { color: #4E2B6E; }
  [data-theme='light'] input::placeholder, [data-theme='light'] textarea::placeholder { color: var(--t3); }
  [data-theme='light'] .bp-grip { color: var(--t3); }
  [data-theme='light'] .hct-phead-txt, [data-theme='light'] .hct-fhead { filter: brightness(0.62) saturate(1.35); }   /* pathway/family headers: attr colors deepened the badge way */
  [data-theme='light'] .atlas-zone-lbl { filter: brightness(0.62) saturate(1.35); }
  [data-theme='light'] #hct-tip .tip-fam { filter: brightness(0.7) saturate(1.35); }
  [data-theme='light'] .bp-next-add:hover .bp-next-chk { color: #8A6A15; }
  [data-theme='light'] .bp-sp-addhex { stroke: rgba(138,106,21,0.55); }
  [data-theme='light'] .bp-sp-add:hover .bp-sp-addhex { stroke: #8A6A15; }
  [data-theme='light'] .bp-sp-add .bp-sp-tx { fill: #8A6A15; }
  /* the track "+" hex carries inline fill/stroke from bpHexSVG — inline needs !important to repaint */
  [data-theme='light'] .bp-node-add .bp-hexbg { fill: rgba(0,0,0,0.02) !important; stroke: color-mix(in srgb, var(--teal-dk) 60%, transparent) !important; }
  [data-theme='light'] .bp-node-add.bp-add-cred .bp-hexbg { stroke: color-mix(in srgb, #8A6A15 65%, transparent) !important; }
  [data-theme='light'] .hct-band-rect { fill: rgba(20,40,45,0.04); }   /* zebra: white-alpha attr fill vanished on light — repaint dark-alpha */
  /* what's on your path is the loudest thing on the board */
  .atlas-node.installed-cur .atlas-hex { fill-opacity: 0.5; }
  .atlas-node.installed-fut .atlas-hex { fill-opacity: 0.34; }
  .atlas-zone-lbl { font-family: var(--display); font-size: 16px; font-weight: 800; letter-spacing: 0.12em; pointer-events: none; }
  .atlas-hex { transition: fill-opacity .12s; }
  .atlas-node { transition: opacity .15s ease; }
  .atlas-node:hover .atlas-hex { fill-opacity: 0.5; }
  /* search highlight: matches pop (brighter fill + glow), non-matches fade back */
  .atlas-node.atlas-lensdim { opacity: 0.3; }   /* before .atlas-dim on purpose: an active search still wins */
  .atlas-node.atlas-dim { opacity: 0.12; pointer-events: none; }
  .atlas-node.atlas-hit { filter: drop-shadow(0 0 6px rgba(127,234,217,0.85)); }
  .atlas-node.atlas-hit .atlas-hex { fill-opacity: 0.6; stroke-width: 2.6; }
  /* multi-select: checked hexes get a solid fill, white ring, and a ✓ badge */
  .atlas-node.atlas-sel .atlas-hex { fill-opacity: 0.72; stroke: #EAF6F4; stroke-width: 2.6; }
  .atlas-check { opacity: 0; pointer-events: none; transition: opacity .12s; }
  .atlas-node.atlas-sel .atlas-check { opacity: 1; }
  .atlas-check circle { fill: #7FEAD9; stroke: #042018; stroke-width: 1; }
  .atlas-check text { font-family: var(--font); font-size: 9px; font-weight: 800; fill: #042018; pointer-events: none; }
  /* (band border + seam label styles retired — depth reads from pips + the corner key) */
  /* on-your-path rings — WHITE, not gold (gold is the Specializations zone color).
     Solid = you have it (Current); dashed = you're aiming (Future, the goal grammar). */
  .atlas-inst-ring { fill: none; stroke: #F6F9FC; stroke-width: 2; opacity: 0; pointer-events: none; }
  .atlas-node.installed-cur .atlas-inst-ring { opacity: 0.95; }
  .atlas-node.installed-fut .atlas-inst-ring { opacity: 0.85; stroke-dasharray: 5 4; }
  [data-theme='light'] .atlas-inst-ring { stroke: #2E4450; }
  .ah-g { font-style: normal; font-family: var(--mono); font-size: 10px; font-weight: 700; color: var(--t3); margin-left: 3px; letter-spacing: 0; }
  /* the have/want pair inside the Education Matrix detail foot */
  .edu-d-foot .hct-add-lbl { margin: 0 0 7px; }
  .edu-d-foot .hct-add-pair { display: flex; gap: 8px; }
  .edu-d-foot .hct-add-pair .edu-d-add { flex: 1; width: auto; }
  /* the 4-zone tally: what you've installed, by zone — stacked, one column */
  /* the tally: one compact row along the bottom — clears the left axis AND the attribution pill */
  .atlas-hud { position: absolute; left: 50%; transform: translateX(-50%); bottom: 40px; display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: 6px; z-index: 5; pointer-events: none; max-width: calc(100% - 24px); }
  .ah-box { display: flex; align-items: center; gap: 7px; padding: 5px 10px; background: var(--surface); border: 1px solid var(--border); border-left: 3px solid var(--zc, var(--teal)); border-radius: 8px; }
  .ah-n { font-family: var(--display); font-size: 15px; font-weight: 800; color: var(--t1); line-height: 1; }
  .ah-w { display: flex; flex-direction: column; gap: 1px; }
  .ah-lbl { font-family: var(--mono); font-size: 8.5px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--t2); }
  .ah-t { display: none; }   /* "of N on your path" retired to the panel — the chip is count + zone */
  @media (max-width: 700px) { .ah-box { padding: 5px 8px; } }
  /* the HUD's way home — the one clickable thing in the tally stack */
  .ah-back { pointer-events: auto; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 6px 11px; cursor: pointer; font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.04em; color: var(--teal); }
  .ah-back:hover { color: var(--t1); border-color: var(--teal); }
  [data-theme='light'] .ah-back { color: var(--teal-dk); }
  #hct-atlas-selbar.on ~ .atlas-hud .ah-back { pointer-events: none; }   /* faded with the HUD in select mode — never an invisible click target */
  .atlas-tools { margin-left: auto; margin-right: auto; display: flex; align-items: center; gap: 9px; }   /* centered in the head bar */
  .atlas-multibtn { padding: 6px 12px; font-size: 11.5px; font-weight: 700; border-radius: 7px; cursor: pointer; white-space: nowrap;
    background: rgba(176,123,214,0.12); border: 1px solid rgba(176,123,214,0.4); color: #C9A6E6; font-family: var(--font); transition: all .12s; }
  .atlas-multibtn:hover { background: rgba(176,123,214,0.22); color: #E6D6F4; }
  .atlas-multibtn.on { background: #B07BD6; border-color: #B07BD6; color: #16091f; }
  .atlas-selbar { position: absolute; left: 50%; bottom: 16px; transform: translateX(-50%); display: none; align-items: center; gap: 10px;
    flex-wrap: wrap; justify-content: center; max-width: calc(100vw - 24px); box-sizing: border-box;
    background: rgba(8,14,22,0.97); border: 1px solid rgba(176,123,214,0.45); border-radius: 11px; padding: 8px 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.55); z-index: 12; }
  .atlas-selbar.on { display: flex; }
  #hct-atlas-selcount { font-size: 12px; font-weight: 700; color: #E6D6F4; font-family: var(--font); min-width: 74px; }
  .atlas-selbtn { padding: 5px 11px; font-size: 11.5px; font-weight: 600; border-radius: 7px; cursor: pointer; white-space: nowrap;
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.16); color: #cfe0e6; font-family: var(--font); transition: all .12s; }
  .atlas-selbtn:hover { background: rgba(255,255,255,0.1); color: #fff; }
  .atlas-selbtn.add { background: rgba(176,123,214,0.18); border-color: rgba(176,123,214,0.5); color: #D9C2EE; }
  .atlas-selbtn.add:hover { background: rgba(176,123,214,0.32); color: #fff; }
  .atlas-selbtn:disabled { opacity: 0.4; cursor: default; }
  .bp-text { width: 100%; box-sizing: border-box; min-height: 92px; resize: vertical;
    background: rgba(0,0,0,0.22); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;
    color: #D6EEF0; font-size: 12.5px; line-height: 1.5; padding: 8px 10px; font-family: var(--font); }
  .bp-text:focus { outline: none; border-color: rgba(78,205,196,0.45); }

  /* ── Pathway filter panel + metric selector (Control Architecture v2) ──
     The .selector / .selector-pop / .pop-opt / .applied-strip primitives live
     in hu-global.css; only tool-specific touches are here. */
  .hct-allgrp { display: flex; gap: 5px; }
  .hct-allgrp .hct-allbtn { flex: 1; }
  .hct-allbtn { padding: 4px 10px; font-size: 11px; font-weight: 700; border-radius: 7px; cursor: pointer; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.16); color: #cfe0e6; white-space: nowrap; }
  .hct-allbtn.show { background: rgba(78,205,196,0.12); border-color: rgba(78,205,196,0.32); color: #8FE8DC; }
  .hct-allbtn:hover { filter: brightness(1.2); }
  #hct-pop-paths .hct-allgrp { padding: 8px 8px 2px; flex-shrink: 0; }
  .pop-opt .pdot, .pop-opt .fdot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .pop-opt .ddc { font-family: var(--mono); font-size: 10px; opacity: 0.7; }
  #hct-pop-paths .pop-opt-pw { font-weight: 700; }
  #hct-pop-paths .pop-opt-sub { padding-left: 28px; }
  .vh { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; }
  #hct-loading { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; color: rgba(140,180,215,0.6); font-size: 14px; z-index: 50; }
  /* ── Light mode ────────────────────────────────────────── */
  [data-theme='light'] #hct-shell { background: #eef3f1; color: #14323a; }
  [data-theme='light'] #hct-tb { background: rgba(255,255,255,0.96); border-bottom-color: rgba(27,95,168,0.18); }
  [data-theme='light'] #hct-panel, [data-theme='light'] #hct-mypath { background: rgba(255,255,255,0.99); }
  [data-theme='light'] .hct-node .hx-back { fill: #eef3f1; }
  [data-theme='light'] .hct-node .hx-pinring { stroke: #2E4450; }
  [data-theme='light'] .hct-node .hx-abbr { fill: #102a30; }
  [data-theme='light'] .hct-p-summary, [data-theme='light'] .hct-list li, [data-theme='light'] .hct-meta .v { color: #1d3b42; }
  [data-theme='light'] #hct-tip { background: #fff; color: #14323a; border-color: rgba(27,95,168,0.3); }
  [data-theme='light'] .hct-band-rect { fill-opacity: 0.6; }
  [data-theme='light'] .hct-band-txt { fill: #16323a; }

  @media (max-width: 720px) {
  .hct-logo { display: none; }
  #hct-panel { width: 300px; }
  
  }


  /* ═══════════════════════════════════════════════════════════════
     THEME ALIGNMENT — re-point the structural surfaces, inputs, and the
     text on them to the site's design tokens, so the tool matches the
     rest of the site in dark mode and follows the day/night toggle.
     Accent colors (teal, amber, field hues) are left intentional.
     Placed last so it wins by source order. */
  #hct-shell { background: var(--dark); color: var(--t2); }
  #hct-tb { background: var(--surface); border-bottom-color: var(--border); }
  #hct-schooling, #hct-panel, .edu-detail, .bp-panel,
  .bp-modal-card, .bp-addmenu,
  #hct-tip { background: var(--surface); border-color: var(--border); }
  #hct-panel { border-left-color: var(--border); }
  #hct-tip { color: var(--t1); }
  .bp-panel-next { background: var(--surface); }
  .hct-p-head, .bp-id { border-bottom-color: var(--border); }
  .top-frozen-bg { fill: var(--surface); }   /* .axis-bg rides the #axisFade gradient */
  .hct-node .hx-back { fill: var(--dark); }
  .hct-band-txt, .hct-node .hx-title { fill: var(--t1); }

  /* inputs — token surfaces keep their text legible in both themes */
  .edu-search, .bp-id-goal-in, .bp-years, .bp-name, .bp-name-area,
  .bp-modal-ta, .bp-text { background: var(--raised); color: var(--t1); border-color: var(--border); }
  .bp-id-name { color: var(--t1); border-bottom-color: var(--border); }
  /* Career Path tiles: role-name + year boxes use higher-specificity lane
     backings, so override them at matching specificity (they were black in
     light mode and near-black-green in dark — now token surfaces in both). */
  .bp-grid-lanes .bp-node .bp-node-lbl,
  .bp-grid-lanes .bp-node .bp-name-role,
  .bp-grid-lanes .bp-years { background: var(--raised); color: var(--t1); }
  /* section search inputs + the results dropdown */
  .bp-cred-in, .bp-pick-in { background: var(--raised); color: var(--t1); border-color: var(--border); }
  .bp-suggest { background: var(--surface); border-color: var(--border); }
  .bp-sg { color: var(--t2); }
  .bp-sg-ab { color: var(--t3); }
  /* Career Path name boxes: tighter + vertically centered so short titles
     don't float in a big box; imported roles are click-to-rename. */
  .bp-grid-lanes .bp-node .bp-node-lbl,
  .bp-grid-lanes .bp-node .bp-name-role { height: 44px; font-size: 11px; line-height: 1.14; padding: 3px 7px; }
  .bp-grid-lanes .bp-node .bp-node-lbl { display: flex; align-items: center; justify-content: center; }
  .bp-node-edit { cursor: text; outline: 1px solid transparent; transition: outline-color .12s; }
  .bp-node-edit:hover { outline-color: var(--border2); }
  .bp-node-edit:focus { outline: 1px solid var(--teal); }
  /* the export poster is always dark — pin its trunk tiles to fixed dark chips
     so an export taken in light mode still looks right */
  .hct-export-sheet .bp-grid-lanes .bp-node .bp-node-lbl,
  .hct-export-sheet .bp-grid-lanes .bp-years { background: rgba(255,255,255,0.06); color: #EAF4F2; border-color: rgba(255,255,255,0.12); }

  /* light mode — turn the previously light-only text dark on the now-light surfaces */
  [data-theme='light'] .bp-legend-tx, [data-theme='light'] .bp-legend-grp,
  [data-theme='light'] .edu-d-ex,
  [data-theme='light'] .hct-chip, [data-theme='light'] .bp-id-sub,
  [data-theme='light'] .bp-id-tagline, [data-theme='light'] .bp-vital-l,
  [data-theme='light'] .bp-dash-lbl, [data-theme='light'] .bp-next-item,
  [data-theme='light'] .bp-next-goal, [data-theme='light'] .bp-next-empty,
  [data-theme='light'] .bp-modal-lbl, [data-theme='light'] .bp-hint,
  [data-theme='light'] .hct-meta .k, [data-theme='light'] .edu-searchnote,
  [data-theme='light'] .hct-blurb, [data-theme='light'] .bp-next-act { color: var(--t2); }
  [data-theme='light'] .bp-legend-tx b,
  [data-theme='light'] .edu-d-ttl, [data-theme='light'] .bp-name { color: var(--t1); }

  /* light mode, continued — chrome text/borders still carrying dark-tuned
     light literals on the now-white token surfaces */
  [data-theme='light'] .hct-seg button { color: var(--t2); }
  [data-theme='light'] .hct-seg button:hover { color: var(--t1); background: rgba(0,0,0,0.04); }
  [data-theme='light'] .hct-lbl { color: var(--t3); }
  [data-theme='light'] .hct-btn { color: var(--t2); background: rgba(0,0,0,0.03); }
  [data-theme='light'] .hct-btn:hover { color: var(--t1); }
  [data-theme='light'] .hct-p-close, [data-theme='light'] .bp-modal-x,
  [data-theme='light'] .bp-card-x { color: var(--t3); }
  [data-theme='light'] .hct-p-close:hover, [data-theme='light'] .bp-modal-x:hover { color: var(--t1); }
  [data-theme='light'] .bp-modal-btn, [data-theme='light'] .mp-fbtn,
  [data-theme='light'] .hct-allbtn,
  [data-theme='light'] .bp-addmenu-item { color: var(--t2); }
  [data-theme='light'] .bp-modal-btn, [data-theme='light'] .mp-fbtn,
  [data-theme='light'] .hct-allbtn { border-color: var(--border); }
  [data-theme='light'] .bp-modal-btn:hover,
  [data-theme='light'] .bp-addmenu-item:hover, [data-theme='light'] .bp-next-item:hover,
  [data-theme='light'] .bp-next-add:hover,
  [data-theme='light'] .hct-chip:hover { color: var(--t1); }
  [data-theme='light'] .bp-modal-btn:hover { background: rgba(0,0,0,0.05); }
  [data-theme='light'] .hct-chip { background: rgba(0,0,0,0.03); border-color: var(--border); }
  [data-theme='light'] .edu-d-chip, [data-theme='light'] .hct-edu-req-deg { color: var(--t2); }
  [data-theme='light'] .edu-detail-empty, [data-theme='light'] .view-hint,
  [data-theme='light'] .bp-sg-head, [data-theme='light'] #hct-loading,
  [data-theme='light'] .bp-next-nogoal { color: var(--t3); }
  [data-theme='light'] .bp-node-lbl { color: var(--t1); }
  [data-theme='light'] .edu-d-add { color: var(--t1); }
  [data-theme='light'] .bp-vital { border-color: var(--border); background: rgba(0,0,0,0.02); }
  [data-theme='light'] .edu-d-top { border-bottom-color: var(--border); }
  [data-theme='light'] .edu-d-foot { border-top-color: var(--border); }
  /* teal accents readable as TEXT on white → dark-teal convention */
  [data-theme='light'] .hct-p-abbr, [data-theme='light'] .hct-list-h,
  [data-theme='light'] .hct-edu-req-face, [data-theme='light'] .bp-id-sub b,
  [data-theme='light'] .bp-vital-n, [data-theme='light'] .bp-card-t,
  [data-theme='light'] .bp-h,
  [data-theme='light'] .bp-modal-h, [data-theme='light'] .view-ttl,
  [data-theme='light'] .edu-d-sech,
  [data-theme='light'] .bp-next-lbl,
  [data-theme='light'] .bp-addbtn,
  [data-theme='light'] .bp-card-t-edit:focus,
  [data-theme='light'] .bp-next-sug .bp-next-chk,
  [data-theme='light'] .hct-bls-stat .v.g-hi, [data-theme='light'] .hct-bls-stat .v.g-mid,
  [data-theme='light'] .hct-bls-src a, [data-theme='light'] #hct-tip .tip-val { color: var(--teal-dk); }
  /* 11px/700 on the white popover needs deeper teal than --teal-dk for 4.5:1 */
  [data-theme='light'] .hct-allbtn.show { color: #0D7268; }
  [data-theme='light'] .hct-edu-add, [data-theme='light'] .hct-edu-add:hover,
  [data-theme='light'] .bp-modal-btn.primary, [data-theme='light'] .bp-modal-btn.primary:hover { color: var(--teal-dk); }
  /* gold accents → darker gold on white */
  [data-theme='light'] .tab-badge, [data-theme='light'] .mp-count,
  [data-theme='light'] .bp-id-lbl,
  [data-theme='light'] .edu-d-time, [data-theme='light'] .bp-modal-lbl b,
  [data-theme='light'] .bp-next-goal b, [data-theme='light'] .bp-next-chk,
  [data-theme='light'] .mp-fbtn:hover,
  [data-theme='light'] .hct-pin-btn { color: #8A6A15; }
  [data-theme='light'] .bp-vital.goal .bp-vital-n { color: #8A6A15; }
  [data-theme='light'] .hct-bls-stat .v.g-lo { color: #8A6A15; }
  [data-theme='light'] .bp-node.bp-future .bp-node-lbl, [data-theme='light'] .bp-node.bp-future .bp-name,
  [data-theme='light'] .bp-node.bp-future .bp-cred-in { color: #8A6A15; }
  /* tile hover corner-buttons: dark discs → white discs, accents to the on-white palette */
  [data-theme='light'] .bp-fork, [data-theme='light'] .bp-del, [data-theme='light'] .bp-layer { background: rgba(255,255,255,0.94); box-shadow: 0 1px 4px rgba(20,40,38,0.28); }
  [data-theme='light'] .bp-fork { color: var(--teal-dk); }
  [data-theme='light'] .bp-fork:hover { color: #0D7268; }
  [data-theme='light'] .bp-del { color: var(--t3); }
  [data-theme='light'] .bp-del:hover { color: #C0392B; }
  [data-theme='light'] .bp-layer { color: #8A6A15; }
  [data-theme='light'] .bp-layer:hover { color: #6E5410; }
  [data-theme='light'] .bp-node.bp-future .bp-layer { color: #1E7A48; }
  [data-theme='light'] .bp-node.bp-future .bp-layer:hover { color: #16613A; }
  /* state re-asserts (same-or-higher specificity rules above would bleed in) */
  [data-theme='light'] .hct-seg button.on { background: var(--teal); color: #062024; }
  [data-theme='light'] .hct-seg.dom button.on { background: rgba(232,168,56,0.2); color: #8A6A15; }
  [data-theme='light'] .mp-fbtn.on { background: rgba(232,197,71,0.22); border-color: rgba(138,106,21,0.5); color: #8A6A15; }
  [data-theme='light'] .hct-pin-btn.pinned { background: rgba(232,197,71,0.9); color: #1a1405; }
  [data-theme='light'] .hct-edu-add.added, [data-theme='light'] .edu-d-add.added { color: #1E7A48; }
  [data-theme='light'] .bp-modal-msg.ok { color: #1E7A48; }
  [data-theme='light'] .bp-modal-msg.err { color: #B03A3A; }
  [data-theme='light'] .hct-btn.reset { color: #B03A3A; border-color: rgba(176,58,58,0.4); }
  [data-theme='light'] .hct-btn.reset:hover { color: #8F2626; background: rgba(176,58,58,0.08); }
  [data-theme='light'] #cred-remove, [data-theme='light'] #item-remove { color: #B03A3A !important; }
  /* purple multi-select accent */
  [data-theme='light'] .atlas-multibtn { color: #7A4AA8; }
  [data-theme='light'] .atlas-multibtn:hover { color: #5D3585; }
  [data-theme='light'] .atlas-multibtn.on { background: #B07BD6; color: #16091f; }
  /* JS-inlined accent chips: darken text + tint together */
  [data-theme='light'] .hct-p-badge,
  [data-theme='light'] .edu-d-badge, [data-theme='light'] .edu-d-sub { filter: brightness(0.72) saturate(1.35); }
  /* career board scene lines drawn with white literals → ink on the light board */
  [data-theme='light'] .hct-rcontainer { fill: rgba(0,40,50,0.02); stroke: rgba(0,40,50,0.14); }
  [data-theme='light'] .hct-region-div { stroke: rgba(0,40,50,0.2); }
  [data-theme='light'] .hct-region-clin { fill: rgba(11,106,96,0.55); }
  [data-theme='light'] .hct-region-biz { fill: rgba(138,106,21,0.5); }
  [data-theme='light'] .hct-band-line { stroke: rgba(27,95,168,0.15); }
  /* schooling zoombar was a pinned-dark pill on the now-white matrix */
  [data-theme='light'] .sch-zoombar button { background: rgba(255,255,255,0.92); border-color: rgba(30,122,72,0.4); color: #1E7A48; }
  [data-theme='light'] .sch-zoombar button:hover { border-color: #1E7A48; color: #14532D; }
  /* Areas of Expertise board: hex styling is dark-tuned (white-literal grid,
     pale hub/zone ink) — pin the board itself dark; its chrome stays themed */
  /* the atlas board FLIPS in light mode (it was pinned dark — that's why the theme "didn't work") */
  [data-theme='light'] #hct-atlas-board { background: var(--surface); border-color: var(--border); }

  /* ═══════════════════════════════════════════════════════════════
     TOUCH · KEYBOARD · SMALL-SCREEN pass (placed last so it wins).
     ═══════════════════════════════════════════════════════════════ */

  /* Keyboard focus: many controls null their :focus outline — restore a visible ring for keyboard users only. */
  #hct-shell button:focus-visible, #hct-shell input:focus-visible, #hct-shell textarea:focus-visible,
  #hct-shell [tabindex]:focus-visible, #hct-shell a:focus-visible {
    outline: 2px solid var(--teal); outline-offset: 2px; border-radius: 4px;
  }

  /* Touch devices have no hover, so the hover-revealed tile controls (delete / fork / layer-flip) are unreachable.
     Show them, and give the small badges a bigger hit area. */
  @media (hover: none) {
    .bp-fork, .bp-del, .bp-layer, .bp-sp-del, .bp-sp-layer { opacity: 1 !important; }
    .bp-fork, .bp-del, .bp-layer { width: 22px; height: 22px; line-height: 21px; }
  }
  /* let the D3 boards own touch gestures (pan/zoom) rather than scrolling the page underneath */
  #hct-svg, #hct-atlas-svg { touch-action: none; }

  /* Heatmap legend: nudge the tiny text up for readability, and show a midpoint value */
  .hct-clegend .cl-ttl { font-size: 10px; }
  .hct-clegend .cl-ends { font-size: 9.5px; }
  .hct-clegend .cl-ends span:nth-child(2) { opacity: .7; }
  #hct-tip .tip-val { font-family: var(--mono); font-size: 11px; color: var(--teal); margin-top: 3px; }

  /* ── Phone layout (≤ 600px) ─────────────────────────────────── */
  @media (max-width: 600px) {
    #hct-tb { padding: 6px 10px; gap: 7px; }
    .hct-tabs { width: 100%; }
    .hct-tabs button { padding: 10px 8px; }
    .tb-ctx { width: 100%; gap: 6px; }
    .hct-btn { height: 38px; }
    .hct-seg button { padding: 9px 10px; min-height: 38px; }
    .edu-search-wrap { margin-left: 0; width: 100%; flex-wrap: wrap; }
    .edu-search { width: 100%; box-sizing: border-box; }

    /* detail panel docks to the BOTTOM as a sheet instead of covering the board from the right edge */
    #hct-panel,
    #hct-canvas-wrap[data-view="path"] #hct-panel {
      width: 100%; max-width: 100%; left: 0; right: 0; top: auto; bottom: 0;
      height: auto; max-height: 66vh;
      border-left: none; border-top: 2px solid var(--border);
      box-shadow: 0 -10px 30px rgba(0,0,0,.55);
      transform: translateY(16px);
    }
    #hct-panel.open { transform: none; }
    .hct-p-close, .bp-modal-x { font-size: 26px; padding: 4px 6px; top: 8px; right: 10px; }

    /* My Path: single column, full-width cards */
    .bp-sheet { padding: 8px; }
    .bp-card { flex: 1 1 100%; min-width: 0; }
    .bp-card.bp-resize { width: 100%; max-width: 100%; }

    /* modals fill the small screen */
    .bp-modal-card { width: 100%; max-width: 100%; max-height: 90vh; padding: 18px 16px 20px; }

    /* zoombar: bigger tap targets */
    .sch-zoombar button { width: 40px; height: 40px; font-size: 17px; }
  }

  /* ── Shared attribution strip ───────────────────────────────
     Slimmed, and kept BELOW the tool's docked overlays (detail panel /
     mobile bottom sheet z30, modals) so they cover it rather than the
     reverse. In the Areas of Expertise view the bottom-right zoombar
     lives at bottom:8px, so lift the strip clear of it there. */
  .tool-attribution--fixed { bottom: 6px; right: 12px; padding: 4px 10px; z-index: 25; }

  /* ── EXPEDITION INSTRUMENT — field-cartography chrome ──────
     Ruler-tick toolbar edge, tabular numerals, hairline dividers,
     standard icon sizing. Token-driven with light-mode overrides; the
     green-black terrain palette stays untouched. #hct-tb is already
     position:relative under its own scheme (not the global sticky
     .tool-bar), so the ::after tick needs no top:0 guard. Ticks layer
     just above the toolbar's existing 2px teal border (kept). */
  #hct-tb::after { content: ""; position: absolute; left: 0; right: 0; bottom: 0; height: 3px;
    background: repeating-linear-gradient(90deg, color-mix(in srgb, var(--teal) 42%, transparent) 0 1px, transparent 1px 8px);
    pointer-events: none; }
  [data-theme='light'] #hct-tb::after { background: repeating-linear-gradient(90deg, color-mix(in srgb, var(--teal-dk) 55%, transparent) 0 1px, transparent 1px 8px); }

  /* instrument numerals: BLS pay/growth readouts, the detail panel, the heatmap legend */
  #hct-panel, .hct-bls, .hct-clegend { font-variant-numeric: tabular-nums; }

  /* hairline dividers on stacked rows (Education detail sections, My Path key) */
  .edu-d-sec + .edu-d-sec { border-top: 1px solid color-mix(in srgb, var(--border) 55%, transparent); padding-top: 12px; }
  .bp-legend-row + .bp-legend-row { border-top: 1px solid color-mix(in srgb, var(--border) 55%, transparent); }

  /* standard 11px teal icons beside STATIC labels only (never inside JS-rebuilt chip hosts) */
  .hct-lbl svg, .hct-tabs button svg, .bp-h svg { width: 11px; height: 11px; stroke-width: 2; color: var(--teal); vertical-align: -1.5px; margin-right: 5px; flex: none; }
  .bp-h svg { margin-right: 0; }                 /* .bp-h is flex + gap — no extra margin */
  .hct-tabs button.on svg { color: #062024; }    /* active tab is teal-filled — icon flips to the chip ink */
  [data-theme='light'] .hct-lbl svg, [data-theme='light'] .hct-tabs button svg, [data-theme='light'] .bp-h svg { color: var(--teal-dk); }
  [data-theme='light'] .hct-tabs button.on svg { color: #062024; }

  /* search fields: inset icon (the operators-map .mapsearch-ico pattern) */
  .hct-search-box { position: relative; display: inline-flex; min-width: 0; }
  .hct-search-ico { position: absolute; left: 11px; top: 50%; transform: translateY(-50%); width: 15px; height: 15px; color: var(--t3); pointer-events: none; }
  .hct-search-ico svg { width: 15px; height: 15px; stroke-width: 1.75; }
  .hct-search-box .edu-search { padding-left: 33px; }

  /* ── global search popover: input pinned above the results list ── */
  .hct-help-wrap { max-height: min(62vh, 540px); overflow-y: auto; padding: 4px 4px 8px; }
  .hct-gs-box { padding: 8px 10px 4px; flex-shrink: 0; }
  .hct-gs-box .hct-search-box { display: flex; }
  .hct-gs-box .edu-search { width: 100%; box-sizing: border-box; }
  #hct-pop-search-list .gs-meta { display: block; font-family: var(--mono); font-size: 9.5px; color: var(--t3); margin-top: 2px; letter-spacing: .03em; }
  #hct-pop-search-list .gs-none { padding: 10px 13px; font-size: 12px; color: var(--t3); }

  /* ── first-run welcome (My Path, empty build only) ── */
  .hct-welcome { max-width: 980px; margin: 18px auto 6px; padding: 20px 22px 18px; background: var(--surface); border: 1px solid var(--border); border-radius: 12px; }
  .hw-kicker { font-family: var(--mono); font-size: 10px; letter-spacing: .18em; text-transform: uppercase; color: var(--teal); font-weight: 600; margin-bottom: 8px; }
  [data-theme="light"] .hw-kicker { color: var(--teal-dk); }
  .hw-title { font-family: var(--display); font-size: clamp(19px, 2.6vw, 25px); font-weight: 800; letter-spacing: -.015em; color: var(--t1); margin-bottom: 6px; }
  .hw-sub { font-size: 13.5px; line-height: 1.6; color: var(--t2); margin: 0 0 16px; max-width: 640px; }
  /* intake survey — question rows of single-select chips + one commit button */
  .hw-form { display: flex; flex-direction: column; gap: 13px; margin-bottom: 15px; }
  .hw-q { display: flex; flex-direction: column; gap: 6px; }
  .hw-q-lbl { font-family: var(--mono); font-size: 10px; letter-spacing: .14em; text-transform: uppercase; color: var(--t2); font-weight: 600; }
  .hw-chips { display: flex; flex-wrap: wrap; gap: 7px; }
  .hw-chip { font-family: var(--font); font-size: 12px; font-weight: 600; color: var(--t2); background: var(--raised); border: 1px solid var(--border); border-radius: 999px; padding: 7px 13px; cursor: pointer; transition: border-color .15s, color .15s, background .15s; }
  .hw-chip:hover { border-color: var(--teal); color: var(--t1); }
  .hw-chip:focus-visible { outline: 2px solid var(--teal); outline-offset: 2px; }
  .hw-chip[aria-pressed="true"] { background: rgba(78,205,196,0.14); border-color: rgba(78,205,196,0.5); color: var(--teal); }
  [data-theme='light'] .hw-chip[aria-pressed="true"] { color: var(--teal-dk); }
  /* conditional follow-up fields (status-dependent) */
  .hw-cond { margin-top: 9px; display: flex; flex-direction: column; gap: 6px; }
  /* our display:flex would beat the UA's [hidden] rule — reassert it */
  .hw-cond[hidden], .hw-suggest[hidden], .hw-strip[hidden], .hw-preview[hidden] { display: none; }
  .hw-cond-lbl i { font-style: normal; color: var(--t3); text-transform: none; letter-spacing: .02em; font-weight: 400; }
  .hw-search-in { width: min(360px, 100%); box-sizing: border-box; background: var(--raised); border: 1px solid var(--border); border-radius: 8px; color: var(--t1); font-family: var(--font); font-size: 12.5px; padding: 8px 12px; outline: none; }
  .hw-search-in:focus { border-color: rgba(78,205,196,0.5); }
  .hw-search-in::placeholder { color: var(--t3); }
  .hw-search-in.picked { border-color: rgba(78,205,196,0.55); }
  .hw-suggest { display: flex; flex-direction: column; gap: 4px; max-height: 190px; overflow-y: auto; width: min(360px, 100%); }
  .hw-sg { text-align: left; background: var(--raised); border: 1px solid var(--border); border-radius: 7px; padding: 7px 11px; font-family: var(--font); font-size: 12px; font-weight: 600; color: var(--t1); cursor: pointer; }
  .hw-sg:hover { border-color: var(--teal); }
  .hw-sg:focus-visible { outline: 2px solid var(--teal); outline-offset: 1px; }
  .hw-sg-meta { display: block; font-family: var(--mono); font-size: 9.5px; font-weight: 600; color: var(--t3); margin-top: 2px; letter-spacing: .03em; }
  @media (hover: none) { .hw-sg { min-height: 44px; } }
  .hw-preview { font-family: var(--mono); font-size: 10.5px; letter-spacing: .04em; line-height: 1.6; color: var(--teal); background: rgba(78,205,196,0.07); border: 1px solid rgba(78,205,196,0.22); border-radius: 8px; padding: 8px 12px; }
  [data-theme='light'] .hw-preview { color: var(--teal-dk); }
  .hw-go-row { display: flex; align-items: center; flex-wrap: wrap; gap: 12px; margin-top: 2px; }
  .hw-go { font-family: var(--font); font-size: 13px; font-weight: 700; color: #062024; background: var(--teal); border: 1px solid var(--teal); border-radius: 9px; padding: 9px 18px; cursor: pointer; transition: opacity .15s, transform .15s; }
  .hw-go:hover:not(:disabled) { transform: translateY(-1px); }
  .hw-go:disabled { opacity: .35; cursor: default; }
  .hw-go:focus-visible { outline: 2px solid var(--teal); outline-offset: 2px; }
  .hw-go-hint { font-size: 11.5px; color: var(--t3); }
  .hw-skip { display: flex; flex-wrap: wrap; align-items: center; gap: 7px; padding-top: 12px; border-top: 1px dashed var(--border); }
  .hw-skip-lbl { font-size: 11.5px; color: var(--t3); }
  .hw-skip-btn { font-family: var(--font); font-size: 11.5px; font-weight: 600; color: var(--t2); background: transparent; border: 1px dashed var(--border); border-radius: 7px; padding: 5px 10px; cursor: pointer; transition: border-color .15s, color .15s; }
  .hw-skip-btn:hover { border-color: var(--teal); color: var(--t1); }
  .hw-skip-btn:focus-visible { outline: 2px solid var(--teal); outline-offset: 2px; }
  @media (hover: none) { .hw-chip, .hw-skip-btn, .hw-go { min-height: 44px; } }   /* coarse-pointer floor */
  /* the welcome rides the bp-modal primitive — size the card for the survey */
  .hw-modal .hct-welcome { width: min(740px, 96%); max-width: none; margin: 0; }
  /* expertise suggestion strip on the sheet — offers keyed to your current role's family */
  .bp-suggest-strip { display: flex; flex-wrap: wrap; align-items: center; gap: 7px; padding: 11px 14px; background: var(--surface); border: 1px dashed var(--border); border-radius: 10px; margin: 2px 0 4px; }
  .bp-suggest-strip[hidden] { display: none; }
  .bp-sgs-lbl { font-family: var(--mono); font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: var(--t3); font-weight: 600; margin-right: 4px; }
  .bp-sgs-chip { display: inline-flex; align-items: center; gap: 7px; font-family: var(--font); font-size: 12px; font-weight: 600; color: var(--t2); background: var(--raised); border: 1px solid var(--border); border-radius: 999px; padding: 6px 12px; cursor: pointer; transition: border-color .15s, color .15s; }
  .bp-sgs-chip::before { content: ''; width: 8px; height: 8px; border-radius: 50%; background: var(--zc, #5AC8BE); flex-shrink: 0; }
  .bp-sgs-chip i { font-style: normal; font-family: var(--mono); font-size: 9px; letter-spacing: .05em; text-transform: uppercase; color: var(--t3); }
  .bp-sgs-chip:hover { border-color: var(--zc, var(--teal)); color: var(--t1); }
  .bp-sgs-chip:focus-visible { outline: 2px solid var(--teal); outline-offset: 2px; }
  @media (hover: none) { .bp-sgs-chip { min-height: 44px; } }
  /* re-entry strip in the old welcome slot (empty build + dismissed modal only) */
  .hw-strip { max-width: 980px; margin: 18px auto 6px; display: flex; align-items: center; flex-wrap: wrap; gap: 12px; padding: 12px 16px; background: color-mix(in srgb, var(--teal) 6%, var(--surface)); border: 1px solid color-mix(in srgb, var(--teal) 30%, transparent); border-radius: 10px; }
  .hw-strip-txt { font-size: 12.5px; color: var(--t2); }
  .hw-strip-txt b { color: var(--t1); font-weight: 700; }
  /* the landing invitation reads SELECTED — the survey no longer pops itself */
  .hw-strip-btn { font-family: var(--font); font-size: 12.5px; font-weight: 700; color: #062024; background: var(--teal); border: 1px solid var(--teal); border-radius: 8px; padding: 7px 16px; cursor: pointer; transition: filter .15s; }
  .hw-strip-btn:hover { filter: brightness(1.12); }
  .hw-strip-btn:focus-visible { outline: 2px solid var(--teal); outline-offset: 2px; }
  @media (hover: none) { .hw-strip-btn { min-height: 44px; } }

  /* ── career matrix usage hint (parity with the other views' .view-hint) ── */
  .hct-blurb-hint { font-family: var(--mono); font-size: 10px; letter-spacing: .05em; color: var(--t3); padding: 0 14px 6px; }

  /* static close buttons adopt the .icon-btn primitive (ids + JS untouched);
     re-assert the primitive over the earlier scene rules that zeroed the border */
  .hct-p-close.icon-btn, .bp-modal-x.icon-btn { border: 1px solid var(--border); background: transparent; color: var(--t2); font-size: 0; }
  .hct-p-close.icon-btn:hover, .bp-modal-x.icon-btn:hover { border-color: rgba(78,205,196,0.5); color: var(--t1); }

  @media (max-width: 600px) {
    .hct-search-box { flex: 1 1 auto; }
    .hct-p-close.icon-btn, .bp-modal-x.icon-btn { width: 34px; height: 34px; padding: 0; }
  }
  </style>

<div id="hct-shell">
  <!-- ── TOP BAR — slim tabs on the left, contextual controls on the right ── -->
  <div id="hct-tb" data-view="path">
    <span class="hct-logo"><span class="tool-bar-kicker">Tool</span><span class="tool-bar-title">Career <span>Tree</span></span></span>
    <span class="hct-sep"></span>

    <!-- PRIMARY TABS: which view is on screen -->
    <div class="hct-seg hct-tabs" id="hct-tabs">
      <button data-view="path" class="on" title="Your buildable career sheet. Pin roles, degrees, and skills; saves in your browser"><i data-lucide="pin" aria-hidden="true"></i>My Path<span class="tab-badge" id="hct-mp-count">0</span></button>
      <button data-view="career" title="158 real roles across 8 pathways. Click a hex for detail, ☆ pins it to your path">Career Matrix</button>
      <button data-view="edu" id="hct-tab-edu" title="Degrees, licenses, and certs stacked by level. See what each one unlocks">Education Matrix</button>
      <button data-view="atlas" id="hct-tab-atlas" title="The skills layer. Clinical and operational expertise areas to tag onto your path">Areas of Expertise</button>
    </div>

    <span class="hct-spacer"></span>

    <!-- CONTEXTUAL CONTROLS — Career tab -->
    <span class="tb-ctx" id="tbc-career">
      <!-- Roles/Patients toggle retired: the Career Matrix is Roles-only. Patient content now lives in Areas of
           Expertise. Kept hidden so the class wiring stays intact and the build defaults to roles. -->
      <span class="hct-lbl" style="display:none">View as</span>
      <div class="hct-seg" id="hct-class" style="display:none">
        <button data-class="roles" class="on">Roles</button>
        <button data-class="patients">Patients</button>
      </div>
      <span class="hct-sep" id="hct-paths-sep"></span>
      <span id="hct-paths-wrap" style="display:inline-flex;align-items:center;">
        <button class="selector" id="hct-sel-paths" type="button" aria-haspopup="listbox" aria-expanded="false" aria-controls="hct-pop-paths" aria-label="Pathway filters">
          <i data-lucide="sliders-horizontal" aria-hidden="true"></i><span class="sel-val" id="hct-sel-paths-val">Pathways</span><i data-lucide="chevron-down" class="sel-caret" aria-hidden="true"></i>
        </button>
      </span>
      <span class="hct-sep" id="hct-cmode-sep"></span>
      <span class="hct-cmode-wrap" id="hct-cmode-wrap">
        <button class="selector" id="hct-sel-metric" type="button" aria-haspopup="listbox" aria-expanded="false" aria-controls="hct-pop-metric" aria-label="Metric">
          <i data-lucide="bar-chart-2" aria-hidden="true"></i><span class="sel-val" id="hct-sel-metric-val">Family</span><i data-lucide="chevron-down" class="sel-caret" aria-hidden="true"></i>
        </button>
      </span>
      <span class="hct-sep"></span>
      <button class="hct-btn" id="hct-zoomout" title="Zoom out">−</button>
      <button class="hct-btn" id="hct-zoomin" title="Zoom in">+</button>
      <button class="hct-btn" id="hct-fit">Fit</button>
      <button class="hct-btn" id="hct-freelook" aria-pressed="false" title="Free look: keep the whole board lit while a role is selected">Free look</button>
    </span>

    <!-- CONTEXTUAL CONTROLS — Education Matrix tab: the career board's tools, education-side -->
    <span class="tb-ctx" id="tbc-edu">
      <button class="selector" id="hct-sel-paths-edu" type="button" aria-haspopup="listbox" aria-expanded="false" aria-controls="hct-pop-paths" aria-label="Pathway filters">
        <i data-lucide="sliders-horizontal" aria-hidden="true"></i><span class="sel-val" id="hct-sel-paths-edu-val">Pathways</span><i data-lucide="chevron-down" class="sel-caret" aria-hidden="true"></i>
      </button>
      <span class="hct-sep"></span>
      <button class="selector" id="hct-sel-emetric" type="button" aria-haspopup="listbox" aria-expanded="false" aria-controls="hct-pop-emetric" aria-label="Metric">
        <i data-lucide="bar-chart-2" aria-hidden="true"></i><span class="sel-val" id="hct-sel-emetric-val">Discipline</span><i data-lucide="chevron-down" class="sel-caret" aria-hidden="true"></i>
      </button>
      <span class="hct-sep"></span>
      <button class="hct-btn" id="hct-edu-tzout" title="Zoom out">−</button>
      <button class="hct-btn" id="hct-edu-tzin" title="Zoom in">+</button>
      <button class="hct-btn" id="hct-edu-tfit">Fit</button>
      <button class="hct-btn" id="hct-edu-freelook" aria-pressed="false" title="Free look: keep the whole matrix lit while a credential is selected">Free look</button>
    </span>

    <!-- CONTEXTUAL CONTROLS — Areas of Expertise tab -->
    <span class="tb-ctx" id="tbc-atlas">
      <button class="hct-btn" id="hct-at-tzout" title="Zoom out">−</button>
      <button class="hct-btn" id="hct-at-tzin" title="Zoom in">+</button>
      <button class="hct-btn" id="hct-at-tfit">Fit</button>
      <button class="hct-btn" id="hct-at-freelook" aria-pressed="false" title="Free look: keep the whole map lit while an area is selected">Free look</button>
    </span>

    <!-- CONTEXTUAL CONTROLS — My Path tab (visibility driven by #hct-tb[data-view]) -->
    <span class="tb-ctx" id="tbc-path">
      <button class="mp-fbtn" id="hct-mp-goals" title="Theorycraft: hide what you have and see just the plan" aria-pressed="false">◇ Goals only</button>
      <span class="bp-addwrap mp-more"><button class="mp-fbtn" id="hct-mp-more" title="Save, load, export, reset" aria-haspopup="true" aria-expanded="false">⋯ More</button>
        <div class="bp-addmenu" id="hct-mp-menu">
          <div class="bp-addmenu-item" id="hct-mp-data" title="Back up your path to a code/file, or restore one">⤓ Save / Load</div>
          <div class="bp-addmenu-item" id="hct-mp-export" title="Download your path as an image">⬇ Export JPEG</div>
          <div class="bp-addmenu-item" id="hct-mp-clear">Reset build</div>
        </div>
      </span>
