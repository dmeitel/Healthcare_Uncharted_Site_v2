  // ── Areas of Expertise Matrix: ONE big honeycomb grid, zones as colored wedges around a hub (Atlas look) ──
  function renderGrowthAtlas(){
    const g = DATA.growth; if (!g) return;
    const svgSel = d3.select('#hct-atlas-svg'); svgSel.selectAll('*').remove();
    growthById = new Map(); g.nodes.forEach(n => growthById.set(n.id, n));

    const CELL = 28, HR = CELL*0.9, N = 8, BG = 2;   // N = usable rings per zone wedge; sector cap ≈ N*(N+1) nodes/zone
    const cellsAll = hexSpiral(1 + 3*(N+BG)*(N+BG+1));
    const px = c => ({ x: CELL*(Math.sqrt(3)*c.q + Math.sqrt(3)/2*c.r), y: CELL*1.5*c.r });
    const ringOf = c => (Math.abs(c.q) + Math.abs(c.q+c.r) + Math.abs(c.r))/2;
    const zonesArr = g.zoneOrder;

    // split the grid: center = hub, inner rings = three angular wedges (one per zone), outer = background
    const sector = {}; zonesArr.forEach(z => sector[z] = []);
    const bgCells = [];
    cellsAll.forEach(c => { const r = ringOf(c); if (r === 0) return; if (r > N){ bgCells.push(c); return; }
      const p = px(c); let a = Math.atan2(p.y, p.x) + Math.PI/2; a = (a % (2*Math.PI) + 2*Math.PI) % (2*Math.PI);
      sector[zonesArr[Math.floor(a/(2*Math.PI/3)) % 3]].push(c); });

    const pos = new Map(); const regionCells = []; const zoneLabel = [];
    zonesArr.forEach(zk => {
      const zn = g.zones[zk];
      const znodes = g.nodes.filter(n => n.zone === zk);
      const groups = [...new Set(znodes.map(n => n.group))];
      znodes.sort((a,b) => groups.indexOf(a.group)-groups.indexOf(b.group) || (a.label<b.label?-1:1));
      const sc = sector[zk].slice().sort((a,b)=>{ const ra=ringOf(a),rb=ringOf(b); if(ra!==rb) return ra-rb;
        const pa=px(a),pb=px(b); return Math.atan2(pa.y,pa.x)-Math.atan2(pb.y,pb.x); });
      znodes.forEach((n,i) => { const c = sc[i]; if (c){ const p = px(c); pos.set(n.id, { x:p.x, y:p.y, color: zn.color }); } });
      sc.slice(znodes.length).forEach(c => regionCells.push({ c, color: zn.color }));
      const ps = sc.map(px), mx = d3.mean(ps,p=>p.x)||0, my = d3.mean(ps,p=>p.y)||0, mag = Math.hypot(mx,my)||1, RAD = N*1.5*CELL + 42;
      zoneLabel.push({ label: zn.label, color: zn.color, x: mx/mag*RAD, y: my/mag*RAD });
    });

    const allPx = cellsAll.map(px), lblR = N*1.5*CELL + 64, LPAD = 96;   // LPAD = room for wide zone words
    const minX = Math.min(-lblR-LPAD, ...allPx.map(p=>p.x))-HR, maxX = Math.max(lblR+LPAD, ...allPx.map(p=>p.x))+HR;
    const minY = Math.min(-lblR, ...allPx.map(p=>p.y))-HR, maxY = Math.max(lblR, ...allPx.map(p=>p.y))+HR;
    atlasDims = { w: maxX-minX, h: maxY-minY };
    svgSel.attr('viewBox', minX.toFixed(1)+' '+minY.toFixed(1)+' '+atlasDims.w.toFixed(1)+' '+atlasDims.h.toFixed(1));

    gAtlasZoom = svgSel.append('g').attr('class','atlas-zoom');
    const gBg = gAtlasZoom.append('g'), gRg = gAtlasZoom.append('g'), gHub = gAtlasZoom.append('g'), gN = gAtlasZoom.append('g'), gL = gAtlasZoom.append('g');

    bgCells.forEach(c => { const p = px(c); gBg.append('path').attr('class','atlas-bg-hex').attr('d', hexPath(p.x, p.y, HR)); });
    regionCells.forEach(rc => { const p = px(rc.c);
      gRg.append('path').attr('class','atlas-region-hex').attr('d', hexPath(p.x, p.y, HR)).style('fill', rc.color).style('stroke', rc.color); });

    const HUBR = 30;   // a touch larger than a cell (still inside its honeycomb slot — no neighbor overlap)
    // fit text to the hex's flat width (√3·R) with margin; ~0.72em/char for Outfit bold, no letter-spacing
    const hubFit = (txt, max) => Math.min(max, (Math.sqrt(3)*HUBR - 14) / (txt.length*0.72));
    gHub.append('path').attr('class','atlas-hub-hex').attr('d', hexPath(0,0,HUBR));
    gHub.append('text').attr('class','atlas-hub-t1').attr('text-anchor','middle').attr('y',-3).style('font-size', hubFit('AREAS OF',10).toFixed(1)+'px').text('AREAS OF');
    gHub.append('text').attr('class','atlas-hub-t2').attr('text-anchor','middle').attr('y',8).style('font-size', hubFit('EXPERTISE',9).toFixed(1)+'px').text('EXPERTISE');

    zoneLabel.forEach(z => gL.append('text').attr('class','atlas-zone-lbl').attr('x', z.x).attr('y', z.y).attr('text-anchor','middle').attr('fill', z.color).text(z.label.toUpperCase()));

    g.nodes.forEach(n => {
      const p = pos.get(n.id); if (!p) return;
      const searchStr = (n.label+' '+n.abbr+' '+(n.group||'')+' '+(g.zones[n.zone]?g.zones[n.zone].label:'')+' '+(n.summary||'')+' '+(n.seen||'')).toLowerCase();
      const node = gN.append('g').attr('class','atlas-node'+(atlasSel.has(n.id)?' atlas-sel':'')).attr('data-id', n.id).attr('data-search', searchStr).attr('transform','translate('+p.x.toFixed(1)+','+p.y.toFixed(1)+')')
        .style('cursor','pointer').on('click', (e) => { e.stopPropagation(); if (atlasMultiMode) toggleAtlasSel(n.id, e.currentTarget); else openGrowthPanel(n); });
      node.append('path').attr('d', hexPath(0,0,HR)).attr('fill','#08120e');
      node.append('path').attr('class','atlas-hex').attr('d', hexPath(0,0,HR))
        .attr('fill', p.color).attr('fill-opacity', 0.26).attr('stroke', p.color).attr('stroke-width', 1.6);
      node.append('text').attr('class','atlas-abbr').attr('text-anchor','middle').attr('y', 4)
        .attr('font-size', n.abbr.length>4 ? 7.5 : 10).attr('font-weight', 800).attr('fill', '#EAF6F4').text(n.abbr);
      const chk = node.append('g').attr('class','atlas-check');   // ✓ badge shown when selected
      chk.append('circle').attr('cx', HR*0.6).attr('cy', -HR*0.6).attr('r', 6.5);
      chk.append('text').attr('x', HR*0.6).attr('y', -HR*0.6+3.2).attr('text-anchor','middle').text('✓');
      node.append('title').text(n.label + (n.group ? ' · ' + n.group : ''));
    });

    if (!atlasZoom) atlasZoom = d3.zoom().scaleExtent([0.3, 3]).on('zoom', e => gAtlasZoom.attr('transform', e.transform));
    svgSel.call(atlasZoom).on('dblclick.zoom', null)
      .on('mousedown.cur', () => svgSel.classed('grabbing', true))
      .on('mouseup.cur',   () => svgSel.classed('grabbing', false));
    atlasBuilt = true;
    fitAtlas();
    const aS = document.getElementById('hct-atlas-search'); if (aS && aS.value) atlasFilter(aS.value);   // keep an active search highlighted after a rebuild
  }
  function fitAtlas(){
    // the SVG viewBox is centered on the hub (0,0) and already fits-to-contain via preserveAspectRatio,
    // so identity centers it. (Applying a pixel-space transform on top of the viewBox pushed it off-screen.)
    const node = document.getElementById('hct-atlas-svg'); if (!node || !atlasZoom) return;
    if (node.clientWidth < 40 || node.clientHeight < 40) return;
    d3.select('#hct-atlas-svg').call(atlasZoom.transform, d3.zoomIdentity);
  }
  function atlasZoomBy(f){ const s = d3.select('#hct-atlas-svg'); if (atlasZoom && s.node()) s.transition().duration(180).call(atlasZoom.scaleBy, f); }

  // forgiving search over the Areas of Expertise hexes: matches the label, abbr, group, zone, summary, and "where you'll
  // find it" (so "vent"→Ventilator/Pulmonology, "icu"→all the ICUs, "epic"→Epic build). Matches glow; the rest fade.
  function atlasFilter(q){
    const svg = document.getElementById('hct-atlas-svg'); if (!svg) return;
    const toks = (q||'').trim().toLowerCase().split(/\s+/).filter(Boolean);
    let total = 0;
    svg.querySelectorAll('.atlas-node').forEach(el => {
      const s = el.getAttribute('data-search') || '';
      const hit = toks.length > 0 && toks.every(t => s.indexOf(t) >= 0);   // AND match — every word must be present
      el.classList.toggle('atlas-hit', hit);
      el.classList.toggle('atlas-dim', toks.length > 0 && !hit);
      if (hit) total++;
    });
    const note = document.getElementById('hct-atlas-searchnote');
    if (note) note.textContent = toks.length ? (total ? total+' match'+(total!==1?'es':'') : 'no matches') : '';
  }

  // ── Areas of Expertise multi-select: check several hexes, add them all to My Path at once ──
  function setAtlasMultiMode(on){
    atlasMultiMode = on;
    const btn = document.getElementById('hct-atlas-multi'); if (btn) btn.classList.toggle('on', on);
    const bar = document.getElementById('hct-atlas-selbar'); if (bar) bar.classList.toggle('on', on);
    if (!on) atlasClearSel();              // leaving select mode clears the checks
    else { closePanel(); updateAtlasSelBar(); }   // entering: drop any open detail so the board is clean to pick from
  }
  function toggleAtlasSel(id, el){
    if (atlasSel.has(id)){ atlasSel.delete(id); if (el) el.classList.remove('atlas-sel'); }
    else { atlasSel.add(id); if (el) el.classList.add('atlas-sel'); }
    updateAtlasSelBar();
  }
  function atlasSelectShown(){   // select every hex currently visible (i.e. the search matches, or all when no search)
    const svg = document.getElementById('hct-atlas-svg'); if (!svg) return;
    svg.querySelectorAll('.atlas-node:not(.atlas-dim)').forEach(el => { const id = el.getAttribute('data-id'); if (id){ atlasSel.add(id); el.classList.add('atlas-sel'); } });
    updateAtlasSelBar();
  }
  function atlasClearSel(){
    atlasSel.clear();
    const svg = document.getElementById('hct-atlas-svg'); if (svg) svg.querySelectorAll('.atlas-node.atlas-sel').forEach(el => el.classList.remove('atlas-sel'));
    updateAtlasSelBar();
  }
  function updateAtlasSelBar(){
    const c = document.getElementById('hct-atlas-selcount'); if (c) c.textContent = atlasSel.size + ' selected';
    const add = document.getElementById('hct-atlas-seladd'); if (add) add.disabled = atlasSel.size === 0;
  }
  function atlasAddSelected(){
    if (!atlasSel.size) return;
    let added = 0;
    atlasSel.forEach(id => {
      const n = growthById.get(id); if (!n) return;
      const z = DATA.growth.zones[n.zone], list = build[z.track];
      if (list.some(s => s.atlasId === n.id)) return;   // already on the path, skip
      list.push({ id:newId(), atlasId:n.id, name:n.label, abbr:n.abbr, zcol:z.color, years:'', layer:activeLayer() });
      added++;
    });
    saveBuild(); renderMyPath();
    atlasClearSel();
    const c = document.getElementById('hct-atlas-selcount'); if (c) c.textContent = added ? ('added '+added+' to My Path') : 'already on your path';
  }

  // detail panel for a Areas of Expertise Matrix node + add to the matching My Path track
  function openGrowthPanel(n){
    const z = DATA.growth.zones[n.zone], col = z.color;
    document.querySelector('#hct-p-badge .hct-p-dot').style.background = col;
    document.querySelector('#hct-p-badge .lbl').textContent = z.label + ' · ' + n.group;
    document.querySelector('#hct-p-badge').style.background = hexA(col, 0.14);
    document.querySelector('#hct-p-badge').style.color = col;
    document.getElementById('hct-p-title').textContent = n.label;
    document.getElementById('hct-p-abbr').textContent = n.abbr;
    let h = '<p class="hct-p-summary">'+esc(n.summary||'')+'</p>';
    if (n.seen) h += '<div class="hct-list-h">Where you’ll find it</div><p class="hct-p-summary" style="margin:-4px 0 14px">'+esc(n.seen)+'</p>';
    const pairs = (n.pairs||[]).map(id => growthById.get(id)).filter(Boolean);   // related areas of expertise → jump to them
    if (pairs.length){
      h += '<div class="hct-list-h">Pairs with</div><div class="hct-leads">';
      pairs.forEach(p => h += '<span class="hct-chip" data-grow="'+esc(p.id)+'">'+esc(p.abbr)+' · '+esc(p.label)+'</span>');
      h += '</div>';
    }
    const already = (build[z.track]||[]).some(s => s.atlasId === n.id);
    h += '<button class="hct-pin-btn'+(already?' pinned':'')+'" id="growth-add">'+(already?'★ On your path — remove':'☆ Add to '+esc(z.label==='Skills'?'Skill Growth':z.label==='Specializations'?'Specialization':'Experience'))+'</button>';
    document.getElementById('hct-p-body').innerHTML = h;
    const panel = document.getElementById('hct-panel'); dockPanel(); panel.classList.add('open'); panel.dataset.owner = 'atlas';
    document.getElementById('growth-add').onclick = () => toggleGrowthNode(n);
    panel.querySelectorAll('.hct-chip[data-grow]').forEach(ch => ch.onclick = () => { const gn = growthById.get(ch.getAttribute('data-grow')); if (gn) openGrowthPanel(gn); });
  }
  function toggleGrowthNode(n){
    const z = DATA.growth.zones[n.zone], list = build[z.track];
    const i = list.findIndex(s => s.atlasId === n.id);
    if (i >= 0) list.splice(i,1);
    else list.push({ id:newId(), atlasId:n.id, name:n.label, abbr:n.abbr, zcol:z.color, years:'', layer:activeLayer() });
    saveBuild(); renderMyPath();
    if (curView === 'atlas') openGrowthPanel(n);   // refresh the panel's add/remove state only on the matrix — don't flash it onto My Path
  }

  // education is roles-only; reflect the current class across the rail + career view title
  function updateClassChrome(){
    const isRoles = curClass === 'roles';
    // Education tab + pathway filters are roles-only
    const eduTab = document.getElementById('hct-tab-edu');
    if (eduTab) eduTab.style.display = isRoles ? '' : 'none';
    const pathsWrap = document.getElementById('hct-paths-wrap');
    if (pathsWrap) pathsWrap.style.display = isRoles ? '' : 'none';
    const sep = document.getElementById('hct-paths-sep');
    if (sep) sep.style.display = isRoles ? '' : 'none';
    if (!isRoles && curView === 'edu') setView('career');
  }

  // ── Fit / zoom ─────────────────────────────────────────
  // Blueprint limits: the full vertical extent (headers → bottom) always fits, so the column headers and the frozen
  // left axis stay visible; min zoom = fit-height (can't zoom out past it), and pan is clamped to the content.
  function applyNavLimits(){
    if (!zoom) return;
    const el = document.getElementById('hct-board');
    const bh = el ? el.clientHeight : 0;
    if (bh < 80 || navBotY <= navTopY) return;
    const kFit = (bh - 22) / (navBotY - navTopY);
    zoom.scaleExtent([kFit, Math.max(kFit * 2.4, kFit + 0.01)]);                 // fit-height … 2.4× detail (headers stay pinned)
    zoom.translateExtent([[navMinX - 322, navTopY - 24], [navMaxX + 110, navBotY + 24]]);   // -322 reserves the frozen axis on the left
  }
  // vertical framing for every fit: headers at the top, content bottom at the base (falls back before first render)
  function navY(){ return (navBotY > navTopY) ? [navTopY, navBotY] : (() => { const ys=[...posMap.values()].map(p=>p.y); return [ (ys.length?Math.min(...ys):0)-150, (ys.length?Math.max(...ys):0)+50 ]; })(); }
  // clip the content/axis to start just below the pinned header band (screen-space rect, follows zoom)
  function updateHeadClip(k){
    if (!clipRect) return;
    const el = document.getElementById('hct-board'); if (!el) return;
    const w = el.clientWidth, h = el.clientHeight;
    if (w < 40 || h < 40){ clipRect.attr('x',0).attr('y',0).attr('width',5000).attr('height',5000); return; }   // not sized → don't clip
    const bandBottom = HEAD_TOP + (k || 1) * (headBandY - headPinY);
    clipRect.attr('x', 0).attr('y', bandBottom).attr('width', w).attr('height', Math.max(0, h - bandBottom));
  }
  const AXIS_RESERVE = 240;   // screen px to reserve for the frozen left axis (so content sits just right of it)
  function fitToBounds(x0, x1, y0, y1, animate, dur, anchorLeft){
    applyNavLimits();
    const wrap = document.getElementById('hct-board').getBoundingClientRect();
    const w = x1 - x0, h = y1 - y0;
    if (w <= 0 || h <= 0 || wrap.width < 120 || wrap.height < 120) return;   // not sized yet; a later re-fit handles it
    const ext = zoom.scaleExtent();
    let k = Math.min(wrap.width/w, wrap.height/h);
    k = Math.max(ext[0], Math.min(k, ext[1]));   // respect the blueprint zoom limits
    // LEFT-ANCHOR horizontally (content's x0 just right of the frozen axis) so a narrow group can't float to the middle and
    // leave a gap; only center when explicitly NOT anchoring. (Mirrors the vertical top-align below.)
    const tx = (anchorLeft && k*w < wrap.width) ? (AXIS_RESERVE - k*x0) : (wrap.width/2 - k*(x0+x1)/2);
    // top-align the board content so it sits right under My Path (only center if it overflows)
    const ty = (k*h < wrap.height) ? (14 - k*y0) : (wrap.height/2 - k*(y0+y1)/2);
    const t = d3.zoomIdentity.translate(tx, ty).scale(k);
    if (animate) svg.transition().duration(dur||520).call(zoom.transform, t).on('end', syncLOD);
    else { svg.call(zoom.transform, t); syncLOD(); }
  }
  function fit(animate, dur){
    const pts = [...posMap.values()];
    if (!pts.length) return;
    const xs = pts.map(p=>p.x), yr = navY();
    fitToBounds(Math.min(...xs)-300, Math.max(...xs)+50, yr[0], yr[1], animate, dur);
  }
  // default Career Matrix view: open zoomed in on the dense CORE of the therapeutic region (Nursing + Respiratory
  // + Physician/APP), not the whole max-zoomed-out board. The rest of the families are a pan away.
  const CORE_FAMILIES = new Set(['nursing','respiratory','physician']);
  function fitDefaultGroup(animate){
    const wrap = document.getElementById('hct-board').getBoundingClientRect();
    if (wrap.width < 120 || wrap.height < 120) return;   // board not sized yet (tab just shown) — DON'T lock userZoomed; a later rAF / the ResizeObserver re-fits
    const lanes = (curFamilyInfo||[]).filter(l => l.pathway === 'therapeutic' && CORE_FAMILIES.has(l.family));
    if (lanes.length){
      // NOTE: don't set userZoomed here — this is the DEFAULT framing; the ResizeObserver re-applies it (no longer fights). userZoomed means "user moved the view".
      const left = Math.min(...lanes.map(l=>l.left)), right = Math.max(...lanes.map(l=>l.right)), yr = navY();
      fitToBounds(left, right + 50, yr[0], yr[1], animate, 520, true);   // anchorLeft → the first family sits just right of the frozen axis, no centered gap
      return;
    }
    const g = (curLaneInfo||[]).find(x => x.pathway === 'therapeutic');   // fallbacks: whole therapeutic, then everything
    if (g) fitGroup(g.left, g.right, animate); else fit(animate);
  }
  // zoom to a horizontal slice (region or pathway), keeping full vertical extent
  function fitGroup(left, right, animate){
    userZoomed = true;   // zooming to a region/pathway is an intentional view; don't auto-refit over it
    const yr = navY();
    fitToBounds(left-50, right+50, yr[0], yr[1], animate, 520);
  }
  function regionBounds(side){
    const gs = curLaneInfo.filter(g=>g.side===side);
    if (!gs.length) return null;
    return [Math.min(...gs.map(g=>g.left)), Math.max(...gs.map(g=>g.right))];
  }

  // ── Helpers ────────────────────────────────────────────
  function esc(s){ return (s==null?'':String(s)).replace(/[&<>"]/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[m])); }
  function hexA(hex, a){
    const h = (hex||'#4ECDC4').replace('#',''); const n = parseInt(h.length===3 ? h.split('').map(x=>x+x).join('') : h, 16);
    return 'rgba('+((n>>16)&255)+','+((n>>8)&255)+','+(n&255)+','+a+')';
  }

  // ── Controls: per-pathway dropdown with specialty multi-select ──
  function applyFilterChange(){ selectedId = null; closePanel(); userZoomed = false; render(false); fit(true); }

  function buildPathwayDropdowns(){
    const wrap = document.getElementById('hct-paths');
    const cls = DATA.classes[curClass];
    if (curClass !== 'roles' || !cls.pathwayOrder){ wrap.innerHTML=''; return; }   // rail-paths section hidden by setView/updateClassChrome

    // families present per pathway, in familyOrder
    const famOrder = cls.familyOrder || Object.keys(cls.families||{});
    const pwFams = {};
    cls.pathwayOrder.forEach(pw => {
      const fams = [...new Set(cls.nodes.filter(n=>n.pathway===pw).map(n=>n.family))]
        .sort((a,b)=> famOrder.indexOf(a)-famOrder.indexOf(b));
      pwFams[pw] = fams;
    });

    wrap.innerHTML = cls.pathwayOrder.map(pw => {
      const p = cls.pathways[pw];
      const fams = pwFams[pw];
      const shownFams = fams.filter(f => !hiddenFamilies.has(f));
      const pwOff = hiddenPathways.has(pw);
      const items = fams.map(f => {
        const fc = cls.families[f] || {};
        const on = !pwOff && !hiddenFamilies.has(f);
        return '<label class="hct-dd-item"><input type="checkbox" data-fam="'+f+'" '+(on?'checked':'')+'>'+
               '<span class="fdot" style="background:'+(fc.color||'#888')+'"></span>'+esc(fc.label||f)+'</label>';
      }).join('');
      return '<div class="hct-dd" data-pw="'+pw+'">'+
        '<button class="hct-dd-btn'+(pwOff?' dim':'')+'"><span class="pdot" style="background:'+p.color+'"></span>'+
        esc(p.label)+' <span class="ddc">'+shownFams.length+'/'+fams.length+'</span><span class="cv">▾</span></button>'+
        '<div class="hct-dd-menu">'+
          '<div class="hct-dd-actions"><button class="hct-dd-act" data-showall="'+pw+'">Show all</button>'+
          '<button class="hct-dd-act" data-hideall="'+pw+'">Hide all</button></div>'+
          items+
        '</div></div>';
    }).join('');

    // open/close menus
    wrap.querySelectorAll('.hct-dd-btn').forEach(btn => btn.onclick = e => {
      e.stopPropagation();
      const dd = btn.parentElement; const wasOpen = dd.classList.contains('open');
      wrap.querySelectorAll('.hct-dd').forEach(x=>x.classList.remove('open'));
      if (!wasOpen) dd.classList.add('open');
    });
    // Show all / Hide all for the whole category
    wrap.querySelectorAll('[data-showall]').forEach(b => b.onclick = e => {
      e.stopPropagation(); const pw = b.getAttribute('data-showall');
      hiddenPathways.delete(pw); pwFams[pw].forEach(f=>hiddenFamilies.delete(f));
      buildPathwayDropdowns(); document.querySelector('.hct-dd[data-pw="'+pw+'"]').classList.add('open');
      applyFilterChange();
    });
    wrap.querySelectorAll('[data-hideall]').forEach(b => b.onclick = e => {
      e.stopPropagation(); const pw = b.getAttribute('data-hideall');
      pwFams[pw].forEach(f=>hiddenFamilies.add(f)); hiddenPathways.add(pw);
      buildPathwayDropdowns(); document.querySelector('.hct-dd[data-pw="'+pw+'"]').classList.add('open');
      applyFilterChange();
    });
    // specialty toggle
    wrap.querySelectorAll('[data-fam]').forEach(cb => cb.onchange = () => {
      const fam = cb.getAttribute('data-fam');
      const pw = cb.closest('.hct-dd').getAttribute('data-pw');
      if (cb.checked){ hiddenFamilies.delete(fam); hiddenPathways.delete(pw); }
      else hiddenFamilies.add(fam);
      buildPathwayDropdowns(); document.querySelector('.hct-dd[data-pw="'+pw+'"]').classList.add('open');
      applyFilterChange();
    });
  }


  // switch the active full-bleed view (top-bar tabs) + swap that tab's contextual controls
  function setView(v){
    if (v === 'edu' && curClass !== 'roles') v = 'career';   // Education is roles-only
    const tbEl = document.getElementById('hct-tb'); if (tbEl) tbEl.dataset.view = v;   // FIRST: CSS swaps the contextual cluster — set before any render that could throw
    if (v === 'career' && !boardRendered) render(false);     // lazy: build the heavy board on first open (before the rAF fit needs curFamilyInfo)
    if (v === 'edu' && !eduRendered) renderSchooling();      // lazy: build the Education Matrix on first open
    const changed = (v !== curView);
    // EVERY tab action (switch OR re-click) drops any open detail panel + clears selection — a panel never carries between views
    const had = selectedId;
    selectedId = null; eduSelId = null; eduMatrixSel = null; closePanel();
    if (had && DATA && curView === 'career') render(false);   // re-render the board we're leaving to drop its selection highlight
    curView = v;
    const cw = document.getElementById('hct-canvas-wrap'); if (cw) cw.setAttribute('data-view', v);   // lets CSS nest the panel per view
    document.querySelectorAll('#hct-tabs button').forEach(b => b.classList.toggle('on', b.dataset.view === v));
    document.querySelectorAll('.hct-view').forEach(s => s.classList.toggle('active', s.dataset.view === v));
    if (changed) requestAnimationFrame(() => {
      if (v === 'career'){ userZoomed = false; fitDefaultGroup(false); requestAnimationFrame(() => fitDefaultGroup(false));
        setTimeout(() => { if (curView === 'career' && !userZoomed) fitDefaultGroup(false); }, 180); }   // settle re-fit: catch the final board size after the tab finishes showing (skips if the user already moved the view)
      else if (v === 'edu'){ /* Education Matrix is static HTML layers — nothing to fit */ }
      else if (v === 'atlas'){ if (!atlasBuilt) renderGrowthAtlas(); else { fitAtlas(); requestAnimationFrame(fitAtlas); } }
      else { renderMyPath(); }
    });
  }

  function setClass(cls){
    if (cls===curClass) return;
    document.querySelectorAll('#hct-class button').forEach(b => b.classList.toggle('on', b.dataset.class===cls));
    hiddenPathways = new Set();
    hiddenFamilies = new Set();
    userZoomed = false;
    selectedId = null;
    loadClass(cls);
    buildPathwayDropdowns();
    updateClassChrome();
    document.getElementById('hct-blurb').textContent = DATA.classes[cls].blurb;
    render(false);
    renderMyPath();
    fit(false);
    requestAnimationFrame(() => { fit(false); });   // re-fit once layout settles (correct measurement → correct detail level)
  }

  // ── Init ───────────────────────────────────────────────
  function init(){
    // clip so the scrolling content + left axis can never bleed up into the pinned header band (screen-space rect)
    clipRect = svg.append('defs').append('clipPath').attr('id','hctBelowHead').append('rect').attr('x',0).attr('y',0).attr('width',5000).attr('height',5000);
    const gClip = svg.append('g').attr('clip-path','url(#hctBelowHead)');
    gZoom  = gClip.append('g');
    gBands = gZoom.append('g').attr('class','bands');
    gContainers = gZoom.append('g').attr('class','containers');
    gTiers = gZoom.append('g').attr('class','tiers');
    gEdges = gZoom.append('g').attr('class','edges');
    gNodes = gZoom.append('g').attr('class','nodes');
    // frozen left axis — follows vertical pan + zoom, ignores horizontal pan; clipped to below the header band
    const gAxisClip = svg.append('g').attr('clip-path','url(#hctBelowHead)');
    gAxis = gAxisClip.append('g').attr('class','axis-frozen');
    // frozen TOP header band (NOT clipped) — on top; follows horizontal pan + zoom, pinned to the top
    gTop = svg.append('g').attr('class','top-frozen');
    gTopBg = gTop.append('rect').attr('class','top-frozen-bg');
    gHeaders = gTop.append('g').attr('class','headers');

    zoom = d3.zoom().scaleExtent([0.07, 2.4])
      // measure the BOARD live for the translate-clamp (same element fitToBounds uses) — d3's default measures the SVG,
      // which can read 0/stale right after the tab is shown and clamps the first fit off to the side
      .extent(() => { const el = document.getElementById('hct-board'); const w = el?el.clientWidth:1, h = el?el.clientHeight:1; return [[0,0],[w||1, h||1]]; })
      .on('zoom', e => {
      gZoom.attr('transform', e.transform);
      gAxis.attr('transform', 'translate(0,' + e.transform.y + ') scale(' + e.transform.k + ')');
      // pin the header band to the top: same horizontal pan + zoom as the content, but a fixed top offset
      gTop.attr('transform', 'translate(' + e.transform.x + ',' + (HEAD_TOP - e.transform.k*headPinY) + ') scale(' + e.transform.k + ')');
      updateHeadClip(e.transform.k);
      if (e.sourceEvent) userZoomed = true;     // a real wheel/drag, not a programmatic fit
      const far = e.transform.k < 0.5;
      if (far !== lodFar){ lodFar = far; styleTiles(); }
    });
    svg.call(zoom);

    // re-fit whenever the board actually changes size (initial settle, resize, My Path toggle) — unless the user took over
    if (window.ResizeObserver){
      new ResizeObserver(() => { if (!DATA) return; applyNavLimits(); updateHeadClip(d3.zoomTransform(svg.node()).k); if (!userZoomed) fitDefaultGroup(false); })   // re-apply the DEFAULT core framing (not fit-all) when the board is (re)sized — catches the first-entry case where the board wasn't sized yet
        .observe(document.getElementById('hct-board'));
    }
    svg.on('mousedown', () => svg.classed('grabbing', true));
    window.addEventListener('mouseup', () => svg.classed('grabbing', false));
    svg.on('click', () => { if (selectedId){ selectedId=null; closePanel(); render(false); } });

    document.querySelectorAll('#hct-class button').forEach(b => b.onclick = () => setClass(b.dataset.class));
    document.getElementById('hct-fit').onclick     = () => { fit(true); userZoomed = true; };   // Fit = an intentional view → lock it so a resize doesn't snap back to the core default
    document.getElementById('hct-showall').onclick = () => { hiddenPathways.clear(); hiddenFamilies.clear(); buildPathwayDropdowns(); applyFilterChange(); };
    document.getElementById('hct-hideall').onclick = () => {
      const cls = DATA.classes[curClass];
      (cls.pathwayOrder||[]).forEach(pw => hiddenPathways.add(pw));
      [...new Set(cls.nodes.map(n=>n.family))].forEach(f => hiddenFamilies.add(f));
      buildPathwayDropdowns(); applyFilterChange();
    };
    document.getElementById('hct-zoomin').onclick  = () => { userZoomed = true; svg.transition().duration(180).call(zoom.scaleBy, 1.4); };
    document.getElementById('hct-zoomout').onclick = () => { userZoomed = true; svg.transition().duration(180).call(zoom.scaleBy, 1/1.4); };
    document.getElementById('hct-p-close').onclick = () => { selectedId=null; eduSelId=null; closePanel(); render(false); renderMyPath(); };
    document.querySelectorAll('#hct-tabs button').forEach(b => b.onclick = () => setView(b.dataset.view));   // setView resets any open detail on a view change
    // click ANYWHERE off the open panel → dismiss it. Global (not scoped to one view) so a click in any empty area works.
    // The Career Matrix board has its own background-click handler; here we cover My Path + Areas of Expertise.
    document.addEventListener('click', e => {
      const p = document.getElementById('hct-panel');
      if (!p.classList.contains('open')) return;
      if (curView === 'career') return;                 // the board's svg background-click manages the role panel
      if (e.target.closest('#hct-panel, .bp-sp-cell, .hct-chip, .bp-sg, [data-go]')) return;   // panel + things that open/switch a panel
      selectedId = null; eduSelId = null; closePanel();
      if (curView === 'path') renderMyPath();
    });
    const eduSearch = document.getElementById('hct-edu-search');
    if (eduSearch) eduSearch.oninput = () => eduFilter(eduSearch.value);
    const atlasSearch = document.getElementById('hct-atlas-search');
    if (atlasSearch) atlasSearch.oninput = () => atlasFilter(atlasSearch.value);
    const aMulti = document.getElementById('hct-atlas-multi'); if (aMulti) aMulti.onclick = () => setAtlasMultiMode(!atlasMultiMode);
    const aShown = document.getElementById('hct-atlas-selshown'); if (aShown) aShown.onclick = () => atlasSelectShown();
    const aAdd = document.getElementById('hct-atlas-seladd'); if (aAdd) aAdd.onclick = () => atlasAddSelected();
    const aClr = document.getElementById('hct-atlas-selclear'); if (aClr) aClr.onclick = () => atlasClearSel();
    if (window.ResizeObserver){
      const ab = document.getElementById('hct-atlas-board');
      if (ab) new ResizeObserver(() => { if (atlasBuilt) fitAtlas(); }).observe(ab);
    }
    document.getElementById('hct-atlas-zin').onclick  = (e) => { e.stopPropagation(); atlasZoomBy(1.3); };
    document.getElementById('hct-atlas-zout').onclick = (e) => { e.stopPropagation(); atlasZoomBy(1/1.3); };
    document.getElementById('hct-atlas-zfit').onclick = (e) => { e.stopPropagation(); fitAtlas(); };
    // build-planner controls — five growth tracks
    document.querySelectorAll('#mp-shift button').forEach(b => b.onclick = (e) => { e.stopPropagation(); setLayerView(b.dataset.layer); });
    document.getElementById('hct-mp-clear').onclick = (e) => { e.stopPropagation(); resetBuild(); };
    const mpExport = document.getElementById('hct-mp-export'); if (mpExport) mpExport.onclick = (e) => { e.stopPropagation(); exportMyPath(); };
    const mpData = document.getElementById('hct-mp-data'); if (mpData) mpData.onclick = (e) => { e.stopPropagation(); openDataModal(); };
    const dX = document.getElementById('bp-data-x'); if (dX) dX.onclick = closeDataModal;
    const dCopy = document.getElementById('bp-data-copy'); if (dCopy) dCopy.onclick = copyBuildCode;
    const dDl = document.getElementById('bp-data-dl'); if (dDl) dDl.onclick = downloadBuildFile;
    const dImport = document.getElementById('bp-data-import'); if (dImport) dImport.onclick = doImport;
    const dFile = document.getElementById('bp-data-file'); if (dFile) dFile.onchange = (e) => { loadBuildFile(e.target.files && e.target.files[0]); e.target.value = ''; };
    const liFile = document.getElementById('bp-li-file'); if (liFile) liFile.onchange = (e) => { importLinkedInPdf(e.target.files && e.target.files[0]); e.target.value = ''; };
    const dModal = document.getElementById('bp-data-modal'); if (dModal) dModal.addEventListener('click', (e) => { if (e.target === dModal) closeDataModal(); });
    renderLegend();   // the key is always on — build it once at load
    const legMin = document.getElementById('bp-legend-min'); if (legMin) legMin.onclick = (e) => { e.stopPropagation(); setLegendMin(true); };
    const legTab = document.getElementById('bp-legend-tab'); if (legTab) legTab.onclick = (e) => { e.stopPropagation(); setLegendMin(false); };
    try { if (localStorage.getItem('hct-legend-min')==='1') setLegendMin(true); } catch(e){}
    document.getElementById('bp-name').oninput  = (e) => { build.name = e.target.value; saveBuild(); };
    document.getElementById('bp-goal').oninput  = (e) => { build.goal = e.target.value; saveBuild(); renderNextSteps(); };
    // sw/notes textareas + the section search bars are inside the movable dashboard cards → wired in renderDash()
    const addSecBtn = document.getElementById('bp-add-section');
    if (addSecBtn) addSecBtn.onclick = (e) => { e.stopPropagation(); document.getElementById('bp-add-menu').classList.toggle('open'); };
    document.addEventListener('click', e => { if (!e.target.closest('.bp-addwrap')){ const m=document.getElementById('bp-add-menu'); if (m) m.classList.remove('open'); } });
    document.addEventListener('click', e => { if (!e.target.closest('.bp-pick')) document.querySelectorAll('.bp-suggest:not(.bp-float).open').forEach(s=>s.classList.remove('open')); });

    // close any open filter dropdown when clicking elsewhere
    document.addEventListener('click', e => { if (!e.target.closest('.hct-dd')) document.querySelectorAll('.hct-dd.open').forEach(d=>d.classList.remove('open')); });

    window.addEventListener('resize', () => { fit(false); renderMyPath(); });

    fetch('/assets/data/career-tree.json').then(r=>r.json()).then(d => {
      DATA = d;
      document.getElementById('hct-loading').style.display = 'none';
      loadClass('roles');
      buildCredIndex();
      buildPathwayDropdowns();
      updateClassChrome();
      document.getElementById('hct-blurb').textContent = d.classes.roles.blurb;
      renderMyPath();
      setView('path');                              // land on My Path; the Career Matrix board + Education Matrix render lazily on first open (saves ~1500 DOM nodes up front)
    }).catch(err => {
      document.getElementById('hct-loading').textContent = 'Could not load the tree data.';
      console.error('career-tree load', err);
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
