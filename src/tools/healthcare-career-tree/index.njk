      announce(edFreeLook ? 'Free look on. The whole matrix stays lit.' : 'Free look off. Selecting snaps to its pathway again.');
    };
    document.getElementById('hct-at-tzin').onclick  = () => { atUserZoomed = true; atlasZoomBy(1.4); };
    document.getElementById('hct-at-tzout').onclick = () => { atUserZoomed = true; atlasZoomBy(1/1.4); };
