      render(false);
      announce(lineageFocus ? 'Career-line focus on' : 'Free look: whole board stays lit');
    };
    document.getElementById('hct-p-close').onclick = () => { const wasSnapped = !!lineageSet; selectedId=null; eduSelId=null; closePanel(); render(wasSnapped && curView==='career'); renderMyPath(); if (wasSnapped && curView==='career') fitDefaultGroup(true); };   // animated expand, in step with the camera
    document.querySelectorAll('#hct-tabs button').forEach(b => b.onclick = () => setView(b.dataset.view));   // setView resets any open detail on a view change
    // click ANYWHERE off the open panel → dismiss it. Global (not scoped to one view) so a click in any empty area works.
    // The Career Matrix board has its own background-click handler; here we cover My Path + Areas of Expertise.
    document.addEventListener('click', e => {
      const p = document.getElementById('hct-panel');
      if (!p.classList.contains('open')) return;
      if (curView === 'career') return;                 // the board's svg background-click manages the role panel
      if (e.target.closest('#hct-panel, .bp-sp-cell, .hct-chip, .bp-sg, [data-go]')) return;   // panel + things that open/switch a panel
      selectedId = null; eduSelId = null; closePanel();
      if (curView === 'path') renderMyPath();
    });
    const eduSearch = document.getElementById('hct-edu-search');
