<script>
(function(){
  'use strict';
  const dcap = HUKit.dcap;
  const $ = id => document.getElementById(id);
  const CFG = window.LENS_CONFIG, SD = window.STATE_DATA, DY = window.DATA_YEARS;
  const status = $('lvStatus');
  const signal = m => { status.textContent = m; status.classList.remove('done'); };
  const signalDone = ms => setTimeout(() => status.classList.add('done'), ms || 1600);
  // one polite live region: committed changes only, never hover (the V1 rule)
  function announce(msg){
    const el = $('lvLive'); if (!el) return;
    el.textContent = '';
    requestAnimationFrame(() => { el.textContent = msg; });
  }

  const LENSES = { patient:'Patient', clinical:'Clinical', operations:'Operations', payer:'Payer', policy:'Policy', baseline:'Baseline', economics:'Economics' };
  const SCALE = ['#FF6B6B','#F2A65A','#E8C547','#7FD2C8','#4ECDC4'];   // worse → better
  // county-grain availability: boot value mirrors countyData.json TODAY, then
  // gets re-derived from the live file the moment it loads — new pulled layers
  // light up with no code change here
  const COUNTY_IDX = { patient:['0','1','2','3','4','7','8','9','10','11','12','13','14'], economics:['0','1'], payer:['0'], baseline:['5','6','13'] };

  let lens = 'patient', mIdx = 0;
  let STATES = null, CDATA = null, CPOP = null;
  const COUNTY_CACHE = new Map();
  const fmtPop = v => v >= 1e6 ? (v / 1e6).toFixed(1) + 'M' : v >= 1e3 ? Math.round(v / 1e3) + 'k' : String(v);
  let selState = null, selCounty = null, cmpState = null, comparePick = false;

  const item = () => CFG[lens].items[mIdx];
  const sVal = abbr => { const l = SD[lens]; const m = l && l[String(mIdx)]; const v = m ? m[abbr] : null; return v == null ? null : +v; };

  // ── the year machinery, ported VERBATIM from the production Multi-Lens:
  //    history is ESTIMATED by per-metric drift rates from the one real data
  //    year (COVID dip modeled for life expectancy) and labeled "est." ──
  // the timeline ENDS at each metric's real data year (David's catch: the
  // pill said 2024 over 2021-vintage data). Seven positions, last = real,
  // the six before it are drift-modeled est. — same machinery, honest axis.
  const YRS = () => {
    const dy = DY[lens] && DY[lens][String(mIdx)];
    const end = (typeof dy === 'number' && dy > 1900) ? dy : 2024;
    const out = [];
    for (let y = end - 6; y <= end; y++) out.push(y);
    return out;
  };
  let yearIdx = 6;   // last of the seven = the real data year
  const TREND_CONFIG = {
    patient: { 0:{type:'pct',rate:-0.008}, 1:{type:'pct',rate:0.003}, 2:{type:'pct',rate:-0.006}, 3:{type:'pct',rate:0.010}, 4:{type:'abs',rate:0.20}, 5:{type:'abs',rate:-1.5}, 6:{type:'lifeExp'}, 7:{type:'pct',rate:0.003} },
    clinical: { 0:{type:'abs',rate:0.5}, 1:{type:'abs',rate:1.5}, 2:{type:'abs',rate:2.5}, 4:{type:'abs',rate:0.15}, 5:{type:'pct',rate:0.08}, 6:{type:'abs',rate:0.15}, 7:{type:'abs',rate:12}, 8:{type:'abs',rate:0.8} },
    operations: { 0:{type:'abs',rate:-0.03}, 1:{type:'abs',rate:-2.0}, 3:{type:'pct',rate:0.005}, 4:{type:'abs',rate:1.0}, 5:{type:'abs',rate:0.02}, 6:{type:'abs',rate:-0.08} },
    payer: { 0:{type:'pct',rate:-0.04}, 1:{type:'pct',rate:0.015}, 2:{type:'pct',rate:0.012}, 3:{type:'pct',rate:0.08}, 4:{type:'pct',rate:-0.005}, 5:{type:'pct',rate:0.040} },
    economics: { 0:{type:'abs',rate:2.5}, 1:{type:'abs',rate:-0.08}, 2:{type:'abs',rate:0.4}, 3:{type:'abs',rate:-0.15}, 4:{type:'abs',rate:1.2} },
    baseline: { 0:{type:'abs',rate:2.5}, 1:{type:'abs',rate:-0.08}, 2:{type:'abs',rate:0.4}, 3:{type:'abs',rate:-0.15}, 4:{type:'abs',rate:1.2}, 5:{type:'abs',rate:0.12}, 6:{type:'abs',rate:-0.10}, 7:{type:'abs',rate:0.15}, 8:{type:'abs',rate:0.05}, 9:{type:'abs',rate:-0.25}, 10:{type:'abs',rate:0.10}, 11:{type:'abs',rate:0.10}, 12:{type:'abs',rate:0.15} }
  };
  function trendPoints(abbr){
    const real = sVal(abbr);
    const dataYear = DY[lens] && DY[lens][String(mIdx)];
    if (real == null || !dataYear) return null;
    const cfg = TREND_CONFIG[lens] && TREND_CONFIG[lens][String(mIdx)];
    if (!cfg) return null;
    return YRS().map(y => {
      const dy = y - dataYear;
      let v;
      if (cfg.type === 'lifeExp'){ v = real + dy * 0.20 - (y === 2020 ? 1.2 : y === 2021 ? 2.4 : 0); }
      else if (cfg.type === 'pct'){ v = real * Math.pow(1 + cfg.rate, dy); }
      else { v = real + cfg.rate * dy; }
      return { year: y, value: Math.max(0, Math.round(v * 10) / 10), real: y === dataYear };
    });
  }
  const hasTrend = () => !!(TREND_CONFIG[lens] && TREND_CONFIG[lens][String(mIdx)]);
  const isCurrentYear = () => yearIdx === YRS().length - 1;
  function vYear(abbr){
    if (isCurrentYear()) return sVal(abbr);
    const pts = trendPoints(abbr);
    if (!pts) return sVal(abbr);
    const pt = pts.find(p => p.year === YRS()[yearIdx]);
    return pt ? pt.value : sVal(abbr);
  }
  const cVal = fips => { const l = CDATA && CDATA[lens]; const m = l && l[String(mIdx)]; const v = m ? m[fips] : null; return v == null ? null : +v; };
  const hasCounty = () => !!(COUNTY_IDX[lens] && COUNTY_IDX[lens].includes(String(mIdx)));
  const fmtVFor = (it, v) => { const u = it.unit || ''; return u === '$' ? '$' + v.toLocaleString('en-US') : u === '$k' ? '$' + v + 'k' : v.toLocaleString('en-US') + (u === '%' ? '%' : u ? ' ' + u : ''); };
  const fmtV = v => fmtVFor(item(), v);

  // ── the OVERLAY: a second metric as sized circles over the choropleth.
  //    Color = the fill metric, size = this one. Hard cap of two — the
  //    third channel is the card. (David's ask: heart disease + nurses
  //    per 100k in one view without it being overwhelming.) ──
  let ovLens = null, ovIdx = null;
  const ovItem = () => ovLens ? CFG[ovLens].items[ovIdx] : null;
  const ovSVal = a => { const m = SD[ovLens] && SD[ovLens][String(ovIdx)]; const v = m ? m[a] : null; return v == null ? null : +v; };
  const ovCVal = f => { const l = CDATA && CDATA[ovLens]; const m = l && l[String(ovIdx)]; const v = m ? m[f] : null; return v == null ? null : +v; };
  const ovHasCounty = () => !!(ovLens && COUNTY_IDX[ovLens] && COUNTY_IDX[ovLens].includes(String(ovIdx)));
  // size = MAGNITUDE, no direction flip — big circle always means "more of it"
  const bucketOf = (v, br) => { let i = 0; while (i < 4 && v >= br[i]) i++; return i; };

  // ── PINS: variables three and up live on the CARD, not the map. The map's
  //    two channels (color, size) are spent; pinned metrics ride every state
  //    and county card as extra tiles. Ceiling of four. ──
  const PINS = [];   // [{ l: lens, i: index }]
  const isPinned = (l, i) => PINS.some(p => p.l === l && p.i === i);

  const styleFor = () => document.documentElement.getAttribute('data-theme') === 'light'
    ? 'https://tiles.openfreemap.org/styles/positron'
    : 'https://tiles.openfreemap.org/styles/fiord';
  const map = new maplibregl.Map({ container:'lvMap', style:styleFor(),
    center:[-96.5,39.3], zoom:3.6, minZoom:2.8, maxZoom:12, renderWorldCopies:false,
    attributionControl:false });
  map.addControl(new maplibregl.AttributionControl({ compact:true }), 'bottom-left');
  map.touchZoomRotate.disableRotation(); map.dragRotate.disable();

  function pip(pt, geom){
    const polys = geom.type === 'Polygon' ? [geom.coordinates] : geom.coordinates;
    const x = pt[0], y = pt[1]; let inside = false;
    for (const rings of polys) for (const ring of rings)
      for (let i = 0, j = ring.length - 1; i < ring.length; j = i++){
        const xi = ring[i][0], yi = ring[i][1], xj = ring[j][0], yj = ring[j][1];
        if (((yi > y) !== (yj > y)) && (x < (xj - xi) * (y - yi) / (yj - yi) + xi)) inside = !inside;
      }
    return inside;
  }
  const stateBounds = f => [[f.properties.bb[0], f.properties.bb[1]], [f.properties.bb[2], f.properties.bb[3]]];
  const FIT_PAD = { top:130, bottom:150, left:28, right:28 };

  // ── sheet ──
  const sheetEl = $('lvSheet');
  const sheet = HUKit.sheet(sheetEl, { startDetent:'dt-half', onDismiss: () => sheetEl.classList.remove('open') });
  $('lvSheetX').addEventListener('click', () => {
    if (tab === 'display'){
      // display X → back to whatever details context exists, or away
      if (selState){ selCounty ? openCountyCard() : openStateCard(); } else sheetEl.classList.remove('open');
      return;
    }
    if (mode === 'rank'){ mode = 'card'; if (selState){ selCounty ? openCountyCard() : openStateCard(); } else sheetEl.classList.remove('open'); return; }
    if (cmpState){ cmpState = null; comparePick = false; paintSel(); openStateCard(); return; }
    if (selCounty){
      // leaving a county ALWAYS refits its state — a state card over a
      // county-deep camera reads as a mismatch (same behavior as the scope chip)
      selCounty = null; paintSel(); openStateCard();
      map.fitBounds(stateBounds(selState.feature), { padding:FIT_PAD, maxZoom:8.5, duration:dcap(800) });
      syncURL();
      return;
    }
    if (selState){ deselectState(); return; }
    sheetEl.classList.remove('open');
  });

  // ── quantile machinery (shared by both grains) ──
  function quantiles(vals){
    const v = vals.slice().sort((a,b) => a - b);
    const q = p => v[Math.min(v.length - 1, Math.floor(p * v.length))];
    return [q(0.2), q(0.4), q(0.6), q(0.8)];
  }
  const colorFor = (v, breaks) => { let i = 0; while (i < 4 && v >= breaks[i]) i++; return item().dir === -1 ? SCALE[4 - i] : SCALE[i]; };

  function paintStates(){
    if (!map.getLayer('lv-state-fill') || !STATES) return;
    const vals = [];
    STATES.features.forEach(f => { const v = vYear(f.properties.abbr); if (v != null) vals.push(v); });
    if (vals.length < 5) return;
    const breaks = quantiles(vals);
    stateBreaks = breaks;   // the AK/HI insets reuse the same scale
    const expr = ['match', ['get','abbr']];
    STATES.features.forEach(f => { const v = vYear(f.properties.abbr); expr.push(f.properties.abbr, v == null ? 'rgba(130,150,170,0.3)' : colorFor(v, breaks)); });
    expr.push('#4ECDC4');
    map.setPaintProperty('lv-state-fill','fill-color',expr);
    map.setPaintProperty('lv-state-fill','fill-opacity',0.55);
    legend();
    syncInsetData();
    refreshStateValues();
  }
  // the number under each state name at the country view — same value the
  // card would show, re-fed on every metric/year change
  function refreshStateValues(){
    const src = map.getSource('lv-state-labels'); if (!src || !STATES) return;
    // overlay buckets computed across all states (magnitude quantiles)
    let ovBreaks = null;
    if (ovItem()){
      const ovs = [];
      STATES.features.forEach(f => { const x = ovSVal(f.properties.abbr); if (x != null) ovs.push(x); });
      if (ovs.length >= 5) ovBreaks = quantiles(ovs);
    }
    src.setData({ type:'FeatureCollection', features: STATES.features.map(f => {
      const v = vYear(f.properties.abbr);
      if (v == null) return null;
      const pt = f._sc || (f._sc = HUKit.innerPoint(f.geometry) || null);
      if (!pt) return null;
      const props = { v: fmtV(v) };
      if (ovBreaks){ const ov = ovSVal(f.properties.abbr); if (ov != null) props.ovb = bucketOf(ov, ovBreaks); }
      return { type:'Feature', geometry:{ type:'Point', coordinates: pt }, properties: props };
    }).filter(Boolean) });
  }
  // county labels: the empty space works for a living (David's call) — the
  // name, plus the metric value at county grain or the population otherwise.
  // GPU symbols, so collision quietly drops labels the screen can't fit.
  function countyCenter(f){
    // kit interior point: sits INSIDE the county, even the bent mountain ones
    // (bbox centers put Sierra and Nevada CA's labels in the neighbors)
    return f._c || (f._c = HUKit.innerPoint(f.geometry) || [0, 0]);
  }
  function refreshCountyLabels(){
    const src = map.getSource('lv-county-labels'); if (!src) return;
    const fc = selState && COUNTY_CACHE.get(selState.fips);
    if (!fc){ src.setData({ type:'FeatureCollection', features:[] }); return; }
    const grain = hasCounty();
    // overlay buckets WITHIN the state — same frame as the county color quantiles
    let ovBreaks = null;
    if (ovItem() && ovHasCounty()){
      const ovs = [];
      fc.features.forEach(f => { const x = ovCVal(f.properties.fips); if (x != null) ovs.push(x); });
      if (ovs.length >= 5) ovBreaks = quantiles(ovs);
    }
    src.setData({ type:'FeatureCollection', features: fc.features.map(f => {
      const fips = f.properties.fips;
      let sub = '';
      if (grain){ const v = cVal(fips); if (v != null) sub = fmtV(v); }
      // population fallback SAYS it is population — an unlabeled "1.2M" under
      // a cost-of-living map reads as a cost (David's catch). "Pop." is the
      // Census Bureau's own map-label convention, prefix style.
      else if (CPOP && CPOP[fips] && CPOP[fips].p) sub = 'Pop. ' + fmtPop(CPOP[fips].p);
      const props = { n: f.properties.name, sub };
      if (ovBreaks){ const ov = ovCVal(fips); if (ov != null) props.ovb = bucketOf(ov, ovBreaks); }
      return { type:'Feature', geometry:{ type:'Point', coordinates: countyCenter(f) }, properties: props };
    })});
  }
  function paintCounties(){
    const src = map.getSource('lv-counties'); if (!src) return;
    const fc = selState && COUNTY_CACHE.get(selState.fips);
    refreshCountyLabels();
    if (!fc){ src.setData({ type:'FeatureCollection', features:[] }); return; }
    src.setData(fc);
    if (!hasCounty()){
      // state-only metric: boundaries and name/population labels stay for
      // context, but no tint and no county taps (nothing to answer with)
      map.setPaintProperty('lv-county-fill','fill-opacity',0);
      return;
    }
    const vals = [];
    fc.features.forEach(f => { const v = cVal(f.properties.fips); if (v != null) vals.push(v); });
    if (vals.length < 3) return;
    const breaks = quantiles(vals);
    const expr = ['match', ['get','fips']];
    fc.features.forEach(f => { const v = cVal(f.properties.fips); expr.push(f.properties.fips, v == null ? 'rgba(130,150,170,0.35)' : colorFor(v, breaks)); });
    expr.push('#4ECDC4');
    map.setPaintProperty('lv-county-fill','fill-color',expr);
    map.setPaintProperty('lv-county-fill','fill-opacity',0.6);
  }
  function legend(){
    const leg = $('lvCleg'); if (!leg) return;
    leg.innerHTML = '<span></span>' + SCALE.map(c => '<i style="background:' + c + '"></i>').join('') + '<span>worse → better</span>';
    leg.firstChild.textContent = item().name.length > 26 ? item().name.slice(0, 24) + '…' : item().name;
    if (ovItem()){
      const s = document.createElement('span');
      const n = ovItem().name;
      s.textContent = '· ◯ size = ' + (n.length > 22 ? n.slice(0, 20) + '…' : n);
      leg.appendChild(s);
    }
    leg.hidden = false;
  }
  function paintSel(){
    if (map.getLayer('lv-state-sel')) map.setFilter('lv-state-sel',
      ['in', ['get','abbr'], ['literal', [selState ? selState.abbr : '___', cmpState ? cmpState.abbr : '___']]]);
    if (map.getLayer('lv-county-sel')) map.setFilter('lv-county-sel', ['==', ['get','fips'], selCounty ? selCounty.fips : '___']);
    const sc = $('lvScope');
    if (!selState){ sc.hidden = true; return; }
    sc.hidden = false;
    sc.textContent = selCounty ? '◀ ' + selState.name : '◀ United States';
  }

  // ── metric chrome (the pill carries the LENS now — the rail is gone,
  //    lenses are sections inside the picker, grammar A) ──
  function metricFace(){
    $('lvMetricName').textContent = LENSES[lens] + ' · ' + item().name + (ovItem() ? '  + ◯ ' + ovItem().name : '');
    const y = DY[lens] && DY[lens][String(mIdx)];
    // position first, year second — mid-shuffle you want to know where you are
    $('lvMetricYear').textContent = (mIdx + 1) + '/' + CFG[lens].items.length + (y ? ' · ' + y : '');
  }
  // ‹ › shuffle: one metric per tap, wraps at the ends of the lens
  function stepMetric(d){
    const n = CFG[lens].items.length;
    mIdx = (mIdx + d + n) % n;
    metricChanged();
  }
  $('lvMetricPrev').addEventListener('click', () => stepMetric(-1));
  $('lvMetricNext').addEventListener('click', () => stepMetric(1));
  // metric picker: lives IN the drawer's Display tab (David's round-two call —
  // the pill is the readout, the drawer is the editor, all view work on ONE side)
  function metricOptHTML(l, i, it, foreign){
    const isOv = ovLens === l && ovIdx === i;
    const pin = isPinned(l, i);
    return '<button class="pop-opt" type="button" role="option" data-lens="' + l + '" data-mi="' + i + '" aria-selected="' + (l === lens && i === mIdx) + '"><span class="mn">' + it.name +
      (foreign ? '<span class="lns">' + LENSES[l] + '</span>' : '') +
      (COUNTY_IDX[l] && COUNTY_IDX[l].includes(String(i)) ? '<span class="grain">· county grain</span>' : '') + '</span>' +
      '<span class="ovbtn' + (isOv ? ' on' : '') + '" data-ovpick="1" title="' + (isOv ? 'Remove circle overlay' : 'Layer as circle overlay') + '">' + (isOv ? '⬤' : '◯') + '</span>' +
      '<span class="pinbtn' + (pin ? ' on' : '') + '" data-pinpick="1" title="' + (pin ? 'Unpin from cards' : 'Pin to cards') + '">' + (pin ? '★' : '☆') + '</span></button>';
  }
  function buildMetricList(q){
    const list = $('lvMetricList'); if (!list) return;
    const norm = (q || '').trim().toLowerCase();
    if (!norm){
      // the whole catalog, grouped: lenses are SECTIONS, current lens first
      const order = [lens, ...Object.keys(LENSES).filter(l => l !== lens)];
      list.innerHTML = order.map(l =>
        '<div class="pop-sec">' + LENSES[l] + '</div>' +
        CFG[l].items.map((it, i) => metricOptHTML(l, i, it, false)).join('')).join('');
    } else {
      // search EVERY lens — flat results, lens-tagged
      const rows = [];
      Object.keys(LENSES).forEach(l => CFG[l].items.forEach((it, i) => {
        if ((it.name + ' ' + (it.sub || '')).toLowerCase().includes(norm)) rows.push(metricOptHTML(l, i, it, l !== lens));
      }));
      list.innerHTML = rows.join('') || '<div class="lv-none">No metric matches</div>';
    }
    list.querySelectorAll('[data-mi]').forEach(el => el.addEventListener('click', e => {
      const l = el.dataset.lens, i = +el.dataset.mi;
      // the ☆ pins this metric to every card; the ◯ makes it the circle overlay
      if (e.target.closest('[data-pinpick]')){ togglePin(l, i); return; }
      if (e.target.closest('[data-ovpick]')){
        (ovLens === l && ovIdx === i) ? clearOverlay() : setOverlay(l, i);
        return;
      }
      lens = l;
      mIdx = i;
      metricChanged();   // refreshes the list + section header itself
      // desktop: stay open — the map repaints beside the list, browsing is the
      // point. Phone: the map IS the point, give the canvas back.
      if (HUKit.phone()) sheetEl.classList.remove('open');
    }));
  }
  function setOverlay(l, i){
    if (l === lens && i === mIdx){ announce('That metric is already the map color.'); return; }
    ovLens = l; ovIdx = i;
    overlayChanged('Overlay: ' + ovItem().name + ', shown as circle size.');
  }
  function clearOverlay(){
    ovLens = null; ovIdx = null;
    overlayChanged('Overlay off.');
  }
  function overlayChanged(msg){
    metricFace(); legend();
    paintStates(); refreshCountyLabels();
    repaintPanel();
    refreshCardBehind();
    syncURL();
    announce(msg);
  }
  // repaint the Display panel in place, search query intact
  function repaintPanel(){
    const find = $('lvMetricFind');
    if (!find) return;
    const q = find.value;
    buildDisplayPanel();
    const nf = $('lvMetricFind');
    if (nf && q){ nf.value = q; buildMetricList(q); }
  }
  // re-render the open card UNDER the Display tab so its tiles stay honest
  // (desktop only — on phone the card re-renders when Details is next opened)
  function refreshCardBehind(){
    if (HUKit.phone() || !sheetEl.classList.contains('open')) return;
    if (tab !== 'display' || mode !== 'card' || (!selState && !selCounty)) return;
    inTabSwitch = true;
    selCounty ? openCountyCard() : (selState && openStateCard());
    inTabSwitch = false;
    showTab('display');
  }
  function togglePin(l, i){
    const at = PINS.findIndex(p => p.l === l && p.i === i);
    if (at >= 0) PINS.splice(at, 1);
    else {
      if (PINS.length >= 4){ announce('Four pinned metrics is the ceiling. Unpin one first.'); return; }
      PINS.push({ l, i });
    }
    repaintPanel();
    refreshCardBehind();
    syncURL();
    announce(at >= 0 ? 'Unpinned.' : 'Pinned to cards: ' + CFG[l].items[i].name + '.');
  }
  $('lvMetricBtn').addEventListener('click', () => {
    openDisplayTab();
    if (!HUKit.phone()){ const f = $('lvMetricFind'); if (f) f.focus(); }   // no keyboard pop on phones
  });
  document.addEventListener('keydown', e => {
    if (e.key !== 'Escape') return;
    if (sheetEl.classList.contains('open')) $('lvSheetX').click();   // Esc = the X, back-walk included
  });
  function metricChanged(){
    // the fill metric caught up with the overlay: one encode is enough
    const ovAutoCleared = !!(ovItem() && ovLens === lens && ovIdx === mIdx);
    if (ovAutoCleared){ ovLens = null; ovIdx = null; }
    metricFace(); yearFace();
    // keep the Display tab's browser honest if it's been built (query survives)
    const secH = $('lvMetricSecH');
    if (secH && ovAutoCleared){
      // the Overlay section changed too — full panel repaint, query intact
      const f0 = $('lvMetricFind'); const q0 = f0 ? f0.value : '';
      buildDisplayPanel();
      const f1 = $('lvMetricFind');
      if (f1 && q0){ f1.value = q0; buildMetricList(q0); }
    } else if (secH){
      secH.textContent = LENSES[lens] + ' · ' + (mIdx + 1) + '/' + CFG[lens].items.length;
      const vb = $('lvViewBlock');
      if (vb) vb.innerHTML = viewBlockHTML();
      const find = $('lvMetricFind');
      if (document.activeElement !== find) buildMetricList(find ? find.value : '');
    }
    // the new metric has no county grain: fall back to the COUNTY'S STATE
    // instead of stranding a "no data" county card (David's call), and REFIT
    // the state so the camera matches the story the card is now telling
    const fellBack = selCounty && !hasCounty();
    if (fellBack) selCounty = null;
    paintStates(); paintCounties(); paintSel();
    if (fellBack && selState) map.fitBounds(stateBounds(selState.feature), { padding:FIT_PAD, maxZoom:8.5, duration:dcap(800) });
    if (selState && sheetEl.classList.contains('open')) selCounty ? openCountyCard() : openStateCard();
    announce('Metric: ' + item().name + (fellBack ? '. No county detail for this metric, showing ' + (selState ? selState.name : 'states') + '.' : '.'));
    syncURL();
  }

  // ── year control: ‹ 2021 est. › — history is modeled, the pill says so ──
  function yearFace(){
    const pill = $('lvYearPill'), lbl = $('lvYearLbl');
    if (!pill || !lbl) return;
    const trend = hasTrend();
    const yrs = YRS();
    pill.classList.toggle('no-trend', !trend);
    if (!trend && !isCurrentYear()) yearIdx = yrs.length - 1;
    lbl.innerHTML = yrs[yearIdx] + (isCurrentYear() ? '' : ' <i>est.</i>');
    $('lvYearPrev').disabled = !trend || yearIdx === 0;
    $('lvYearNext').disabled = !trend || isCurrentYear();
  }
  function stepYear(d){
    if (!hasTrend()) return;
    const n = Math.max(0, Math.min(YRS().length - 1, yearIdx + d));
    if (n === yearIdx) return;
    yearIdx = n;
    yearFace(); paintStates(); syncURL();
    announce('Year ' + YRS()[yearIdx] + (isCurrentYear() ? '.' : ', estimated.'));
    if (sheetEl.classList.contains('open')){
      if (mode === 'rank') openRankings();
      else if (selState) (cmpState ? openCompareCard() : (selCounty ? openCountyCard() : openStateCard()));
    }
  }
  $('lvYearPrev').addEventListener('click', () => stepYear(-1));
  $('lvYearNext').addEventListener('click', () => stepYear(1));

  // ── URL state, v1-compatible: the old page's ?lens=&metric=<name-slug>&state=
  //    links keep resolving; ?year= and ?county= are new. replaceState only. ──
  const metricSlug = n => n.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
  // scope changes PUSH (back unwinds county → state → US before leaving the
  // page — the phone back contract); lens/metric/year tweaks replace
  let applyingURL = false, lastScope = '§init';
  const scopeKey = () => (selState ? selState.abbr : '') + '/' + (selCounty ? selCounty.fips : '');
  function syncURL(){
    if (applyingURL) return;
    const p = new URLSearchParams();
    if (lens !== 'patient') p.set('lens', lens);
    if (mIdx !== 0) p.set('metric', metricSlug(item().name));
    if (ovItem()) p.set('ov', ovLens + ':' + metricSlug(ovItem().name));   // shareable two-metric views
    if (PINS.length) p.set('pins', PINS.map(pn => pn.l + ':' + metricSlug(CFG[pn.l].items[pn.i].name)).join(','));
    if (!isCurrentYear()) p.set('year', String(YRS()[yearIdx]));
    if (selState) p.set('state', selState.abbr);
    if (selCounty) p.set('county', selCounty.fips);
    if (cmpState) p.set('cmp', cmpState.abbr);   // shareable comparisons
    const q = p.toString();
    const key = scopeKey();
    const method = (lastScope !== '§init' && key !== lastScope) ? 'pushState' : 'replaceState';
    lastScope = key;
    try { history[method](null, '', q ? ('?' + q) : location.pathname); } catch(e){}
  }
  window.addEventListener('popstate', async () => {
    // quiet reset, then rebuild the whole view from the entry's querystring
    selState = null; selCounty = null; cmpState = null; comparePick = false; mode = 'card';
    sheetEl.classList.remove('open');
    paintSel(); paintCounties();
    const p = new URLSearchParams(location.search);
    if ([...p.keys()].length){
      await applyURLState();
    } else {
      lens = 'patient'; mIdx = 0; yearIdx = YRS().length - 1;
      ovLens = null; ovIdx = null; PINS.length = 0;
      metricFace(); yearFace(); paintStates();
      map.flyTo({ center:[-96.5,39.3], zoom:3.6, duration:dcap(900) });
    }
    lastScope = scopeKey();
  });
  async function applyURLState(){
    const p = new URLSearchParams(location.search);
    if (![...p.keys()].length) return;
    applyingURL = true;
    try {
      const L = p.get('lens');
      if (L && LENSES[L]){ lens = L; mIdx = 0; }
      const mk = p.get('metric');
      if (mk){ const idx = CFG[lens].items.findIndex(it => metricSlug(it.name) === mk); if (idx >= 0) mIdx = idx; }
      const ov = p.get('ov');
      if (ov){
        const ci = ov.indexOf(':');
        const ol = ov.slice(0, ci), oslug = ov.slice(ci + 1);
        if (LENSES[ol]){
          const oi = CFG[ol].items.findIndex(it => metricSlug(it.name) === oslug);
          if (oi >= 0 && !(ol === lens && oi === mIdx)){ ovLens = ol; ovIdx = oi; }
        }
      }
      const pinsQ = p.get('pins');
      if (pinsQ) pinsQ.split(',').slice(0, 4).forEach(tok => {
        const pc = tok.indexOf(':');
        const pl = tok.slice(0, pc), ps = tok.slice(pc + 1);
        if (!LENSES[pl]) return;
        const pi = CFG[pl].items.findIndex(it => metricSlug(it.name) === ps);
        if (pi >= 0 && !isPinned(pl, pi)) PINS.push({ l: pl, i: pi });
      });
      metricFace(); yearFace();
      const y = parseInt(p.get('year'), 10);
      const yi = YRS().indexOf(y);
      if (yi >= 0 && hasTrend()) yearIdx = yi;
      yearFace(); paintStates();
      const st = p.get('state');
      if (st){
        const sf = STATES.features.find(f => f.properties.abbr === st);
        if (sf){
          await selectState(sf);
          const co = p.get('county');
          if (co && COUNTY_CACHE.has(sf.properties.fips)){
            const cf = COUNTY_CACHE.get(sf.properties.fips).features.find(x => x.properties.fips === co);
            if (cf){ selCounty = { fips:cf.properties.fips, name:cf.properties.name }; paintSel(); openCountyCard(); }
          }
          const cmp = p.get('cmp');
          if (cmp && !selCounty){
            const cf2 = STATES.features.find(x => x.properties.abbr === cmp);
            if (cf2 && cf2.properties.abbr !== selState.abbr){
              cmpState = { fips:cf2.properties.fips, abbr:cf2.properties.abbr, name:cf2.properties.name, feature:cf2 };
              paintSel(); openCompareCard();
            }
          }
        }
      }
    } finally { applyingURL = false; }
  }

  // ── rankings: every state at the current metric + year, best first ──
  let mode = 'card';
  function openRankings(){
    mode = 'rank';
    showTab('details');
    const rows = STATES.features
      .map(f => ({ abbr:f.properties.abbr, name:f.properties.name, v:vYear(f.properties.abbr) }))
      .filter(r => r.v != null)
      .sort((a,b) => item().dir === -1 ? a.v - b.v : b.v - a.v);
    const b = $('lvSheetBody');
    b.innerHTML = '<div class="lv-kicker">Rankings · ' + yearTag() + '</div><div class="lv-name"></div><div class="lv-sub"></div><div class="lv-rows"></div>';
    b.querySelector('.lv-name').textContent = item().name;
    b.querySelector('.lv-sub').textContent = 'Best first · tap a state to open it';
    const host = b.querySelector('.lv-rows');
    host.innerHTML = rows.map((r,i) =>
      '<button class="pop-opt lv-rank-row" type="button" data-ab="' + r.abbr + '" aria-selected="' + (selState && selState.abbr === r.abbr) + '"><b>#' + (i+1) + '</b><span class="rn"></span><span class="gv-sr-meta" style="margin-left:auto;font-family:var(--mono);font-size:10px;color:var(--t3)">' + fmtV(r.v) + '</span></button>').join('');
    host.querySelectorAll('.lv-rank-row').forEach((el,i) => {
      el.querySelector('.rn').textContent = rows[i].name;
      el.addEventListener('click', () => {
        mode = 'card';
        const sf = STATES.features.find(x => x.properties.abbr === el.dataset.ab);
        if (sf) selectState(sf);
      });
    });
    sheetEl.classList.add('open');
    sheet.setDetent('dt-full');
  }
  $('lvRankBtn').addEventListener('click', () => {
    if (mode === 'rank' && sheetEl.classList.contains('open')){
      mode = 'card';
      if (selState){ selCounty ? openCountyCard() : openStateCard(); } else sheetEl.classList.remove('open');
    } else openRankings();
  });

  // ── cards (values + rank, straight from the flagship's numbers) ──
  function natStats(){
    const vals = [];
    STATES.features.forEach(f => { const v = vYear(f.properties.abbr); if (v != null) vals.push(v); });
    return vals;
  }
  // state + national population, rolled once from the county file
  let SPOP = null, NPOP = 0;
  function popOf(){
    if (SPOP || !CPOP) return;
    SPOP = {};
    Object.entries(CPOP).forEach(([f, o]) => {
      const s = f.slice(0, 2);
      SPOP[s] = (SPOP[s] || 0) + (o.p || 0);
      NPOP += o.p || 0;
    });
  }
  // secondary tiles (◯ overlay + ★ pins) fold behind one switch; the open
  // state survives across cards so a working session stays open
  let moreOpen = false;
  function moreBlock(host, sec){
    if (!sec.length){ host.innerHTML = ''; return; }
    host.innerHTML = '<div class="lv-tgl">More metrics · ' + sec.length +
      ' <span class="lv-sw' + (moreOpen ? ' on' : '') + '" id="lvMoreSw" role="switch" aria-checked="' + moreOpen + '" tabindex="0" aria-label="Show secondary metrics"></span></div>' +
      '<div class="hu-stats" id="lvMoreTiles">' +
      sec.map(s => '<div class="hu-stat"><div class="v' + (s.cls || '') + '">' + s.v + '</div><div class="k">' + s.k + '</div></div>').join('') + '</div>';
    const tilesEl = $('lvMoreTiles');
    tilesEl.style.display = moreOpen ? 'grid' : 'none';   // inline style beats [hidden]
    $('lvMoreSw').addEventListener('click', () => {
      moreOpen = !moreOpen;
      $('lvMoreSw').classList.toggle('on', moreOpen);
      $('lvMoreSw').setAttribute('aria-checked', String(moreOpen));
      tilesEl.style.display = moreOpen ? 'grid' : 'none';
    });
  }
  // the ◯ + ★ tile set for a state (used by both card grains)
  function secondaryTilesState(abbr){
    const sec = [];
    if (ovItem()){
      const ov = ovSVal(abbr);
      if (ov != null){
        const ovAll = [];
        STATES.features.forEach(f => { const x = ovSVal(f.properties.abbr); if (x != null) ovAll.push(x); });
        const ovSorted = ovAll.slice().sort((a,b) => ovItem().dir === -1 ? a - b : b - a);
        const r2 = ovSorted.indexOf(ov) + 1;
        sec.push({ v: fmtVFor(ovItem(), ov), k:'◯ ' + ovItem().name + (r2 ? ' · #' + r2 : '') });
      }
    }
    PINS.forEach(pn => {
      if (pn.l === lens && pn.i === mIdx) return;
      if (ovItem() && pn.l === ovLens && pn.i === ovIdx) return;
      const it = CFG[pn.l].items[pn.i];
      const m = SD[pn.l] && SD[pn.l][String(pn.i)];
      const v = m && m[abbr] != null ? +m[abbr] : null;
      if (v == null) return;
      const all = Object.values(m).filter(x => x != null).map(Number);
      const sorted3 = all.slice().sort((a,b) => it.dir === -1 ? a - b : b - a);
      const r3 = sorted3.indexOf(v) + 1;
      sec.push({ v: fmtVFor(it, v), k:'★ ' + it.name + (r3 ? ' · #' + r3 : '') });
    });
    return sec;
  }
  const yearTag = () => YRS()[yearIdx] + (isCurrentYear() ? '' : ' est.');
  // tiny trend sparkline: seven points, the real data year marked solid
  function sparkSVG(pts){
    if (!pts || pts.length < 2) return '';
    const W = 250, H = 54, P = 8;
    const vs = pts.map(p => p.value);
    const mn = Math.min(...vs), mx = Math.max(...vs), span = (mx - mn) || 1;
    const x = i => P + i * (W - 2*P) / (pts.length - 1);
    const y = v => H - P - (v - mn) * (H - 2*P) / span;
    const line = pts.map((p,i) => (i ? 'L' : 'M') + x(i).toFixed(1) + ' ' + y(p.value).toFixed(1)).join(' ');
    const yi = yearIdx;
    return '<svg class="lv-spark" viewBox="0 0 ' + W + ' ' + H + '" aria-hidden="true">' +
      '<path d="' + line + '" fill="none" stroke="#4ECDC4" stroke-width="2" opacity=".85"/>' +
      pts.map((p,i) =>
        '<circle cx="' + x(i).toFixed(1) + '" cy="' + y(p.value).toFixed(1) + '" r="' + (i === yi ? 4 : p.real ? 3 : 1.6) + '" ' +
        'fill="' + (i === yi ? '#E8A838' : p.real ? '#4ECDC4' : 'rgba(160,190,200,.55)') + '"/>').join('') +
      '</svg>';
  }
  function openStateCard(){
    if (!selState) return;
    mode = 'card';
    showTab('details');
    if (cmpState){ openCompareCard(); return; }
    const v = vYear(selState.abbr);
    const vals = natStats();
    const sorted = vals.slice().sort((a,b) => item().dir === -1 ? a - b : b - a);   // rank 1 = best
    const rank = v == null ? null : sorted.indexOf(v) + 1;
    const avg = vals.length ? vals.reduce((a,x) => a + x, 0) / vals.length : null;
    const b = $('lvSheetBody');
    b.innerHTML = '<div class="lv-kicker">State · ' + LENSES[lens] + '</div><div class="lv-name"></div><div class="lv-sub"></div><div class="lv-ptable"></div><div class="lv-more"></div><div class="lv-trend"></div><div class="lv-actions"></div><div class="lv-src"></div>';
    b.querySelector('.lv-name').textContent = selState.name;
    b.querySelector('.lv-sub').textContent = item().name + ' · ' + yearTag() + (hasCounty() ? ' · tap a county' : '');
    // primary table: STATE vs NATION × value / rank / population
    popOf();
    const cell = (html, cls) => '<div class="' + (cls || '') + '">' + html + '</div>';
    const spop = SPOP && SPOP[selState.fips];
    b.querySelector('.lv-ptable').innerHTML =
      cell('', 'th') + cell(selState.abbr + ' state', 'th') + cell('Nation', 'th') +
      cell('Value · ' + yearTag(), 'rl') +
      cell(v == null ? 'no data' : fmtV(v), 'val') +
      cell(avg == null ? '—' : fmtV(Math.round(avg * 10) / 10) + '<span>avg</span>', 'val sm') +
      cell('Rank', 'rl') +
      cell(rank ? '#' + rank + '<span>of ' + vals.length + '</span>' : '—', 'val sm' + (rank && rank <= 10 ? ' hi' : rank && rank > vals.length - 10 ? ' lo' : '')) +
      cell('<span>1 = best on this metric</span>', 'val sm') +
      cell('Population', 'rl') +
      cell(spop ? fmtPop(spop) : '—', 'val sm') +
      cell(NPOP ? fmtPop(NPOP) : '—', 'val sm');
    moreBlock(b.querySelector('.lv-more'), secondaryTilesState(selState.abbr));
    if (hasTrend()){
      const tr = b.querySelector('.lv-trend');
      const yrs = YRS();
      tr.innerHTML = sparkSVG(trendPoints(selState.abbr)) + '<div class="lv-trend-lbl">' + yrs[0] + '–' + yrs[yrs.length - 1] + ' · solid dot = real data year, rest estimated from trend rates</div>';
    }
    const act = b.querySelector('.lv-actions');
    const cbtn = document.createElement('button');
    cbtn.className = 'hu-chip'; cbtn.type = 'button';
    cbtn.textContent = comparePick ? 'Now tap the state to compare with…' : '⇄ Compare with another state';
    cbtn.addEventListener('click', () => { comparePick = !comparePick; openStateCard(); });
    act.appendChild(cbtn);
    b.querySelector('.lv-src').textContent = 'Source: ' + (item().source || '') + (DY[lens] && DY[lens][String(mIdx)] ? ' · ' + DY[lens][String(mIdx)] + ' data' : '');
    sheetEl.classList.add('open');
    sheet.setDetent('dt-peek');
  }
  function openCompareCard(){
    if (!selState || !cmpState) return;
    mode = 'card';
    showTab('details');
    const va = vYear(selState.abbr), vb = vYear(cmpState.abbr);
    const b = $('lvSheetBody');
    b.innerHTML = '<div class="lv-kicker">Compare · ' + item().name + ' · ' + yearTag() + '</div><div class="lv-name"></div><div class="hu-stats"></div><div class="lv-actions"></div>';
    b.querySelector('.lv-name').textContent = selState.name + ' vs ' + cmpState.name;
    const tiles = [
      { v: va == null ? '—' : fmtV(va), k: selState.abbr },
      { v: vb == null ? '—' : fmtV(vb), k: cmpState.abbr }
    ];
    if (va != null && vb != null){
      const d = Math.round((va - vb) * 10) / 10;
      const better = item().dir === -1 ? (va < vb ? selState.abbr : cmpState.abbr) : (va > vb ? selState.abbr : cmpState.abbr);
      tiles.push({ v:(d >= 0 ? '+' : '') + fmtV(d).replace('%','') + (item().unit === '%' ? 'pp' : ''), k:'Δ · ' + better + ' better', cls:' hi' });
    }
    b.querySelector('.hu-stats').innerHTML = tiles.map(s => '<div class="hu-stat"><div class="v' + (s.cls||'') + '">' + s.v + '</div><div class="k">' + s.k + '</div></div>').join('');
    const act = b.querySelector('.lv-actions');
    const x = document.createElement('button');
    x.className = 'hu-chip'; x.type = 'button'; x.textContent = '✕ End compare';
    x.addEventListener('click', () => { cmpState = null; paintSel(); openStateCard(); syncURL(); });
    act.appendChild(x);
    sheetEl.classList.add('open');
    sheet.setDetent('dt-half');
  }
  function openCountyCard(){
    if (!selCounty || !selState) return;
    mode = 'card';
    showTab('details');
    const v = cVal(selCounty.fips);
    const fc = COUNTY_CACHE.get(selState.fips);
    const vals = [];
    if (fc) fc.features.forEach(f => { const x = cVal(f.properties.fips); if (x != null) vals.push(x); });
    const sorted = vals.slice().sort((a,b) => item().dir === -1 ? a - b : b - a);
    const rank = v == null ? null : sorted.indexOf(v) + 1;
    const b = $('lvSheetBody');
    b.innerHTML = '<div class="lv-kicker">County · ' + selState.abbr + '</div><div class="lv-name"></div><div class="lv-sub"></div><div class="lv-ptable"></div><div class="lv-more"></div><div class="lv-src"></div>';
    b.querySelector('.lv-name').textContent = selCounty.name + ' County';
    b.querySelector('.lv-sub').textContent = item().name + (isCurrentYear() ? '' : ' · county grain shows the latest data year');
    // primary table (David's spec): COUNTY vs STATE × value / rank / population —
    // the county ranks within its state, the state ranks within the nation
    const dataYr = (DY[lens] && DY[lens][String(mIdx)]) || 'latest';
    const sv = vYear(selState.abbr);
    const nVals = natStats();
    const nSorted = nVals.slice().sort((a,b) => item().dir === -1 ? a - b : b - a);
    const sRank = sv == null ? null : nSorted.indexOf(sv) + 1;
    popOf();
    const cpop = CPOP && CPOP[selCounty.fips] && CPOP[selCounty.fips].p;
    const spop = SPOP && SPOP[selState.fips];
    const cell = (html, cls) => '<div class="' + (cls || '') + '">' + html + '</div>';
    b.querySelector('.lv-ptable').innerHTML =
      cell('', 'th') + cell('County', 'th') + cell(selState.abbr + ' state', 'th') +
      cell('Value · ' + dataYr, 'rl') +
      cell(v == null ? 'no data' : fmtV(v), 'val') +
      cell(sv == null ? '—' : fmtV(sv), 'val') +
      cell('Rank', 'rl') +
      cell(rank ? '#' + rank + '<span>of ' + vals.length + ' in ' + selState.abbr + '</span>' : '—', 'val sm' + (rank && rank <= 5 ? ' hi' : '')) +
      cell(sRank ? '#' + sRank + '<span>of ' + nVals.length + ' US</span>' : '—', 'val sm' + (sRank && sRank <= 10 ? ' hi' : sRank && sRank > nVals.length - 10 ? ' lo' : '')) +
      cell('Population', 'rl') +
      cell(cpop ? fmtPop(cpop) : '—', 'val sm') +
      cell(spop ? fmtPop(spop) : '—', 'val sm');
    // secondary metrics fold behind the switch: county grain when it exists
    const sec = [];
    if (ovItem()){
      const ovc = ovHasCounty() ? ovCVal(selCounty.fips) : null;
      const ovs2 = ovSVal(selState.abbr);
      if (ovc != null) sec.push({ v: fmtVFor(ovItem(), ovc), k:'◯ ' + ovItem().name + ' · county' });
      else if (ovs2 != null) sec.push({ v: fmtVFor(ovItem(), ovs2), k:'◯ ' + ovItem().name + ' · ' + selState.abbr + ' state' });
    }
    PINS.forEach(pn => {
      if (pn.l === lens && pn.i === mIdx) return;
      if (ovItem() && pn.l === ovLens && pn.i === ovIdx) return;
      const it = CFG[pn.l].items[pn.i];
      const cg = COUNTY_IDX[pn.l] && COUNTY_IDX[pn.l].includes(String(pn.i));
      const cvv = cg && CDATA && CDATA[pn.l] && CDATA[pn.l][String(pn.i)] ? CDATA[pn.l][String(pn.i)][selCounty.fips] : null;
      const svv = SD[pn.l] && SD[pn.l][String(pn.i)] ? SD[pn.l][String(pn.i)][selState.abbr] : null;
      if (cvv != null) sec.push({ v: fmtVFor(it, +cvv), k:'★ ' + it.name + ' · county' });
      else if (svv != null) sec.push({ v: fmtVFor(it, +svv), k:'★ ' + it.name + ' · ' + selState.abbr });
    });
    moreBlock(b.querySelector('.lv-more'), sec);
    b.querySelector('.lv-src').textContent = 'County grain: CDC PLACES / BLS / Census, same joins as the production map.';
    sheetEl.classList.add('open');
    sheet.setDetent('dt-half');
  }

  // ── selection ──
  async function selectState(f){
    selCounty = null; cmpState = null; comparePick = false;
    selState = { fips:f.properties.fips, abbr:f.properties.abbr, name:f.properties.name, feature:f };
    paintSel(); syncInsets();
    map.fitBounds(stateBounds(f), { padding:FIT_PAD, maxZoom:8.5, duration:dcap(900) });
    openStateCard();
    announce(selState.name + '.');
    if (!COUNTY_CACHE.has(selState.fips)){
      signal('Loading ' + selState.name + ' counties…');
      try {
        const fc = await fetch('/assets/data/geo/counties/' + selState.fips + '.json').then(r => r.json());
        COUNTY_CACHE.set(selState.fips, fc);
      } catch(e){}
      signalDone(400);
    }
    paintCounties();
    syncURL();
  }
  function deselectState(){
    selState = null; selCounty = null; cmpState = null; comparePick = false;
    paintSel(); paintCounties(); syncInsets();
    sheetEl.classList.remove('open');
    map.flyTo({ center:[-96.5,39.3], zoom:3.6, duration:dcap(900) });
    syncURL();
  }
  $('lvScope').addEventListener('click', () => {
    if (selCounty){ selCounty = null; paintSel(); openStateCard(); map.fitBounds(stateBounds(selState.feature), { padding:FIT_PAD, maxZoom:8.5, duration:dcap(800) }); return; }
    if (selState) deselectState();
  });

  // ── locate (kit: permission on tap; resolves to state + county) ──
  HUKit.locate($('lvLocate'), {
    onFix: async fix => {
      const pt = [fix.lon, fix.lat];
      const st = STATES && STATES.features.find(f => pip(pt, f.geometry));
      if (!st){ signal('Your location is outside the mapped states'); signalDone(2600); return; }
      await selectState(st);
      const fc = COUNTY_CACHE.get(st.properties.fips);
      if (fc && hasCounty()){
        const cf = fc.features.find(f => pip(pt, f.geometry));
        if (cf){ selCounty = { fips:cf.properties.fips, name:cf.properties.name }; paintSel(); openCountyCard(); }
      }
    },
    onError: () => { signal('Location unavailable. Tap your state instead'); signalDone(2600); }
  });

  // ── map-label toggles: basemap state/city names on or off, persisted and
  //    SHARED with the operations map (one preference, both canvases) ──
  const LABEL_PREFS_KEY = 'hu-map-labels';
  const labelPrefs = () => { try { return Object.assign({ state:true, city:true }, JSON.parse(localStorage.getItem(LABEL_PREFS_KEY) || '{}')); } catch(e){ return { state:true, city:true }; } };
  // our own lv-* layers are DATA, never governed by these toggles
  const labelGroup = id => /^lv-/.test(id) || /country|continent/.test(id) ? null
    : /state|region/.test(id) ? 'state'
    : /place|city|town|village|suburb/.test(id) ? 'city' : null;
  function applyLabelPrefs(){
    const p = labelPrefs();
    map.getStyle().layers.forEach(l => {
      if (l.type !== 'symbol') return;
      const g = labelGroup(l.id);
      if (!g) return;
      try { map.setLayoutProperty(l.id, 'visibility', p[g] ? 'visible' : 'none'); } catch(e){}
    });
  }
  function toggleLabelPref(k){
    const p = labelPrefs(); p[k] = !p[k];
    try { localStorage.setItem(LABEL_PREFS_KEY, JSON.stringify(p)); } catch(e){}
    [['lvLabState','state'],['lvLabCity','city']].forEach(([id, key]) => {
      const el = $(id); if (!el) return;
      el.classList.toggle('on', p[key]);
      el.setAttribute('aria-checked', String(p[key]));
    });
    applyLabelPrefs();
    announce((k === 'state' ? 'State names ' : 'City names ') + (p[k] ? 'on.' : 'off.'));
  }

  // ── drawer tabs: Details | Display (grammar A — one home for view controls) ──
  let tab = 'details';
  let inTabSwitch = false;
  function showTab(t){
    const was = tab;
    tab = t;
    if (t === 'display') buildDisplayPanel();   // the tab itself is an entry point
    // the details body carries an inline display:flex, which BEATS the hidden
    // attribute — drive display directly or the switch is a no-op
    const det = $('lvSheetBody'), dis = $('lvDisplayBody');
    det.hidden = t !== 'details'; det.style.display = t === 'details' ? 'flex' : 'none';
    dis.hidden = t !== 'display'; dis.style.display = t === 'display' ? 'block' : 'none';
    document.querySelectorAll('#lvTabs button').forEach(b => {
      b.classList.toggle('on', b.dataset.tab === t);
      b.setAttribute('aria-selected', String(b.dataset.tab === t));
    });
    // arriving FROM Display: the card may have gone stale (pins, overlay) —
    // re-render the scope's card; inTabSwitch stops the render recursing here
    if (t === 'details' && was === 'display' && !inTabSwitch && mode === 'card' && (selState || selCounty)){
      inTabSwitch = true;
      selCounty ? openCountyCard() : (selState && openStateCard());
      inTabSwitch = false;
    }
    if (t === 'details' && !det.innerHTML.trim())
      det.innerHTML = '<div class="lv-sub" style="margin-top:8px">Tap a state for its card, or Rankings for the field.</div>';
  }
  // the whole composition in words: what's color, what's circles, what's
  // pinned — with the fill metric's actual definition, read as one piece
  function viewBlockHTML(){
    const it = item();
    const y = DY[lens] && DY[lens][String(mIdx)];
    let h = '<div class="lv-vrow"><span class="role">Color</span><b>' + it.name + '</b></div>' +
      '<div class="lv-vdefn">' + (it.defn || it.sub || '') +
      (it.source ? '<span class="src">' + it.source + (y ? ' · ' + y : '') + '</span>' : '') + '</div>';
    if (ovItem()) h += '<div class="lv-vrow"><span class="role">◯ Size</span><b>' + ovItem().name + '</b></div>';
    PINS.forEach(pn => { h += '<div class="lv-vrow"><span class="role">★ Card</span><b>' + CFG[pn.l].items[pn.i].name + '</b></div>'; });
    return h;
  }
  function buildDisplayPanel(){
    const p = labelPrefs();
    $('lvDisplayBody').innerHTML =
      '<div class="lv-dsec"><h5>This view</h5><div class="lv-view" id="lvViewBlock">' + viewBlockHTML() + '</div></div>' +
      '<div class="lv-dsec"><h5>Metric <span class="sub" id="lvMetricSecH">' + LENSES[lens] + ' · ' + (mIdx + 1) + '/' + CFG[lens].items.length + '</span></h5>' +
      '<div class="lv-find"><input id="lvMetricFind" type="text" placeholder="Search all lenses…" autocomplete="off" aria-label="Search metrics across every lens"></div>' +
      '<div id="lvMetricList" role="listbox" aria-label="Metrics"></div></div>' +
      '<div class="lv-dsec"><h5>Overlay <span class="sub">sized circles</span></h5>' + (ovItem()
        ? '<div class="lv-tgl"><span>⬤ ' + ovItem().name + '</span><button class="hu-chip" id="lvOvClear" type="button">✕ Clear</button></div>'
        : '<div class="lv-src" style="margin-top:0">Tap the ◯ on any metric above to layer it as SIZED CIRCLES over the colors — e.g. heart disease as color, nurses per 100k as size.</div>') +
      '</div>' +
      '<div class="lv-dsec"><h5>Pinned to cards <span class="sub">' + PINS.length + '/4</span></h5>' + (PINS.length
        ? '<div class="lv-drow">' + PINS.map((pn, k) =>
            '<button class="hu-chip on" type="button" data-unpin="' + k + '">★ ' + CFG[pn.l].items[pn.i].name + ' ✕</button>').join('') + '</div>'
        : '<div class="lv-src" style="margin-top:0">Tap the ☆ on any metric to add its value to every state and county card — the card holds what the map can\'t.</div>') +
      '</div>' +
      '<div class="lv-dsec"><h5>Map labels <span class="sub">basemap text</span></h5>' +
      '<div class="lv-tgl">State names <span class="lv-sw' + (p.state ? ' on' : '') + '" id="lvLabState" role="switch" aria-checked="' + p.state + '" tabindex="0"></span></div>' +
      '<div class="lv-tgl">City names <span class="lv-sw' + (p.city ? ' on' : '') + '" id="lvLabCity" role="switch" aria-checked="' + p.city + '" tabindex="0"></span></div></div>' +
      '<div class="lv-dsec"><h5>Reading the map</h5>' +
      '<div class="lv-src" style="margin-top:0">Colors are quintiles of the current metric, red = worse end, teal = better. Metrics marked "county grain" drill to county detail inside a state. Years before the data year are drift-model estimates, labeled est.</div></div>';
    buildMetricList();
    const find = $('lvMetricFind');
    find.addEventListener('input', () => buildMetricList(find.value));
    find.addEventListener('keydown', e => {
      if (e.key === 'ArrowDown'){ e.preventDefault(); e.stopPropagation(); const f = $('lvMetricList').querySelector('.pop-opt'); if (f) f.focus(); }
      // Esc with a query clears it; the sheet handler only closes when it's empty
      else if (e.key === 'Escape' && find.value){ find.value = ''; buildMetricList(); e.stopPropagation(); }
    });
  }
  $('lvDisplayBody').addEventListener('click', e => {
    if (e.target.id === 'lvLabState'){ toggleLabelPref('state'); return; }
    if (e.target.id === 'lvLabCity'){ toggleLabelPref('city'); return; }
    if (e.target.id === 'lvOvClear' || e.target.closest('#lvOvClear')){ clearOverlay(); return; }
    const un = e.target.closest('[data-unpin]');
    if (un){
      PINS.splice(+un.dataset.unpin, 1);
      repaintPanel(); refreshCardBehind(); syncURL();
      announce('Unpinned.');
      return;
    }
  });
  // arrow keys walk the metric list (delegated — the list is rebuilt often)
  $('lvDisplayBody').addEventListener('keydown', e => {
    if (e.key !== 'ArrowDown' && e.key !== 'ArrowUp') return;
    const list = $('lvMetricList'); if (!list || !list.contains(document.activeElement)) return;
    const opts = [...list.querySelectorAll('.pop-opt')];
    const i = opts.indexOf(document.activeElement);
    e.preventDefault();
    if (e.key === 'ArrowDown') (opts[i+1] || opts[0]).focus();
    else (opts[i-1] || opts[opts.length-1]).focus();
  });
  $('lvTabs').addEventListener('click', e => { const b = e.target.closest('[data-tab]'); if (b) showTab(b.dataset.tab); });
  function openDisplayTab(){
    showTab('display');   // builds the panel on entry
    sheetEl.classList.add('open');
    sheet.setDetent('dt-half');
  }

  // ── drawer resize: drag the LEFT edge on a monitor; phones keep the sheet.
  //    Width is shared with the operations map (one preference). ──
  (function(){
    const KEY = 'hu-drawer-w';
    const shell = document.querySelector('.lv-shell');
    const saved = parseInt(localStorage.getItem(KEY), 10);
    if (saved >= 300 && saved <= 640) shell.style.setProperty('--drawer-w', saved + 'px');
    const grip = document.createElement('div');
    grip.className = 'lv-resize';
    grip.setAttribute('aria-hidden', 'true');
    sheetEl.appendChild(grip);
    let sx = 0, sw = 0, lastW = 0, on = false;
    grip.addEventListener('pointerdown', e => {
      if (window.innerWidth < 1100) return;
      on = true; sx = e.clientX; sw = sheetEl.getBoundingClientRect().width;
      grip.setPointerCapture(e.pointerId);
      e.preventDefault();
    });
    grip.addEventListener('pointermove', e => {
      if (!on) return;
      lastW = Math.max(300, Math.min(640, Math.round(sw + (sx - e.clientX))));
      shell.style.setProperty('--drawer-w', lastW + 'px');
    });
    grip.addEventListener('pointerup', () => {
      if (!on) return;
      on = false;
      if (lastW) try { localStorage.setItem(KEY, String(lastW)); } catch(e){}
    });
  })();

  // ── AK/HI insets: two tiny non-interactive cameras, desktop, US zoom only.
  // Unlike the operations map's count badges, these carry the CHOROPLETH —
  // each box shows its state tinted on the live metric scale, value in the badge. ──
  const INSETS = [];
  let insetsBuilt = false;
  let stateBreaks = null;   // written by paintStates, read by syncInsetData
  function buildInsets(){
    if (insetsBuilt || window.innerWidth < 700) return;
    insetsBuilt = true;
    [['lvInsetAKmap', [-152.5, 63.5], 1.6, 'AK'], ['lvInsetHImap', [-157.4, 20.6], 4.6, 'HI']].forEach(([el, center, zoom, abbr]) => {
      const m = new maplibregl.Map({ container: $(el), style: styleFor(), center, zoom,
        interactive:false, attributionControl:false });
      INSETS.push({ m, abbr });
      m.on('load', () => installInsetTint(m, abbr));
      $(el).parentElement.addEventListener('click', () => {
        const sf = STATES && STATES.features.find(f => f.properties.abbr === abbr);
        if (sf) selectState(sf);
      });
    });
  }
  function installInsetTint(m, abbr){
    if (!STATES || m.getSource('lv-inset-states')) return;
    const before = (m.getStyle().layers.find(l => l.type === 'symbol') || {}).id;
    m.addSource('lv-inset-states', { type:'geojson', data:STATES });
    m.addLayer({ id:'lv-inset-fill', type:'fill', source:'lv-inset-states',
      filter:['==', ['get','abbr'], abbr],
      paint:{ 'fill-color':'#4ECDC4', 'fill-opacity':0.55 }}, before);
    m.addLayer({ id:'lv-inset-line', type:'line', source:'lv-inset-states',
      filter:['==', ['get','abbr'], abbr],
      paint:{ 'line-color': document.documentElement.getAttribute('data-theme') === 'light'
        ? 'rgba(27,42,52,.35)' : 'rgba(255,255,255,.35)', 'line-width':1 }}, before);
    syncInsetData();
  }
  function syncInsetData(){
    INSETS.forEach(({ m, abbr }) => {
      const v = vYear(abbr);
      const el = $('lvInset' + abbr + 'n');
      if (el) el.textContent = v == null ? '' : fmtV(v);
      if (m.getLayer('lv-inset-fill')) m.setPaintProperty('lv-inset-fill','fill-color',
        v == null || !stateBreaks ? 'rgba(130,150,170,0.3)' : colorFor(v, stateBreaks));
    });
  }
  function syncInsets(){
    const el = $('lvInsets'); if (!el) return;
    el.classList.toggle('hide', map.getZoom() >= 4.6 || !!selState);
  }
  map.on('moveend', syncInsets);

  // ── layers + router ──
  function installLayers(){
    if (map.getSource('lv-states') || !STATES) return;
    // ink flips with the basemap: white lines vanish on positron, dark ink
    // vanishes on fiord — every hardcoded white here was a light-theme bug
    const light = document.documentElement.getAttribute('data-theme') === 'light';
    const lineInk = light ? 'rgba(27,42,52,.35)' : 'rgba(255,255,255,.35)';
    const lineInkSoft = light ? 'rgba(27,42,52,.25)' : 'rgba(255,255,255,.22)';
    const selInk = light ? '#26333B' : '#F6F9FC';
    // the choropleth rides UNDER the basemap's label layers: city names draw
    // over the tint at full ink instead of drowning in 55% fill (David's catch)
    const beforeId = (map.getStyle().layers.find(l => l.type === 'symbol') || {}).id;
    map.addSource('lv-states', { type:'geojson', data:STATES });
    map.addSource('lv-counties', { type:'geojson', data:{ type:'FeatureCollection', features:[] } });
    map.addLayer({ id:'lv-state-fill', type:'fill', source:'lv-states', paint:{ 'fill-color':'#4ECDC4', 'fill-opacity':0.08 }}, beforeId);
    map.addLayer({ id:'lv-county-fill', type:'fill', source:'lv-counties', paint:{ 'fill-color':'#4ECDC4', 'fill-opacity':0 }}, beforeId);
    map.addLayer({ id:'lv-county-line', type:'line', source:'lv-counties', paint:{ 'line-color':lineInkSoft, 'line-width':0.7 }}, beforeId);
    map.addLayer({ id:'lv-state-line', type:'line', source:'lv-states', paint:{ 'line-color':lineInk, 'line-width':1 }}, beforeId);
    map.addLayer({ id:'lv-state-sel', type:'line', source:'lv-states', filter:['==', ['get','abbr'], '___'], paint:{ 'line-color':selInk, 'line-width':2.4 }}, beforeId);
    map.addLayer({ id:'lv-county-sel', type:'line', source:'lv-counties', filter:['==', ['get','fips'], '___'], paint:{ 'line-color':selInk, 'line-width':2 }}, beforeId);
    // place labels: defined but SECONDARY — a muted ink + halo keeps city
    // names legible over the tint without competing with our data labels
    // (David: county names and city names were blending at equal weight)
    map.getStyle().layers.forEach(l => {
      if (l.type !== 'symbol' || !/place|city|town|village|suburb|state/.test(l.id)) return;
      try {
        map.setPaintProperty(l.id, 'text-color', light ? '#5A6B76' : '#9FB1BA');
        map.setPaintProperty(l.id, 'text-halo-color', light ? 'rgba(255,255,255,.9)' : 'rgba(8,16,20,.85)');
        map.setPaintProperty(l.id, 'text-halo-width', 1.3);
      } catch(e){}
    });
    // county name + value/population labels — visible once inside a state
    map.addSource('lv-county-labels', { type:'geojson', data:{ type:'FeatureCollection', features:[] } });
    // overlay circles (county grain) — under the text, size by quantile bucket
    map.addLayer({ id:'lv-ov-county', type:'circle', source:'lv-county-labels', minzoom:5.4,
      filter:['has','ovb'],
      paint:{ 'circle-color':'rgba(27,95,168,.32)',
        'circle-stroke-color': light ? 'rgba(13,17,23,.65)' : 'rgba(255,255,255,.85)', 'circle-stroke-width':1.4,
        'circle-radius':['interpolate',['linear'],['zoom'], 5.4, ['*',['+',['get','ovb'],1], 2.2], 9, ['*',['+',['get','ovb'],1], 4.2]] }});
    map.addLayer({ id:'lv-county-name', type:'symbol', source:'lv-county-labels', minzoom:5.4,
      layout:{ 'text-field':['format', ['get','n'], {}, '\n', {}, ['get','sub'], { 'font-scale':0.82 }],
        // bold: OUR labels carry the data, the basemap's muted places sit back
        'text-font':['Noto Sans Bold'],
        // text grows with the zoom (David's ask): small and collision-friendly
        // at state view, readable when one county fills the screen
        'text-size':['interpolate', ['linear'], ['zoom'], 5.4, 10, 7, 12.5, 9, 17, 11, 22],
        'text-max-width':8 },
      paint:{ 'text-color': light ? '#26333B' : '#F0F6F8',
        // halo carries the contrast over saturated choropleth fills — keep it heavy
        'text-halo-color': light ? 'rgba(255,255,255,.92)' : 'rgba(8,16,20,.85)', 'text-halo-width':1.8 }});
    // state VALUES at the national view (David's ask): the basemap already
    // says MONTANA, we put the number right under it; county labels take
    // the baton past z5.4
    map.addSource('lv-state-labels', { type:'geojson', data:{ type:'FeatureCollection', features:[] } });
    // overlay circles (state grain) — same bucket sizing at country zoom
    map.addLayer({ id:'lv-ov-state', type:'circle', source:'lv-state-labels', maxzoom:5.4,
      filter:['has','ovb'],
      paint:{ 'circle-color':'rgba(27,95,168,.32)',
        'circle-stroke-color': light ? 'rgba(13,17,23,.65)' : 'rgba(255,255,255,.85)', 'circle-stroke-width':1.4,
        'circle-radius':['interpolate',['linear'],['zoom'], 2.8, ['*',['+',['get','ovb'],1], 2.4], 4.6, ['*',['+',['get','ovb'],1], 3.4]] }});
    map.addLayer({ id:'lv-state-val', type:'symbol', source:'lv-state-labels', maxzoom:5.4,
      layout:{ 'text-field':['get','v'], 'text-font':['Noto Sans Bold'],
        'text-size':['interpolate', ['linear'], ['zoom'], 2.8, 10.5, 4.6, 14],
        'text-offset':[0, 0.9], 'text-anchor':'top', 'text-allow-overlap':false },
      paint:{ 'text-color': light ? '#26333B' : '#F0F6F8',
        'text-halo-color': light ? 'rgba(255,255,255,.92)' : 'rgba(8,16,20,.85)', 'text-halo-width':1.8 }});
    wireRouter();
    paintStates(); paintCounties(); paintSel();
    applyLabelPrefs();   // saved label toggles survive boot AND theme swaps
  }
  let wired = false;
  function wireRouter(){
    if (wired) return; wired = true;
    map.on('click', e => {
      const order = ['lv-county-fill','lv-state-fill'].filter(l => map.getLayer(l));
      const hits = map.queryRenderedFeatures(e.point, { layers:order });
      if (!hits.length) return;
      hits.sort((a,b) => order.indexOf(a.layer.id) - order.indexOf(b.layer.id));
      const top = hits[0];
      if (top.layer.id === 'lv-county-fill' && selState){
        if (!hasCounty()){ if (!sheetEl.classList.contains('open')) openStateCard(); return; }   // no county grain: nothing to answer
        selCounty = { fips:top.properties.fips, name:top.properties.name };
        paintSel(); openCountyCard(); syncURL(); return;
      }
      const sf = STATES.features.find(x => x.properties.abbr === top.properties.abbr || x.properties.fips === top.properties.fips);
      if (!sf) return;
      // compare mode: the NEXT state tap becomes the partner, not a new selection
      if (comparePick && selState && sf.properties.abbr !== selState.abbr){
        cmpState = { fips:sf.properties.fips, abbr:sf.properties.abbr, name:sf.properties.name, feature:sf };
        comparePick = false;
        paintSel(); openCompareCard();
        announce('Comparing ' + selState.name + ' with ' + cmpState.name + '.');
        syncURL();
        return;
      }
      selectState(sf);
    });
    ['lv-county-fill','lv-state-fill'].forEach(l => {
      map.on('mouseenter', l, () => { map.getCanvas().style.cursor = 'pointer'; });
      map.on('mouseleave', l, () => { map.getCanvas().style.cursor = ''; });
    });
    map.on('dragstart', () => { if (sheetEl.classList.contains('open') && HUKit.phone()) sheet.setDetent('dt-peek'); });
  }
  // theme swap: full deterministic reload + reinstall once truly ready
  // (same fix as the operators map — diff mode strands runtime layers)
  let themeSwapping = false;
  new MutationObserver(() => {
    if (themeSwapping) return;
    themeSwapping = true;
    map.setStyle(styleFor(), { diff:false });
    const reinstall = () => {
      if (!map.isStyleLoaded()){ setTimeout(reinstall, 120); return; }
      installLayers();
      themeSwapping = false;
      // re-theme the insets only AFTER the main map settles — three GL style
      // swaps in the same frames is the freeze the operations map taught us
      map.once('idle', () => INSETS.forEach(({ m, abbr }) => {
        m.setStyle(styleFor(), { diff:false });
        const re = () => { if (!m.isStyleLoaded()){ setTimeout(re, 120); return; } installInsetTint(m, abbr); };
        setTimeout(re, 120);
      }));
    };
    setTimeout(reinstall, 120);
  }).observe(document.documentElement, { attributes:true, attributeFilter:['data-theme'] });

  map.on('load', async () => {
    signal('Loading state lines…');
    try { STATES = await fetch('/assets/data/geo/us-states.json?v=2').then(r => r.json()); }
    catch(e){ signal("Couldn't load the boundaries"); return; }
    // county-grain values + populations ride in behind (same files the operators map uses)
    fetch('/assets/data/countyData.json').then(r => r.json()).then(d => {
      CDATA = d;
      // availability now mirrors the FILE, not a hand-kept list
      Object.keys(CDATA).forEach(l => { if (l === 'meta' || l.startsWith('_')) return; COUNTY_IDX[l] = Object.keys(CDATA[l]); });
      paintCounties();
    }).catch(() => {});
    fetch('/assets/data/us-counties.json').then(r => r.json()).then(d => { CPOP = d; refreshCountyLabels(); }).catch(() => {});
    installLayers();
    metricFace();
    yearFace();
    buildInsets();
    syncInsets();
    await applyURLState();   // old v1 links land exactly where they pointed
    lastScope = scopeKey();  // the first drill after load must PUSH, not replace
    signal('✓ Six lenses + baseline, 50+ metrics · tap a state');
    signalDone(3000);
  });
  map.on('error', ev => { if (!map.loaded()) signal('Basemap failed to load. Check the connection'); if (ev && ev.error) console.warn('maplibre', ev.error); });
})();
</script>
