<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — Healthcare Uncharted</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=IBM+Plex+Mono:wght@400;500;600&family=Syne:wght@700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/hu-global.css">
  <script>if(localStorage.getItem('hu-theme')==='light'){document.documentElement.setAttribute('data-theme','light');}</script>
</head>
<body>

<nav>
  <a class="nav-brand" href="/">
    <img src="/assets/images/Icon.png" alt="Healthcare Uncharted" class="nav-logo-img">
    <span class="nav-wordmark">Healthcare <span>Uncharted</span></span>
  </a>
  <div class="nav-links" id="navLinks">
    <a class="nav-link {% if navPage == 'home' %}active{% endif %}" href="/">Home</a>
    <a class="nav-link {% if navPage == 'tools' %}active{% endif %}" href="/tools/">Tools</a>
    <a class="nav-link {% if navPage == 'learn' %}active{% endif %}" href="/learn/">Learn</a>
    <a class="nav-link {% if navPage == 'about' %}active{% endif %}" href="/about/">About</a>
    <a class="nav-pill" href="/lab/">Map &rarr;</a>
    <button class="nav-theme-btn" id="themeToggle" aria-label="Toggle light / dark mode" title="Toggle light / dark mode">☀</button>
  </div>
  <button class="nav-ham" id="navHam" aria-label="Menu">&#9776;</button>
</nav>

{{ content | safe }}

<footer>
  <div class="footer-inner">
    <div class="footer-top">
      <div>
        <div class="footer-logo-row">
          <img src="/assets/images/logotransparency.png" alt="Healthcare Uncharted" class="footer-logo-img">
        </div>
        <div class="footer-tagline">A living resource for clinical informatics, healthcare data architecture, and the real story behind the systems that run modern medicine.<br><br>Built by David Eitel, RRT, MHA, MSRT, RRT-ACCS</div>
      </div>
      <div>
        <div class="footer-col-title">Explore</div>
        <div class="footer-nav-list">
          <a class="footer-nav-link" href="/tools/">Tools</a>
          <a class="footer-nav-link" href="/learn/">Learn</a>
          <a class="footer-nav-link" href="/lab/">Map</a>
          <a class="footer-nav-link" href="/about/">About</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-copy">&copy; 2026 Healthcare Uncharted &middot; David Eitel &middot; Educational use &mdash; not clinical advice</div>
      <div class="footer-live"><span class="live-dot"></span> Active development</div>
    </div>
    <div class="content-policy">
      <span class="cp-marker">Source Policy</span>
      <div class="cp-text">
        All vendor-specific terminology, technical specifications, and system references on this site are derived from publicly available documentation &mdash; including
        <a href="https://fhir.epic.com/" target="_blank" rel="noopener">fhir.epic.com</a>,
        <a href="https://fhir.cerner.com/" target="_blank" rel="noopener">fhir.cerner.com</a>,
        <a href="https://hl7.org/fhir/R4/" target="_blank" rel="noopener">HL7 FHIR R4</a>,
        <a href="https://www.healthit.gov/" target="_blank" rel="noopener">ONC HealthIT.gov</a>, and
        <a href="https://www.hhs.gov/" target="_blank" rel="noopener">HHS.gov</a>.
        Each factual claim is linked to its source. This site does not reproduce proprietary materials, internal vendor training content, or licensed documentation.
      </div>
    </div>
  </div>
</footer>

<script>
const ham = document.getElementById('navHam');
const navLinks = document.getElementById('navLinks');
if (ham) {
  ham.addEventListener('click', () => {
    navLinks.classList.toggle('open');
    ham.innerHTML = navLinks.classList.contains('open') ? '&#10005;' : '&#9776;';
  });
}
</script>

<script>
const themeToggle = document.getElementById('themeToggle');
function syncToggleLabel() {
  themeToggle.textContent = document.documentElement.getAttribute('data-theme') === 'light' ? '☽' : '☀';
}
syncToggleLabel();
themeToggle.addEventListener('click', () => {
  const goingLight = document.documentElement.getAttribute('data-theme') !== 'light';
  if (goingLight) {
    document.documentElement.setAttribute('data-theme', 'light');
    localStorage.setItem('hu-theme', 'light');
  } else {
    document.documentElement.removeAttribute('data-theme');
    localStorage.setItem('hu-theme', 'dark');
  }
  syncToggleLabel();
});
</script>

</body>
</html>
