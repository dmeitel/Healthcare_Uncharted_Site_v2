<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — Healthcare Uncharted</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}

  <!-- Search engines: index normally, unless the page opts out. AI scrapers: always opt out. -->
  {% if noindex %}
  <meta name="robots" content="noindex, nofollow">
  {% else %}
  <meta name="robots" content="index, follow, max-image-preview:large">
  <meta name="googlebot" content="index, follow">
  {% endif %}
  <meta name="robots" content="noai, noimageai">

  <!-- Canonical -->
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <!-- Browser chrome + PWA -->
  <meta name="theme-color" id="metaThemeColor" content="#0a0f1a">
  <link rel="manifest" href="/site.webmanifest">

  <!-- Favicon / app icons (brand kit) — scheme-aware: light art on light tabs, dark art on dark tabs -->
  <link rel="icon" href="/brand/favicon.svg" type="image/svg+xml" media="(prefers-color-scheme: light)">
  <link rel="icon" href="/brand/favicon-32.png" sizes="32x32" type="image/png" media="(prefers-color-scheme: light)">
  <link rel="icon" href="/brand/favicon-16.png" sizes="16x16" type="image/png" media="(prefers-color-scheme: light)">
  <link rel="icon" href="/brand/favicon-32-dark.png" sizes="32x32" type="image/png" media="(prefers-color-scheme: dark)">
  <link rel="icon" href="/brand/favicon-16-dark.png" sizes="16x16" type="image/png" media="(prefers-color-scheme: dark)">
  <link rel="shortcut icon" href="/favicon.ico">
  <link rel="apple-touch-icon" href="/brand/apple-touch-icon.png">

  <!-- Open Graph -->
  <meta property="og:site_name" content="Healthcare Uncharted">
  <meta property="og:title" content="{{ title }} — Healthcare Uncharted">
  <meta property="og:description" content="{{ description or site.tagline }}">
  <meta property="og:type" content="{{ og_type or 'website' }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}{{ og_image or '/brand/og-image.png' }}">

  <!-- Twitter / X Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }} — Healthcare Uncharted">
  <meta name="twitter:description" content="{{ description or site.tagline }}">
  <meta name="twitter:image" content="{{ site.url }}{{ og_image or '/brand/og-image.png' }}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="preconnect" href="https://unpkg.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=IBM+Plex+Mono:wght@400;500;600&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">
  <!-- versioned: /assets/css/* ships with stale-while-revalidate, so returning
       visitors get a CACHED copy after a deploy unless the URL changes. Bump
       the v= stamp whenever hu-global.css changes. -->
  <link rel="stylesheet" href="/assets/css/hu-global.css?v=20260719">
  <link rel="stylesheet" href="/brand/web/brand.css">

  <!-- Structured data: brand + author identity -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "{{ site.url }}/#organization",
        "name": "Healthcare Uncharted",
        "url": "{{ site.url }}",
        "logo": "{{ site.url }}/brand/hu-logo.png",
        "description": "{{ site.tagline }}",
        "founder": { "@id": "{{ site.url }}/#person" }
      },
      {
        "@type": "Person",
        "@id": "{{ site.url }}/#person",
        "name": "David Eitel",
        "url": "{{ site.url }}/about/",
        "image": "{{ site.url }}/assets/images/David_Picture.jpg",
        "jobTitle": "Senior Clinical Informatics Analyst",
        "honorificSuffix": "RRT, MHA, MSRT, RRT-ACCS",
        "worksFor": { "@type": "Organization", "name": "Intermountain Health" },
        "affiliation": { "@type": "CollegeOrUniversity", "name": "Utah Valley University" },
        "knowsAbout": ["Clinical Informatics", "Healthcare AI", "Healthcare Data Architecture", "Respiratory Care", "Workforce Policy"]
      },
      {
        "@type": "WebSite",
        "@id": "{{ site.url }}/#website",
        "url": "{{ site.url }}",
        "name": "Healthcare Uncharted",
        "publisher": { "@id": "{{ site.url }}/#organization" }
      }
    ]
  }
  </script>

  {% if section == 'rounds' or section == 'learn' or section == 'talk' %}
  <!-- Article structured data for editorial pages -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": {{ title | json | safe }},
    "description": {{ (description or summary or site.tagline) | json | safe }},
    {% if posted or date %}"datePublished": "{{ (posted or date) | dateISO }}",{% endif %}
    "url": "{{ site.url }}{{ page.url }}",
    "image": "{{ site.url }}{{ og_image or '/brand/og-image.png' }}",
    "author": { "@id": "{{ site.url }}/#person" },
    "publisher": { "@id": "{{ site.url }}/#organization" }
  }
  </script>
  {% endif %}

  {% block extraHead %}{% endblock %}
  <script>
    (function(){
      var t = localStorage.getItem('hu-theme') === 'light' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', t);
      var m = document.getElementById('metaThemeColor');
      if (m) m.setAttribute('content', t === 'light' ? '#EEF2F7' : '#0a0f1a');
    })();
  </script>
</head>
<body>

<a class="skip-to-main" href="#main-content">Skip to main content</a>

<nav>
  <a class="nav-brand" href="/" aria-label="Healthcare Uncharted — home">
    <img src="/brand/hu-logo-inline-dark.svg" alt="Healthcare Uncharted" class="hu-logo-nav hu-logo-ondark">
    <img src="/brand/hu-logo-inline.svg" alt="Healthcare Uncharted" class="hu-logo-nav hu-logo-onlight">
  </a>
  <div class="nav-links" id="navLinks">
    <a class="nav-link {% if navPage == 'home' %}active{% endif %}" href="/">Home</a>
    <a class="nav-link {% if navPage == 'tools' %}active{% endif %}" href="/tools/">Tools</a>
    <a class="nav-link {% if navPage == 'learn' %}active{% endif %}" href="/learn/">Learn</a>
    <a class="nav-link {% if navPage == 'rounds' %}active{% endif %}" href="/rounds/">Rounds</a>
    <a class="nav-link {% if navPage == 'about' %}active{% endif %}" href="/about/">About</a>
    <a class="nav-pill" href="/atlas/">Atlas &rarr;</a>
    <button class="nav-theme-btn" id="themeToggle" aria-label="Toggle light / dark mode" title="Toggle light / dark mode">☀</button>
  </div>
  <button class="nav-ham" id="navHam" aria-label="Menu">&#9776;</button>
</nav>

<main id="main-content">
{{ content | safe }}
</main>

{% if not no_footer %}<footer>
  <div class="footer-inner">
    <div class="footer-top">
      <div>
        <div class="footer-logo-row">
          <img src="/brand/hu-logo-dark.svg" alt="Healthcare Uncharted" class="hu-logo-footer hu-logo-ondark">
          <img src="/brand/hu-logo.svg" alt="Healthcare Uncharted" class="hu-logo-footer hu-logo-onlight">
        </div>
        <div class="footer-tagline">A living resource for clinical informatics, healthcare data architecture, and the real story behind the systems that run modern medicine.<br><br>Built by David Eitel, RRT, MHA, MSRT, RRT-ACCS</div>
      </div>
      <div>
        <div class="footer-col-title">Explore</div>
        <div class="footer-nav-list">
          <a class="footer-nav-link" href="/tools/">Tools</a>
          <a class="footer-nav-link" href="/learn/">Learn</a>
          <a class="footer-nav-link" href="/rounds/">Rounds</a>
          <a class="footer-nav-link" href="/atlas/">Atlas</a>
          <a class="footer-nav-link" href="/about/">About</a>
        </div>
      </div>
      <div>
        <div class="footer-col-title">Tools</div>
        <div class="footer-nav-list">
          <a class="footer-nav-link" href="/atlas/">Healthcare Atlas</a>
          <a class="footer-nav-link" href="/tools/healthcare-iceberg-map/">Iceberg Map</a>
          <a class="footer-nav-link" href="/tools/multi-lens-map/">Pop Health Multi-Lens Map</a>
          <a class="footer-nav-link" href="/tools/healthcare-vendor-directory/">Vendor Directory</a>
          <a class="footer-nav-link" href="/tools/clinical-sql-mystery/">Clinical SQL Mystery</a>
        </div>
      </div>
    </div>
    <div class="footer-subscribe">
      <div class="footer-col-title">Field Notes</div>
      <p class="fs-sub">New tools, new data, no noise. When something ships, you hear about it.</p>
      <form name="field-notes" method="POST" action="/thanks/" data-netlify="true" netlify-honeypot="bot-field" class="fs-form">
        <input type="hidden" name="form-name" value="field-notes">
        <p class="fs-hp" aria-hidden="true"><label>Skip this field: <input name="bot-field"></label></p>
        <label class="fs-label" for="fsEmail">Email</label>
        <div class="fs-row">
          <input class="fs-input" id="fsEmail" type="email" name="email" required autocomplete="email" placeholder="you@hospital.org">
          <button class="fs-btn" type="submit">Sign up</button>
        </div>
      </form>
    </div>
    <div class="footer-bottom">
      <div class="footer-copy">&copy; 2026 Healthcare Uncharted &middot; David Eitel &middot; Educational use &mdash; not clinical advice</div>
    </div>
    <div class="content-policy">
      <span class="cp-marker">Source Policy</span>
      <div class="cp-text">
        All vendor-specific terminology, technical specifications, and system references on this site are derived from publicly available documentation &mdash; including
        <a href="https://fhir.epic.com/" target="_blank" rel="noopener">fhir.epic.com</a>,
        <a href="https://fhir.cerner.com/" target="_blank" rel="noopener">fhir.cerner.com</a>,
        <a href="https://hl7.org/fhir/R4/" target="_blank" rel="noopener">HL7 FHIR R4</a>,
        <a href="https://www.healthit.gov/" target="_blank" rel="noopener">ONC HealthIT.gov</a>, and
        <a href="https://www.hhs.gov/" target="_blank" rel="noopener">HHS.gov</a>.
        Each factual claim is linked to its source. This site does not reproduce proprietary materials, internal vendor training content, or licensed documentation.
      </div>
    </div>
  </div>
</footer>{% endif %}

<script>
const ham = document.getElementById('navHam');
const navLinks = document.getElementById('navLinks');
if (ham) {
  ham.addEventListener('click', () => {
    navLinks.classList.toggle('open');
    ham.innerHTML = navLinks.classList.contains('open') ? '&#10005;' : '&#9776;';
  });
}
</script>

<script>
const themeToggle = document.getElementById('themeToggle');
function syncToggleLabel() {
  themeToggle.textContent = document.documentElement.getAttribute('data-theme') === 'light' ? '☽' : '☀';
}
syncToggleLabel();
themeToggle.addEventListener('click', () => {
  const next = document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('hu-theme', next);
  const m = document.getElementById('metaThemeColor');
  if (m) m.setAttribute('content', next === 'light' ? '#EEF2F7' : '#0a0f1a');
  syncToggleLabel();
});
</script>

<script src="https://unpkg.com/lucide@0.454.0/dist/umd/lucide.min.js"></script>
<script>lucide.createIcons();</script>

{% if site.goatcounter %}
<script data-goatcounter="https://{{ site.goatcounter }}.goatcounter.com/count" async src="https://gc.zgo.at/count.js"></script>
{% endif %}
</body>
</html>
