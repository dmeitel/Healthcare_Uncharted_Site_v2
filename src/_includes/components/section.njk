{% macro sectionHeader(eyebrow, title, intro) %}
<div class="section-header-v2">
  {% if eyebrow %}
  <div class="eyebrow">
    <div class="eyebrow-line"></div>
    <span>{{ eyebrow }}</span>
  </div>
  {% endif %}
  {% if title %}
  <h2 class="section-h-v2">{{ title }}</h2>
  <div class="section-accent-v2"></div>
  {% endif %}
  {% if intro %}
  <p class="section-intro">{{ intro }}</p>
  {% endif %}
</div>
{% endmacro %}
