{% macro pageHero(eyebrow, title, sub, actions) %}
<div class="page-hero">
  <div class="page-hero-inner">
    {% if eyebrow %}
    <div class="eyebrow">
      <div class="eyebrow-line"></div>
      <span>{{ eyebrow }}</span>
    </div>
    {% endif %}
    <h1 class="page-title-v2">{{ title }}</h1>
    {% if sub %}
    <p class="page-sub-v2">{{ sub }}</p>
    {% endif %}
    {% if actions %}
    <div class="page-hero-actions">
      {% for action in actions %}
      <a href="{{ action.url }}" class="{{ 'btn-primary-v2' if action.primary else 'btn-ghost-v2' }}">{{ action.label }}</a>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</div>
{% endmacro %}
