{% macro compassRose(cssClass) %}
<svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="compass-rose-brand{{ ' ' + cssClass if cssClass }}" aria-hidden="true">
  <circle cx="100" cy="100" r="90" stroke="currentColor" stroke-width="1"/>
  <circle cx="100" cy="100" r="70" stroke="currentColor" stroke-width="0.75" stroke-opacity="0.7"/>
  <circle cx="100" cy="100" r="45" stroke="currentColor" stroke-width="0.75" stroke-opacity="0.5"/>
  <circle cx="100" cy="100" r="20" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.4"/>
  <!-- Cardinal axes -->
  <line x1="100" y1="10" x2="100" y2="190" stroke="currentColor" stroke-width="1"/>
  <line x1="10" y1="100" x2="190" y2="100" stroke="currentColor" stroke-width="1"/>
  <!-- Intercardinal axes -->
  <line x1="36" y1="36" x2="164" y2="164" stroke="currentColor" stroke-width="0.75" stroke-opacity="0.7"/>
  <line x1="164" y1="36" x2="36" y2="164" stroke="currentColor" stroke-width="0.75" stroke-opacity="0.7"/>
  <!-- Eighth-mark axes -->
  <line x1="100" y1="10" x2="190" y2="100" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.4"/>
  <line x1="190" y1="100" x2="100" y2="190" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.4"/>
  <line x1="100" y1="190" x2="10" y2="100" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.4"/>
  <line x1="10" y1="100" x2="100" y2="10" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.4"/>
  <!-- Cardinal darts -->
  <polygon points="100,10 94,50 100,40 106,50" fill="currentColor"/>
  <polygon points="100,190 94,150 100,160 106,150" fill="currentColor" fill-opacity="0.5"/>
  <polygon points="190,100 150,94 160,100 150,106" fill="currentColor" fill-opacity="0.5"/>
  <polygon points="10,100 50,94 40,100 50,106" fill="currentColor" fill-opacity="0.5"/>
  <circle cx="100" cy="100" r="4" fill="currentColor"/>
</svg>
{% endmacro %}
