{# Compact attribution strip for interactive tools.
   Usage:
     {% set ta_fixed = true %}          — optional, floats bottom-right
     {% set ta_source = 'CMS Provider Data · 2024' %}  — optional source line
     {% set ta_source_href = '/learn/healthcare-data-sources/' %} — optional link target
     {% include "components/tool-attribution.njk" %}
#}
<div class="tool-attribution{% if ta_fixed %} tool-attribution--fixed{% endif %}">
  <span class="ta-brand">Healthcare <span>Uncharted</span></span>
  <span class="ta-sep">&middot;</span>
  <span>Educational use, not clinical advice</span>
  {% if ta_source %}
  <span class="ta-sep">&middot;</span>
  {% if ta_source_href %}<a href="{{ ta_source_href }}">{{ ta_source }}</a>{% else %}<span>{{ ta_source }}</span>{% endif %}
  {% endif %}
</div>
