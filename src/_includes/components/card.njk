{% macro card(type, title, summary, url, tags, date, read_time, motif) %}
{% set typeColors = {
  "interactive": "#4ECDC4",
  "learn":       "#6aabff",
  "talk":        "#5DBF87",
  "lab":         "#E8A838",
  "reference":   "#a99ee8",
  "rounds":      "#7B92AB"
} %}
{% set typeBadges = {
  "interactive": "Tool",
  "learn":       "Learn",
  "talk":        "Talk",
  "lab":         "Lab",
  "reference":   "Reference",
  "rounds":      "Rounds"
} %}
{% set typeColor = typeColors[type] or "#4ECDC4" %}
{% set badgeText = typeBadges[type] or type %}

<a href="{{ url }}" class="card card--{{ type }}" style="--type-color: {{ typeColor }}">
  <div class="card-bg">
    {% if motif == "compass-rose" %}{% include "motifs/compass-rose.njk" %}
    {% elif motif == "network" %}{% include "motifs/network.njk" %}
    {% elif motif == "ecg" %}{% include "motifs/ecg.njk" %}
    {% elif motif == "radiating" %}{% include "motifs/radiating.njk" %}
    {% elif motif == "oscilloscope" %}{% include "motifs/oscilloscope.njk" %}
    {% elif motif == "newsprint" %}{% include "motifs/newsprint.njk" %}
    {% elif type == "interactive" %}{% include "motifs/network.njk" %}
    {% elif type == "learn" %}{% include "motifs/radiating.njk" %}
    {% elif type == "talk" %}{% include "motifs/oscilloscope.njk" %}
    {% elif type == "lab" %}{% include "motifs/ecg.njk" %}
    {% elif type == "reference" %}{% include "motifs/network.njk" %}
    {% elif type == "rounds" %}{% include "motifs/newsprint.njk" %}
    {% endif %}
  </div>
  <div class="card-content">
    <div class="card-badge">{{ badgeText }}</div>
    <div class="card-mark">
      {% if type == "interactive" %}
        <i data-lucide="sliders-horizontal" width="18" height="18" aria-hidden="true"></i>
      {% elif type == "learn" %}
        <i data-lucide="book-open" width="18" height="18" aria-hidden="true"></i>
      {% elif type == "talk" %}
        <i data-lucide="mic" width="18" height="18" aria-hidden="true"></i>
      {% elif type == "lab" %}
        <i data-lucide="flask-conical" width="18" height="18" aria-hidden="true"></i>
      {% elif type == "reference" %}
        <i data-lucide="bookmark" width="18" height="18" aria-hidden="true"></i>
      {% elif type == "rounds" %}
        <i data-lucide="clipboard-list" width="18" height="18" aria-hidden="true"></i>
      {% endif %}
    </div>
    <h3 class="card-title">{{ title }}</h3>
    {% if type == "rounds" and (date or read_time) %}
    <p class="card-meta">{{ date | dateFilter }}{% if read_time %} · {{ read_time }} min read{% endif %}</p>
    {% endif %}
    <p class="card-desc">{{ summary }}</p>
    {% if tags and tags.length %}
    <div class="card-tags">
      {% for tag in tags %}<span class="tag">{{ tag }}</span>{% endfor %}
    </div>
    {% endif %}
    <div class="card-arrow">
      <i data-lucide="chevron-right" width="16" height="16" aria-hidden="true"></i>
    </div>
  </div>
</a>
{% endmacro %}
