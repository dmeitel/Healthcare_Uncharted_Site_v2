<script>
(function(){
'use strict';

// ── HEX GEOMETRY — single global pointy-top grid ──────────────────────────────
// Hub at (0,0). Zones ring the hub clockwise: MedSci N, Provider NE, Patient SE,
// PubHealth S, HealthTech SW, Policy W, Payer NW. Ring-1 moat is genuinely empty.
const s   = 40;
const sq3 = Math.sqrt(3);
const OX  = 1100, OY = 950;   // pixel origin = MedSci center

function hPx(q, r) {
  return [OX + sq3*s*q + sq3*s/2*r,  OY + 1.5*s*r];
}
function hPath(cx, cy, r) {
  r = r || s;
  let d = '';
  for (let i = 0; i < 6; i++) {
    const a = Math.PI/3*i - Math.PI/2;
    d += (i===0?'M':'L') + (cx + r*Math.cos(a)).toFixed(1) + ',' + (cy + r*Math.sin(a)).toFixed(1);
  }
  return d + 'Z';
}

// ── ZONE DATA ──────────────────────────────────────────────────────────────────
// displayLabel: short name rendered on overview map (Foxhole-style territory name)
