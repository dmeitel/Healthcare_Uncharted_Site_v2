// ── HUD RESIZE ────────────────────────────────────────────────────────────────
{
  const hudEl = document.getElementById('atlas-hud');
  const grip  = document.getElementById('hud-grip');
  const MIN_H = 64, MAX_H = 420;

  function startResize(e) {
    e.preventDefault(); e.stopPropagation();
    const isTouch = !!e.touches;
    const startY  = isTouch ? e.touches[0].clientY : e.clientY;
    const startH  = hudEl.offsetHeight;

    function onMove(ev) {
      const y = ev.touches ? ev.touches[0].clientY : ev.clientY;
      const newH = Math.max(MIN_H, Math.min(MAX_H, startH + (startY - y)));
      hudEl.style.height = newH + 'px';
    }
    function onEnd() {
      document.removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseup',   onEnd);
      document.removeEventListener('touchmove', onMove);
      document.removeEventListener('touchend',  onEnd);
    }
    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup',   onEnd);
    document.addEventListener('touchmove', onMove, {passive:false});
    document.addEventListener('touchend',  onEnd);
  }

  grip.addEventListener('mousedown',  startResize);
  grip.addEventListener('touchstart', startResize, {passive:false});
}

// ── LAYERS PANEL — toggles + legend behind one trigger (Control Architecture v2)
// Popover contract per the Operators Map reference: one open at a time, Esc
// closes and refocuses the trigger, outside click closes, arrows walk options.
let openPop=null;
function closePop(refocus){
  if(!openPop) return;
  const p=openPop; openPop=null;
  p.pop.hidden=true; p.btn.setAttribute('aria-expanded','false');
  if(refocus) p.btn.focus();
}
function openPopover(btn,pop,build){
  if(openPop&&openPop.pop===pop){ closePop(true); return; }
  closePop(false);
  build();
  pop.hidden=false; btn.setAttribute('aria-expanded','true');
  // desktop anchor: under the toolbar, left-aligned to the trigger; the phone
  // sheet CSS (hu-global, <700px) overrides both with !important
  const tb=document.getElementById('atlas-tb');
  pop.style.left=btn.offsetLeft+'px';
  pop.style.top=(tb.offsetTop+tb.offsetHeight+6)+'px';
  // right-edge clamp: the popover must never overflow the shell
  const host=pop.offsetParent;
  if(host){ const max=host.clientWidth-pop.offsetWidth-8; if(max>0&&btn.offsetLeft>max) pop.style.left=max+'px'; }
  openPop={pop,btn};
  const f=pop.querySelector('.pop-opt');
  if(f) f.focus();
}
document.addEventListener('click',e=>{ if(openPop&&!e.target.closest('.selector-pop')&&!e.target.closest('.selector')) closePop(false); });
document.addEventListener('keydown',e=>{ if(e.key==='Escape'&&openPop) closePop(true); });
const layersBtn=document.getElementById('atlas-layers-btn');
const layersPop=document.getElementById('atlas-layers-pop');
layersPop.addEventListener('keydown',e=>{
  const opts=[...layersPop.querySelectorAll('.pop-opt')], i=opts.indexOf(document.activeElement);
  if(!opts.length) return;
  if(e.key==='ArrowDown'){e.preventDefault();(opts[i+1]||opts[0]).focus();}
  else if(e.key==='ArrowUp'){e.preventDefault();(opts[i-1]||opts[opts.length-1]).focus();}
  else if(e.key==='Home'){e.preventDefault();opts[0].focus();}
  else if(e.key==='End'){e.preventDefault();opts[opts.length-1].focus();}
});
layersPop.querySelector('[data-close]').addEventListener('click',()=>closePop(true));
layersBtn.addEventListener('click',()=>openPopover(layersBtn,layersPop,syncLayersPop));

// one polite live region for the tool — announce COMMITTED layer/legend
// changes only, never hover
function announce(msg){
  const el=document.getElementById('a11yLive'); if(!el) return;
  el.textContent='';                                  // clear first so repeats re-announce
  requestAnimationFrame(()=>{el.textContent=msg;});
}

const anyExpanded=()=>expandedSet.size>0;
function setOpt(id,on){ const b=document.getElementById(id); if(b) b.setAttribute('aria-pressed',on?'true':'false'); }
// faces sync from live state on every open — expansion state can change from
// the map itself (landmark clicks) between opens
function syncLayersPop(){
  setOpt('af-labels',zoneLabelsOn); setOpt('af-routes',routesOn);
  setOpt('af-expand-all',anyExpanded()); setOpt('af-tools',toolNodesOn);
}

function setZoneLabels(on){
  zoneLabelsOn=on; setOpt('af-labels',on);
  updateLOD(d3.zoomTransform(svgEl).k);
  renderAppliedStrip(); announce('Zone labels '+(on?'on':'off'));
}
function setRoutes(on){
  routesOn=on; setOpt('af-routes',on);
  updateLOD(d3.zoomTransform(svgEl).k);
  renderAppliedStrip(); announce('Routes '+(on?'on':'off'));
}
function setExpandAll(open){
  const allIds=Object.keys(EXPANSION_REGISTRY);
  if(open) allIds.forEach(expandExpansion);
  else allIds.filter(id=>expandedSet.has(id)).forEach(collapseExpansion);
  setOpt('af-expand-all',anyExpanded());
  renderAppliedStrip(); announce(open?'All landmark nodes expanded':'All landmark nodes collapsed');
}
let toolNodesOn=false;
function setToolNodes(on){
  toolNodesOn=on; setOpt('af-tools',on);
  d3.selectAll('.az-node-cell').each(function(){
    const el=d3.select(this), zid=el.attr('data-zoneid'), nid=el.attr('data-nodeid');
    const z2=ZONE_DEFS.find(z=>z.id===zid), c2=z2&&z2.cells.find(c=>c.nodeId===nid);
    const isLM=c2&&c2.type==='landmark';
    const hasLinks=c2&&c2.links&&c2.links.length>0;
    if (toolNodesOn) {
      if (hasLinks) el.select('.hex-body').attr('fill-opacity',isLM?0.38:0.26).attr('stroke-opacity',isLM?0.95:0.72);
      else el.select('.hex-body').attr('fill-opacity',0.02).attr('stroke-opacity',0.08);
    } else {
      el.select('.hex-body').attr('fill-opacity',isLM?0.18:0.08).attr('stroke-opacity',isLM?0.78:0.32);
    }
  });
  renderAppliedStrip(); announce(on?'Tool nodes highlighted':'Tool node highlight off');
}
document.getElementById('af-labels').addEventListener('click',()=>setZoneLabels(!zoneLabelsOn));
document.getElementById('af-routes').addEventListener('click',()=>setRoutes(!routesOn));
document.getElementById('af-expand-all').addEventListener('click',()=>setExpandAll(!anyExpanded()));
document.getElementById('af-tools').addEventListener('click',()=>setToolNodes(!toolNodesOn));

// applied strip: once the panel closes, non-default layer/legend state is
// invisible — surface it as removable chips. Everything at defaults = no strip.
function renderAppliedStrip(){
  const s=document.getElementById('atlas-applied'); if(!s) return;
  const chips=[];
  if(!zoneLabelsOn) chips.push('<span class="applied-chip">Zone labels: <b>off</b><button class="ac-x" data-clear="labels" aria-label="Turn zone labels back on">&#10005;</button></span>');
  if(!routesOn) chips.push('<span class="applied-chip">Routes: <b>off</b><button class="ac-x" data-clear="routes" aria-label="Turn routes back on">&#10005;</button></span>');
  if(expandedSet.size) chips.push('<span class="applied-chip">Expanded: <b>'+expandedSet.size+(expandedSet.size===1?' node':' nodes')+'</b><button class="ac-x" data-clear="expand" aria-label="Collapse all expanded nodes">&#10005;</button></span>');
  if(toolNodesOn) chips.push('<span class="applied-chip">Tool nodes: <b>on</b><button class="ac-x" data-clear="tools" aria-label="Turn off the tool node highlight">&#10005;</button></span>');
  document.querySelectorAll('#atlas-layers-pop .pop-opt[data-type][aria-pressed="true"]').forEach(b=>{
    const lbl=b.textContent.trim();
    chips.push('<span class="applied-chip">Highlight: <b>'+lbl+'</b><button class="ac-x" data-clear="conn:'+b.dataset.type+'" aria-label="Stop highlighting '+lbl.toLowerCase()+' routes">&#10005;</button></span>');
  });
  s.innerHTML=chips.join('');
  s.hidden=!chips.length;
}
document.getElementById('atlas-applied').addEventListener('click',e=>{
  const x=e.target.closest('[data-clear]'); if(!x) return;
  const k=x.dataset.clear;
  if(k==='labels') setZoneLabels(true);
  else if(k==='routes') setRoutes(true);
  else if(k==='expand') setExpandAll(false);
  else if(k==='tools') setToolNodes(false);
  else if(k.indexOf('conn:')===0){
    const b=document.querySelector('#atlas-layers-pop .pop-opt[data-type="'+k.slice(5)+'"]');
    if(b&&b.getAttribute('aria-pressed')==='true') b.click();   // reuse the toggle path
  }
});

document.getElementById('conn-panel-close').addEventListener('click', () => {
  document.getElementById('atlas-conn').classList.remove('open');
});

// ── MOBILE: one-time desktop hint ─────────────────────────────────────────────
// The layers panel needs no per-viewport JS — the .selector-pop primitive
// renders as a bottom sheet under 700px on its own.
{
  const mq = window.matchMedia('(max-width: 768px)');
  const strip = document.getElementById('atlas-desk-hint');
