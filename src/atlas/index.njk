// ── AUTO-FILL TERRAIN ─────────────────────────────────────────────────────────
// Scan every hex within ring 9. Any unoccupied hex gets assigned as terrain to
// the nearest zone (by pixel distance to zone centroid). Eliminates all gaps.
(function autoFill() {
  const MAX_R = 9;
  const occupied = new Set();
  ZONE_DEFS.forEach(z => z.cells.forEach(c => occupied.add(`${c.q},${c.r}`)));

  const centroids = ZONE_DEFS.map(z => {
    const n = z.cells.filter(c => c.type !== 'terrain');
    const ql = n.reduce((s,c)=>s+c.q,0)/n.length;
    const rl = n.reduce((s,c)=>s+c.r,0)/n.length;
    const [cx,cy] = hPx(ql,rl);
    return {zone:z, cx, cy};
  });

  function hd(q,r){ return (Math.abs(q)+Math.abs(r)+Math.abs(q+r))/2; }

  for (let q=-MAX_R; q<=MAX_R; q++) {
    for (let r=-MAX_R; r<=MAX_R; r++) {
      const d = hd(q,r);
      if (d < 2 || d > MAX_R) continue;
      const key = `${q},${r}`;
      if (occupied.has(key)) continue;
      const [px,py] = hPx(q,r);
      let best=centroids[0], bestD=Infinity;
      centroids.forEach(c => {
        const dist = (px-c.cx)**2 + (py-c.cy)**2;
        if (dist < bestD) { bestD=dist; best=c; }
      });
      best.zone.cells.push({q,r,type:'terrain',label:'',nodeId:null,desc:''});
      occupied.add(key);
    }
  }
})();

// ── GRID MAP ─────────────────────────────────────────────────────────────────
// Single source of truth for every occupied hex. Built after autoFill so it
// includes both hand-placed cells and auto-filled terrain. Used by expansion
// system and route pathfinder to verify positions before placing anything.
const GRID_MAP = new Map();
ZONE_DEFS.forEach(zone => {
  zone.cells.forEach(cell => {
    GRID_MAP.set(`${cell.q},${cell.r}`, {zoneId: zone.id, nodeId: cell.nodeId, type: cell.type});
  });
});
// Reverse index: nodeId → original {q,r}. Used so multi-expansion push deltas can
// be computed against the SVG base position (where the path was drawn) rather than
// the cell's intermediate position from a prior expansion's displacement.
const NODE_ORIGIN = new Map();
GRID_MAP.forEach((v, k) => {
  if (v.nodeId) {
    const [q, r] = k.split(',').map(Number);
    NODE_ORIGIN.set(v.nodeId, {q, r});
  }
});
function gridGet(q, r)      { return GRID_MAP.get(`${q},${r}`); }
function gridOccupied(q, r) { return GRID_MAP.has(`${q},${r}`); }

// ── ANCHOR LATTICE (fixed blank waypoint tiles) ──────────────────────────────
// Six 60-degree corners of rings 4 and 8, each snapped to the nearest BLANK cell
// so an anchor never sits on a content tile. These are LOCKED: the expansion engine
// never places a sub on, nor displaces a cell onto, an anchor (ANCHOR_KEYS guards
// every placement path), so anchors stay blank. Connection routes hop through them.
const ANCHOR_RINGS = [4, 8];
const ANCHOR_DIRS = [[1,0],[0,1],[-1,1],[-1,0],[0,-1],[1,-1]];
const ANCHOR_LIST = [];
const ANCHOR_KEYS = [];
(function buildAnchors() {
  const seen = new Set();
  const nearestBlank = (px) => {
    let best = null, bd = Infinity;
    GRID_MAP.forEach((v, key) => {
      if (v.type !== 'terrain') return;
      const [q, r] = key.split(',').map(Number);
      const d = (hPx(q, r)[0] - px[0]) ** 2 + (hPx(q, r)[1] - px[1]) ** 2;
      if (d < bd) { bd = d; best = { q, r }; }
    });
    return best;
  };
  ANCHOR_RINGS.forEach(dd => ANCHOR_DIRS.forEach(dir => {
    const c = nearestBlank(hPx(dir[0] * dd, dir[1] * dd));
    if (!c) return; const k = c.q + ',' + c.r;
    if (seen.has(k)) return; seen.add(k);
    ANCHOR_LIST.push({ q: c.q, r: c.r, px: hPx(c.q, c.r), ring: dd });
    ANCHOR_KEYS.push(k);
  }));
})();

// The central moat ring (d=1) also serves as INNER anchors, so links can route
// AROUND the hub through the empty centre instead of looping far out. The moat
// hexes aren't normally in the grid, so add them as blank cells (the router can
// then traverse the ring), plus the hub as an impassable cell. Both stay locked
// for expansion (they're already in MOAT_KEYS). edgeCost bars any hub-touching
// edge, so routes hug the moat ring but never cross the centre.
[[1,0],[-1,0],[0,1],[0,-1],[1,-1],[-1,1]].forEach(([q, r]) => {
  const k = q + ',' + r;
  if (!GRID_MAP.has(k)) GRID_MAP.set(k, { zoneId: null, nodeId: null, type: 'terrain' });
  if (!ANCHOR_KEYS.includes(k)) { ANCHOR_LIST.push({ q, r, px: hPx(q, r), ring: 1 }); ANCHOR_KEYS.push(k); }
});
if (!GRID_MAP.has('0,0')) GRID_MAP.set('0,0', { zoneId: null, nodeId: null, type: 'hub' });

// ── COMPUTE PIXEL POSITIONS ───────────────────────────────────────────────────
ZONE_DEFS.forEach(zone => {
  zone.cells.forEach(cell => {
    const [wx,wy] = hPx(cell.q, cell.r);
    cell.wx = wx; cell.wy = wy;
  });
  const nc = zone.cells.filter(c=>c.type!=='terrain');
  zone.cx = nc.reduce((a,c)=>a+c.wx,0)/nc.length;
  zone.cy = nc.reduce((a,c)=>a+c.wy,0)/nc.length;
  zone.topY = Math.min(...nc.map(c=>c.wy));
});

