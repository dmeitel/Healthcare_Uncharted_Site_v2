// ── FRONTIER HEXES (unified map silhouette) ───────────────────────────────────
// Expand all zone cells outward 2 rings. Ring 1 fills inter-zone gaps and creates
// the inner border; Ring 2 creates a fading outer edge so the map reads as one shape.
{
  const ND = [[1,0],[-1,0],[0,1],[0,-1],[1,-1],[-1,1]];
  const zSet = new Set();
  ZONE_DEFS.forEach(z => z.cells.forEach(c => zSet.add(`${c.q},${c.r}`)));

  const ring1 = new Set();
  zSet.forEach(key => {
    const [q,r] = key.split(',').map(Number);
    ND.forEach(([dq,dr]) => {
      const nk = `${q+dq},${r+dr}`;
      if (!zSet.has(nk)) ring1.add(nk);
    });
  });

  const ring2 = new Set();
  ring1.forEach(key => {
    const [q,r] = key.split(',').map(Number);
    ND.forEach(([dq,dr]) => {
      const nk = `${q+dq},${r+dr}`;
      if (!zSet.has(nk) && !ring1.has(nk)) ring2.add(nk);
    });
  });

  const ftG = g.append('g').attr('id','frontier-g').attr('pointer-events','none');
  ring2.forEach(key => {
    const [q,r] = key.split(',').map(Number);
    const [fx,fy] = hPx(q,r);
    ftG.append('path').attr('d',hPath(fx,fy,s-2))
      .attr('fill','#060e07').attr('fill-opacity',0.30)
      .attr('stroke','rgba(78,205,196,0.04)').attr('stroke-width',0.4);
  });
  ring1.forEach(key => {
    const [q,r] = key.split(',').map(Number);
    const [fx,fy] = hPx(q,r);
    ftG.append('path').attr('d',hPath(fx,fy,s-2))
      .attr('fill','#08130a').attr('fill-opacity',0.50)
      .attr('stroke','rgba(78,205,196,0.07)').attr('stroke-width',0.5);
  });
}

// ── CONNECTION ROUTES ─────────────────────────────────────────────────────────
// True vertex-graph routing: routes travel vertex-to-vertex along hex edges,
// exactly like Catan roads — they hug hex corners, never cross cell interiors.
// A* on the vertex graph prefers zone-boundary edges (cost 0.7) over interior
// edges (1.8) and penalises the moat (5). Routes re-draw when hexes move.
{
  const ZONE_LM = {
    medsci:'pathophys', provider:'informatics', patient:'access',
    pubhealth:'pop-health', techeco:'vendor-dir', policy:'fed-law', payer:'medicare',
  };

  // Pixel position of vertex vi (0-5, clockwise from upper-right) of hex (q,r).
  // Routes are anchored to the STATIC hex grid — they never follow displaced cells.
  // Cells move on top of the grid during expansion; routes stay on the grid and
  // re-route around the expansion cluster (see routeBlocked / edgeCost). This is
  // what keeps every route segment a true hex edge instead of a diagonal cut.
  // vi=0 upper-right, 1 top, 2 upper-left, 3 lower-left, 4 bottom, 5 lower-right
  function hexVtx(q, r, vi) {
    const [cx,cy] = hPx(q,r);
    const rad = -(30 + 60*vi) * Math.PI / 180;
    return [cx + s*Math.cos(rad), cy + s*Math.sin(rad)];
  }

  // Hexes currently occupied by an active expansion (sub-nodes + displaced cells).
  // Routes treat these as expensive so they detour around the expansion footprint.
  const routeBlocked = new Set();
  function rebuildRouteBlocked() {
    routeBlocked.clear();
    expandedSet.forEach(id => {
      const reg = EXPANSION_REGISTRY[id];
      if (!reg) return;
      if (reg.subTargets) reg.subTargets.forEach(({q, r}) => routeBlocked.add(`${q},${r}`));
      if (reg.lastDisplacements) reg.lastDisplacements.forEach(({toQ, toR}) => routeBlocked.add(`${toQ},${toR}`));
    });
  }

  // Stable integer key for a vertex pixel position
  function vk(vx, vy) { return `${Math.round(vx)},${Math.round(vy)}`; }

  // Build vertex→hexes map from all grid cells (static grid positions only)
  // Each entry: vertex_key → [{q,r,vi}] listing which hex+vertex-index share that point
  const vtxMap = new Map();
  GRID_MAP.forEach((_, ck) => {
    const [q,r] = ck.split(',').map(Number);
    for (let vi=0; vi<6; vi++) {
      const [vx,vy] = hexVtx(q,r,vi,false);
      const k = vk(vx,vy);
      if (!vtxMap.has(k)) vtxMap.set(k,[]);
      vtxMap.get(k).push({q,r,vi});
    }
  });

  // All vertex-graph neighbours of vertex key vk0
  // Returns Map<neighbour_key, canonical {q,r,vi} for that neighbour>
  function vtxNeighbours(vk0) {
    const out = new Map();
    for (const {q,r,vi} of (vtxMap.get(vk0)||[])) {
      for (const dv of [1,5]) {
        const nvi = (vi+dv)%6;
        const [nx,ny] = hexVtx(q,r,nvi,false);
        const nk = vk(nx,ny);
        if (nk !== vk0 && !out.has(nk)) out.set(nk, {q,r,vi:nvi});
      }
    }
    return out;
  }

  function hexD(q1,r1,q2,r2) {
    return (Math.abs(q1-q2)+Math.abs(r1-r2)+Math.abs((q1+r1)-(q2+r2)))/2;
  }

  // Edge traversal cost between adjacent vertex keys vka, vkb. Zone-BOUNDARY edges
  // (the line between two different zones) and the outer map perimeter are the
  // cheap "roads" (1.0); cutting through a zone INTERIOR is dearer (1.6), so A*
  // hugs the borders and only dips inside near the endpoints to reach a landmark.
  // Off-grid vertices cost more so routes do not wander past the map edge. The d=2
  // ring just outside the moat carries a small surcharge so the cross-hub routes
  // spread across it instead of all piling onto the same moat-edge vertices. The
  // hub stays a hard barrier, but the moat ring is now passable so links can route
  // around the hub through it. Min cost stays 1.0 so the heuristic stays admissible.
  function edgeCost(vka, vkb) {
    const ha = vtxMap.get(vka)||[], hb = vtxMap.get(vkb)||[];
    const shared = ha.filter(a => hb.some(b => b.q===a.q && b.r===a.r));
    // Hub is an impassable barrier (never cross the centre); the moat RING is now
    // passable so links route around the hub through it. Use the closest ring among
    // the shared hexes: d=0 touches the hub, d=1 is the moat ring.
    let minD = Infinity;
    for (const {q,r} of shared) { const d = hexD(q,r,0,0); if (d < minD) minD = d; }
    if (minD === 0) return 80;   // hub-touching edge: hard barrier (never cross the centre)
    // Per-hex penalties + anchor detection.
    let pen = 0, onAnchor = false;
    for (const {q,r} of shared) {
      const k = `${q},${r}`;
      if (routeBlocked.has(k)) pen += 14;
      if (ANCHOR_KEYS.includes(k)) onAnchor = true;
    }
    // Anchor highway: edges touching a fixed anchor (the moat ring included) are
    // cheap, so one continuous A* threads through the lattice and around the hub
    // instead of stitching independent legs (which kinked and backtracked).
    if (onAnchor) return 0.5 + pen;
    if (minD === 1) return 1.6 + pen;            // moat ring (non-anchor) — passable
    for (const {q,r} of shared) if (hexD(q,r,0,0) === 2) pen += 1.0;   // de-congest the d=2 ring
    let base;
    if (shared.length === 0) base = 2.0;         // off-grid: discourage wandering off the map
    else if (shared.length === 1) base = 1.0;    // map-edge perimeter (clean coastline road)
    else { const zones = [...new Set(shared.map(h=>(GRID_MAP.get(`${h.q},${h.r}`)||{}).zoneId).filter(Boolean))]; base = (zones.length > 1 ? 1.0 : 1.6); } // boundary road vs interior cut
    return base + pen;
  }

  // Edge direction bucket (0-5, hex edges are 60 deg apart) from vertex key a to b.
  function edgeDir(aK, bK) {
    const a = aK.split(',').map(Number), b = bK.split(',').map(Number);
    return Math.round(Math.atan2(b[1] - a[1], b[0] - a[0]) / (Math.PI / 3));
  }
  // Small penalty for changing direction. Hex zone borders are themselves a
  // stair-step, so without this a border-hugging route zig-zags every edge. This
  // makes A* prefer long straight runs and turn only when it must, for a cleaner,
  // more road-like line. Kept below the interior surcharge so borders still win.
  function turnPen(prevK, curK, nextK) {
    if (prevK == null) return 0;
    return edgeDir(prevK, curK) === edgeDir(curK, nextK) ? 0 : 0.25;
  }

  // Vertex-graph A*. Multi-source / multi-target: A* may leave from any of the
  // start landmark's six vertices and TERMINATES at the first vertex of the end
  // landmark it reaches — so the route connects at whatever corner the most
  // direct path naturally arrives at, not a pre-chosen one. Returns the canonical
  // [{q,r,vi}] tuple sequence, or null.
  function vtxAstar(startQ, startR, endQ, endR) {
    const [ecx,ecy] = hPx(endQ,endR);
    // Heuristic: hex-steps to the end landmark, scaled by the MIN edge cost (0.5,
    // the anchor-highway rate) so it never overestimates and A* stays optimal.
    const h = (vx,vy) => Math.max(0, Math.hypot(vx-ecx, vy-ecy) - s) / s * 0.5;
    const endKeys = new Set();
    for (let vi=0;vi<6;vi++) {
      const [vx,vy]=hexVtx(endQ,endR,vi);
      endKeys.add(vk(vx,vy));
    }
    const open=new Map(), gScore=new Map(), cameFrom=new Map(), nodeInfo=new Map();
    for (let vi=0;vi<6;vi++) {
      const [vx,vy]=hexVtx(startQ,startR,vi);
      const k=vk(vx,vy);
      if (endKeys.has(k)) return [{q:startQ,r:startR,vi}]; // landmarks share a corner
      gScore.set(k,0);
      nodeInfo.set(k,{q:startQ,r:startR,vi});
      open.set(k,{f:h(vx,vy)});
    }
    let iter=0;
    while (open.size>0 && iter++<16000) {
      let ck=null,mf=Infinity;
      open.forEach((n,k)=>{ if(n.f<mf){mf=n.f;ck=k;} });
      if (endKeys.has(ck)) {
        const path=[]; let k=ck;
        while (k!==undefined) { path.unshift(nodeInfo.get(k)); k=cameFrom.get(k); }
        return path;
      }
      open.delete(ck);
      vtxNeighbours(ck).forEach((nInfo,nk)=>{
        const tg=(gScore.get(ck)||0)+edgeCost(ck,nk)+turnPen(cameFrom.get(ck),ck,nk);
        if (!gScore.has(nk)||tg<gScore.get(nk)) {
          gScore.set(nk,tg); cameFrom.set(nk,ck); nodeInfo.set(nk,nInfo);
          const [nx,ny]=hexVtx(nInfo.q,nInfo.r,nInfo.vi);
          open.set(nk,{f:tg+h(nx,ny)});
        }
      });
    }
    return null;
  }

  // SVG path string from a canonical vertex sequence. Path runs vertex-to-vertex
  // along hex edges and terminates at the entry vertex of each landmark hex (not
  // the hex centre) so the landmark's centre stays click-clear for expansion.
  function buildVtxPath(canonical) {
    if (!canonical||canonical.length<1) return null;
    const pts = canonical.map(({q,r,vi})=>hexVtx(q,r,vi));
    let d = `M${pts[0][0].toFixed(1)},${pts[0][1].toFixed(1)}`;
    for (let i=1;i<pts.length;i++) d += ` L${pts[i][0].toFixed(1)},${pts[i][1].toFixed(1)}`;
    return d;
  }

  // ── Anchor-lattice routing ───────────────────────────────────────────────────
  // Connections follow the hex BORDERS (flat vertex paths) through a fixed lattice
  // of BLANK anchor tiles (six 60-degree corners of rings 4 & 8 snapped to blank
  // cells, plus the central moat ring). Anchors aren't stitched waypoints; they are
  // cheap edges in edgeCost, so a single continuous A* per link is pulled through
  // them and around the hub via the moat. Fixed lattice, so routes stay stable.
  const ANCHORS = ANCHOR_LIST;     // fixed blank waypoint tiles (markers; the cheap-edge highway lives in edgeCost)
  // ONE continuous border-following A* per link. Anchor + moat edges are cheap
  // (edgeCost), so the single path is naturally pulled through the fixed lattice and
  // around the hub on its own, with NO stitching of independent legs, which is what
  // produced the kinks and backtracks. Stable because the lattice never moves.
  function anchorRoute(fq, fr, tq, tr) {
    const canon = vtxAstar(fq, fr, tq, tr);
    if (!canon || !canon.length) return { d: '', e0: null, e1: null };
    const f = canon[0], l = canon[canon.length - 1];
    return { d: buildVtxPath(canon), e0: hexVtx(f.q, f.r, f.vi), e1: hexVtx(l.q, l.r, l.vi) };
  }

  const connTip  = document.getElementById('conn-tooltip');
  const tipLabel = document.getElementById('ctt-label');
  const tipDesc  = document.getElementById('ctt-desc');
  const canvasEl = document.getElementById('atlas-canvas');

  const connG=g.append('g').attr('id','conn-g').attr('opacity',0);
  const builtRoutes=[];

  CONNECTIONS.forEach((conn,ci)=>{
    const fz=ZONE_DEFS.find(z=>z.id===conn.from),tz=ZONE_DEFS.find(z=>z.id===conn.to);
    if(!fz||!tz) return;
    const col=CONN_COL[conn.type]||'#4ECDC4';

    const fcell=fz.cells.find(c=>c.nodeId===ZONE_LM[conn.from])||
      fz.cells.filter(c=>c.type!=='terrain').reduce((b,c)=>
        ((c.wx-fz.cx)**2+(c.wy-fz.cy)**2)<((b.wx-fz.cx)**2+(b.wy-fz.cy)**2)?c:b);
    const tcell=tz.cells.find(c=>c.nodeId===ZONE_LM[conn.to])||
      tz.cells.filter(c=>c.type!=='terrain').reduce((b,c)=>
        ((c.wx-tz.cx)**2+(c.wy-tz.cy)**2)<((b.wx-tz.cx)**2+(b.wy-tz.cy)**2)?c:b);

    const rt = anchorRoute(fcell.q,fcell.r,tcell.q,tcell.r);
    const pathD = rt.d;

    const rg=connG.append('g').attr('class','route-group')
      .attr('data-from',conn.from).attr('data-to',conn.to);

    const rGlow=rg.append('path').attr('class','r-glow').attr('d',pathD).attr('fill','none')
      .attr('stroke',col).attr('stroke-width',10).attr('stroke-opacity',0.025)
      .attr('pointer-events','none');
    const rBody=rg.append('path').attr('class','r-body').attr('d',pathD).attr('fill','none')
      .attr('stroke',col).attr('stroke-width',2).attr('stroke-opacity',0.14)
      .attr('stroke-linecap','round').attr('stroke-linejoin','round')
      .attr('pointer-events','none');
    const fp=rg.append('path').attr('class','r-flow').attr('d',pathD).attr('fill','none')
      .attr('stroke',col).attr('stroke-width',1.2).attr('stroke-opacity',0.36)
      .attr('stroke-dasharray','5 22').attr('stroke-linecap','round')
      .attr('pointer-events','none');
    const fe=fp.node();
    if(fe) fe.style.animation=`routeFlow 3s linear ${(-ci*0.42).toFixed(2)}s infinite`;

    // Endpoint indicators: small filled circle at each terminating vertex marks
    // the cell the route attaches to without covering its centre/click target.
    const endpoints = [
      rg.append('circle').attr('class','r-endpoint').attr('r',3.2)
        .attr('fill',col).attr('fill-opacity',0.75)
        .attr('stroke',col).attr('stroke-width',1.2).attr('stroke-opacity',0.95)
        .attr('pointer-events','none'),
      rg.append('circle').attr('class','r-endpoint').attr('r',3.2)
        .attr('fill',col).attr('fill-opacity',0.75)
        .attr('stroke',col).attr('stroke-width',1.2).attr('stroke-opacity',0.95)
        .attr('pointer-events','none'),
    ];
    function placeEndpoints(p0, p1, dur) {
      if (!p0 || !p1) { endpoints.forEach(e=>e.attr('opacity',0)); return; }
      endpoints[0].attr('opacity',1); endpoints[1].attr('opacity',1);
      const ep0 = dur ? endpoints[0].transition().duration(dur).ease(d3.easeCubicInOut) : endpoints[0];
      const ep1 = dur ? endpoints[1].transition().duration(dur).ease(d3.easeCubicInOut) : endpoints[1];
      ep0.attr('cx',p0[0]).attr('cy',p0[1]);
      ep1.attr('cx',p1[0]).attr('cy',p1[1]);
    }
    placeEndpoints(rt.e0, rt.e1);

    const hit=rg.append('path').attr('d',pathD).attr('fill','none')
      .attr('stroke','transparent').attr('stroke-width',16).attr('cursor','pointer');
    hit.on('mouseover',()=>{
      hoverConn=conn; refreshRouteVis();
      tipLabel.textContent=conn.label||''; tipDesc.textContent=conn.desc||''; connTip.style.display='block';
    });
    hit.on('mousemove',ev=>{
      if(connTip.style.display!=='block') return;
      const rect=canvasEl.getBoundingClientRect();
      let tx=ev.clientX-rect.left+14,ty=ev.clientY-rect.top-connTip.offsetHeight-8;
      if(tx+268>rect.width) tx=ev.clientX-rect.left-268;
      if(ty<0) ty=ev.clientY-rect.top+14;
      connTip.style.left=tx+'px'; connTip.style.top=ty+'px';
    });
    hit.on('mouseout',()=>{ connTip.style.display='none'; hoverConn=null; refreshRouteVis(); });
    hit.on('click', ev=>{
      ev.stopPropagation();
      connTip.style.display='none';
      if(activeRouteConn===conn){ window._deselectRoute(); return; }
      if(typeof deselectNode==='function') deselectNode();
      window._selectRoute(conn, col);
    });

    builtRoutes.push({conn, rg, col, fp, e0:rt.e0, e1:rt.e1, endpoints, placeEndpoints,
      fq:fcell.q, fr:fcell.r, tq:tcell.q, tr:tcell.r, layers:[rGlow,rBody,fp,hit]});
  });

  // Anchor markers — the fixed lattice waypoints, drawn as subtle focus points so
  // the structure the lines hop through is visible. Inside connG so they show with
  // the connections.
  const anchorG = connG.append('g').attr('id','anchor-g').attr('pointer-events','none');
  ANCHORS.forEach(a => {
    anchorG.append('circle').attr('cx', a.px[0]).attr('cy', a.px[1]).attr('r', s * 0.5)
      .attr('fill','none').attr('stroke','#4ECDC4').attr('stroke-opacity',0.16).attr('stroke-width',1).attr('stroke-dasharray','2 5');
    anchorG.append('circle').attr('cx', a.px[0]).attr('cy', a.px[1]).attr('r', 2)
      .attr('fill','#4ECDC4').attr('fill-opacity',0.4);
  });

  // ── Route selection & highlighting ─────────────────────────────────────────
  // Visual state from three inputs: the selected route (HUD), the legend type
  // checkboxes (multi-select), and a hovered/previewed route. A hovered route
  // ISOLATES — it overrides the type highlight so a single link can be traced
  // out of the tangle. Glow + body width scale down as more routes light up so
  // the all-on view never blooms into an indistinct haze. The two endpoint
  // landmark hexes of the hovered/selected route get a bright ring.
  let activeRouteConn = null;
  let hoverConn = null;
  let focusZone = null;          // when a zone hex is selected, only its links light up (calm default)
  const checkedTypes = new Set();

  // Endpoint highlight rings — repositioned over the two landmark hexes of the
  // hovered (or, failing that, selected) route. Appended last so they sit on top.
  const endpointHlG = connG.append('g').attr('id','route-endpt-hl').attr('pointer-events','none');
  const endpointRings = [0,1].map(() =>
    endpointHlG.append('path').attr('fill','none').attr('stroke-width',3)
      .attr('opacity',0).attr('filter','url(#n-glow)'));
  function routeByConn(conn) { return conn ? builtRoutes.find(b => b.conn === conn) : null; }
  function updateEndpointHl() {
    const r = routeByConn(hoverConn) || routeByConn(activeRouteConn);
    if (!r) { endpointRings.forEach(e => e.transition().duration(140).attr('opacity',0)); return; }
    const [ax,ay] = hPx(r.fq, r.fr), [bx,by] = hPx(r.tq, r.tr);
    endpointRings[0].attr('d', hPath(ax,ay,s+3)).attr('stroke', r.col)
      .transition().duration(140).attr('opacity',0.92);
    endpointRings[1].attr('d', hPath(bx,by,s+3)).attr('stroke', r.col)
      .transition().duration(140).attr('opacity',0.92);
  }

  function refreshRouteVis() {
    const hasTypes = checkedTypes.size > 0;
    const isolate = !!hoverConn;
    const hasFocus = !!focusZone;
    const anyActive = isolate || !!activeRouteConn || hasTypes || hasFocus;
    const isOn = conn => isolate
      ? conn === hoverConn
      : (conn === activeRouteConn || (hasTypes && checkedTypes.has(conn.type)) ||
         (hasFocus && (conn.from === focusZone || conn.to === focusZone)));
    let onCount = 0;
    builtRoutes.forEach(({conn}) => { if (isOn(conn)) onCount++; });
    // As more routes light up, shrink the glow + body so they stay distinct
    // colored lines instead of merging into one bright haze.
    const k = onCount <= 2 ? 1 : Math.max(0.16, 2 / onCount);
    const glowW = 10 + 16 * k, glowO = 0.03 + 0.15 * k;
    const bodyW = onCount <= 2 ? 4.5 : 3.2;
    // Calm default: at rest (nothing hovered/selected/focused) the whole web sits
    // quiet and faint; selecting a zone (or hovering a link) brings its lines up.
    builtRoutes.forEach(({conn, rg, fp}) => {
      const on = isOn(conn);
      const dim = anyActive && !on;
      rg.select('.r-body').transition().duration(160)
        .attr('stroke-width', on ? bodyW : 2)
        .attr('stroke-opacity', on ? 0.94 : dim ? 0.04 : 0.09);
      rg.select('.r-glow').transition().duration(160)
        .attr('stroke-width', on ? glowW : 10)
        .attr('stroke-opacity', on ? glowO : dim ? 0.006 : 0.015);
      fp.transition().duration(160)
        .attr('stroke-width', on ? 2.0 : 1.2)
        .attr('stroke-opacity', on ? 0.96 : dim ? 0.05 : 0.16);
      rg.selectAll('.r-endpoint').transition().duration(160)
        .attr('r', on ? 4.3 : 3.0)
        .attr('fill-opacity', on ? 0.95 : dim ? 0.12 : 0.45)
        .attr('stroke-opacity', on ? 1 : dim ? 0.18 : 0.55);
    });
    updateEndpointHl();
  }

  // When routes overlap, the hover hit-test lands on whichever route's hit path
  // is drawn last (topmost). Raise the routes of any checked type (and the
  // selected route) so the hover resolves to a route relevant to what's
  // highlighted — e.g. hovering a shared line while "Financial" is on picks the
  // financial route, not a clinical route sharing the same path.
  function reorderRoutes() {
    builtRoutes.forEach(r => {
      if (checkedTypes.has(r.conn.type) || r.conn === activeRouteConn) r.rg.raise();
    });
    endpointHlG.raise();
  }

  // Toggle a connection type in the legend highlight set. Returns new on-state.
  window._toggleRouteType = function(type) {
    if (checkedTypes.has(type)) checkedTypes.delete(type);
    else checkedTypes.add(type);
    reorderRoutes();
    refreshRouteVis();
    return checkedTypes.has(type);
  };

  // Called by node selection: focus a zone so only its links light up (calm default).
  // Pass null to clear. Does not touch route/type selection state.
  window._focusZoneRoutes = function(zoneId) {
    focusZone = zoneId || null;
    reorderRoutes();
    refreshRouteVis();
  };

  window._selectRoute = function(conn, col) {
    activeRouteConn = conn;
    reorderRoutes();
    refreshRouteVis();
    const badge = document.getElementById('h-badge');
    badge.textContent = conn.type.toUpperCase() + ' · ROUTE';
    badge.style.setProperty('--hz', col);
    document.getElementById('h-type').textContent = '↔ Connection';
    document.getElementById('hud-title').textContent = conn.label || '';
    document.getElementById('hud-desc').textContent = conn.desc || '';
    document.getElementById('hud-links').innerHTML = '';
    document.getElementById('hud-links-col').classList.remove('has-links');
    fillHudData(null);   // connections are routes, not concept hexes — clear any bound data
    document.getElementById('atlas-hud').classList.add('open');
    if (window._syncConnPanel) window._syncConnPanel();
  };

  window._deselectRoute = function() {
    if (!activeRouteConn) return;
    activeRouteConn = null;
    refreshRouteVis();
    document.getElementById('atlas-hud').classList.remove('open');
    if (window._syncConnPanel) window._syncConnPanel();
  };

  // Re-route every connection with A* against the current expansion state, then
  // redraw. Routes stay on the static hex grid (every segment a true hex edge) but
  // detour around hexes occupied by active expansions via the edgeCost penalty.
  // Debounced through requestAnimationFrame so a burst of expand/collapse calls
  // (e.g. Expand All firing 7×) collapses into a single re-route pass.
  let _routeUpdatePending = false;
  function doUpdateRoutes() {
    // Anchors are fixed, so routes are stable across expand/collapse. Rebuild the
    // expansion-blocked set so the border-following legs detour around an open
    // expansion's footprint, then re-assert each route's path.
    rebuildRouteBlocked();
    builtRoutes.forEach(route => {
      const rt = anchorRoute(route.fq, route.fr, route.tq, route.tr);
      route.layers.forEach(p => p.attr('d', rt.d));
      route.placeEndpoints(rt.e0, rt.e1);
    });
  }
  window.updateRoutes = function() {
    if (_routeUpdatePending) return;
    _routeUpdatePending = true;
    requestAnimationFrame(() => { _routeUpdatePending = false; doUpdateRoutes(); });
  };

  // ── Connections panel ──────────────────────────────────────────────────────
  // Clicking a route in a tangle is unreliable, so route selection also lives in
  // a searchable/filterable side drawer. Each row hover-previews its route and
  // click-selects it. Rows are built once; search + type chips toggle visibility.
  {
    const listEl   = document.getElementById('conn-list');
    const emptyEl  = document.getElementById('conn-empty');
    const searchEl = document.getElementById('conn-search');
    const chipsEl  = document.getElementById('conn-filters');
    let typeFilter = 'all', query = '';

    const ZONE_NAME = {};
    ZONE_DEFS.forEach(z => { ZONE_NAME[z.id] = z.displayLabel || z.label; });

    const rows = builtRoutes.map(route => {
      const row = document.createElement('div');
      row.className = 'conn-row';
      const dot = document.createElement('span');
      dot.className = 'conn-dot';
      dot.style.background = route.col;
      const txt = document.createElement('div');
      txt.className = 'conn-row-text';
      const lab = document.createElement('div');
      lab.className = 'conn-row-label';
      lab.textContent = route.conn.label || `${route.conn.from} ↔ ${route.conn.to}`;
      const zns = document.createElement('div');
      zns.className = 'conn-row-zones';
      zns.textContent = `${ZONE_NAME[route.conn.from]||route.conn.from} → ${ZONE_NAME[route.conn.to]||route.conn.to}`;
      txt.append(lab, zns);
      row.append(dot, txt);
      row.addEventListener('mouseenter', () => { hoverConn = route.conn; refreshRouteVis(); });
      row.addEventListener('mouseleave', () => { hoverConn = null; refreshRouteVis(); });
      row.addEventListener('click', () => {
        if (typeof deselectNode === 'function') deselectNode();
        window._selectRoute(route.conn, route.col);
      });
      listEl.appendChild(row);
      return {route, row, search: `${lab.textContent} ${zns.textContent} ${route.conn.type}`.toLowerCase()};
    });

    function renderConnList() {
      let shown = 0;
      rows.forEach(({route, row, search}) => {
        const visible = (typeFilter === 'all' || route.conn.type === typeFilter)
          && (!query || search.includes(query));
        row.style.display = visible ? 'flex' : 'none';
        row.classList.toggle('active', route.conn === activeRouteConn);
        if (visible) shown++;
      });
      emptyEl.style.display = shown ? 'none' : 'block';
    }

    searchEl.addEventListener('input', () => { query = searchEl.value.trim().toLowerCase(); renderConnList(); });
    chipsEl.querySelectorAll('.cf-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        chipsEl.querySelectorAll('.cf-chip').forEach(c => c.classList.remove('on'));
        chip.classList.add('on');
        typeFilter = chip.dataset.type;
        renderConnList();
      });
    });

    // Exposed so map-side selection (direct route click) keeps the panel's
    // active-row highlight in sync.
    window._syncConnPanel = renderConnList;
    renderConnList();
  }

  window._hlRoutes=function(zoneId){
    builtRoutes.forEach(({conn,rg,fp})=>{
      const on=conn.from===zoneId||conn.to===zoneId;
      rg.select('.r-body').transition().duration(200).attr('stroke-width',2).attr('stroke-opacity',on?0.52:0.07);
      rg.select('.r-glow').transition().duration(200).attr('stroke-width',10).attr('stroke-opacity',on?0.09:0.01);
      fp.transition().duration(200).attr('stroke-width',1.2).attr('stroke-opacity',on?0.80:0.12);
    });
  };
  window._clrRoutes=function(){
    // Return to whatever the legend/selection state dictates rather than a flat ambient.
    refreshRouteVis();
  };

  // ── Legend connection toggles (in the layers panel) + popout ──────────────
  document.querySelectorAll('#atlas-layers-pop .pop-opt[data-type]').forEach(btn => {
    btn.addEventListener('click', () => {
      const on = window._toggleRouteType(btn.dataset.type);
      btn.setAttribute('aria-pressed', on ? 'true' : 'false');
      renderAppliedStrip();
      announce(btn.textContent.trim() + ' routes ' + (on ? 'highlighted' : 'highlight cleared'));
    });
  });
  const connPopout = document.getElementById('leg-conn-popout');
  if (connPopout) connPopout.addEventListener('click', () => {
    closePop(true);   // the connections panel takes over from the layers panel
    document.getElementById('atlas-conn').classList.toggle('open');
  });
}

// ── ZONE TERRITORIES ──────────────────────────────────────────────────────────
const zonesG = g.append('g');
let activeZone=null, activeNode=null;

ZONE_DEFS.forEach(zone => {
  const zg = zonesG.append('g').attr('class','az').attr('data-id',zone.id);

  // Terrain backing for every hex in the zone, including named-cell positions.
  // This way when a named cell animates away during expansion, the position still
  // shows a zone-colored hex outline underneath instead of a black hole.
  zone.cells.forEach(cell => {
    const cx = cell.wx, cy = cell.wy;
    zg.append('path').attr('class','zone-bg').attr('d', hPath(cx,cy,s-2))
      .attr('fill', zone.color).attr('fill-opacity', 0.05)
      .attr('stroke', zone.color).attr('stroke-width', 0.6).attr('stroke-opacity', 0.12)
      .attr('pointer-events', 'none');
  });

  zone.cells.forEach(cell => {
    const cx=cell.wx, cy=cell.wy;
    const isTerrain = cell.type==='terrain';
    const isLM      = cell.type==='landmark';

    if (isTerrain) {
      // Backing already drawn above; nothing further to render for terrain.
      return;
    }

    const cg = zg.append('g').attr('class','az-node-cell')
      .attr('data-nodeid',cell.nodeId).attr('data-zoneid',zone.id)
      .attr('data-wx',cell.wx).attr('data-wy',cell.wy);

    // Landmark pulse ring
    if (isLM) {
      cg.append('path').attr('d',hPath(cx,cy,s+6))
        .attr('fill','none').attr('stroke',zone.color)
        .attr('stroke-width',2.5).attr('stroke-opacity',0.18)
        .attr('pointer-events','none').attr('filter','url(#n-glow)');
    }

    // Status: auto-derived from content completeness
    const isLive     = !!(cell.links && cell.links.length > 0);
    const isFrontier = !isLM && (!cell.desc || cell.desc.length < 20);
    const fillOp  = isLM ? 0.18 : isFrontier ? 0.04 : 0.10;
    const strkOp  = isLM ? 0.78 : isFrontier ? 0.15 : 0.46;

    // Main hex
    const hexBody = cg.append('path').attr('class','hex-body')
      .attr('d',hPath(cx,cy,s-1.8))
      .attr('fill',zone.color).attr('fill-opacity',fillOp)
      .attr('stroke',zone.color).attr('stroke-width',isLM?2.2:1.2)
      .attr('stroke-opacity',strkOp)
      .attr('cursor','pointer');
    if (!isFrontier) hexBody.attr('filter','url(#hex-glow)');

    // Inner ring (adds visual depth, looks like Foxhole double-border)
    cg.append('path').attr('d',hPath(cx,cy,s-9))
      .attr('fill','none').attr('stroke',zone.color)
      .attr('stroke-width',0.6).attr('stroke-opacity',isLM?0.22:isFrontier?0.10:0.20)
      .attr('pointer-events','none');

    // Node labels — revealed by LOD
    const lines = (cell.label||'').split('\n').filter(Boolean);
    const lbG = cg.append('g').attr('class','az-lbl').attr('opacity',0).attr('pointer-events','none');
    lines.forEach((ln,li)=>{
      lbG.append('text')
        .attr('x',cx).attr('y',cy-2+li*11-(lines.length-1)*5.5)
        .attr('text-anchor','middle')
        .attr('font-family',isLM?'Outfit, sans-serif':'DM Sans, sans-serif')
        .attr('font-size',isLM?'9.5px':'7.5px')
        .attr('font-weight',isLM?'700':'400')
        .attr('fill',isLM?'#E2EEF4':'#B8D4C8')
        .attr('fill-opacity',isLM?0.94:0.80)
        .text(ln);
    });
    if (isLM) {
      lbG.append('circle').attr('cx',cx).attr('cy',cy+(s-6))
        .attr('r',2.5).attr('fill',zone.color).attr('fill-opacity',0.70);
    }

    // Live status dot — always-on indicator for nodes with connected tools/content
    if (isLive && !isLM) {
      cg.append('circle').attr('class','status-dot')
        .attr('cx', cx).attr('cy', cy + (s-6))
        .attr('r', 2.4).attr('fill', zone.color).attr('fill-opacity', 0.72)
        .attr('pointer-events','none');
    }

    hexBody.on('click', ev=>{ev.stopPropagation(); selectNode(zone,cell);});
    hexBody.on('dblclick', ev=>{ev.stopPropagation(); selectNode(zone,cell); zoomToCell(cell);});
    hexBody.on('mouseenter', function(){ d3.select(this).attr('fill-opacity',isLM?0.32:0.20).attr('stroke-opacity',isLM?0.95:0.65); });
    hexBody.on('mouseleave', function(){
      if (!activeNode||activeNode.nodeId!==cell.nodeId)
        d3.select(this).attr('fill-opacity',fillOp).attr('stroke-opacity',strkOp);
    });
  });

  // ── ZONE NAME — Foxhole-style: large, clean, no pill box, fades out on zoom-in
  const nlG = zg.append('g').attr('class','az-zone-label').attr('pointer-events','none')
    .attr('data-cx',zone.cx).attr('data-cy',zone.topY - 16).attr('data-zoneid',zone.id);

  // Anchor just above the zone's northernmost hex — keeps MedSci label above the hub
  const labelY = zone.topY - 16;
  nlG.append('text')
    .attr('x',zone.cx).attr('y',labelY)
    .attr('text-anchor','middle')
    .attr('font-family','Outfit, sans-serif')
    .attr('font-size','18px').attr('font-weight','900')
    .attr('letter-spacing','0.05em')
    .attr('fill',zone.color).attr('fill-opacity',0.92)
    .attr('filter','url(#txt-shadow)')
    .text(zone.displayLabel.toUpperCase());

  // Thin underline rule below zone name
  const tw = zone.displayLabel.length * 9;   // rough char-width estimate
  nlG.append('line')
    .attr('x1',zone.cx-tw/2).attr('y1',labelY+5)
    .attr('x2',zone.cx+tw/2).attr('y2',labelY+5)
    .attr('stroke',zone.color).attr('stroke-width',0.8).attr('stroke-opacity',0.35);
});

// ── HUB CENTER MARKER ─────────────────────────────────────────────────────────
// Prominent focal point at the geographic center. Rendered last → always on top.
// Clicking it resets to overview. Visually tells you "this is the center of everything."
const hubG = g.append('g').attr('id','hub-center');

// Moat ring: blank opaque tiles at ring-1 positions create a visible buffer
// between the hub and all zone territories. Zone cells underneath are covered.
[[1,0],[-1,0],[0,1],[0,-1],[1,-1],[-1,1]].forEach(([dq,dr]) => {
  const [bx,by] = hPx(dq, dr);
  hubG.append('path').attr('d', hPath(bx, by, s+1.5))
    .attr('class','hub-moat-tile')
    .attr('fill','#06100a').attr('fill-opacity',0.90)
    .attr('pointer-events','none');
  hubG.append('path').attr('d', hPath(bx, by, s-1.5))
    .attr('class','hub-moat-border')
    .attr('fill','none')
    .attr('stroke','#4ECDC4').attr('stroke-width',0.8).attr('stroke-opacity',0.25)
    .attr('stroke-dasharray','4 6')
    .attr('pointer-events','none');
});

// Hub core node — the brand compass rose, drawn inline as native SVG (not a
// loaded <image>) so it renders crisp and fully transparent with no backdrop,
// and adapts to the theme like the home-page compass. Geometry matches
// /brand/hu-atlas-core-node.svg: centre (340,218) in a "158 36 364 364" viewBox,
// so HUB_SZ = 2*s scales it to exactly one grid cell.
const HUB_SZ = 2 * s;

// Build the compass interior markup for the current theme (deeper palette in light).
function compassInner(dark) {
  const BLUE    = dark ? '#3585cc' : '#1B5FA8';
  const BLUE_LT = dark ? '#5aa6e6' : '#3585cc';
  const TEAL    = dark ? '#4ecdc4' : '#2FA79E';
  const TEAL_LT = dark ? '#7ff0e6' : '#4ecdc4';
  const TEAL_DK = dark ? '#3fa9a2' : '#1f7d76';
  const CENTER  = dark ? '#0d1117' : '#ffffff';   // pure white centre in light mode, not a dark/grey blob
  const BG      = dark ? '#06100a' : '#eaf0eb';   // hub-cell backing, matches the board so there's no grey box

  let ticks = '';
  for (let i = 0; i < 36; i++) {
    const a = (-90 + i * 10) * Math.PI / 180, c = Math.cos(a), sn = Math.sin(a);
    const major = i % 9 === 0, sec = i % 3 === 0;
    const len = major ? 12 : sec ? 8 : 5;
    const w = major ? 2 : sec ? 1.5 : 1, op = major ? 0.9 : sec ? 0.6 : 0.4;
    const x1 = (340 + c * 115).toFixed(1), y1 = (218 + sn * 115).toFixed(1);
    const x2 = (340 + c * (115 - len)).toFixed(1), y2 = (218 + sn * (115 - len)).toFixed(1);
    ticks += `<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" stroke="${TEAL}" stroke-width="${w}" opacity="${op}"/>`;
  }

  const lblStyle = 'font-family:Poppins,sans-serif;font-size:21px;font-weight:bold';
  return `<polygon points="340,36 497.6,127 497.6,309 340,400 182.4,309 182.4,127" fill="${BG}"/>`
    + `<polygon points="340,36 497.6,127 497.6,309 340,400 182.4,309 182.4,127" fill="none" stroke="${BLUE}" stroke-width="2.5" opacity="0.85"/>`
    + `<circle cx="340" cy="218" r="115" fill="none" stroke="${TEAL}" stroke-width="2" opacity="0.9"/>`
    + ticks
    + `<polygon points="340,203 350,203 355,162 340,118" fill="${TEAL_LT}"/><polygon points="340,203 330,203 325,162 340,118" fill="${TEAL_DK}"/>`
    + `<polygon points="355,218 355,228 394,233 440,218" fill="${BLUE_LT}"/><polygon points="355,218 355,208 394,203 440,218" fill="${BLUE}"/>`
    + `<polygon points="340,233 330,233 325,274 340,318" fill="${TEAL_LT}"/><polygon points="340,233 350,233 355,274 340,318" fill="${TEAL_DK}"/>`
    + `<polygon points="325,218 325,208 286,203 240,218" fill="${BLUE_LT}"/><polygon points="325,218 325,228 286,233 240,218" fill="${BLUE}"/>`
    + `<text x="340" y="86" text-anchor="middle" fill="${TEAL_LT}" style="${lblStyle}" dominant-baseline="middle">N</text>`
    + `<text x="340" y="350" text-anchor="middle" fill="${TEAL}" style="${lblStyle}" dominant-baseline="middle">S</text>`
    + `<text x="474" y="218" text-anchor="middle" fill="${BLUE_LT}" style="${lblStyle}" dominant-baseline="middle">E</text>`
    + `<text x="206" y="218" text-anchor="middle" fill="${BLUE_LT}" style="${lblStyle}" dominant-baseline="middle">W</text>`
    + `<polygon points="340,186 367.7,202 367.7,234 340,250 312.3,234 312.3,202" fill="${CENTER}"/>`
    + (dark ? `<circle cx="340" cy="218" r="27" fill="${BLUE}" opacity="0.20"/>` : '')
    + `<polygon points="340,186 367.7,202 367.7,234 340,250 312.3,234 312.3,202" fill="none" stroke="${BLUE}" stroke-width="2.5" opacity="0.9" stroke-linejoin="round"/>`
    + `<g transform="translate(318.75,203.72) scale(0.34)">`
    +   `<path d="M0.00,4.00 Q0.00,0.00 4.00,0.00 L15.00,0.00 Q19.00,0.00 19.00,4.00 L19.00,23.00 Q19.00,27.00 15.70,29.26 L3.30,37.74 Q0.00,40.00 0.00,36.00 Z" fill="${BLUE}"/>`
    +   `<path d="M0.00,50.00 Q0.00,46.00 3.38,43.86 L15.62,36.14 Q19.00,34.00 23.00,34.00 L46.00,34.00 Q50.00,34.00 50.00,38.00 L50.00,49.00 Q50.00,53.00 46.00,53.00 L23.00,53.00 Q19.00,53.00 19.00,57.00 L19.00,80.00 Q19.00,84.00 15.00,84.00 L4.00,84.00 Q0.00,84.00 0.00,80.00 Z" fill="${BLUE}"/>`
    +   `<path d="M57,1.5 Q57,-2.5 61,-2.5 L72,-2.5 Q76,-2.5 76,1.5 L76,52.5 Q76,67.5 91,67.5 Q106,67.5 106,52.5 L106,1.5 Q106,-2.5 110,-2.5 L121,-2.5 Q125,-2.5 125,1.5 L125,52.5 Q125,86.5 91,86.5 Q57,86.5 57,52.5 Z" fill="${TEAL}"/>`
    + `</g>`;
}

// Draw (or redraw) the compass as a nested <svg> whose viewBox scales the brand
// geometry to one grid cell. Re-run on theme change to repaint the palette.
function renderHubCompass() {
  hubG.selectAll('.hub-compass').remove();
  const node = hubG.append('svg')
    .attr('class', 'hub-compass')
    .attr('x', OX - HUB_SZ / 2).attr('y', OY - HUB_SZ / 2)
    .attr('width', HUB_SZ).attr('height', HUB_SZ)
    .attr('viewBox', '158 36 364 364')
    .attr('overflow', 'visible')
    .attr('pointer-events', 'none');
  node.node().innerHTML = compassInner(!isLight());
}
renderHubCompass();

// Transparent hit hex over the compass keeps the click-to-reset target.
const hubBody = hubG.append('path').attr('d',hPath(OX,OY,s+4))
  .attr('id','hub-body').attr('fill','transparent').attr('cursor','pointer');

// Hub interactivity
hubBody.on('click', ev=>{ev.stopPropagation(); deselectNode(); resetView();});
hubBody.on('mouseenter', () => hubG.select('.hub-compass').transition().duration(160).attr('opacity',0.85));
hubBody.on('mouseleave', () => hubG.select('.hub-compass').transition().duration(160).attr('opacity',1));

// Lift zone name labels above hub moat so adjacent zones (Public Health, etc.) aren't obscured
d3.selectAll('.az-zone-label').each(function(){ g.node().appendChild(this); });

// Routes must render above moat tiles (hub-center drawn before this point).
// Expansion overlays are created next, so they stay on top of routes.
d3.select('#conn-g').raise();

// ── LANDMARK EXPANSION OVERLAYS ──────────────────────────────────────────────
// Build overlay SVGs for all registered landmarks. Must run after zone cells rendered.
[EXPAND_PATHOPHYS, EXPAND_INFORMATICS, EXPAND_MEDICARE, EXPAND_ACCESS, EXPAND_POP_HEALTH, EXPAND_FED_LAW, EXPAND_SCOPE, EXPAND_EHR].forEach(initExpansion);

// ── EXPAND INDICATORS ────────────────────────────────────────────────────────
// After overlays are built, inject 4-chevron expand arrows into every expandable landmark hex.
// Arrows point outward (N/S/E/W), rounded ends, zone-colored. Dim when expanded.
(function addExpandIndicators() {
  Object.keys(EXPANSION_REGISTRY).forEach(nodeId => {
    d3.selectAll(`.az-node-cell[data-nodeid="${nodeId}"]`).each(function() {
      const cg  = d3.select(this);
      const zid = cg.attr('data-zoneid');
      const z   = ZONE_DEFS.find(z => z.id === zid);
      const col = z ? z.color : '#fff';

      const wx = +cg.attr('data-wx');
      const wy = +cg.attr('data-wy');

      const ig = cg.append('g')
        .attr('class', 'expand-indicator')
        .attr('pointer-events', 'none')
        .attr('transform', `translate(${wx},${wy + 18})`);

      // 4 outward-pointing rounded chevrons
      [
        [[-2.5,-2.5],[0,-6.5],[2.5,-2.5]],   // N
        [[-2.5, 2.5],[0, 6.5],[2.5, 2.5]],   // S
        [[ 2.5,-2.5],[6.5, 0],[ 2.5, 2.5]],  // E
        [[-2.5,-2.5],[-6.5,0],[-2.5, 2.5]],  // W
      ].forEach(pts => {
        ig.append('polyline')
          .attr('points', pts.map(p=>p.join(',')).join(' '))
          .attr('fill', 'none')
          .attr('stroke', col)
          .attr('stroke-width', 1.6)
          .attr('stroke-linecap', 'round')
          .attr('stroke-linejoin', 'round')
          .attr('opacity', 0.55);
      });
    });
  });
})();

// Toggle indicator opacity when expansion state changes
function updateExpandIndicator(nodeId) {
  const on = expandedSet.has(nodeId);
  d3.selectAll(`.az-node-cell[data-nodeid="${nodeId}"] .expand-indicator`)
    .transition().duration(200)
    .attr('opacity', on ? 0.2 : 1.0);
}

// ── LOD ───────────────────────────────────────────────────────────────────────
// Two LOD tiers: zone names fade OUT as you zoom in; node labels fade IN.
// zoneLabelsOn flag lets the toolbar filter override LOD visibility.
let zoneLabelsOn = true;
let routesOn = true;
function updateLOD(k) {
  // Zone names: overview only, fade out as you zoom in
  const zoneNameOp = zoneLabelsOn ? (k < 0.75 ? 1.0 : k < 1.5 ? 1-(k-0.75)/0.75 : 0) : 0;
  d3.selectAll('.az-zone-label').transition().duration(160).attr('opacity', zoneNameOp);
  // Connection routes: invisible at full overview, reveal at medium zoom — toggleable
  const connOp = routesOn ? (k < 0.50 ? 0 : k < 0.78 ? (k-0.50)/0.28 : 1) : 0;
  d3.select('#conn-g').transition().duration(140).attr('opacity', connOp);
  // Node labels: only when zoomed into a territory
  const nodeLabelOp = k >= 0.90 ? Math.min(1,(k-0.90)/0.45) : 0;
  d3.selectAll('.az-lbl').transition().duration(110).attr('opacity', nodeLabelOp);
  hideHint();
}

// ── ZOOM ──────────────────────────────────────────────────────────────────────
const zoom = d3.zoom().scaleExtent([0.28, 4.5])
  .on('zoom', ev => { g.attr('transform',ev.transform); updateLOD(ev.transform.k); });
svg.call(zoom).on('dblclick.zoom', null);
svg.on('click', ev=>{ if(ev.target===svgEl) deselectNode(); });

function getInitT() {
  const vw=svgEl.clientWidth||1300, vh=svgEl.clientHeight||720;
  // Zones pulled inward to border the ring-1 moat. Map spans ~x:750–1516, y:490–1370.
  const mapCX=1150, mapCY=950, mapW=1060, mapH=1020;
  const k = Math.min((vw-80)/mapW, (vh-80)/mapH, 0.70);
  return d3.zoomIdentity.translate(vw/2-mapCX*k, vh/2-mapCY*k).scale(k);
}

function zoomToZone(zone) {
  const vw=svgEl.clientWidth||1300, vh=svgEl.clientHeight||720;
  const nc=zone.cells.filter(c=>c.type!=='terrain');
  const xs=nc.map(c=>c.wx), ys=nc.map(c=>c.wy), pad=s*3;
  const zCX=(Math.min(...xs)+Math.max(...xs))/2, zCY=(Math.min(...ys)+Math.max(...ys))/2;
  const zW=Math.max(...xs)-Math.min(...xs)+pad*2, zH=Math.max(...ys)-Math.min(...ys)+pad*2;
  const k=Math.min((vw-60)/zW,(vh-60)/zH,2.6);
  activeZone=zone; updateBC(zone,null);
  svg.transition().duration(680).ease(d3.easeCubicInOut)
    .call(zoom.transform,d3.zoomIdentity.translate(vw/2-zCX*k,vh/2-zCY*k).scale(k));
}

function zoomToCell(cell) {
  const vw=svgEl.clientWidth||1300, vh=svgEl.clientHeight||720;
  // Offset center upward by half the HUD height so the hex lands above the HUD
  const hudEl=document.getElementById('atlas-hud');
  const hudH=hudEl.classList.contains('open') ? hudEl.offsetHeight : 0;
  const cx=vw/2, cy=(vh-hudH)/2;
  const k=2.2;
  svg.transition().duration(480).ease(d3.easeCubicInOut)
    .call(zoom.transform,d3.zoomIdentity.translate(cx-cell.wx*k, cy-cell.wy*k).scale(k));
}

function resetView() {
  activeZone=null; activeNode=null;
  updateHash(null, null);
  closeHud(); updateBC(null,null);
  svg.transition().duration(560).ease(d3.easeCubicInOut).call(zoom.transform,getInitT());
}

// ── BREADCRUMB ────────────────────────────────────────────────────────────────
function updateBC(zone,node) {
  const bc=document.getElementById('atlas-bc');
  let h='<span class="abc-item" id="bc-ov">Overview</span>';
  if (zone) h+=`<span class="abc-sep">›</span><span class="abc-item${!node?' active':''}" id="bc-z" style="color:${zone.color}">${zone.label}</span>`;
  if (node) h+=`<span class="abc-sep">›</span><span class="abc-item active">${(node.label||'').replace('\n',' ')}</span>`;
  if (!zone) h=h.replace('class="abc-item"','class="abc-item active"');
  bc.innerHTML=h;
  document.getElementById('bc-ov').addEventListener('click',resetView);
  const bz=document.getElementById('bc-z');
  if (bz&&zone) bz.addEventListener('click',()=>zoomToZone(zone));
}

// ── URL HASH STATE ────────────────────────────────────────────────────────────
function updateHash(zone, cell) {
  const h = cell ? `#${zone.id}/${cell.nodeId}` : zone ? `#${zone.id}` : '';
  history.replaceState(null, '', location.pathname + location.search + h);
}

function applyHash() {
  const raw = location.hash.replace('#','');
  if (!raw) return;
  const [zid, nid] = raw.split('/');
  const zone = ZONE_DEFS.find(z => z.id === zid);
  if (!zone) return;
  if (nid) {
    const cell = zone.cells.find(c => c.nodeId === nid);
    if (cell) { selectNode(zone, cell); zoomToCell(cell); return; }
  }
  zoomToZone(zone);
}

window.addEventListener('hashchange', () => {
  const raw = location.hash.replace('#','');
  if (!raw) { resetView(); return; }
  applyHash();
});

// ── BOTTOM HUD ────────────────────────────────────────────────────────────────
// Populate the HUD "Live data" section with a hex's bound values from the entity
// graph (resolved by the search IIFE, exposed via window.__atlasBind). Empty/hidden
// for hexes with no data links; rows drill into the full entity detail on click.
function fillHudData(nodeId){
  const el = document.getElementById('hud-data');
  if (!el) return;
  window.__lastHudNode = nodeId;
  // Graph is lazy-loaded; first hex select kicks it off. Until it lands this
  // renders empty, then the load's .then re-fills via __lastHudNode.
  if (nodeId && window.__atlasEnsureGraph) window.__atlasEnsureGraph();
  const items = (nodeId && window.__atlasBind) ? window.__atlasBind(nodeId) : [];
  if (!items || !items.length){ el.innerHTML = ''; el.style.display = 'none'; return; }
  let h = '<div class="hud-dhdr">Live data</div>';
  for (const it of items){
    h += '<div class="hud-drow"' + (it.uid ? (' data-uid="' + it.uid + '"') : '') + '>' +
         '<span class="hud-dlabel">' + it.label + '</span>' +
         (it.value ? ('<span class="hud-dval">' + it.value + '</span>') : '') +
         (it.sub ? ('<span class="hud-dsub">' + it.sub + '</span>') : '') +
         '</div>';
  }
  el.innerHTML = h; el.style.display = 'block';
  el.querySelectorAll('.hud-drow[data-uid]').forEach(r => { r.onclick = () => { if (window.__atlasSelect) window.__atlasSelect(r.getAttribute('data-uid')); }; });
}

// ── CONTENT LINKS ─────────────────────────────────────────────────────────────
// Published site content that deep-links to atlas tiles, inverted at build time
// from _data/rounds.js atlasLinks. Keys are 'zoneId/nodeId' (the hash format).
// Kept OUTSIDE the ZONE_DEFS span that scripts/lib/adapters/atlas-concepts.js
// text-slices — do not move this above ZONE_DEFS.
const CONTENT_LINKS = {};
{%- for entry in rounds.entries %}{% if entry.status == 'published' and entry.atlasLinks %}{% for lnk in entry.atlasLinks %}
(CONTENT_LINKS[{{ lnk.to | dump | safe }}] = CONTENT_LINKS[{{ lnk.to | dump | safe }}] || []).push({ label: {{ entry.title | dump | safe }}, url: '/rounds/{{ entry.slug }}/', icon: '📋' });
{%- endfor %}{% endif %}{% endfor %}

function selectNode(zone,cell) {
  activeNode=cell; activeZone=zone;
  if (typeof window._deselectRoute === 'function') window._deselectRoute();
  if (typeof window._focusZoneRoutes === 'function') window._focusZoneRoutes(zone.id);
  updateHash(zone, cell);
  updateBC(zone,cell);

  const badge=document.getElementById('h-badge');
  badge.textContent=zone.abbr+' · '+zone.label;
  badge.style.setProperty('--hz',zone.color);
  document.getElementById('h-type').textContent=cell.type==='landmark'?'★ Landmark':'◆ Node';
  document.getElementById('hud-title').textContent=(cell.label||'').replace('\n',' ');
  document.getElementById('hud-desc').textContent=cell.desc||'';

  const linksEl=document.getElementById('hud-links');
  const linksCol=document.getElementById('hud-links-col');
  linksEl.innerHTML='';
  const seen=new Set();
  const links=[...(cell.links||[]),...(CONTENT_LINKS[zone.id+'/'+cell.nodeId]||[])]
    .filter(l=>!seen.has(l.url)&&seen.add(l.url));
  linksCol.classList.toggle('has-links', links.length>0);
  links.forEach(lk=>{
    const a=document.createElement('a');
    a.className='hud-link'; a.href=lk.url;
    a.innerHTML=`<span>${lk.icon}</span><span>${lk.label}</span>`;
    linksEl.appendChild(a);
  });
  document.getElementById('atlas-hud').classList.add('open');
  fillHudData(cell.nodeId);

  d3.selectAll('.az-node-cell').each(function(){
    const el=d3.select(this), nid=el.attr('data-nodeid'), zid=el.attr('data-zoneid');
    const on=nid===cell.nodeId&&zid===zone.id;
    const z2=ZONE_DEFS.find(z=>z.id===zid), c2=z2&&z2.cells.find(c=>c.nodeId===nid);
    const op=getCellBaseOpacity(c2);
    el.select('.hex-body')
      .attr('fill-opacity',on?0.38:op.fill)
      .attr('stroke-opacity',on?1.0:op.strk)
      .attr('filter',on?'url(#n-glow)':null);
  });

  // Toggle landmark expansion — any registered landmark expands on click, collapses on re-click
  if (cell.type === 'landmark' && EXPANSION_REGISTRY[cell.nodeId]) {
    if (expandedSet.has(cell.nodeId)) collapseExpansion(cell.nodeId);
    else expandExpansion(cell.nodeId);
  }
  if (typeof window._hlRoutes === 'function') window._hlRoutes(zone.id);
}

function getCellBaseOpacity(c2) {
  const lm = c2&&c2.type==='landmark';
  const terrain = c2&&c2.type==='terrain';
  const frontier = !lm && !terrain && (!c2||!c2.desc||c2.desc.length<20);
  return { fill: lm?0.18:terrain?0.14:frontier?0.07:0.10, strk: lm?0.78:terrain?0.52:frontier?0.22:0.46 };
}

function deselectNode() {
  if (!activeNode) return;
  activeNode=null; closeHud(); updateBC(activeZone,null);
  d3.selectAll('.az-node-cell').each(function(){
    const el=d3.select(this), zid=el.attr('data-zoneid'), nid=el.attr('data-nodeid');
    const z2=ZONE_DEFS.find(z=>z.id===zid), c2=z2&&z2.cells.find(c=>c.nodeId===nid);
    const op=getCellBaseOpacity(c2);
    el.select('.hex-body').attr('fill-opacity',op.fill).attr('stroke-opacity',op.strk).attr('filter',null);
  });
  if (typeof window._focusZoneRoutes === 'function') window._focusZoneRoutes(null);
  if (typeof window._clrRoutes === 'function') window._clrRoutes();
  if (typeof window._deselectRoute === 'function') window._deselectRoute();
}

