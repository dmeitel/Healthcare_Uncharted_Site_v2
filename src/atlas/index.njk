<script src="https://cdn.jsdelivr.net/npm/d3@7"></script>

<style>
#atlas-shell {
  background: #06100a;
  height: calc(100vh - 64px);
  display: flex; flex-direction: column;
  overflow: hidden; position: relative;
  font-family: var(--font);
}
#atlas-tb {
  height: 52px; background: rgba(3,7,6,0.99);
  border-bottom: 2px solid rgba(78,205,196,0.2);
  box-shadow: 0 2px 16px rgba(0,0,0,0.4);
  display: flex; align-items: center;
  padding: 0 16px; gap: 10px; flex-shrink: 0; z-index: 20;
  /* instrument chrome needs an anchor; #atlas-tb is NOT .tool-bar, so there is
     no global sticky top:64px to neutralize — top:0 is belt-and-braces only */
  position: relative; top: 0;
}
/* instrument header: ruler-tick bottom edge, scene-tinted (decorative) */
#atlas-tb::after {
  content: ''; position: absolute; left: 0; right: 0; bottom: 0; height: 3px;
  background: repeating-linear-gradient(90deg, rgba(78,205,196,0.30) 0 1px, transparent 1px 8px);
  pointer-events: none;
}
[data-theme='light'] #atlas-tb::after {
  background: repeating-linear-gradient(90deg, rgba(27,95,168,0.30) 0 1px, transparent 1px 8px);
}
/* logo rides the shared .tool-bar-title (Outfit 13px 700, teal span);
   this rule only keeps the scene's uppercase tracking */
.atlas-logo { letter-spacing: 0.10em; text-transform: uppercase; flex-shrink: 0; }
.atlas-sep { width: 1px; height: 22px; background: rgba(78,205,196,0.15); flex-shrink: 0; }
#atlas-bc { display: flex; align-items: center; flex: 1; overflow: hidden; }
.abc-item { font-size: 13px; color: rgba(140,180,215,0.50); cursor: pointer; padding: 4px 7px; white-space: nowrap; transition: color .12s; flex-shrink: 0; }
.abc-item:hover { color: #E2EEF4; }
.abc-item.active { color: #9B8FE0; font-weight: 600; }
.abc-sep { font-size: 13px; color: rgba(78,205,196,0.25); margin: 0 2px; flex-shrink: 0; }
#atlas-controls { display: flex; gap: 5px; flex-shrink: 0; }
.atlas-btn {
  width: 32px; height: 32px;
  background: rgba(78,205,196,0.04); border: 1px solid rgba(78,205,196,0.18);
  color: rgba(78,205,196,0.60); cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; transition: all .12s; font-family: inherit;
}
.atlas-btn:hover { background: rgba(78,205,196,0.10); border-color: rgba(78,205,196,0.50); color: #4ECDC4; }
.atlas-craft-link { display: flex; align-items: center; gap: 5px; font-family: var(--font); font-size: 12px; font-weight: 600; letter-spacing: 0.03em; color: #4ECDC4; background: rgba(78,205,196,0.08); border: 1px solid rgba(78,205,196,0.35); padding: 5px 12px; text-decoration: none; white-space: nowrap; flex-shrink: 0; transition: all .12s; }
.atlas-craft-link:hover { background: rgba(78,205,196,0.16); border-color: rgba(78,205,196,0.6); color: #7fead9; }
[data-theme='light'] .atlas-craft-link { color: #1B5FA8; background: rgba(27,95,168,0.06); border-color: rgba(27,95,168,0.30); }
[data-theme='light'] .atlas-craft-link:hover { background: rgba(27,95,168,0.12); border-color: rgba(27,95,168,0.55); color: #1B5FA8; }
#atlas-canvas { flex: 1; position: relative; overflow: hidden; }
#atlas-svg { width: 100%; height: 100%; display: block; cursor: grab; touch-action: none; }
#atlas-svg:active { cursor: grabbing; }

/* ── EXPEDITION INSTRUMENT CHROME ─────────────────────────────────────────
   Corner brackets + chart stamp on the map canvas. Decorative only:
   aria-hidden + pointer-events:none, and z-index sits BELOW every overlay
   (hint z-10, find z-30, panels z-40; the layers popover rides z-350 from hu-global).
   NO graticule here — the scene already draws its own hex terrain texture
   and a grid overlay would fight it. */
.chart-corners { position: absolute; inset: 8px; z-index: 4; pointer-events: none; }
.chart-corners i { position: absolute; width: 14px; height: 14px; border: 0 solid rgba(78,205,196,0.35); }
.chart-corners i:nth-child(1) { top: 0; left: 0; border-top-width: 2px; border-left-width: 2px; border-color: var(--teal); }
.chart-corners i:nth-child(2) { top: 0; right: 0; border-top-width: 2px; border-right-width: 2px; }
.chart-corners i:nth-child(3) { bottom: 0; left: 0; border-bottom-width: 2px; border-left-width: 2px; }
.chart-corners i:nth-child(4) { bottom: 0; right: 0; border-bottom-width: 2px; border-right-width: 2px; }
/* stamp lives bottom-right: the only free corner (find panel top-right,
   attribution chip bottom-left, pan hint bottom-center) */
#atlas-stamp {
  position: absolute; right: 16px; bottom: 12px; z-index: 4;
  pointer-events: none; user-select: none; text-align: right;
  font-family: var(--mono); font-size: 9px; letter-spacing: 0.1em; line-height: 1.8;
  color: rgba(140,180,215,0.34);
}
[data-theme='light'] .chart-corners i { border-color: rgba(27,95,168,0.30); }
[data-theme='light'] .chart-corners i:nth-child(1) { border-color: var(--teal-dk); }
[data-theme='light'] #atlas-stamp { color: rgba(15,30,50,0.40); }

/* ── LAYERS PANEL — layer toggles + legend, one surface (Control Architecture v2)
   Primitives (.selector, .selector-pop, .pop-head, .pop-sec, .pop-opt,
   .applied-strip) come from hu-global.css; under 700px the popover renders as
   a bottom sheet automatically. This block only styles the toggle check state
   (options here are multi-select, aria-pressed) and the legend key rows. */
#atlas-layers-pop .pop-opt[aria-pressed="true"] { color: var(--t1); font-weight: 600; }
#atlas-layers-pop .pop-opt[aria-pressed="true"]::after { color: var(--teal); }
[data-theme='light'] #atlas-layers-pop .pop-opt[aria-pressed="true"]::after { color: var(--teal-dk); }
#atlas-layers-pop .pop-opt svg { width: 14px; height: 14px; stroke-width: 1.75; color: var(--teal); flex: none; }
[data-theme='light'] #atlas-layers-pop .pop-opt svg { color: var(--teal-dk); }
/* node-legend glyphs carry inline steel-blue stroke attrs (fine on dark, ~1.4:1 on the
   white popover); presentation attributes lose to any CSS rule, so this flips them */
[data-theme='light'] .leg-row svg polyline,
[data-theme='light'] .leg-row svg path { stroke: #4A5568; }
/* legend key rows (zones/nodes) — non-interactive, aligned with .pop-opt padding */
.leg-row { display: flex; align-items: center; gap: 9px; padding: 3px 10px; }
.leg-line {
  width: 22px; height: 1px; flex-shrink: 0;
  background: repeating-linear-gradient(90deg, currentColor 0, currentColor 4px, transparent 4px, transparent 8px);
  opacity: 0.75;
}
.leg-dot { width: 7px; height: 7px; border-radius: 1px; flex-shrink: 0; opacity: 0.75; }
.leg-lbl { font-family: var(--font); font-size: 12px; color: var(--t2); }
/* visually-hidden utility (tool h1 + the polite live region) */
.vh { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; }

/* ── BOTTOM HUD ────────────────────────────────────────────────────────── */
/* node detail HUD — flows directly under the search field, inside the right-side panel column */
#atlas-hud {
  position: relative; margin-top: 7px; width: 100%;
  max-height: min(58vh, 540px);
  background: rgba(8,14,20,0.97); border: 1px solid rgba(78,205,196,0.24);
  border-radius: 11px; box-shadow: 0 14px 36px rgba(0,0,0,0.5);
  display: none; flex-direction: column; overflow: hidden;
}
#atlas-hud.open { display: flex; }
#hud-grip { display: none; }
#hud-inner { flex: 1; min-height: 0; overflow-y: auto; display: block; }
#hud-inner::-webkit-scrollbar { width: 4px; }
#hud-inner::-webkit-scrollbar-thumb { background: rgba(78,205,196,0.18); }
#hud-id {
  padding: 16px 42px 12px 16px;
  border-bottom: 1px solid rgba(78,205,196,0.10);
  display: flex; flex-direction: column; gap: 7px;
}
.hud-badge {
  display: inline-flex; align-items: center;
  font-family: var(--mono);
  font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--hz, #4ECDC4); border: 1px solid var(--hz, #4ECDC4);
  padding: 3px 10px; width: fit-content; opacity: 0.90;
}
.hud-ktype {
  font-family: var(--mono);
  font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase;
  color: rgba(140,180,215,0.48);
}
#hud-title {
  font-family: var(--display); font-size: 19px; font-weight: 700;
  color: #E2EEF4; line-height: 1.18;
}
#hud-body { display: block; }
#hud-desc-col { padding: 13px 16px; display: block; }
#hud-desc {
  font-family: var(--font);
  font-size: 13px; color: rgba(140,180,215,0.80); line-height: 1.62;
}
#hud-data { margin-top: 11px; padding-top: 10px; border-top: 1px solid rgba(78,205,196,0.14); }
.hud-dhdr { font-family: var(--mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: #4ECDC4; margin-bottom: 7px; display: flex; align-items: center; gap: 6px; }
.hud-dhdr::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: #4ECDC4; box-shadow: 0 0 7px #4ECDC4; }
.hud-drow { display: flex; align-items: baseline; gap: 8px; padding: 4px 0; font-size: 12px; border-bottom: 1px solid rgba(78,205,196,0.06); }
.hud-drow:last-child { border-bottom: none; }
.hud-drow[data-uid] { cursor: pointer; }
.hud-drow[data-uid]:hover .hud-dlabel { color: #4ECDC4; }
.hud-dlabel { color: #cfe0ea; flex: 1; line-height: 1.35; }
.hud-dval { font-family: var(--mono); color: #fff; font-weight: 600; white-space: nowrap; font-variant-numeric: tabular-nums; }
.hud-dsub { font-family: var(--mono); font-size: 9px; letter-spacing: 0.04em; color: rgba(140,180,200,0.6); text-transform: uppercase; }
[data-theme='light'] #hud-data { border-top-color: rgba(27,95,168,0.16); }
[data-theme='light'] .hud-dlabel { color: #22405c; }
[data-theme='light'] .hud-dval { color: #0d1117; }
[data-theme='light'] .hud-dhdr { color: var(--teal-dk); }
[data-theme='light'] .hud-dhdr::before { background: var(--teal-dk); box-shadow: none; }
[data-theme='light'] .hud-dsub { color: rgba(40,70,100,0.65); }
/* zone accent (--hz) arrives dark-tuned from JS — darken badge for contrast on white */
[data-theme='light'] .hud-badge { filter: brightness(.72) saturate(1.3); }
#hud-links-col {
  padding: 2px 16px 16px; display: none; flex-direction: column; gap: 5px;
}
#hud-links-col.has-links { display: flex; }
.hud-lhdr {
  font-family: var(--mono);
  font-size: 8.5px; letter-spacing: 0.14em; text-transform: uppercase;
  color: rgba(78,205,196,0.52); margin-bottom: 6px;
}
.hud-link {
  display: flex; align-items: center; gap: 9px; padding: 7px 11px;
  background: rgba(78,205,196,0.04); border: 1px solid rgba(78,205,196,0.12);
  color: rgba(140,180,215,0.85); font-family: var(--font);
  font-size: 12px; text-decoration: none; transition: all .12s;
}
.hud-link:hover { background: rgba(78,205,196,0.10); border-color: rgba(78,205,196,0.32); color: #E2EEF4; }
#hud-close {
  position: absolute; top: 10px; right: 10px; z-index: 2; margin: 0;
  width: 26px; height: 26px; flex-shrink: 0;
  background: rgba(78,205,196,0.06); border: 1px solid rgba(78,205,196,0.20);
  color: rgba(78,205,196,0.55); cursor: pointer; font-size: 16px;
  display: flex; align-items: center; justify-content: center; transition: all .12s;
}
#hud-close:hover { background: rgba(78,205,196,0.14); border-color: rgba(78,205,196,0.45); color: #4ECDC4; }
#atlas-hint {
  position: absolute; bottom: 16px; left: 50%; transform: translateX(-50%);
  background: rgba(3,8,6,0.82); border: 1px solid rgba(78,205,196,0.1);
  padding: 6px 16px; font-size: 11px; color: rgba(140,180,215,0.42);
  letter-spacing: 0.06em; pointer-events: none; white-space: nowrap;
  z-index: 10; transition: opacity .4s; font-family: var(--font);
}
/* shared attribution chip: bottom-left, clear of the centered hint
   and the right-side find/help panels */
.tool-attribution--fixed {
  left: 16px; right: auto; bottom: 12px;
  background: rgba(3,8,6,0.85); border-color: rgba(78,205,196,0.18);
}
[data-theme='light'] .tool-attribution--fixed { background: rgba(255,255,255,0.92); border-color: rgba(27,95,168,0.15); }
/* ── HELP PANEL ──────────────────────────────────────────────────────────── */
#atlas-help {
  position: absolute; top: 0; right: 0; bottom: 0; z-index: 40;
  width: 320px; background: rgba(2,6,4,0.99);
  border-left: 2px solid rgba(78,205,196,0.22);
  box-shadow: -6px 0 32px rgba(0,0,0,0.6);
  transform: translateX(100%); transition: transform .28s cubic-bezier(.4,0,.2,1);
  display: flex; flex-direction: column; overflow: hidden;
}
#atlas-help.open { transform: translateX(0); }
#help-hdr {
  padding: 16px 18px 12px;
  border-bottom: 1px solid rgba(78,205,196,0.12);
  display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
}
#help-hdr-title {
  font-family: var(--display); font-size: 14px; font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase; color: rgba(78,205,196,0.92);
}
#help-close {
  width: 26px; height: 26px; background: rgba(78,205,196,0.06);
  border: 1px solid rgba(78,205,196,0.18); color: rgba(78,205,196,0.55);
  cursor: pointer; font-size: 15px; display: flex; align-items: center;
  justify-content: center; transition: all .12s;
}
#help-close:hover { background: rgba(78,205,196,0.14); color: #4ECDC4; }
#help-body { flex: 1; overflow-y: auto; padding: 18px; }
#help-body::-webkit-scrollbar { width: 3px; }
#help-body::-webkit-scrollbar-thumb { background: rgba(78,205,196,0.15); }
.help-section { margin-bottom: 22px; }
.help-section:last-child { margin-bottom: 0; }
.help-section-title {
  font-family: var(--mono); font-size: 9px;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: rgba(78,205,196,0.55); margin-bottom: 10px;
  padding-bottom: 6px; border-bottom: 1px solid rgba(78,205,196,0.10);
}
.help-item {
  display: flex; gap: 10px; margin-bottom: 9px; align-items: flex-start;
}
.help-item:last-child { margin-bottom: 0; }
.help-icon {
  font-size: 13px; flex-shrink: 0; width: 20px; text-align: center;
  color: rgba(78,205,196,0.70); margin-top: 1px;
}
.help-text {
  font-family: var(--font); font-size: 13px;
  color: rgba(140,180,215,0.78); line-height: 1.55;
}
.help-text strong { color: rgba(200,220,240,0.90); font-weight: 600; }

/* ── MOBILE ──────────────────────────────────────────────────────────────── */
/* The layers panel is the same surface at every width — the .selector-pop
   primitive renders as a bottom sheet under 700px on its own. Only the
   one-time desktop hint is viewport-conditional. */
#atlas-desk-hint { display: none; }

@media (max-width: 768px) {
  /* instrument chrome steps back on small screens */
  #atlas-stamp { display: none; }
  .atlas-logo { font-size: 12px; }
  /* the Layers trigger compacts to its icon in the crowded phone toolbar */
  #atlas-layers-btn .sel-val, #atlas-layers-btn .sel-caret { display: none; }
  #hud-inner { grid-template-columns: 1fr; }
  #hud-id { border-right: none; border-bottom: 1px solid rgba(78,205,196,0.10); }
  #hud-desc-col { border-right: none; }
  #hud-links-col.has-links { min-width: unset; }
  #atlas-help { width: 100%; }

  #atlas-desk-hint:not([hidden]) {
    display: flex; align-items: center; gap: 10px; flex-shrink: 0;
    padding: 5px 14px;
    background: rgba(78,205,196,0.05); border-bottom: 1px solid rgba(78,205,196,0.12);
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.04em;
    color: var(--t3); line-height: 1.5;
  }
  #atlas-desk-hint span { flex: 1; }
  #adh-x {
    background: none; border: none; color: var(--t3); cursor: pointer;
    font-size: 14px; line-height: 1; padding: 0 2px; font-family: inherit;
  }
}

/* ── LIGHT MODE ──────────────────────────────────────────────────────────── */
[data-theme='light'] #atlas-shell { background: #eaf0eb; }
[data-theme='light'] #atlas-tb { background: rgba(255,255,255,0.97); border-bottom-color: rgba(27,95,168,0.15); box-shadow: 0 2px 12px rgba(0,0,0,0.08); }
[data-theme='light'] .atlas-logo span { color: #1B5FA8; }
[data-theme='light'] .atlas-sep { background: rgba(27,95,168,0.15); }
[data-theme='light'] .abc-item { color: rgba(15,30,50,0.50); }
[data-theme='light'] .abc-item:hover { color: #0d1117; }
[data-theme='light'] .abc-item.active { color: #1B5FA8; }
[data-theme='light'] .abc-sep { color: rgba(27,95,168,0.28); }
[data-theme='light'] .atlas-btn { background: rgba(27,95,168,0.05); border-color: rgba(27,95,168,0.18); color: rgba(27,95,168,0.60); }
[data-theme='light'] .atlas-btn:hover { background: rgba(27,95,168,0.12); border-color: rgba(27,95,168,0.45); color: #1B5FA8; }
[data-theme='light'] #atlas-hud { background: rgba(249,252,250,0.98); border-color: rgba(27,95,168,0.20); box-shadow: 0 14px 36px rgba(0,0,0,0.14); }
[data-theme='light'] #hud-grip { background: rgba(27,95,168,0.025); border-bottom-color: rgba(27,95,168,0.10); }
[data-theme='light'] #hud-grip::after { background: rgba(27,95,168,0.20); }
[data-theme='light'] #hud-grip:hover::after { background: rgba(27,95,168,0.45); }
[data-theme='light'] #hud-id { border-right-color: rgba(27,95,168,0.10); }
[data-theme='light'] .hud-ktype { color: rgba(15,30,50,0.45); }
[data-theme='light'] #hud-title { color: #0d1117; }
[data-theme='light'] #hud-desc-col { border-right-color: rgba(27,95,168,0.10); }
[data-theme='light'] #hud-desc { color: rgba(15,30,50,0.78); }
[data-theme='light'] .hud-lhdr { color: rgba(27,95,168,0.58); }
[data-theme='light'] .hud-link { background: rgba(27,95,168,0.04); border-color: rgba(27,95,168,0.12); color: rgba(15,30,50,0.80); }
[data-theme='light'] .hud-link:hover { background: rgba(27,95,168,0.10); border-color: rgba(27,95,168,0.32); color: #0d1117; }
[data-theme='light'] #hud-close { background: rgba(27,95,168,0.06); border-color: rgba(27,95,168,0.18); color: rgba(27,95,168,0.55); }
[data-theme='light'] #hud-close:hover { background: rgba(27,95,168,0.12); color: #1B5FA8; }
[data-theme='light'] #atlas-hint { background: rgba(255,255,255,0.90); border-color: rgba(27,95,168,0.12); color: rgba(15,30,50,0.48); }
[data-theme='light'] #conn-tooltip { background: rgba(255,255,255,0.99); border-color: rgba(27,95,168,0.25); box-shadow: 0 4px 18px rgba(0,0,0,0.12); }
[data-theme='light'] .ctt-label { color: rgba(27,95,168,0.82); }
[data-theme='light'] .ctt-desc { color: rgba(15,30,50,0.75); }
[data-theme='light'] #atlas-help { background: rgba(249,252,250,0.99); border-left-color: rgba(27,95,168,0.18); box-shadow: -6px 0 32px rgba(0,0,0,0.10); }
[data-theme='light'] #help-hdr { border-bottom-color: rgba(27,95,168,0.12); }
[data-theme='light'] #help-hdr-title { color: #1B5FA8; }
[data-theme='light'] #help-close { background: rgba(27,95,168,0.06); border-color: rgba(27,95,168,0.18); color: rgba(27,95,168,0.55); }
[data-theme='light'] #help-close:hover { background: rgba(27,95,168,0.12); color: #1B5FA8; }
[data-theme='light'] .help-section-title { color: rgba(27,95,168,0.58); border-bottom-color: rgba(27,95,168,0.10); }
[data-theme='light'] .help-icon { color: rgba(27,95,168,0.72); }
[data-theme='light'] .help-text { color: rgba(15,30,50,0.78); }
[data-theme='light'] .help-text strong { color: #0d1117; }
[data-theme='light'] .hub-moat-tile { fill: #eaf0eb; fill-opacity: 1; }
[data-theme='light'] .hub-moat-border { stroke: #1B5FA8; stroke-opacity: 0.18; }
[data-theme='light'] .hub-glow-ring { stroke: #1B5FA8; stroke-opacity: 0.10; }
[data-theme='light'] .hub-tint { fill: #1B5FA8; fill-opacity: 0.05; }
[data-theme='light'] .hub-label-text { fill: #1B5FA8; fill-opacity: 1; }
[data-theme='light'] .az-lbl text { fill: #1a2a3a; fill-opacity: 0.82; }

/* ── ROUTE FLOW ANIMATION ───────────────────────────────────────────────── */
@keyframes routeFlow {
  to { stroke-dashoffset: -27; }
}

/* ── CONNECTION TOOLTIP ──────────────────────────────────────────────────── */
#conn-tooltip {
  position: absolute; pointer-events: none; display: none;
  background: rgba(3,8,6,0.97); border: 1px solid rgba(78,205,196,0.30);
  padding: 8px 13px; max-width: 260px; z-index: 25;
  box-shadow: 0 4px 18px rgba(0,0,0,0.55);
}
.ctt-label {
  font-family: var(--mono); font-size: 9px;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: rgba(78,205,196,0.80); margin-bottom: 5px;
}
