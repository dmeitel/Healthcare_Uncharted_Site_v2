// ── INIT ──────────────────────────────────────────────────────────────────────
requestAnimationFrame(()=>requestAnimationFrame(()=>{
  const t=getInitT();
  svg.call(zoom.transform,t);
  updateLOD(t.k);
  // Apply deep link if URL has a hash on load
  if (location.hash) setTimeout(applyHash, 80);
}));

/* ── UNIFIED ATLAS SEARCH — the entity graph over the whole dataset ───────
   Additive: reads ZONE_DEFS, calls the existing selectNode()/zoomToCell().
   Click any result -> a detail summary right here (facets + connects-to /
   referenced-by, walkable). A concept result also focuses its hex. Matching
   on-atlas concepts glow while you type. */
(function(){
  const inp=document.getElementById('find-input'), resEl=document.getElementById('find-results'),
        detEl=document.getElementById('find-detail'), cntEl=document.getElementById('find-count');
  if(!inp) return;
  const CELL_BY_NODE=new Map();
  ZONE_DEFS.forEach(z=>z.cells.forEach(c=>{ if(c.nodeId) CELL_BY_NODE.set(c.nodeId,{zone:z,cell:c}); }));
  const TC={concept:'#4ECDC4',role:'#5DBF87',facility:'#5BC8FF',metric:'#1B5FA8',supply:'#8E7CFF','patient-state':'#E8A838',expertise:'#9ED4A8',place:'#9AA7B2',system:'#B07BD6'};
  const TL={concept:'On the atlas',role:'Roles',facility:'Facilities',metric:'Metrics',supply:'Supply','patient-state':'Patient states',expertise:'Expertise',place:'Places',system:'Systems'};
  const TN={concept:'Atlas concept',role:'Role',facility:'Facility',metric:'Metric',supply:'Supply','patient-state':'Patient state',expertise:'Expertise',place:'Place',system:'System'};
  const ORDER=['concept','role','expertise','metric','supply','patient-state','system','place','facility'], CAP=8;
  const esc=s=>String(s).replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
  const nodeIdOf=uid=>(uid.indexOf('concept:')===0 && uid.indexOf('concept:zone:')!==0) ? uid.slice(8) : null;
  let GRAPH=[], GBY=new Map(), INC=new Map(), ready=false, graphPromise=null;
  // Lazy: the graph is ~10MB raw. Nothing fetches it until someone shows intent
  // (search focus/typing, a hex select wanting HUD data) or the page goes idle.
  function ensureGraph(){
    if(!graphPromise){
      graphPromise=fetch('/assets/data/derived/search-graph.json').then(r=>r.json()).then(d=>{
        GRAPH=d.nodes; GBY=new Map(GRAPH.map(n=>[n.uid,n]));
        for(const n of GRAPH){ for(const e of (n.rels||[])){ const to=e[1]; let a=INC.get(to); if(!a){a=[];INC.set(to,a);} a.push([e[0],n.uid,e[2]]); } }
        ready=true; if(inp.value) run();
        window.__atlasBind = resolveBindings; window.__atlasSelect = select;
        if (window.__lastHudNode != null && typeof fillHudData === 'function') fillHudData(window.__lastHudNode);
      }).catch(()=>{ graphPromise=null; cntEl.textContent='offline'; });
    }
    return graphPromise;
  }
  window.__atlasEnsureGraph = ensureGraph;

  // Resolve a hex's bound live data from the graph: metric national averages
  // (measured-by) + the entities it represents. Empty for hexes with no links.
  function resolveBindings(nodeId){
    const n = GBY.get('concept:'+nodeId);
    if (!n || !n.rels) return [];
    const out = [];
    for (const e of n.rels){
      const rel = e[0], to = e[1];
      if (rel === 'measured-by'){
        const m = GBY.get(to); if (!m) continue;
        const vals = (m.rels||[]).filter(x=>x[0]==='describes' && typeof x[2]==='number').map(x=>x[2]);
        const avg = vals.length ? Math.round(vals.reduce((a,b)=>a+b,0)/vals.length*10)/10 : null;
        const unit = (m.facets && m.facets.unit) || '';
        let value, sub = vals.length ? 'US avg' : '';
        if (avg == null) value = '—';
        else if (unit === 'Y/N') { value = Math.round(avg*100) + '% of states'; sub = ''; }   // Y/N metrics: share of states
        else if (unit === '#' || unit === 'HPSAs') value = Math.round(avg).toLocaleString() + (unit==='HPSAs' ? ' HPSAs' : '');
        else value = avg + (unit ? (' ' + unit) : '');
        out.push({ label: m.label, value, sub, uid: to });
      } else if (rel === 'represents'){
        const t = GBY.get(to);
        out.push({ label: t ? t.label : to, value: '', sub: t ? t.type : '', uid: to });
      }
    }
    return out;
  }

  function clearHits(){ document.querySelectorAll('.az-node-cell.az-find-hit').forEach(el=>el.classList.remove('az-find-hit')); }
  function highlight(matches){ clearHits(); matches.forEach(n=>{ const nid=nodeIdOf(n.uid); if(nid&&CELL_BY_NODE.has(nid)){ try{ document.querySelectorAll('.az-node-cell[data-nodeid="'+CSS.escape(nid)+'"]').forEach(el=>el.classList.add('az-find-hit')); }catch(e){} } }); }
  function subOf(n){ const f=n.facets||{}; if(n.type==='facility')return [f.state,f.facType].filter(Boolean).join(' · '); if(n.type==='role')return f.family||''; if(n.type==='metric')return f.lens||''; if(n.type==='supply')return f.kind||''; if(n.type==='expertise')return f.group||''; if(n.type==='place')return f.kind||''; return ''; }
  function hl(s,toks){ s=esc(s); toks.forEach(t=>{ if(!t)return; s=s.replace(new RegExp('('+t.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+')','ig'),'<mark>$1</mark>'); }); return s; }

  function run(){
    const toks=inp.value.trim().toLowerCase().split(/\s+/).filter(Boolean);
    if(!ready){
      if(toks.length){ ensureGraph(); cntEl.textContent='…'; resEl.innerHTML='<div class="find-more">loading search index…</div>'; resEl.classList.add('open'); }
      else { resEl.classList.remove('open'); resEl.innerHTML=''; cntEl.textContent=''; }
      return;
    }
    detEl.classList.remove('open');
    if(typeof closeHud==='function') closeHud();
    if(!toks.length){ resEl.classList.remove('open'); resEl.innerHTML=''; cntEl.textContent=''; clearHits(); return; }
    const matches=GRAPH.filter(n=>toks.every(t=>n.search.indexOf(t)>=0));
    cntEl.textContent=matches.length.toLocaleString();
    highlight(matches);
    const g={}; matches.forEach(n=>{(g[n.type]=g[n.type]||[]).push(n);});
    let html='';
    ORDER.filter(t=>g[t]).forEach(t=>{
      const arr=g[t], col=TC[t]||'#9AA7B2';
      html+='<div class="find-grp"><div class="find-grp-h"><span class="find-dot" style="background:'+col+'"></span>'+(TL[t]||t)+' <span class="gn">'+arr.length+'</span></div>';
      arr.slice(0,CAP).forEach(n=>{
        const nid=nodeIdOf(n.uid), onAtlas=!!(nid&&CELL_BY_NODE.has(nid)), sub=subOf(n);
        html+='<div class="find-row" data-uid="'+esc(n.uid)+'">'
          +'<span class="find-dot" style="background:'+col+'"></span>'
          +'<span class="find-lbl">'+hl(n.label,toks)+'</span>'
          +(onAtlas?'<span class="find-on">on map</span>':(sub?'<span class="find-sub">'+esc(sub)+'</span>':''))+'</div>';
      });
      if(arr.length>CAP) html+='<div class="find-more">+'+(arr.length-CAP)+' more — add a word to narrow</div>';
      html+='</div>';
    });
    resEl.innerHTML=html; resEl.classList.add('open');
    resEl.querySelectorAll('.find-row[data-uid]').forEach(row=>row.addEventListener('click',()=>select(row.getAttribute('data-uid'))));
  }

  function select(uid){
    const n=GBY.get(uid); if(!n) return;
    const nid=nodeIdOf(uid);
    if(nid&&CELL_BY_NODE.has(nid)){ const ref=CELL_BY_NODE.get(nid); if(typeof selectNode==='function')selectNode(ref.zone,ref.cell); if(typeof zoomToCell==='function')zoomToCell(ref.cell); if(typeof closeHud==='function')closeHud(); }
    renderDetail(n);
  }

  function relGroups(list,incoming){
    const g={}; list.forEach(a=>{(g[a[0]]=g[a[0]]||[]).push([a[1],a[2]]);});
    let out='';
    for(const rel in g){ const arr=g[rel];
      out+='<div class="fd-rel"><div class="fd-rv'+(incoming?' inc':'')+'">'+(incoming?'← ':'')+esc(rel.replace(/-/g,' '))+' <span class="fd-rn">'+arr.length+'</span></div><div class="fd-chips">';
      arr.slice(0,12).forEach(p=>{ const t=GBY.get(p[0]), col=t?(TC[t.type]||'#9AA7B2'):'#9AA7B2'; out+='<span class="fd-chip" data-uid="'+esc(p[0])+'"><span class="fd-cdot" style="background:'+col+'"></span>'+esc(t?t.label:p[0])+(p[1]!=null?'<span class="fd-cv">'+esc(p[1])+'</span>':'')+'</span>'; });
      if(arr.length>12) out+='<span class="fd-chip" style="cursor:default;opacity:.55">+'+(arr.length-12)+' more</span>';
      out+='</div></div>';
    }
    return out;
  }

  function renderDetail(n){
    const col=TC[n.type]||'#9AA7B2';
    let h='<div class="fd-top"><button class="fd-back" id="fd-back">‹ results</button><span class="fd-type" style="background:'+col+'22;color:'+col+'">'+(TN[n.type]||n.type)+'</span></div>';
    h+='<div class="fd-title">'+esc(n.label)+'</div><div class="fd-uid">'+esc(n.uid)+'</div>';
    const fk=Object.entries(n.facets||{}).filter(kv=>kv[0]!=='layer'&&kv[0]!=='stats');
    if(fk.length) h+='<div class="fd-facets">'+fk.map(kv=>'<span class="fk">'+esc(kv[0])+'</span><span class="fv">'+esc(kv[1])+'</span>').join('')+'</div>';
    const stats=n.facets&&n.facets.stats;
    if(stats&&stats.length){ h+='<div class="fd-sec">data</div><div class="fd-facets">'+stats.map(s=>{const u=s.unit==='%'?'%':s.unit==='$k'?'k':s.unit?(' '+s.unit):''; return '<span class="fk">'+esc(s.label)+'</span><span class="fv">'+esc(s.value+u)+'</span>';}).join('')+'</div>'; }
    if(n.rels&&n.rels.length) h+='<div class="fd-sec">connects to</div>'+relGroups(n.rels,false);
    const inc=INC.get(n.uid)||[];
    if(inc.length) h+='<div class="fd-sec">referenced by</div>'+relGroups(inc,true);
    if(n.href) h+='<a class="fd-link" href="'+esc(n.href)+'" target="_blank" rel="noopener">Open in its tool →</a>';
    detEl.innerHTML=h; detEl.classList.add('open'); resEl.classList.remove('open'); detEl.scrollTop=0;
    detEl.querySelector('#fd-back').onclick=()=>{ detEl.classList.remove('open'); if(inp.value.trim())resEl.classList.add('open'); };
    detEl.querySelectorAll('.fd-chip[data-uid]').forEach(c=>c.onclick=()=>select(c.getAttribute('data-uid')));
  }

  inp.addEventListener('input',run);
  inp.addEventListener('focus',()=>{ ensureGraph(); if(inp.value.trim()&&resEl.innerHTML&&!detEl.classList.contains('open')) resEl.classList.add('open'); });
  inp.addEventListener('keydown',ev=>{ if(ev.key==='Escape'){ inp.value=''; run(); inp.blur(); } });
  document.addEventListener('click',ev=>{ const p=document.getElementById('atlas-find'); if(p&&!p.contains(ev.target)){ resEl.classList.remove('open'); detEl.classList.remove('open'); } });

  // A query can land pre-filled without focus or input events: browser form
  // restoration on back-nav (pageshow) or a value already there at parse time.
  // ensureGraph's .then re-runs the search once the index is in.
  if(inp.value.trim()) ensureGraph();
  window.addEventListener('pageshow',()=>{ if(inp.value.trim()) ensureGraph(); });

  // Idle warm-up: desktop visitors who linger get the index before they type.
  // Never blocks load, and skipped entirely when the visitor asked to save data.
  const conn=navigator.connection;
  if(!(conn&&conn.saveData)){
    if('requestIdleCallback' in window) requestIdleCallback(()=>ensureGraph(),{timeout:8000});
    else setTimeout(ensureGraph,8000);
  }
})();

}());
</script>
