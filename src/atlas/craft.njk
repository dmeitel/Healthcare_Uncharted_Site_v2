/* ---------- color system: element override > category color > default ----------
   catOf(node) = provider (pcat) else raw type. three in-memory maps drive everything
   and persist to localStorage: categoryColors (by category, incl. verifiedLine/userLine),
   elementColors (by node uid), edgeColors (by edge key). */
const DEFAULT_CAT = Object.assign({}, TYPE_COLOR, { provider: PROVIDER_COLOR });
const DEFAULT_LINE = { verifiedLine: '#4ECDC4', userLine: '#8FA6BE' };
const PRESETS = ['#4ECDC4','#6AABFF','#A99EE8','#E8A838','#E879B6','#4EC99A',
                 '#7FA0C4','#F59E6B','#EA7B5B','#DF5752','#F2C94C','#B8CFE8'];
const LS_KEY = 'atlascraft.colors.v1';
const categoryColors = {};   // cat -> hex
const elementColors = {};    // uid -> hex
const edgeColors = {};       // edgeKey -> hex

function catOf(node){ return (node && node.facets && node.facets.pcat === 'provider') ? 'provider' : (node ? node.type : ''); }
function catColor(cat){ return categoryColors[cat] || DEFAULT_CAT[cat] || DEFAULT_LINE[cat] || '#888'; }

/* display resolver: element override wins, then category color, then default.
   the tag is unchanged (provider vs the raw type name). */
function disp(node){
  const cat = catOf(node);
  const color = (node && elementColors[node.uid]) || catColor(cat);
  const tag = cat === 'provider' ? 'provider' : (cat || '').replace('patient-state', 'patient');
  return { color, tag };
}
/* edge color resolver: per-edge override, then the line category, then default */
function edgeColor(e){
  return edgeColors[e.key] || (e.verified ? catColor('verifiedLine') : catColor('userLine'));
}

function loadColors(){
  try {
    const s = JSON.parse(localStorage.getItem(LS_KEY) || '{}');
    Object.assign(categoryColors, s.cat || {});
    Object.assign(elementColors, s.el || {});
    Object.assign(edgeColors, s.edge || {});
  } catch (e) { /* no storage, run with defaults */ }
}
function saveColors(){
  try {
    localStorage.setItem(LS_KEY, JSON.stringify({ cat: categoryColors, el: elementColors, edge: edgeColors }));
  } catch (e) { /* storage blocked, keep in memory only */ }
}

/* live refresh: retint every tile + ghost, re-apply edge colors, rebuild the legend,
   and re-render the search rows + LINKS dots that carry category color */
function recolorAll(){
  for (const it of board.values()){ const n = nodesById.get(it.uid); it.el.style.setProperty('--c', disp(n).color); }
  for (const g of ghosts.values()){ const n = nodesById.get(g.uid); g.el.style.setProperty('--c', disp(n).color); }
  for (const e of edges.values()) applyEdgeColor(e);
  buildLegend();
  renderResults($('search').value);
  renderLinks();
  requestEdgeDraw();
}
function refreshTile(uid){
  const it = board.get(uid);
  if (it) it.el.style.setProperty('--c', disp(nodesById.get(uid)).color);
  renderResults($('search').value);
  renderLinks();
}
function applyEdgeColor(e){ e.g.style.setProperty('--ec', edgeColor(e)); }

/* setters used by the palette panel and the per-element popovers */
function setCategoryColor(cat, c){ categoryColors[cat] = c; saveColors(); recolorAll(); buildPalettePanel(); }
function setElementColor(uid, c){ elementColors[uid] = c; saveColors(); refreshTile(uid); }
function clearElementColor(uid){ delete elementColors[uid]; saveColors(); refreshTile(uid); }
function setEdgeColor(key, c){ edgeColors[key] = c; saveColors(); const e = edges.get(key); if (e){ applyEdgeColor(e); requestEdgeDraw(); } }
function clearEdgeColor(key){ delete edgeColors[key]; saveColors(); const e = edges.get(key); if (e){ applyEdgeColor(e); requestEdgeDraw(); } }
function resetColors(){
  for (const k in categoryColors) delete categoryColors[k];
  for (const k in elementColors) delete elementColors[k];
  for (const k in edgeColors) delete edgeColors[k];
  saveColors(); recolorAll(); buildPalettePanel();
}

/* which hover action buttons a real tile shows (open only when it has an href) */
function actionSpec(node){
  const a = ['links', 'paint'];
  if (node.href) a.push('open');
  a.push('remove');
  return a;
}
const ICONS = {
  links:  '<path d="M4 2 V10 M4 4 H8 M4 8 H8"/>',        // trunk with two branches
  paint:  '<path d="M6 1.6 C6 1.6 2.7 5 2.7 7.4 a3.3 3.3 0 0 0 6.6 0 C9.3 5 6 1.6 6 1.6 Z"/>',  // droplet
  open:   '<path d="M4 8 L9 3 M6 3 H9 V6"/>',            // up-right arrow
  remove: '<path d="M3 3 L9 9 M9 3 L3 9"/>'              // x
};
function iconSvg(name){
  return '<svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" ' +
         'stroke-linecap="round" stroke-linejoin="round">' + ICONS[name] + '</svg>';
}

/* ---------- hex geometry (pointy-top, axial, Atlas exact) ---------- */
const s = 88;                       // hex size, bumped so in-hex names read at 2-3 lines
const sq3 = Math.sqrt(3);
const TILEF = 0.9;                  // tile inset inside its cell, leaves a hairline gap
const HW = sq3 * s;                 // full cell width
const HH = 2 * s;                   // full cell height
const TR = s * TILEF;               // tile radius (circumradius of the drawn hex)
const HEX_DIRS = [[1,0],[1,-1],[0,-1],[-1,0],[-1,1],[0,1]];
function hPx(q, r){ return [sq3*s*q + sq3*s/2*r, 1.5*s*r]; }
// unit vectors to the 6 hex vertices (points), same angles as hPath, used at radius TR.
// order from the top point clockwise: top, upper-right, lower-right, bottom, lower-left, upper-left
const VERT_DIRS = [];
for (let vi = 0; vi < 6; vi++){ const a = Math.PI/3*vi - Math.PI/2; VERT_DIRS.push([Math.cos(a), Math.sin(a)]); }
function hPath(cx, cy, r){
  let d = '';
  for (let i = 0; i < 6; i++){
    const a = Math.PI/3*i - Math.PI/2;               // first corner at top = pointy-top
    d += (i ? 'L' : 'M') + (cx + r*Math.cos(a)).toFixed(1) + ',' + (cy + r*Math.sin(a)).toFixed(1);
  }
  return d + 'Z';
}
function cubeRound(qf, rf){
  let x = qf, z = rf, y = -x - z;
  let rx = Math.round(x), ry = Math.round(y), rz = Math.round(z);
  const dx = Math.abs(rx-x), dy = Math.abs(ry-y), dz = Math.abs(rz-z);
  if (dx > dy && dx > dz) rx = -ry - rz;
  else if (dy > dz) ry = -rx - rz;
  else rz = -rx - ry;
  return [rx, rz];
}
/* pixel -> nearest cell: invert hPx, then cube-round */
function pixelToCell(x, y){
  const qf = (sq3/3 * x - 1/3 * y) / s;
  const rf = (2/3 * y) / s;
  return cubeRound(qf, rf);
}

/* ---------- state ---------- */
const nodesById = new Map();   // uid -> graph node
const adj = new Map();         // uid -> [{rel, other, out, value}]  (undirected, mirrored)
const board = new Map();       // uid -> {uid,q,r,px,py,el,hex,handle}
const cells = new Map();       // "q,r" -> uid  (one node per cell)
const edges = new Map();       // key -> {a,b,verified,rel,value,g,wire,hit,arrow,pill,text}
const ghosts = new Map();      // neighborUid -> preview {uid,q,r,px,py,el,out,rel,arrowG,gwire,ghead,gtext}
let ghostMoreEl = null;        // "+N more" chip when neighbors exceed the ghost cap
const view = { x:0, y:0, k:1 };
let selected = null;           // selected node uid
let selectedEdge = null;       // selected edge key
let pendingCell = null;        // [q,r] awaiting a chosen card from the palette
let interacting = false;       // suppresses hover during node drag / connect
let rafPending = false;
let activeType = 'all';        // palette type filter

const $ = id => document.getElementById(id);
const boardEl = $('board'), worldEl = $('world'), svg = $('edges'), tempEdge = $('tempEdge');

/* ---------- boot ---------- */
if (!GRAPH || !GRAPH.nodes) {
  $('nodata').style.display = 'flex';
} else {
  init();
}

function init(){
  for (const n of GRAPH.nodes) nodesById.set(n.uid, n);
  for (const n of GRAPH.nodes){
    for (const r of (n.rels || [])){
      const [rel, target, value] = r;
      if (!nodesById.has(target)) continue;
      pushAdj(n.uid, { rel, other: target, out: true, value });
      pushAdj(target, { rel, other: n.uid, out: false, value });
    }
  }
  loadColors();          // restore saved category / element / edge colors before first paint
  buildLegend();
  buildChips();
  buildPalettePanel();
  bindBoard();
  bindPalette();
  bindKeys();
  // center-plus hex sits at world origin (0,0)
  $('gridCenter').querySelector('path').setAttribute('d', hPath(0, 0, s));
  const cpt = $('gridCenter').querySelector('text');
  cpt.setAttribute('x', 0); cpt.setAttribute('y', s*0.33); cpt.setAttribute('font-size', s*0.95);
  $('gridHoverPlus').setAttribute('font-size', s*0.5);
  $('btnGrid').addEventListener('click', () => {
    const hidden = $('grid').classList.toggle('hidden');
    $('btnGrid').classList.toggle('on', !hidden);
  });
  $('btnPalette').addEventListener('click', () => {
    const open = $('palettePanel').classList.toggle('open');
    $('btnPalette').classList.toggle('on', open);
  });
  $('btnReset').addEventListener('click', resetBoard);
  $('btnFit').addEventListener('click', fitView);
  $('rightToggle').addEventListener('click', () => {
    const closed = $('right').classList.toggle('closed');
    $('rightToggle').innerHTML = closed ? '&#9666;' : '&#9656;';
  });
  window.addEventListener('resize', () => { applyView(); });
  // origin at viewport center so the center-plus reads as the middle of the board
  const rc = boardEl.getBoundingClientRect();
  view.x = rc.width / 2; view.y = rc.height / 2;
  applyView();
  renderResults('');
  renderLinks();
  updateStats();
  updateCenterPlus();   // board starts empty, center-plus visible
}

function pushAdj(uid, entry){
  let a = adj.get(uid);
  if (!a){ a = []; adj.set(uid, a); }
  a.push(entry);
}

/* ---------- header legend + palette chips ---------- */
function buildLegend(){
  const el = $('legend');
  el.innerHTML = '';   // rebuilt on any category recolor
  // type swatches, plus the provider presentation category, using current category colors
  const cats = Object.keys(TYPE_COLOR).concat(['provider']);
  for (const cat of cats){
    const s2 = document.createElement('span');
    s2.innerHTML = '<i style="background:' + catColor(cat) + '"></i>' + cat.replace('patient-state','patient');
    el.appendChild(s2);
  }
}
/* per-category palette panel (top-bar Palette button toggles it) */
function buildPalettePanel(){
  const p = $('palettePanel');
  p.innerHTML = '';
  const head = document.createElement('div');
  head.className = 'pp-head';
  head.textContent = 'PALETTE';
  p.appendChild(head);
  const rows = [
    ['concept','Concept'],['provider','Provider'],['role','Role'],['expertise','Expertise'],
    ['metric','Metric'],['vendor','Vendor'],['patient-state','Patient'],['place','Place'],['supply','Supply'],
    ['verifiedLine','Verified line'],['userLine','User link']
  ];
  for (const [cat, label] of rows){
    const row = document.createElement('div');
    row.className = 'pp-row' + (cat === 'verifiedLine' ? ' pp-sep' : '');
    const sw = document.createElement('button');
    sw.className = 'pp-sw';
    sw.style.background = catColor(cat);
    sw.title = 'Set ' + label + ' color';
    sw.addEventListener('click', ev => {
      ev.stopPropagation();
      openColorPopover(ev.clientX, ev.clientY, catColor(cat), { onPick: c => setCategoryColor(cat, c) });
    });
    const nm = document.createElement('span');
    nm.className = 'pp-name';
    nm.textContent = label;
    row.appendChild(sw); row.appendChild(nm);
    p.appendChild(row);
  }
  const reset = document.createElement('button');
  reset.id = 'btnResetColors';
  reset.textContent = 'Reset colors';
  reset.addEventListener('click', resetColors);
  p.appendChild(reset);
}
function buildChips(){
  const defs = [
    ['all','All'],['concept','Concept'],['role','Role'],['expertise','Expertise'],
    ['metric','Metric'],['vendor','Vendor'],['patient-state','Patient'],['place','Place'],
    ['provider','Provider']
  ];
  const wrap = $('chips');
  for (const [val, label] of defs){
    const b = document.createElement('button');
    b.className = 'chip' + (val === 'all' ? ' on' : '');
    b.textContent = label;
    b.dataset.type = val;
    b.addEventListener('click', () => {
      activeType = val;
      wrap.querySelectorAll('.chip').forEach(c => c.classList.toggle('on', c === b));
      renderResults($('search').value);
    });
    wrap.appendChild(b);
  }
}

/* ---------- search ---------- */
function bindPalette(){
  $('search').addEventListener('input', e => renderResults(e.target.value));
}
function searchNodes(q){
  q = q.trim().toLowerCase();
  const out = [];
  for (const n of GRAPH.nodes){
    // provider chip filters by presentation category (spans concept + expertise types)
    if (activeType === 'provider'){ if (!(n.facets && n.facets.pcat === 'provider')) continue; }
    else if (activeType !== 'all' && n.type !== activeType) continue;
    if (!q){ out.push([5, n]); continue; }
    const lbl = n.label.toLowerCase();
    let score = -1;
    if (lbl === q) score = 0;
    else if (lbl.startsWith(q)) score = 1;
    else if (n.search.startsWith(q)) score = 2;
    else if (n.search.includes(' ' + q)) score = 3;
    else if (n.search.includes(q)) score = 4;
    if (score >= 0) out.push([score, n]);
  }
  out.sort((a, b) => a[0] - b[0] || a[1].label.localeCompare(b[1].label));
  return out.slice(0, 60).map(x => x[1]);
}
function renderResults(q){
  const wrap = $('results');
  wrap.innerHTML = '';
  const hits = searchNodes(q);
  $('noresults').style.display = hits.length ? 'none' : 'block';
  for (const n of hits){
    const d = disp(n);
    const row = document.createElement('div');
    row.className = 'result' + (board.has(n.uid) ? ' onboard' : '');
    row.innerHTML =
      '<div class="r1"><span class="dot" style="background:' + d.color + '"></span>' +
      '<span class="lbl"></span><span class="tag" style="color:' + d.color + '"></span></div>' +
      '<span class="uid"></span>';
    row.querySelector('.lbl').textContent = n.label;
    row.querySelector('.tag').textContent = d.tag;
    row.querySelector('.uid').textContent = n.uid;
    bindResultDrag(row, n);
    wrap.appendChild(row);
  }
}

/* drag a result onto a specific cell, or click to drop into the pending / origin cell */
function bindResultDrag(row, node){
  row.addEventListener('pointerdown', e => {
    if (e.button !== 0) return;
    e.preventDefault();
    const sx = e.clientX, sy = e.clientY;
    let dragging = false;
    const ghost = $('ghost');
    const move = ev => {
      if (!dragging && Math.hypot(ev.clientX - sx, ev.clientY - sy) > 5){
        dragging = true;
        ghost.textContent = node.label;
        ghost.style.display = 'block';
      }
      if (dragging){
        ghost.style.left = (ev.clientX + 10) + 'px';
        ghost.style.top = (ev.clientY + 10) + 'px';
      }
    };
    const up = ev => {
      window.removeEventListener('pointermove', move);
      window.removeEventListener('pointerup', up);
      ghost.style.display = 'none';
      const r = boardEl.getBoundingClientRect();
      if (dragging && ev.clientX >= r.left && ev.clientX <= r.right &&
          ev.clientY >= r.top && ev.clientY <= r.bottom){
        const [wx, wy] = clientToWorld(ev.clientX, ev.clientY);
        const [q, rr] = pixelToCell(wx, wy);
        addToBoard(node.uid, q, rr);        // nearest free if that cell is taken
        clearPending();
      } else if (!dragging){
        if (pendingCell){ addToBoard(node.uid, pendingCell[0], pendingCell[1]); clearPending(); }
        else addToBoard(node.uid, 0, 0);    // nearest free cell to the origin
      }
    };
    window.addEventListener('pointermove', move);
    window.addEventListener('pointerup', up);
  });
}

/* ---------- coords + view ---------- */
function clientToWorld(cx, cy){
  const r = boardEl.getBoundingClientRect();
  return [ (cx - r.left - view.x) / view.k, (cy - r.top - view.y) / view.k ];
}
function applyView(){
  worldEl.style.transform = 'translate(' + view.x + 'px,' + view.y + 'px) scale(' + view.k + ')';
  drawGrid();
  requestEdgeDraw();
}

/* draw all cell outlines in view as ONE path, cheap to rebuild per pan frame */
function drawGrid(){
  const r = boardEl.getBoundingClientRect();
  const xmin = (0 - view.x) / view.k, xmax = (r.width - view.x) / view.k;
  const ymin = (0 - view.y) / view.k, ymax = (r.height - view.y) / view.k;
  const rmin = Math.floor((2/3 * ymin) / s) - 1;
  const rmax = Math.ceil((2/3 * ymax) / s) + 1;
  let d = '';
  for (let rr = rmin; rr <= rmax; rr++){
    const qmin = Math.floor(xmin / (sq3*s) - rr/2) - 1;
    const qmax = Math.ceil(xmax / (sq3*s) - rr/2) + 1;
    for (let qq = qmin; qq <= qmax; qq++){
      const [cx, cy] = hPx(qq, rr);
      d += hPath(cx, cy, s);
    }
  }
  $('gridCells').setAttribute('d', d);
}

/* ---------- board: pan, click-empty-cell add-flow, hover + ---------- */
function bindBoard(){
  let panning = false, moved = false, px = 0, py = 0;
  boardEl.addEventListener('pointerdown', e => {
    if (e.button !== 0) return;
    if (e.target.closest('.node') || e.target.closest('.edge')) return;
    panning = true; moved = false; px = e.clientX; py = e.clientY;
    boardEl.classList.add('panning');
    boardEl.setPointerCapture(e.pointerId);
  });
  boardEl.addEventListener('pointermove', e => {
    if (panning){
      if (!moved && Math.hypot(e.clientX - px, e.clientY - py) > 4) moved = true;
      view.x += e.clientX - px; view.y += e.clientY - py;
      px = e.clientX; py = e.clientY;
      applyView();
    } else {
      updateHover(e);
    }
  });
  boardEl.addEventListener('pointerup', e => {
    if (!panning) return;
    panning = false; boardEl.classList.remove('panning');
    if (moved) return;                        // it was a pan, not a click
    clearEdgeSelection();
    const [wx, wy] = clientToWorld(e.clientX, e.clientY);
    const [q, r] = pixelToCell(wx, wy);
    const key = q + ',' + r;
    if (cells.has(key)){ selectNode(cells.get(key)); }
    else { clearSelection(); openAddFlow(q, r); }
  });
  boardEl.addEventListener('pointercancel', () => { panning = false; boardEl.classList.remove('panning'); });
  boardEl.addEventListener('pointerleave', hideHover);
  boardEl.addEventListener('wheel', e => {
    e.preventDefault();
    const r = boardEl.getBoundingClientRect();
    const mx = e.clientX - r.left, my = e.clientY - r.top;
    const k2 = Math.min(2.5, Math.max(0.3, view.k * Math.exp(-e.deltaY * 0.0014)));
    view.x = mx - (mx - view.x) * (k2 / view.k);
    view.y = my - (my - view.y) * (k2 / view.k);
    view.k = k2;
    applyView();
  }, { passive: false });
}

function updateHover(e){
  if (interacting || pendingCell){ hideHover(); return; }
  const [wx, wy] = clientToWorld(e.clientX, e.clientY);
  const [q, r] = pixelToCell(wx, wy);
  if (cells.has(q + ',' + r)){ hideHover(); return; }
  const [cx, cy] = hPx(q, r);
  const hv = $('gridHover'); hv.setAttribute('d', hPath(cx, cy, s)); hv.style.display = '';
  const hp = $('gridHoverPlus'); hp.setAttribute('x', cx); hp.setAttribute('y', cy + s*0.18); hp.style.display = '';
}
function hideHover(){ $('gridHover').style.display = 'none'; $('gridHoverPlus').style.display = 'none'; }

function openAddFlow(q, r){
  pendingCell = [q, r];
  hideHover();
  const [cx, cy] = hPx(q, r);
  const pg = $('gridPending'); pg.setAttribute('d', hPath(cx, cy, s)); pg.style.display = '';
  $('addHint').style.display = 'block';
  const inp = $('search');
  inp.focus(); if (inp.select) inp.select();
  toast('Pick a card to drop into this cell');
}
function clearPending(){
  pendingCell = null;
  $('gridPending').style.display = 'none';
  $('addHint').style.display = 'none';
}

/* ---------- keyboard ---------- */
function bindKeys(){
  window.addEventListener('keydown', e => {
    if (e.target.tagName === 'INPUT'){ if (e.key === 'Escape') e.target.blur(); return; }
    if (e.key === 'Escape'){ clearSelection(); clearEdgeSelection(); clearPending(); }
    if (e.key === 'Delete' || e.key === 'Backspace'){
      if (selectedEdge){ removeEdge(selectedEdge); }   // removeEdge clears selectedEdge + handles
      else if (selected){ removeFromBoard(selected); selected = null; renderLinks(); }
    }
  });
}

/* ---------- cells (one node per cell) ---------- */
function nearestFreeCell(cq, cr){
  if (!cells.has(cq + ',' + cr)) return [cq, cr];
  // hex spiral outward: ring by ring, first free cell wins
  for (let k = 1; k < 400; k++){
    let q = cq + HEX_DIRS[4][0]*k, r = cr + HEX_DIRS[4][1]*k;
    for (let side = 0; side < 6; side++){
      for (let step = 0; step < k; step++){
        if (!cells.has(q + ',' + r)) return [q, r];
        q += HEX_DIRS[side][0]; r += HEX_DIRS[side][1];
      }
    }
  }
  return [cq, cr];
}

/* ---------- add / remove nodes ---------- */
function addToBoard(uid, q, r, defer){
  if (board.has(uid)) return board.get(uid);
  const node = nodesById.get(uid);
  if (!node) return null;
  const [tq, tr] = nearestFreeCell(q, r);
  cells.set(tq + ',' + tr, uid);
  const [px, py] = hPx(tq, tr);

  const el = makeCard(node);
  worldEl.appendChild(el);
  const item = { uid, q: tq, r: tr, px, py, el, hex: el.querySelector('.hex') };
  board.set(uid, item);
  positionCard(item);

  el.classList.add('spawn');
  el.addEventListener('animationend', () => el.classList.remove('spawn'), { once: true });

  if (!defer){
    requestEdgeDraw();
    updateStats();
    renderResults($('search').value);
    renderLinks();
    updateCenterPlus();
    hideHover();
  }
  return item;
}

function makeCard(node){
  const d = disp(node);
  const NS = 'http://www.w3.org/2000/svg';
  const el = document.createElement('div');
  el.className = 'node';
  el.style.setProperty('--c', d.color);
  el.style.width = HW + 'px'; el.style.height = HH + 'px';   // real box so children center
  el.dataset.uid = node.uid;

  const tile = document.createElementNS(NS, 'svg');
  tile.setAttribute('class', 'tile');
  tile.setAttribute('width', HW); tile.setAttribute('height', HH);
  tile.setAttribute('viewBox', '0 0 ' + HW + ' ' + HH);
  const hex = document.createElementNS(NS, 'path');
  hex.setAttribute('class', 'hex');
  hex.setAttribute('d', hPath(HW/2, HH/2, TR));
  const ttl = document.createElementNS(NS, 'title');
  ttl.textContent = node.label;
  hex.appendChild(ttl);
  tile.appendChild(hex);
  el.appendChild(tile);

  const body = document.createElement('div');
  body.className = 'body';
  const lbl = document.createElement('span');
  lbl.className = 'lbl';
  lbl.textContent = node.label;
  body.appendChild(lbl);
  el.appendChild(body);

  const tag = document.createElement('span');
  tag.className = 'tag';
  tag.textContent = d.tag;
  tag.style.top = (HH/2 - TR * 0.5) + 'px';   // just inside the top point
  el.appendChild(tag);

  // hover action cluster (real tiles only; ghosts never get these), sitting inside
  // the hex near the top, clearly below the top-point nub
  const actions = document.createElement('div');
  actions.className = 'actions';
  actions.style.top = (HH/2 - TR * 0.44) + 'px';
  const ATITLE = { remove: 'Remove tile', links: 'Show connections', open: 'Open source', paint: 'Recolor tile' };
  for (const act of actionSpec(node)){
    const b = document.createElement('button');
    b.className = 'abtn' + (act === 'remove' ? ' danger' : '');
    b.title = ATITLE[act] || act;
    b.innerHTML = iconSvg(act);
    b.dataset.act = act;
    b.addEventListener('pointerdown', e => e.stopPropagation());
    b.addEventListener('click', e => { e.stopPropagation(); onTileAction(act, node.uid, e); });
    actions.appendChild(b);
  }
  actions.addEventListener('pointerenter', () => hoverOn(node.uid));
  actions.addEventListener('pointerleave', () => hoverOff(node.uid));
  el.appendChild(actions);

  // six connection nubs at the hex vertices (points): drag any to wire this tile to another
  const cx = HW/2, cy = HH/2;
  for (let i = 0; i < 6; i++){
    const [vx, vy] = VERT_DIRS[i];
    const nub = document.createElement('div');
    nub.className = 'nub';
    nub.style.left = (cx + TR * vx) + 'px';
    nub.style.top = (cy + TR * vy) + 'px';
    nub.title = 'Drag to connect';
    nub.addEventListener('pointerenter', () => hoverOn(node.uid));
    nub.addEventListener('pointerleave', () => hoverOff(node.uid));
    bindNub(nub, node.uid, i);
    el.appendChild(nub);
  }

  if (node.ext){
    const parts = [];
    for (const [k, v] of Object.entries(node.ext)){
      parts.push('+' + Number(v).toLocaleString('en-US') + ' ' + (EXT_LABEL[k] || k));
    }
    if (parts.length){
      const ext = document.createElement('div');
      ext.className = 'ext';
      ext.textContent = parts.join(' · ');
      el.appendChild(ext);
    }
  }

  bindCard(hex, node.uid);
  return el;
}

function positionCard(item){
  item.el.style.transform = 'translate(' + (item.px - HW/2) + 'px,' + (item.py - HH/2) + 'px)';
}

function removeFromBoard(uid){
  const item = board.get(uid);
  if (!item) return;
  clearIsolate();
  item.el.remove();
  cells.delete(item.q + ',' + item.r);
  board.delete(uid);
  for (const [key, e] of [...edges]){
    if (e.from === uid || e.to === uid){
      e.g.remove(); edges.delete(key);
      if (selectedEdge === key){ hideEdgeHandles(); selectedEdge = null; }
    }
  }
  if (selected === uid) selected = null;
  // a removed real tile can flip a neighbor on/off board, so rebuild the preview
  if (selected && board.has(selected)) revealAndGhost(selected);
  else clearGhosts();
  updateStats();
  renderResults($('search').value);
  renderLinks();
  updateCenterPlus();
}

function resetBoard(){
  clearIsolate();
  clearGhosts();
  hideEdgeHandles();
  for (const item of board.values()) item.el.remove();
  board.clear();
  cells.clear();
  for (const e of edges.values()) e.g.remove();
  edges.clear();
  selected = null;
  selectedEdge = null;
  clearPending();
  updateStats();
  renderResults($('search').value);
  renderLinks();
  updateCenterPlus();
}

function updateCenterPlus(){
  $('gridCenter').style.display = board.size === 0 ? '' : 'none';
}

/* ---------- card interaction: reposition + snap (body), select (click), connect (handle) ---------- */
function bindCard(hex, uid){
  hex.addEventListener('pointerdown', e => {
    if (e.button !== 0) return;
    e.preventDefault(); e.stopPropagation();
    const item = board.get(uid);
    if (!item) return;
    interacting = true;
    const sx = e.clientX, sy = e.clientY;
    const opx = item.px, opy = item.py;
    let moved = false;
    hex.setPointerCapture(e.pointerId);
    const move = ev => {
      if (!moved && Math.hypot(ev.clientX - sx, ev.clientY - sy) > 4){
        moved = true;
        item.el.classList.add('dragging');
        clearIsolate();
        if (uid === selected) clearGhosts();   // ghosts re-fan around the new spot on drop
      }
      if (!moved) return;
      item.px = opx + (ev.clientX - sx) / view.k;
      item.py = opy + (ev.clientY - sy) / view.k;
      positionCard(item);
      requestEdgeDraw();
    };
    const up = () => {
      hex.removeEventListener('pointermove', move);
      hex.removeEventListener('pointerup', up);
      item.el.classList.remove('dragging');
      interacting = false;
      if (moved){ snapToCell(item); if (uid === selected) revealAndGhost(uid); }
      else selectNode(uid);
    };
    hex.addEventListener('pointermove', move);
    hex.addEventListener('pointerup', up);
  });
  hex.addEventListener('pointerenter', () => hoverOn(uid));
  hex.addEventListener('pointerleave', () => hoverOff(uid));
}

/* 'hot' reveals the connect handle + action cluster (the node box is
   pointer-events:none, so CSS :hover cannot see it). a short debounce keeps
   'hot' alive while the pointer crosses the gap from hex to the floating buttons */
let hoveredUid = null, hotTimer = null;
function hoverOn(uid){
  if (hotTimer){ clearTimeout(hotTimer); hotTimer = null; }
  if (hoveredUid && hoveredUid !== uid){
    const p = board.get(hoveredUid); if (p) p.el.classList.remove('hot');
  }
  hoveredUid = uid;
  const it = board.get(uid); if (it) it.el.classList.add('hot');
  if (!interacting) isolate(uid);
}
function hoverOff(uid){
  if (hotTimer) clearTimeout(hotTimer);
  hotTimer = setTimeout(() => {
    hotTimer = null;
    if (hoveredUid !== uid) return;            // moved onto another part of the same node
    const it = board.get(uid); if (it) it.el.classList.remove('hot');
    hoveredUid = null;
    if (!interacting) clearIsolate();
  }, 90);
}

/* tile hover buttons: remove (tile + edges + ghosts), links (select + ghosts), open */
function onTileAction(act, uid, ev){
  if (act === 'remove'){ removeFromBoard(uid); }
  else if (act === 'links'){ selectNode(uid); }
  else if (act === 'open'){ const n = nodesById.get(uid); if (n && n.href) window.open(n.href, '_blank'); }
  else if (act === 'paint'){
    const cur = elementColors[uid] || disp(nodesById.get(uid)).color;
    openColorPopover(ev.clientX, ev.clientY, cur, {
      showClear: true,
      onPick: c => setElementColor(uid, c),
      onClear: () => clearElementColor(uid)
    });
  }
}

/* ---------- color popover (12 presets + native custom + optional clear) ---------- */
function normalizeHex(c){
  if (typeof c !== 'string') return null;
  const m = c.trim().match(/^#([0-9a-fA-F]{6})$/);
  return m ? ('#' + m[1].toLowerCase()) : null;
}
function closeColorPopover(){
  const pop = $('colorPop');
  if (pop) pop.remove();
  window.removeEventListener('pointerdown', popOutside, true);
}
function popOutside(e){
  const pop = document.getElementById('colorPop');
  if (pop && !pop.contains(e.target)) closeColorPopover();
}
function openColorPopover(cx, cy, current, opts){
  closeColorPopover();
  const pop = document.createElement('div');
  pop.id = 'colorPop';
  pop.className = 'colorpop';
  const grid = document.createElement('div');
  grid.className = 'cp-grid';
  for (const c of PRESETS){
    const sw = document.createElement('button');
    sw.className = 'cp-sw' + (normalizeHex(c) === normalizeHex(current) ? ' on' : '');
    sw.style.background = c;
    sw.title = c;
    sw.addEventListener('click', () => { opts.onPick(c); closeColorPopover(); });
    grid.appendChild(sw);
  }
  pop.appendChild(grid);
  const row = document.createElement('div');
  row.className = 'cp-row';
  const inp = document.createElement('input');
  inp.type = 'color';
  inp.value = normalizeHex(current) || '#4ECDC4';
  inp.addEventListener('input', () => opts.onPick(inp.value));   // live as the user drags
  const lbl = document.createElement('span');
  lbl.textContent = 'Custom';
  row.appendChild(inp); row.appendChild(lbl);
  pop.appendChild(row);
  if (opts.showClear){
    const clr = document.createElement('button');
    clr.className = 'cp-clear';
    clr.textContent = 'Clear override';
    clr.addEventListener('click', () => { opts.onClear(); closeColorPopover(); });
    pop.appendChild(clr);
  }
  document.body.appendChild(pop);
  const pw = pop.offsetWidth || 190, ph = pop.offsetHeight || 150;
  let x = cx, y = cy + 10;
  if (x + pw > window.innerWidth - 8) x = window.innerWidth - 8 - pw;
  if (y + ph > window.innerHeight - 8) y = cy - 10 - ph;
  pop.style.left = Math.max(8, x) + 'px';
  pop.style.top = Math.max(8, y) + 'px';
  setTimeout(() => window.addEventListener('pointerdown', popOutside, true), 0);
}

/* snap a dropped tile to the nearest cell, spiralling out if that cell is taken */
function snapToCell(item){
  const [q, r] = pixelToCell(item.px, item.py);
  cells.delete(item.q + ',' + item.r);          // free own cell so it can snap back
  const [tq, tr] = nearestFreeCell(q, r);
  cells.set(tq + ',' + tr, item.uid);
  item.q = tq; item.r = tr;
  [item.px, item.py] = hPx(tq, tr);
  positionCard(item);
  requestEdgeDraw();
}

/* nub drag = draw a point-to-point link. starts at the grabbed vertex (fromV);
   while over a candidate tile its 6 nubs light up and the wire snaps to the NEAREST
   target vertex; drop commits toV = that vertex, drop on empty cancels */
function bindNub(nub, srcUid, fromV){
  nub.addEventListener('pointerdown', e => {
    if (e.button !== 0) return;
    e.preventDefault(); e.stopPropagation();
    if (!board.has(srcUid)) return;
    interacting = true;
    let target = null, snapV = null;
    const [sx, sy] = vertexPoint(srcUid, fromV);
    svg.style.pointerEvents = 'none';
    tempEdge.style.display = '';
    hideHover();
    const move = ev => {
      const [wx, wy] = clientToWorld(ev.clientX, ev.clientY);
      const under = document.elementFromPoint(ev.clientX, ev.clientY);
      const card = under && under.closest ? under.closest('.node') : null;
      const tid = card && card.dataset ? card.dataset.uid : null;
      clearSnap();
      // only real tiles are valid targets (ghost tiles are .node too, so guard on board)
      if (tid && tid !== srcUid && board.has(tid)){
        target = tid; snapV = nearestVertex(tid, wx, wy);
        const tt = board.get(tid);
        tt.el.classList.add('linktarget');
        const nubEl = tt.el.querySelectorAll('.nub')[snapV];
        if (nubEl) nubEl.classList.add('snap');
        const [tx, ty] = vertexPoint(tid, snapV);
        tempEdge.setAttribute('d', edgePath(sx, sy, tx, ty).d);
      } else {
        target = null; snapV = null;
        tempEdge.setAttribute('d', edgePath(sx, sy, wx, wy).d);
      }
    };
    const up = () => {
      window.removeEventListener('pointermove', move);
      window.removeEventListener('pointerup', up);
      tempEdge.style.display = 'none';
      svg.style.pointerEvents = '';
      interacting = false;
      clearSnap();
      if (target && snapV !== null) createEdgeVerts(srcUid, fromV, target, snapV);
    };
    window.addEventListener('pointermove', move);
    window.addEventListener('pointerup', up);
  });
}

/* ---------- selection ---------- */
function selectNode(uid){
  clearEdgeSelection();
  clearPending();
  clearSelection();
  selected = uid;
  const it = board.get(uid);
  if (it) it.el.classList.add('selected');
  revealAndGhost(uid);   // solid arrows to present neighbors, ghost stubs for available ones
  renderLinks();
}
function clearSelection(){
  if (selected){
    const it = board.get(selected);
    if (it) it.el.classList.remove('selected');
  }
  selected = null;
  clearGhosts();
  renderLinks();
}

/* ---------- real-link assist + point-to-point edges ----------
   an edge anchors to CHOSEN vertices: { from, fromV, to, toV }. dedup is on the
   unordered pair of (tile, vertex) endpoints, so a point can fan out to many tiles
   and only an EXACT duplicate endpoint pair is rejected. */
let ehFrom = null, ehTo = null, ehPaint = null;   // endpoint edit handles + paint button

function endKey(uid, v){ return uid + '#' + v; }
function edgeKey2(from, fromV, to, toV){
  const a = endKey(from, fromV), b = endKey(to, toV);
  return a < b ? a + '|' + b : b + '|' + a;
}
function directRel(a, b){
  for (const n of (adj.get(a) || [])){
    if (n.other === b) return { rel: n.rel, value: n.value, out: n.out };
  }
  return null;
}
function relText(rel, value){
  let lbl = REL_LABEL[rel] || rel.replace(/-/g, ' ');
  if (value !== undefined && value !== null){
    const num = typeof value === 'number'
      ? value.toLocaleString('en-US', { maximumFractionDigits: 1 }) : String(value);
    lbl += ' · ' + num;
  }
  return lbl;
}
/* world point of a tile vertex (0..5), at circumradius TR along the vertex angle */
function vertexPoint(uid, v){
  const it = board.get(uid);
  if (!it) return [0, 0];
  return [it.px + TR * VERT_DIRS[v][0], it.py + TR * VERT_DIRS[v][1]];
}
function nearestVertex(uid, wx, wy){
  let best = 0, bd = Infinity;
  for (let i = 0; i < 6; i++){
    const p = vertexPoint(uid, i);
    const d = Math.hypot(p[0] - wx, p[1] - wy);
    if (d < bd){ bd = d; best = i; }
  }
  return best;
}
/* vertex of `uid` whose point faces the center of `towardUid` (auto anchoring) */
function facingVertex(uid, towardUid){
  const ot = board.get(towardUid);
  return ot ? nearestVertex(uid, ot.px, ot.py) : 0;
}
/* any committed edge between two tiles, ignoring which vertices (for the LINKS panel) */
function hasEdgeBetween(a, b){
  for (const e of edges.values()){
    if ((e.from === a && e.to === b) || (e.from === b && e.to === a)) return true;
  }
  return false;
}

/* panel / reveal / ghost convenience: auto-pick the FACING vertex pair so they read
   point-anchored too (source vertex nearest the target, target vertex nearest the source) */
function createEdge(a, b){ return createEdgeFacing(a, b); }
function createEdgeFacing(a, b){
  if (a === b || !board.has(a) || !board.has(b)) return null;
  return createEdgeVerts(a, facingVertex(a, b), b, facingVertex(b, a));
}
/* the real constructor: anchor to explicit vertices, reject only exact duplicates */
function createEdgeVerts(from, fromV, to, toV){
  if (from === to) return null;
  const key = edgeKey2(from, fromV, to, toV);
  if (edges.has(key)){
    const ex = edges.get(key);        // flash the existing one so the drop is not silent
    ex.g.classList.add('selected');
    setTimeout(() => { if (selectedEdge !== key) ex.g.classList.remove('selected'); }, 500);
    return ex;
  }
  const e = makeEdge(key);
  e.from = from; e.fromV = fromV; e.to = to; e.toV = toV;
  reevalEdge(e);
  edges.set(key, e);
  requestEdgeDraw();
  updateStats();
  return e;
}

function makeEdge(key){
  const NS = 'http://www.w3.org/2000/svg';
  const g = document.createElementNS(NS, 'g');
  g.setAttribute('class', 'edge user');
  const hit = document.createElementNS(NS, 'path'); hit.setAttribute('class', 'hit');
  const wire = document.createElementNS(NS, 'path'); wire.setAttribute('class', 'wire');
  const arrow = document.createElementNS(NS, 'path'); arrow.setAttribute('class', 'arrow');
  const pill = document.createElementNS(NS, 'rect'); pill.setAttribute('class', 'pill');
  pill.setAttribute('rx', '7'); pill.setAttribute('height', '15');
  const text = document.createElementNS(NS, 'text');
  // paint order: hit (wide target) < wire < arrowhead < pill backing < label
  g.appendChild(hit); g.appendChild(wire); g.appendChild(arrow);
  g.appendChild(pill); g.appendChild(text);
  svg.appendChild(g);
  g.addEventListener('click', ev => { ev.stopPropagation(); selectEdge(key); });
  g.addEventListener('pointerenter', () => emphEdge(key, true));
  g.addEventListener('pointerleave', () => emphEdge(key, false));
  return { key, g, wire, hit, arrow, pill, text, dragFloat: null };
}

/* (re)evaluate the rel for an edge's current endpoints. fwd = true means the arrow
   points at `to` (from is the source per the data). a re-pointed edge flips here. */
function reevalEdge(e){
  const rel = directRel(e.from, e.to);
  e.verified = !!rel;
  e.rel = rel ? rel.rel : null;
  e.value = rel ? rel.value : null;
  e.fwd = rel ? rel.out : true;
  e.g.setAttribute('class', 'edge ' + (e.verified ? 'verified' : 'user') +
    (e.key === selectedEdge ? ' selected' : ''));
  e.text.textContent = e.verified ? relText(e.rel, e.value) : 'your link';
  applyEdgeColor(e);   // verified/user default may have changed
}

function removeEdge(key){
  const e = edges.get(key);
  if (!e) return;
  e.g.remove();
  edges.delete(key);
  if (selectedEdge === key){ hideEdgeHandles(); selectedEdge = null; }
  updateStats();
  renderLinks();
}
function selectEdge(key){
  clearSelection();
  clearEdgeSelection();
  selectedEdge = key;
  const e = edges.get(key);
  if (!e) return;
  e.g.classList.add('selected');
  showEdgeHandles();
  requestEdgeDraw();
}
function clearEdgeSelection(){
  if (selectedEdge){
    const e = edges.get(selectedEdge);
    if (e) e.g.classList.remove('selected');
  }
  hideEdgeHandles();
  selectedEdge = null;
}
function emphEdge(key, on){
  const e = edges.get(key);
  if (!e) return;
  for (const u of [e.from, e.to]){
    const it = board.get(u);
    if (it) it.el.classList.toggle('emph', on);
  }
}

/* ---------- edit links: draggable endpoint handles + a midpoint paint button ---------- */
function showEdgeHandles(){
  hideEdgeHandles();
  const e = edges.get(selectedEdge);
  ehFrom = mkEdgeHandle('from');
  ehTo = mkEdgeHandle('to');
  ehPaint = document.createElement('div');
  ehPaint.className = 'epaint';
  ehPaint.title = 'Recolor link';
  ehPaint.innerHTML = iconSvg('paint');
  ehPaint.addEventListener('pointerdown', ev => ev.stopPropagation());
  ehPaint.addEventListener('click', ev => {
    ev.stopPropagation();
    const key = selectedEdge, ed = edges.get(key);
    if (!ed) return;
    openColorPopover(ev.clientX, ev.clientY, edgeColors[key] || edgeColor(ed), {
      showClear: true,
      onPick: c => setEdgeColor(key, c),
      onClear: () => clearEdgeColor(key)
    });
  });
  worldEl.appendChild(ehFrom);
  worldEl.appendChild(ehTo);
  worldEl.appendChild(ehPaint);
  if (e){   // position now so they do not flash at the world origin before the first draw
    const fp = vertexPoint(e.from, e.fromV), tp = vertexPoint(e.to, e.toV);
    ehFrom.style.transform = 'translate(' + (fp[0] - 8) + 'px,' + (fp[1] - 8) + 'px)';
    ehTo.style.transform = 'translate(' + (tp[0] - 8) + 'px,' + (tp[1] - 8) + 'px)';
  }
}
function hideEdgeHandles(){
  if (ehFrom){ ehFrom.remove(); ehFrom = null; }
  if (ehTo){ ehTo.remove(); ehTo = null; }
  if (ehPaint){ ehPaint.remove(); ehPaint = null; }
}
function mkEdgeHandle(which){
  const el = document.createElement('div');
  el.className = 'ehandle';
  el.title = 'Drag to re-point this end';
  bindEdgeHandle(el, which);
  return el;
}
function clearSnap(){
  worldEl.querySelectorAll('.nub.snap').forEach(n => n.classList.remove('snap'));
  worldEl.querySelectorAll('.node.linktarget').forEach(n => n.classList.remove('linktarget'));
}
/* drag one endpoint to a new tile+vertex; re-evaluates verified/user on the new pair,
   reverts on empty, rejects an exact-duplicate re-point */
function bindEdgeHandle(el, which){
  el.addEventListener('pointerdown', e => {
    if (e.button !== 0) return;
    e.preventDefault(); e.stopPropagation();
    const key = selectedEdge;
    const ed = edges.get(key);
    if (!ed) return;
    interacting = true;
    const orig = which === 'from' ? { uid: ed.from, v: ed.fromV } : { uid: ed.to, v: ed.toV };
    let snapUid = null, snapV = null;
    svg.style.pointerEvents = 'none';
    const setEnd = (uid, v) => { if (which === 'from'){ ed.from = uid; ed.fromV = v; } else { ed.to = uid; ed.toV = v; } };
    const move = ev => {
      const [wx, wy] = clientToWorld(ev.clientX, ev.clientY);
      const under = document.elementFromPoint(ev.clientX, ev.clientY);
      const card = under && under.closest ? under.closest('.node') : null;
      const tid = card && card.dataset ? card.dataset.uid : null;
      const otherUid = which === 'from' ? ed.to : ed.from;
      clearSnap();
      if (tid && board.has(tid) && tid !== otherUid){
        snapUid = tid; snapV = nearestVertex(tid, wx, wy);
        const tt = board.get(tid);
        tt.el.classList.add('linktarget');
        const nubEl = tt.el.querySelectorAll('.nub')[snapV];
        if (nubEl) nubEl.classList.add('snap');
        setEnd(snapUid, snapV); ed.dragFloat = null;
        reevalEdge(ed);                                  // live flip verified <-> user
      } else {
        snapUid = null; snapV = null;
        setEnd(orig.uid, orig.v);                        // preview against original pairing
        reevalEdge(ed);
        ed.dragFloat = { which, x: wx, y: wy };          // wire floats to the cursor
      }
      requestEdgeDraw();
    };
    const up = () => {
      window.removeEventListener('pointermove', move);
      window.removeEventListener('pointerup', up);
      svg.style.pointerEvents = '';
      interacting = false;
      clearSnap();
      ed.dragFloat = null;
      if (snapUid){
        const newKey = edgeKey2(ed.from, ed.fromV, ed.to, ed.toV);
        const clash = edges.get(newKey);
        if (clash && clash !== ed){                      // exact duplicate -> revert
          setEnd(orig.uid, orig.v); reevalEdge(ed);
          toast('that exact link already exists');
        } else if (newKey !== key){                      // re-key the map to the new endpoints
          edges.delete(key); edges.set(newKey, ed); ed.key = newKey; selectedEdge = newKey;
          reevalEdge(ed);
        }
      } else {
        setEnd(orig.uid, orig.v); reevalEdge(ed);         // dropped on empty -> revert
      }
      updateStats(); renderLinks(); requestEdgeDraw();
    };
    window.addEventListener('pointermove', move);
    window.addEventListener('pointerup', up);
  });
}

/* simple bowed quadratic center-to-cursor, used by the live connect line + ghost arrows */
function edgePath(x1, y1, x2, y2){
  const dx = x2 - x1, dy = y2 - y1;
  const dist = Math.hypot(dx, dy) || 1;
  const bow = Math.min(46, dist * 0.14);
  const mx = (x1 + x2) / 2 - (dy / dist) * bow;
  const my = (y1 + y2) / 2 + (dx / dist) * bow;
  return { d: 'M' + x1 + ' ' + y1 + ' Q' + mx + ' ' + my + ' ' + x2 + ' ' + y2, mx, my };
}

/* center-to-center bowed curve TRIMMED to tile boundaries (ghost preview arrows) */
function edgeGeom(x1, y1, x2, y2){
  const dx = x2 - x1, dy = y2 - y1;
  const dist = Math.hypot(dx, dy) || 1;
  const bow = Math.min(46, dist * 0.16);
  const mx = (x1 + x2) / 2 - (dy / dist) * bow;
  const my = (y1 + y2) / 2 + (dx / dist) * bow;
  const trim = Math.min(TR * 0.92, dist * 0.4);
  let s1x = mx - x1, s1y = my - y1; const sl = Math.hypot(s1x, s1y) || 1; s1x /= sl; s1y /= sl;
  let e1x = x2 - mx, e1y = y2 - my; const el = Math.hypot(e1x, e1y) || 1; e1x /= el; e1y /= el;
  const sx = x1 + s1x * trim, sy = y1 + s1y * trim;
  const ex = x2 - e1x * trim, ey = y2 - e1y * trim;
  const d = 'M' + sx.toFixed(1) + ' ' + sy.toFixed(1) + ' Q' + mx.toFixed(1) + ' ' + my.toFixed(1) +
            ' ' + ex.toFixed(1) + ' ' + ey.toFixed(1);
  const midx = 0.25 * sx + 0.5 * mx + 0.25 * ex;
  const midy = 0.25 * sy + 0.5 * my + 0.25 * ey;
  const ang = Math.atan2(e1y, e1x) * 180 / Math.PI;
  return { d, sx, sy, ex, ey, midx, midy, ang };
}

/* vertex-to-vertex bowed curve: the endpoints are already ON the tile outline, so the
   wire starts at the source vertex and the arrowhead tip lands on the target vertex */
function edgeGeomV(x1, y1, x2, y2){
  const dx = x2 - x1, dy = y2 - y1, dist = Math.hypot(dx, dy) || 1;
  const bow = Math.min(46, dist * 0.16);
  const mx = (x1 + x2) / 2 - (dy / dist) * bow;
  const my = (y1 + y2) / 2 + (dx / dist) * bow;
  let e1x = x2 - mx, e1y = y2 - my; const el = Math.hypot(e1x, e1y) || 1; e1x /= el; e1y /= el;
  const wex = x2 - e1x * 9, wey = y2 - e1y * 9;          // stop the wire just short of the head
  const d = 'M' + x1.toFixed(1) + ' ' + y1.toFixed(1) + ' Q' + mx.toFixed(1) + ' ' + my.toFixed(1) +
            ' ' + wex.toFixed(1) + ' ' + wey.toFixed(1);
  const midx = 0.25 * x1 + 0.5 * mx + 0.25 * wex;
  const midy = 0.25 * y1 + 0.5 * my + 0.25 * wey;
  const ang = Math.atan2(e1y, e1x) * 180 / Math.PI;
  return { d, midx, midy, ang, tipx: x2, tipy: y2 };
}

function requestEdgeDraw(){
  if (rafPending) return;
  rafPending = true;
  requestAnimationFrame(() => { rafPending = false; drawEdges(); drawGhosts(); });
}

function drawEdges(){
  for (const e of edges.values()){
    if (!board.has(e.from) || !board.has(e.to)) continue;
    let fp = vertexPoint(e.from, e.fromV);
    let tp = vertexPoint(e.to, e.toV);
    if (e.dragFloat){
      if (e.dragFloat.which === 'from') fp = [e.dragFloat.x, e.dragFloat.y];
      else tp = [e.dragFloat.x, e.dragFloat.y];
    }
    // arrow points at the rel target; if verified and !fwd, the target is `from`
    let sx, sy, tx, ty;
    if (e.verified && !e.fwd){ sx = tp[0]; sy = tp[1]; tx = fp[0]; ty = fp[1]; }
    else { sx = fp[0]; sy = fp[1]; tx = tp[0]; ty = tp[1]; }
    const gm = edgeGeomV(sx, sy, tx, ty);
    e.wire.setAttribute('d', gm.d);
    e.hit.setAttribute('d', gm.d);
    const w = e.text.textContent.length * 5.4 + 14;
    e.pill.setAttribute('x', gm.midx - w / 2);
    e.pill.setAttribute('y', gm.midy - 8.5);
    e.pill.setAttribute('width', w);
    e.text.setAttribute('x', gm.midx);
    e.text.setAttribute('y', gm.midy + 3);
    if (e.verified){
      e.arrow.setAttribute('d', 'M-9 -4 L0 0 L-9 4 Z');   // filled head, tip on the target vertex
      e.arrow.setAttribute('transform', 'translate(' + gm.tipx + ' ' + gm.tipy + ') rotate(' + gm.ang + ')');
    }
    if (e.key === selectedEdge && ehFrom && ehTo){
      ehFrom.style.transform = 'translate(' + (fp[0] - 8) + 'px,' + (fp[1] - 8) + 'px)';
      ehTo.style.transform = 'translate(' + (tp[0] - 8) + 'px,' + (tp[1] - 8) + 'px)';
      if (ehPaint) ehPaint.style.transform = 'translate(' + (gm.midx - 11) + 'px,' + (gm.midy - 24) + 'px)';
    }
  }
}

/* ghost preview arrows track the selected tile (source) and each ghost cell */
function drawGhosts(){
  if (!selected || !board.has(selected)){ return; }
  const sel = board.get(selected);
  for (const g of ghosts.values()){
    // arrowhead lands on the target per the atlas rel direction
    const [x1, y1, x2, y2] = g.out ? [sel.px, sel.py, g.px, g.py] : [g.px, g.py, sel.px, sel.py];
    const gm = edgeGeom(x1, y1, x2, y2);
    g.gwire.setAttribute('d', gm.d);
    g.ghead.setAttribute('d', 'M-8 -3.5 L0 0 L-8 3.5 Z');
    g.ghead.setAttribute('transform', 'translate(' + gm.ex + ' ' + gm.ey + ') rotate(' + gm.ang + ')');
    g.gtext.setAttribute('x', gm.midx);
    g.gtext.setAttribute('y', gm.midy - 4);
  }
}

/* ---------- isolate on hover ---------- */
function isolate(uid){
  boardEl.classList.add('isolate');
  const lit = new Set([uid]);
  for (const e of edges.values()){
    const inc = e.from === uid || e.to === uid;
    e.g.classList.toggle('lit', inc);
    if (inc){ lit.add(e.from); lit.add(e.to); }
  }
  for (const item of board.values()){
    item.el.classList.toggle('lit', lit.has(item.uid));
  }
}
function clearIsolate(){
  boardEl.classList.remove('isolate');
  worldEl.querySelectorAll('.lit').forEach(n => n.classList.remove('lit'));
  svg.querySelectorAll('.lit').forEach(n => n.classList.remove('lit'));
}

/* ---------- LINKS inspector ---------- */
function neighborsOf(uid){
  const seen = new Set(), out = [];
  for (const n of (adj.get(uid) || [])){
    if (seen.has(n.other)) continue;
    seen.add(n.other);
    out.push(n);
  }
  out.sort((a, b) => (a.rel < b.rel ? -1 : a.rel > b.rel ? 1 : 0) ||
    nodesById.get(a.other).label.localeCompare(nodesById.get(b.other).label));
  return out;
}
function renderLinks(){
  const head = $('linksSel'), list = $('linksList'), hint = $('linksHint');
  if (!selected || !board.has(selected)){
    head.style.display = 'none';
    list.innerHTML = '';
    list.appendChild(hint);
    hint.style.display = 'block';
    return;
  }
  hint.style.display = 'none';
  const node = nodesById.get(selected);
  const neigh = neighborsOf(selected);

  head.style.display = 'block';
  head.innerHTML =
    '<div class="name"></div><div class="sub"></div><button id="addAll">Add all real links</button>';
  head.querySelector('.name').textContent = node.label;
  head.querySelector('.sub').textContent =
    disp(node).tag.toUpperCase() + ' · ' +
    neigh.length + (neigh.length === 1 ? ' direct link' : ' direct links');
  const addAll = head.querySelector('#addAll');
  const missing = neigh.filter(n => !board.has(n.other) || !hasEdgeBetween(selected, n.other));
  addAll.disabled = missing.length === 0;
  addAll.textContent = missing.length ? ('Add all real links (' + missing.length + ')') : 'All real links added';
  addAll.addEventListener('click', () => addAllLinks(selected));

  list.innerHTML = '';
  if (!neigh.length){
    const empty = document.createElement('div');
    empty.id = 'linksHint';
    empty.textContent = 'No direct atlas links for this one. You can still draw a manual line from its handle.';
    list.appendChild(empty);
    return;
  }
  for (const n of neigh){
    const nn = nodesById.get(n.other);
    const nc = disp(nn).color;
    const onBoard = board.has(n.other);
    const linked = hasEdgeBetween(selected, n.other);
    const row = document.createElement('div');
    row.className = 'lrow';
    row.innerHTML =
      '<div class="li"><div class="rel"></div>' +
      '<div class="nl"><span class="ndot" style="background:' + nc + '"></span>' +
      '<span class="nn"></span></div></div>';
    row.querySelector('.rel').textContent = REL_LABEL[n.rel] || n.rel.replace(/-/g, ' ');
    row.querySelector('.nn').textContent = nn.label;
    if (linked){
      const d = document.createElement('span');
      d.className = 'done'; d.textContent = '✓ linked';
      row.appendChild(d);
    } else {
      const b = document.createElement('button');
      b.className = 'act';
      b.textContent = onBoard ? '+ Link' : '+ Add';
      b.addEventListener('click', () => {
        if (board.has(n.other)) linkNeighbor(selected, n.other);
        else addNeighbor(selected, n.other);
      });
      row.appendChild(b);
    }
    list.appendChild(row);
  }
}

/* fan a real neighbor into a free cell around the source, then draw the verified edge */
function addNeighbor(srcUid, uid){
  const src = board.get(srcUid);
  addToBoard(uid, src.q, src.r);   // nearestFreeCell from source = adjacent ring, spiralling out
  createEdge(srcUid, uid);
  renderLinks();
}
function linkNeighbor(srcUid, uid){
  createEdge(srcUid, uid);
  renderLinks();
}
function addAllLinks(srcUid){
  const src = board.get(srcUid);
  const neigh = neighborsOf(srcUid);
  for (const n of neigh){
    if (!board.has(n.other)) addToBoard(n.other, src.q, src.r, true);   // fan into terrain
  }
  for (const n of neigh) createEdge(srcUid, n.other);
  requestEdgeDraw();
  updateStats();
  renderResults($('search').value);
  renderLinks();
  updateCenterPlus();
}

function updateStats(){
  $('stats').textContent = board.size + (board.size === 1 ? ' node, ' : ' nodes, ') +
    edges.size + (edges.size === 1 ? ' link' : ' links');
}

/* ---------- ghost neighbors (the headline: preview + reveal on select) ---------- */
const GHOST_CAP = 14;

/* on select: draw solid verified arrows to on-board neighbors, ghost stubs for the rest */
function revealAndGhost(uid){
  clearGhosts();
  const it = board.get(uid);
  if (!it) return;
  const neigh = neighborsOf(uid);
  // 1) reveal existing links: verified directional edges to neighbors already present
  for (const n of neigh){
    if (board.has(n.other) && !hasEdgeBetween(uid, n.other)) createEdge(uid, n.other);
  }
  // 2) ghost the off-board neighbors, capped, fanned into nearby free cells
  const off = neigh.filter(n => !board.has(n.other));
  const show = off.slice(0, GHOST_CAP);
  const cellList = buildGhostCells(it.q, it.r, show.length);
  for (let i = 0; i < show.length; i++){
    const c = cellList[i];
    if (!c) break;   // ran out of nearby free cells
    makeGhost(uid, show[i], c[0], c[1]);
  }
  const overflow = off.length - show.length;
  if (overflow > 0) showOverflowChip(it, overflow);
  requestEdgeDraw();
}

/* free cells around a center: ring-1 (the 6 adjacents) first, then spiral outward.
   reads real occupancy AND cells already claimed by other ghosts; never mutates cells */
function buildGhostCells(cq, cr, count){
  const used = new Set();
  const res = [];
  for (let k = 1; k < 400 && res.length < count; k++){
    let q = cq + HEX_DIRS[4][0]*k, r = cr + HEX_DIRS[4][1]*k;
    for (let side = 0; side < 6 && res.length < count; side++){
      for (let step = 0; step < k && res.length < count; step++){
        const key = q + ',' + r;
        if (!cells.has(key) && !used.has(key)){ used.add(key); res.push([q, r]); }
        q += HEX_DIRS[side][0]; r += HEX_DIRS[side][1];
      }
    }
  }
  return res;
}

function makeGhost(srcUid, entry, q, r){
  const nbUid = entry.other;
  const node = nodesById.get(nbUid);
  const [px, py] = hPx(q, r);
  const el = makeGhostTile(node);
  worldEl.appendChild(el);
  el.style.transform = 'translate(' + (px - HW/2) + 'px,' + (py - HH/2) + 'px)';
  const ar = makeGhostArrow(entry);
  const g = { uid: nbUid, q, r, px, py, el, out: entry.out, rel: entry.rel,
              arrowG: ar.arrowG, gwire: ar.gwire, ghead: ar.ghead, gtext: ar.gtext };
  ghosts.set(nbUid, g);
  const hex = el.querySelector('.hex');
  hex.addEventListener('click', ev => { ev.stopPropagation(); materializeGhost(nbUid); });
  el.addEventListener('pointerenter', () => { el.classList.add('ghost-hot'); ar.arrowG.classList.add('hot'); });
  el.addEventListener('pointerleave', () => { el.classList.remove('ghost-hot'); ar.arrowG.classList.remove('hot'); });
}

function makeGhostTile(node){
  const d = disp(node);
  const NS = 'http://www.w3.org/2000/svg';
  const el = document.createElement('div');
  el.className = 'node ghost';
  el.style.setProperty('--c', d.color);
  el.style.width = HW + 'px'; el.style.height = HH + 'px';   // same real box as real tiles
  el.dataset.uid = node.uid;
  const tile = document.createElementNS(NS, 'svg');
  tile.setAttribute('class', 'tile');
  tile.setAttribute('width', HW); tile.setAttribute('height', HH);
  tile.setAttribute('viewBox', '0 0 ' + HW + ' ' + HH);
  const hex = document.createElementNS(NS, 'path');
  hex.setAttribute('class', 'hex');
  hex.setAttribute('d', hPath(HW/2, HH/2, TR));
  const ttl = document.createElementNS(NS, 'title');
  ttl.textContent = node.label + ' (click to add)';
  hex.appendChild(ttl);
  tile.appendChild(hex);
  el.appendChild(tile);
  const body = document.createElement('div');
  body.className = 'body';
  const lbl = document.createElement('span');
  lbl.className = 'lbl';
  lbl.textContent = node.label;
  body.appendChild(lbl);
  el.appendChild(body);
  const tag = document.createElement('span');
  tag.className = 'tag';
  tag.textContent = d.tag;
  tag.style.top = (HH/2 - TR * 0.5) + 'px';
  el.appendChild(tag);
  return el;
}

function makeGhostArrow(entry){
  const NS = 'http://www.w3.org/2000/svg';
  const g = document.createElementNS(NS, 'g'); g.setAttribute('class', 'gedge');
  const gwire = document.createElementNS(NS, 'path'); gwire.setAttribute('class', 'gwire');
  const ghead = document.createElementNS(NS, 'path'); ghead.setAttribute('class', 'ghead');
  const gtext = document.createElementNS(NS, 'text');
  gtext.textContent = REL_LABEL[entry.rel] || entry.rel.replace(/-/g, ' ');
  g.appendChild(gwire); g.appendChild(ghead); g.appendChild(gtext);
  $('ghostArrows').appendChild(g);
  return { arrowG: g, gwire, ghead, gtext };
}

function showOverflowChip(it, n){
  const el = document.createElement('div');
  el.className = 'ghost-more';
  el.textContent = '+' + n.toLocaleString('en-US') + ' more';
  worldEl.appendChild(el);
  el.style.transform = 'translate(' + (it.px - HW/2 + 8) + 'px,' + (it.py - HH/2 - 4) + 'px)';
  ghostMoreEl = el;
}

/* click a ghost -> commit it: real tile in that cell, verified edge, keep source selected */
function materializeGhost(nbUid){
  const g = ghosts.get(nbUid);
  if (!g) return;
  const src = selected;
  addToBoard(nbUid, g.q, g.r);          // g cell was left free, so it lands exactly there
  if (src && board.has(src)){
    createEdge(src, nbUid);             // solid verified directional arrow
    revealAndGhost(src);                // rebuild so remaining ghosts stay, overflow refills
  }
  renderLinks();
}

function clearGhosts(){
  for (const g of ghosts.values()){ g.el.remove(); g.arrowG.remove(); }
  ghosts.clear();
  if (ghostMoreEl){ ghostMoreEl.remove(); ghostMoreEl = null; }
}

/* ---------- fit + toast ---------- */
function fitView(){ fitToUids([...board.keys()]); }
function fitToUids(uids){
  if (!uids.length) return;
  let x1 = Infinity, y1 = Infinity, x2 = -Infinity, y2 = -Infinity;
  for (const u of uids){
    const it = board.get(u);
    if (!it) continue;
    x1 = Math.min(x1, it.px - HW/2); y1 = Math.min(y1, it.py - HH/2);
    x2 = Math.max(x2, it.px + HW/2); y2 = Math.max(y2, it.py + HH/2);
  }
  if (x1 === Infinity) return;
  const r = boardEl.getBoundingClientRect();
  const pad = 90;
  const k = Math.min(2.5, Math.max(0.3,
    Math.min((r.width - pad*2) / Math.max(1, x2 - x1), (r.height - pad*2) / Math.max(1, y2 - y1), 1.4)));
  view.k = k;
  view.x = r.width / 2 - (x1 + x2) / 2 * k;
  view.y = r.height / 2 - (y1 + y2) / 2 * k;
  applyView();
}

let toastTimer = null;
function toast(msg){
  const t = $('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2400);
}
</script>

