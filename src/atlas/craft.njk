---
layout: base.njk
permalink: /atlas/craft/
title: Atlas Craft
description: A hex-grid canvas for exploring the healthcare atlas.
navPage: atlas
no_footer: true
---
{% raw %}
<style>
/* ---------- tokens ----------
   Scene palette (deliberate green-black terrain look) lives under --craft-*
   names so it never repaints the global nav or inverts the global tokens.
   Accents (--teal/--blue), fonts (--display/--font/--mono) come from hu-global. */
:root{
  --craft-dark:#060d09; --craft-surface:#080f0b; --craft-raised:#0f1a14; --craft-raised2:#16241c;
  --craft-border:rgba(78,205,196,0.14); --craft-border2:rgba(78,205,196,0.24);
  --craft-t1:#FFFFFF; --craft-t2:#b8cfe8; --craft-t3:#5A7898;
  --board:#06100a;
  --c-concept:#4ECDC4; --c-role:#6AABFF; --c-expertise:#A99EE8; --c-metric:#E8A838;
  --c-vendor:#E879B6; --c-patient-state:#4EC99A; --c-place:#7FA0C4; --c-supply:#F59E6B;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden}
body{background:var(--craft-dark);color:var(--craft-t1);font-family:var(--font);font-size:14px}

/* ---------- app frame ---------- */
/* position:relative so the .shell-gate overlay (auto-appears <900px) can
   pin itself to the whole app region */
#app{display:flex;flex-direction:column;height:calc(100vh - 64px);position:relative}
/* shared .tool-bar chrome, pinned into this page's height-locked flex shell:
   sticky is meaningless here (nothing scrolls), so position is forced back to
   relative and the scene keeps its own background/border. */
header.tool-bar{
  position:relative;top:0;height:52px;min-height:52px;flex:0 0 52px;
  display:flex;align-items:center;gap:14px;padding:0 16px;
  background:rgba(3,7,6,0.99);border-bottom:2px solid rgba(78,205,196,0.2);z-index:20;
  box-shadow:0 2px 16px rgba(0,0,0,0.4);backdrop-filter:none;
}
header.tool-bar .tool-bar-title{color:var(--craft-t1);letter-spacing:.12em}
header.tool-bar .tool-bar-crumb{font-size:10.5px;color:var(--craft-t3);letter-spacing:.04em}
.legend{display:flex;gap:10px;align-items:center;font-family:var(--mono);font-size:9.5px;color:var(--craft-t3);flex-wrap:nowrap}
.legend span{display:inline-flex;align-items:center;gap:4px;white-space:nowrap}
.legend i{width:7px;height:7px;border-radius:2px;display:inline-block}
.btn{
  font-family:var(--display);font-size:12px;letter-spacing:.06em;color:rgba(78,205,196,0.72);
  background:rgba(78,205,196,0.04);border:1px solid rgba(78,205,196,0.18);border-radius:999px;
  padding:6px 14px;cursor:pointer;transition:all .15s;
}
.btn:hover{color:#4ECDC4;border-color:rgba(78,205,196,0.5);background:rgba(78,205,196,0.10)}
.btn.on{color:#062024;background:var(--teal);border-color:var(--teal);font-weight:600}

#main{flex:1;display:flex;min-height:0}

/* ---------- left palette ---------- */
#palette{
  width:280px;flex:0 0 280px;background:var(--craft-surface);border-right:1px solid var(--craft-border);
  display:flex;flex-direction:column;min-height:0;z-index:15;
}
#searchWrap{padding:12px 12px 8px}
#search{
  width:100%;background:var(--craft-raised);border:1px solid var(--craft-border2);border-radius:8px;
  color:var(--craft-t1);font-family:var(--font);font-size:13px;padding:9px 12px;outline:none;
}
#search::placeholder{color:var(--craft-t3)}
#search:focus{border-color:var(--teal)}
#chips{display:flex;flex-wrap:wrap;gap:5px;padding:2px 12px 10px;border-bottom:1px solid var(--craft-border)}
.chip{
  font-family:var(--mono);font-size:9.5px;letter-spacing:.05em;text-transform:uppercase;
  color:var(--craft-t3);background:transparent;border:1px solid var(--craft-border2);border-radius:999px;
  padding:3px 9px;cursor:pointer;transition:all .12s;
}
.chip:hover{color:var(--craft-t2)}
.chip.on{color:#062024;background:var(--teal);border-color:var(--teal);font-weight:600}
#results{flex:1;overflow-y:auto;padding:6px}
.result{
  display:flex;flex-direction:column;gap:2px;padding:8px 10px;border-radius:8px;cursor:grab;
  border:1px solid transparent;user-select:none;
}
.result:hover{background:var(--craft-raised);border-color:var(--craft-border)}
.result .r1{display:flex;align-items:center;gap:8px}
.result .dot{width:8px;height:8px;border-radius:50%;flex:0 0 8px}
.result .lbl{font-size:13px;color:var(--craft-t2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1}
.result:hover .lbl{color:var(--craft-t1)}
.result .tag{font-family:var(--mono);font-size:8.5px;letter-spacing:.08em;text-transform:uppercase}
.result .uid{font-family:var(--mono);font-size:9px;color:var(--craft-t3);opacity:.55;padding-left:16px;
  overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.result.onboard{opacity:.45}
#noresults{padding:24px 14px;color:var(--craft-t3);font-size:12.5px;line-height:1.5;display:none}
#addHint{display:none;padding:9px 12px;margin:0 12px 8px;border-radius:8px;
  background:rgba(78,205,196,.09);border:1px solid var(--craft-border2);
  font-family:var(--mono);font-size:10px;color:var(--teal);line-height:1.5}

/* ---------- board (hex grid) ---------- */
#boardWrap{flex:1;position:relative;min-width:0}
#board{position:absolute;inset:0;overflow:hidden;background:var(--board);cursor:grab}
#board.panning{cursor:grabbing}
#world{position:absolute;left:0;top:0;transform-origin:0 0;will-change:transform}

/* grid layer (all non-interactive; the board handles clicks and hover) */
#grid{position:absolute;left:0;top:0;width:10px;height:10px;overflow:visible;pointer-events:none}
#grid.hidden{display:none}
#gridCells{fill:none;stroke:rgba(78,205,196,.12);stroke-width:1}
#gridHover{fill:rgba(78,205,196,.07);stroke:rgba(78,205,196,.4);stroke-width:1.5;display:none}
#gridHoverPlus{fill:rgba(78,205,196,.8);font-family:var(--mono);text-anchor:middle;display:none}
#gridPending{fill:rgba(78,205,196,.12);stroke:var(--teal);stroke-width:2;display:none}
#gridCenter{display:none}
#gridCenter path{fill:rgba(78,205,196,.10);stroke:var(--teal);stroke-width:2;
  filter:drop-shadow(0 0 10px rgba(78,205,196,.5))}
#gridCenter text{fill:var(--teal);font-family:var(--display);font-weight:700;text-anchor:middle;animation:cpulse 2s ease-in-out infinite}
@keyframes cpulse{0%,100%{opacity:.72}50%{opacity:1}}

/* edges */
#edges{position:absolute;left:0;top:0;width:10px;height:10px;overflow:visible;pointer-events:none}
#tempEdge{fill:none;stroke:var(--teal);stroke-width:2;stroke-dasharray:5 5;opacity:.85;display:none}
/* edges carry their own color in --ec (element override > line category > default) */
#edges .edge{pointer-events:auto;cursor:pointer}
#edges .edge .hit{fill:none;stroke:transparent;stroke-width:16}
#edges .edge .wire{fill:none;stroke:var(--ec,#4ECDC4);transition:stroke-opacity .15s,stroke-width .15s}
#edges .edge .arrow{opacity:0;fill:var(--ec,#4ECDC4)}
#edges .edge .pill{fill:rgba(6,16,10,.82);stroke:var(--ec,#4ECDC4);stroke-opacity:.35;stroke-width:1}
#edges .edge text{font-family:var(--mono);font-size:9px;fill:var(--craft-t2);text-anchor:middle;transition:fill .15s}
/* verified edge = directional arrow + rel pill (source -> target) */
#edges .edge.verified .wire{stroke-opacity:.62;stroke-width:1.8}
#edges .edge.verified .arrow{opacity:.92}
#edges .edge.verified text{fill:var(--ec,#4ECDC4)}
/* user edge = dashed, no arrowhead, "your link" */
#edges .edge.user .wire{stroke-width:1.5;stroke-dasharray:6 5;stroke-opacity:.6}
#edges .edge.user .arrow{display:none}
#edges .edge.user text{fill:var(--craft-t3);opacity:.75;font-style:italic}
#edges .edge:hover .wire{stroke-opacity:1;stroke-width:2.3}
#edges .edge:hover text{fill:var(--ec,#4ECDC4)}
#edges .edge.selected .wire{stroke-opacity:1;stroke-width:2.7;filter:drop-shadow(0 0 5px var(--ec,#4ECDC4))}
#edges .edge.selected text{fill:var(--ec,#4ECDC4)}
/* ghost arrows = faint dashed preview stubs to off-board neighbors */
#ghostArrows .gedge .gwire{fill:none;stroke:rgba(78,205,196,.28);stroke-dasharray:4 5;stroke-width:1.4;transition:stroke .15s}
#ghostArrows .gedge .ghead{fill:rgba(78,205,196,.35);transition:fill .15s}
#ghostArrows .gedge text{font-family:var(--mono);font-size:8.5px;fill:var(--craft-t3);opacity:.5;text-anchor:middle;
  paint-order:stroke;stroke:#06100a;stroke-width:3px;transition:all .15s}
#ghostArrows .gedge.hot .gwire{stroke:rgba(78,205,196,.75);stroke-width:1.9}
#ghostArrows .gedge.hot .ghead{fill:var(--teal)}
#ghostArrows .gedge.hot text{fill:var(--teal);opacity:.95}

/* isolate-on-hover, like the atlas */
#board.isolate .node:not(.lit){opacity:.16}
#board.isolate #edges .edge:not(.lit){opacity:.07}
.node, #edges .edge{transition:opacity .18s}

/* ---------- node hex tiles ---------- */
/* the node is an explicit HW x HH box (set inline from JS) so its absolute children
   lay out against real dimensions; without a size it collapses to 0x0 and inset:0 /
   left:50% children pin to the top-left. pointer-events:none, children re-enable */
.node{position:absolute;left:0;top:0;pointer-events:none;user-select:none}
.node .tile{position:absolute;left:0;top:0;overflow:visible;pointer-events:none}
.node .hex{
  fill:var(--c);fill-opacity:.14;stroke:var(--c);stroke-width:1.6;
  pointer-events:auto;cursor:grab;transition:fill-opacity .15s,stroke-width .15s;
}
.node .hex:hover{fill-opacity:.22;stroke-width:2.3}
.node.dragging .hex{cursor:grabbing}
.node.selected .hex{stroke-width:2.8;fill-opacity:.24;filter:drop-shadow(0 0 9px var(--c))}
.node.emph .hex{stroke-width:2.4;fill-opacity:.2}
.node.linktarget .hex{stroke:var(--teal);stroke-width:2.8;filter:drop-shadow(0 0 9px var(--teal))}
/* name is the primary content, centered inside the hex, wrapped to the flat-to-flat
   inner width, up to 3 lines then ellipsis (full name in the tile title) */
.node .body{
  position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
  text-align:center;padding:26% 14% 18%;pointer-events:none;
}
.node .lbl{
  font-family:var(--font);font-size:12.5px;font-weight:600;color:var(--craft-t1);line-height:1.15;
  display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;
}
/* type / PROVIDER tag: small secondary label tucked just inside the top of the hex.
   it hides while the action cluster is showing so the two do not overlap */
.node .tag{
  position:absolute;left:50%;transform:translate(-50%,-50%);pointer-events:none;white-space:nowrap;
  font-family:var(--mono);font-size:8px;letter-spacing:.09em;text-transform:uppercase;color:var(--c);
  transition:opacity .12s;
}
.node.hot .tag,.node.selected .tag{opacity:0}
/* hover action cluster, sitting INSIDE the hex near the top (below the top point),
   centered. quiet until hover, stays while selected, like a skill-tree node */
.node .actions{
  position:absolute;left:50%;display:flex;gap:5px;z-index:8;
  opacity:0;pointer-events:none;transform:translate(-50%,-50%) scale(.9);
  transition:opacity .14s ease,transform .14s ease;
}
.node.hot .actions,.node.selected .actions{opacity:1;pointer-events:auto;transform:translate(-50%,-50%) scale(1)}
.node .abtn{
  width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;
  background:rgba(22,32,48,.95);border:1px solid var(--craft-border2);color:var(--craft-t2);cursor:pointer;
  pointer-events:auto;transition:all .12s;box-shadow:0 2px 6px rgba(0,0,0,.4);
}
.node .abtn svg{width:11px;height:11px;display:block}
.node .abtn:hover{color:var(--craft-t1);border-color:var(--teal);background:var(--craft-raised2)}
.node .abtn.danger:hover{color:#fff;border-color:#DF5752;background:rgba(223,87,82,.28)}
/* six connection nubs at the hex vertices (points); drag any to wire tiles together */
.node .nub{
  position:absolute;width:12px;height:12px;border-radius:50%;
  background:var(--craft-raised2);border:1.5px solid var(--teal);box-shadow:0 0 0 1px rgba(0,0,0,.5);
  transform:translate(-50%,-50%);opacity:0;cursor:crosshair;pointer-events:auto;z-index:7;
  transition:opacity .12s,background .12s,width .1s,height .1s;
}
.node.hot .nub,.node.selected .nub,.node.linktarget .nub{opacity:1}
.node .nub:hover{background:var(--teal);width:15px;height:15px}
/* the nearest target vertex while wiring, snapped and highlighted */
.node .nub.snap{background:var(--teal);width:17px;height:17px;box-shadow:0 0 8px var(--teal),0 0 0 1px rgba(0,0,0,.5)}
/* endpoint edit handles shown on the selected edge, draggable to re-point it */
.ehandle{
  position:absolute;left:0;top:0;width:16px;height:16px;border-radius:50%;
  background:var(--teal);border:2px solid var(--craft-surface);
  box-shadow:0 0 0 1px rgba(0,0,0,.5),0 0 8px rgba(78,205,196,.65);
  cursor:grab;pointer-events:auto;z-index:9;
}
.ehandle:active{cursor:grabbing}
/* midpoint paint button for the selected edge */
.epaint{
  position:absolute;left:0;top:0;width:22px;height:22px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  background:rgba(22,32,48,.96);border:1px solid var(--craft-border2);color:var(--craft-t2);
  box-shadow:0 2px 6px rgba(0,0,0,.5);cursor:pointer;pointer-events:auto;z-index:9;
}
.epaint svg{width:12px;height:12px;display:block}
.epaint:hover{color:var(--craft-t1);border-color:var(--teal);background:var(--craft-raised2)}
.node .ext{
  position:absolute;top:100%;left:50%;transform:translateX(-50%);margin-top:1px;
  font-family:var(--mono);font-size:9px;color:var(--craft-t3);white-space:nowrap;pointer-events:none;
  background:rgba(6,16,10,.7);padding:1px 6px;border-radius:8px;
}
.node.spawn{animation:spawn .28s cubic-bezier(.2,.9,.3,1.2)}
@keyframes spawn{from{scale:.6;opacity:0}}

/* ghost neighbour tiles: preview only, dashed + dimmed, click to materialize */
.node.ghost{opacity:.42;cursor:pointer;transition:opacity .15s}
.node.ghost .hex{stroke-dasharray:5 4;stroke-opacity:.75;fill-opacity:.06;cursor:pointer}
.node.ghost .body{opacity:.85}
.node.ghost.ghost-hot{opacity:.96}
.node.ghost.ghost-hot .hex{fill-opacity:.17;stroke-opacity:1}
.ghost-more{
  position:absolute;left:0;top:0;font-family:var(--mono);font-size:9.5px;color:var(--teal);
  background:rgba(6,16,10,.88);border:1px solid var(--craft-border2);border-radius:10px;padding:2px 8px;
  pointer-events:none;white-space:nowrap;z-index:5;
}

/* ---------- right panel: LINKS inspector ---------- */
#right{
  width:260px;flex:0 0 260px;background:var(--craft-surface);border-left:1px solid var(--craft-border);
  display:flex;flex-direction:column;min-height:0;transition:margin-right .2s;z-index:15;
}
#right.closed{margin-right:-260px}
#rightHead{display:flex;align-items:center;gap:8px;padding:12px;border-bottom:1px solid var(--craft-border)}
#rightHead h2{font-family:var(--display);font-size:12px;letter-spacing:.14em;color:var(--craft-t2);font-weight:700}
#stats{font-family:var(--mono);font-size:9.5px;color:var(--craft-t3);margin-left:auto;white-space:nowrap}
#linksSel{padding:11px 12px;border-bottom:1px solid var(--craft-border);display:none}
#linksSel .name{font-family:var(--display);font-weight:600;font-size:14px;color:var(--craft-t1);line-height:1.3}
#linksSel .sub{font-family:var(--mono);font-size:9.5px;color:var(--craft-t3);margin-top:4px}
#addAll{
  margin-top:9px;width:100%;font-family:var(--display);font-size:11.5px;letter-spacing:.04em;
  color:var(--craft-dark);background:var(--teal);border:none;border-radius:6px;padding:7px;cursor:pointer;
}
#addAll:hover{filter:brightness(1.08)}
#addAll:disabled{background:var(--craft-raised2);color:var(--craft-t3);cursor:default;filter:none}
#linksList{flex:1;overflow-y:auto;padding:6px}
.lrow{display:flex;align-items:center;gap:8px;padding:7px 8px;border-radius:8px;border:1px solid transparent}
.lrow:hover{background:var(--craft-raised);border-color:var(--craft-border)}
.lrow .li{flex:1;min-width:0}
.lrow .rel{font-family:var(--mono);font-size:8px;letter-spacing:.07em;text-transform:uppercase;color:var(--craft-t3)}
.lrow .nl{display:flex;align-items:center;gap:6px;margin-top:1px}
.lrow .ndot{width:7px;height:7px;border-radius:50%;flex:0 0 7px}
.lrow .nn{font-size:12.5px;color:var(--craft-t2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.lrow .act{
  font-family:var(--mono);font-size:9.5px;letter-spacing:.03em;color:var(--teal);
  background:transparent;border:1px solid var(--craft-border2);border-radius:14px;padding:3px 9px;
  cursor:pointer;white-space:nowrap;transition:all .12s;
}
.lrow .act:hover{background:var(--craft-raised2);border-color:var(--teal)}
.lrow .done{font-family:var(--mono);font-size:9.5px;color:var(--teal);opacity:.7;white-space:nowrap}
#linksHint{padding:20px 14px;color:var(--craft-t3);font-size:12px;line-height:1.55}
#rightToggle{
  position:absolute;top:64px;right:12px;z-index:30;width:26px;height:26px;
  background:var(--craft-raised);border:1px solid var(--craft-border2);border-radius:6px;color:var(--craft-t3);
  cursor:pointer;font-size:12px;line-height:1;display:flex;align-items:center;justify-content:center;
}
#rightToggle:hover{color:var(--teal);border-color:var(--teal)}

/* ---------- per-category palette panel ---------- */
#palettePanel{
  position:absolute;top:60px;right:44px;z-index:40;width:206px;max-height:calc(100% - 76px);
  overflow-y:auto;display:none;padding:10px;background:var(--craft-surface);
  border:1px solid var(--craft-border2);border-radius:10px;box-shadow:0 10px 30px rgba(0,0,0,.5);
}
#palettePanel.open{display:block}
#palettePanel .pp-head{font-family:var(--display);font-size:11px;letter-spacing:.14em;color:var(--craft-t2);
  font-weight:700;margin-bottom:8px}
#palettePanel .pp-row{display:flex;align-items:center;gap:9px;padding:4px 2px}
#palettePanel .pp-row.pp-sep{margin-top:8px;padding-top:9px;border-top:1px solid var(--craft-border)}
#palettePanel .pp-sw{width:22px;height:22px;border-radius:6px;border:1px solid rgba(0,0,0,.4);
  cursor:pointer;flex:0 0 22px;box-shadow:inset 0 0 0 1px rgba(255,255,255,.08)}
#palettePanel .pp-name{font-size:12.5px;color:var(--craft-t2)}
#btnResetColors{margin-top:10px;width:100%;font-family:var(--display);font-size:11.5px;letter-spacing:.04em;
  color:var(--craft-t2);background:var(--craft-raised);border:1px solid var(--craft-border2);border-radius:6px;padding:7px;cursor:pointer}
#btnResetColors:hover{color:var(--craft-t1);border-color:var(--teal);background:var(--craft-raised2)}

/* ---------- color picker popover (presets + native custom + optional clear) ---------- */
.colorpop{
  position:fixed;z-index:300;width:auto;padding:9px;background:var(--craft-raised);
  border:1px solid var(--craft-border2);border-radius:10px;box-shadow:0 10px 30px rgba(0,0,0,.55);
}
.colorpop .cp-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:5px;margin-bottom:8px}
.colorpop .cp-sw{width:22px;height:22px;border-radius:6px;border:1px solid rgba(0,0,0,.4);cursor:pointer;
  box-shadow:inset 0 0 0 1px rgba(255,255,255,.08)}
.colorpop .cp-sw.on{outline:2px solid var(--craft-t1);outline-offset:1px}
.colorpop .cp-row{display:flex;align-items:center;gap:8px;margin-bottom:6px}
.colorpop .cp-row input[type=color]{width:30px;height:24px;padding:0;border:1px solid var(--craft-border2);
  border-radius:5px;background:var(--craft-raised2);cursor:pointer}
.colorpop .cp-row span{font-family:var(--mono);font-size:10px;color:var(--craft-t3)}
.colorpop .cp-clear{width:100%;font-family:var(--mono);font-size:10px;letter-spacing:.03em;color:var(--craft-t2);
  background:transparent;border:1px solid var(--craft-border2);border-radius:6px;padding:5px;cursor:pointer}
.colorpop .cp-clear:hover{color:var(--craft-t1);border-color:var(--teal);background:var(--craft-raised2)}

/* ---------- toast, ghost, placeholder ---------- */
#toast{
  position:fixed;left:50%;bottom:28px;transform:translateX(-50%) translateY(10px);
  background:var(--craft-raised2);border:1px solid var(--craft-border2);border-radius:8px;
  color:var(--craft-t2);font-family:var(--mono);font-size:11px;padding:9px 16px;
  opacity:0;pointer-events:none;transition:all .25s;z-index:100;
}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
#ghost{
  position:fixed;z-index:200;pointer-events:none;display:none;
  background:var(--craft-raised2);border:1px solid var(--teal);border-radius:8px;
  color:var(--craft-t1);font-family:var(--display);font-size:12px;padding:6px 12px;opacity:.9;
}
#nodata{
  position:absolute;inset:0;display:none;align-items:center;justify-content:center;
  color:var(--craft-t3);font-family:var(--mono);font-size:13px;text-align:center;line-height:2;
}
::-webkit-scrollbar{width:9px}
::-webkit-scrollbar-thumb{background:var(--craft-raised2);border-radius:5px}
::-webkit-scrollbar-track{background:transparent}

/* shared attribution chip: parked at the board's bottom-left, clear of the
   palette column (280px) on the left and the links panel on the right */
.tool-attribution--fixed{
  left:292px;right:auto;bottom:12px;
  background:rgba(6,16,10,.85);border-color:var(--craft-border);
  color:var(--craft-t3);
}
.tool-attribution--fixed .ta-brand{color:var(--craft-t2)}
</style>

<div id="app">
  <header class="tool-bar">
    <span class="tool-bar-title">ATLAS <span>CRAFT</span></span>
    <span class="tool-bar-crumb">connective tissue of the healthcare atlas</span>
    <span class="tool-bar-spacer"></span>
    <div class="legend" id="legend"></div>
    <button class="btn" id="btnPalette">Palette</button>
    <button class="btn on" id="btnGrid">Grid</button>
    <button class="btn" id="btnReset">Reset</button>
    <button class="btn" id="btnFit">Fit</button>
  </header>
  <div id="main">
    <aside id="palette">
      <div id="searchWrap">
        <input id="search" type="text" autocomplete="off" spellcheck="false"
               placeholder="Search the atlas… roles, metrics, concepts, vendors">
      </div>
      <div id="addHint">Cell chosen. Pick a card below to drop it in.</div>
      <div id="chips"></div>
      <div id="results"></div>
      <div id="noresults">Nothing in the atlas matches that. Try a broader term, or clear the type filter.</div>
    </aside>
    <div id="boardWrap">
      <div id="board">
        <div id="world">
          <svg id="grid" xmlns="http://www.w3.org/2000/svg">
            <path id="gridCells"></path>
            <path id="gridHover"></path>
            <text id="gridHoverPlus">+</text>
            <path id="gridPending"></path>
            <g id="gridCenter"><path></path><text>+</text></g>
          </svg>
          <svg id="edges" xmlns="http://www.w3.org/2000/svg"><g id="ghostArrows"></g><path id="tempEdge"></path></svg>
        </div>
      </div>
      <button id="rightToggle" title="Toggle links panel">&#9656;</button>
      <div id="palettePanel"></div>
      <div id="nodata">NO DATA INJECTED<br>this template expects GRAPH to be filled by the build step</div>
    </div>
    <aside id="right">
      <div id="rightHead"><h2>LINKS</h2><span id="stats">0 nodes, 0 links</span></div>
      <div id="linksSel"></div>
      <div id="linksList"><div id="linksHint">Click the glowing + on the grid to place your first card. Then select any tile to see its real atlas links, or drag from a tile's handle to draw your own line.</div></div>
    </aside>
  </div>
  <div class="shell-gate">
    <h2>Atlas Craft is a desktop tool</h2>
    <p>This authoring canvas needs a big screen and a mouse. Drag, drop, and wire don't work at this size. Explore the Atlas itself on mobile, or come back on a desktop.</p>
    <a class="toggle-chip" href="/atlas/">&larr; Back to the Atlas</a>
  </div>
</div>
