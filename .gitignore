# Build cache — large CMS source files fetched by scripts/build-suppliers.js
scripts/.cache/

# Dependencies. Netlify reinstalls these on every deploy via `npm install`,
# so committing them is pure bloat and drags every dependency vuln into history.
node_modules/

# Build output. Netlify regenerates this from source on every deploy.
_site/
build-output.txt

# Secrets. Never commit these. The day a key exists, this line is what stops it.
.env
.env.*
!.env.example
